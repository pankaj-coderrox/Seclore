---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const programs = [
  {
    title: "Deal registration",
    text: "Seclore's Deal registration program rewards and protects partners by offering exclusive benefits for identifying and registering new opportunities."
  },
  {
    title: "Scale go-to-market",
    text: "Extend your reach and drive demand with differentiated products, services, and strategies."
  },
  {
    title: "Optimize investments",
    text: "Unlock sales tools, marketing benefits, and security specializations to showcase your validated offerings."
  }
];

---

<BaseLayout
  title="Partners | seclore"
  description="Join Seclore's partner community for deal registration, channel programs, service provider partnerships, and technology alliances."
>
  <main id="top" class="partners-page">
    <Nav />

    <section class="partner-hero">
      <div class="hero-inner">
        <h1>Seclore Partner Pulse Community</h1>
        <p>
          Join a global community of world-class innovators committed to making security breaches a
          thing of the past, with data-centric security.
        </p>
        <div class="hero-actions">
          <a class="primary-button muted" href="/partners/login/">Login</a>
          <a class="primary-button" href="/partners/register/">Partner Inquiries</a>
        </div>
      </div>
    </section>

    <section class="intro-split" id="overview">
      <img
        src="/images/partners/partner-meeting.png"
        alt="Partner team meeting around a conference table"
        loading="lazy"
      />
      <div>
        <h2>Securing enterprise data, together</h2>
        <p>
          Your success depends on a partner program that enables differentiation, enhances
          profitability, expands opportunities, and empowers success. You can get support today when
          you join the Seclore partner community.
        </p>
        <a class="primary-button" href="#program">Partner Program Overview</a>
      </div>
    </section>

    <section class="community-section" id="program">
      <div class="section-heading">
        <h2>Join an award-winning partner community</h2>
        <p>
          At Seclore, our partner ecosystem is at the center of what we do. Together, we're building
          a world where organizations can safely protect their most sensitive data no matter where it
          travels.
        </p>
      </div>
      <div class="program-grid">
        {programs.map((program) => (
          <article>
            <h3>{program.title}</h3>
            <p>{program.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="solutions-band">
      <h2>Integrated data-centric security and compliance solutions</h2>
      <p>
        Incorporate Seclore's data-centric security platform into your organization's data security
        and compliance operations to ensure that your most sensitive data is always protected,
        visible, and under organizational control.
      </p>
    </section>

    <section class="portal-band" id="portal">
      <h2>Login to the Partner Portal</h2>
      <div class="hero-actions">
        <a class="primary-button" href="/partners/register/">Sign up</a>
        <a class="outline-button" href="/partners/login/">Login here</a>
      </div>
    </section>

    <section class="partner-types">
      <article class="type-row" id="channel">
        <div>
          <h2>Channel and distribution</h2>
          <p>
            Increase your organization's growth and profitability with Seclore's recurring revenue
            model, coupled with low investment and cost of entry. Our partner-centric approach
            provides comprehensive support including sales enablement, marketing resources, and
            technical training to accelerate your go-to-market strategy.
          </p>
        </div>
        <img
          src="/images/partners/channel-distribution.png"
          alt="Business team discussing a partner growth plan"
          loading="lazy"
        />
      </article>

      <article class="type-row reverse" id="services">
        <img
          src="/images/partners/services-handshake.png"
          alt="Business partners shaking hands"
          loading="lazy"
        />
        <div>
          <h2>Service providers &amp; accredited services partners</h2>
          <p>
            As a Service Provider, Managed Security Service Provider, and Global System Integrator,
            you can offer a complete range of cybersecurity services to reach a wider audience,
            accelerate your revenue growth, and deliver effective solutions to meet your customers'
            needs.
          </p>
        </div>
      </article>

      <article class="technology-row" id="technology">
        <div>
          <h2>Strategic technology partners</h2>
          <p>
            Integrate innovative cybersecurity solutions with the world's leading data-centric
            security platform.
          </p>
        </div>
      </article>
    </section>

    <section class="ecosystem-section" id="inquiries">
      <h2>Join our elite ecosystem</h2>
    </section>

    <section class="ready-section">
      <h2>Ready to get started?</h2>
      <p>Contact our sales team to find out how Seclore can help with data security and compliance.</p>
      <a class="primary-button" href="#top">Book a Demo</a>
    </section>
  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #ffffff;
    --page-soft: #f6f6f7;
    --page-text: #3f3f46;
    --page-muted: #6f737c;
    --purple: #5b2bd7;
    --purple-dark: #3f1cad;
    --violet: #7f19f5;
    --line: rgba(35, 35, 42, 0.15);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #5b2bd7;
    --demo-button-text: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    font: inherit;
  }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    font-size: 1.35rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .nav-links,
  .nav-utilities {
    align-items: center;
    display: flex;
  }

  .nav-links {
    flex: 1 1 auto;
    gap: clamp(18px, 2.2vw, 34px);
    justify-content: center;
    min-width: 0;
  }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:hover .nav-trigger,
  .nav-item:focus-within .nav-trigger {
    color: var(--header-text);
  }

  .nav-item {
    position: static;
  }

  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret {
    transform: rotate(225deg) translateY(-1px);
  }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .mega-column,
  .mega-sublinks {
    display: grid;
  }

  .mega-column {
    gap: 10px;
  }

  .mega-title {
    color: var(--dropdown-title);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mega-link,
  .mega-link-group {
    border: 1px solid transparent;
    border-radius: 8px;
  }

  .mega-link {
    display: grid;
    gap: 5px;
    padding: 13px;
  }

  .mega-link strong {
    color: var(--dropdown-text);
  }

  .mega-link small,
  .mega-sublinks a {
    color: var(--dropdown-muted);
  }

  .mega-link:hover,
  .mega-link-group:hover {
    background: var(--dropdown-link-hover);
    border-color: var(--dropdown-link-border);
  }

  .mega-link-group {
    display: grid;
    gap: 4px;
    padding: 4px;
  }

  .mega-sublinks {
    gap: 2px;
    padding: 0 9px 8px 22px;
  }

  .mega-sublinks a {
    font-size: 0.84rem;
    padding: 5px 0;
  }

  .mega-feature {
    align-content: end;
    background: var(--dropdown-feature-bg);
    border: 1px solid var(--dropdown-feature-border);
    border-radius: 8px;
    display: grid;
    min-height: 268px;
    padding: 24px;
  }

  .mega-feature span,
  .mega-feature em {
    color: var(--dropdown-title);
  }

  .mega-feature strong {
    color: var(--dropdown-text);
    font-size: 1.35rem;
    line-height: 1.18;
    margin-top: auto;
  }

  .nav-utilities {
    flex: 0 0 auto;
    gap: clamp(12px, 1.5vw, 20px);
    margin-left: clamp(12px, 2vw, 28px);
  }

  .utility-link,
  .language-button,
  .utility-icon,
  .theme-toggle {
    display: none;
  }

  .demo-button,
  .primary-button,
  .outline-button {
    align-items: center;
    border-radius: 7px;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.86rem;
    font-weight: 850;
    justify-content: center;
    min-height: 38px;
    padding: 0 18px;
  }

  .demo-button,
  .primary-button {
    background: var(--purple);
    color: #ffffff;
  }

  .primary-button.muted {
    background: var(--purple-dark);
  }

  .outline-button {
    background: #ffffff;
    border: 1px solid rgba(91, 43, 215, 0.35);
    color: var(--purple);
  }

  .nav-toggle {
    background: transparent;
    border: 0;
    display: none;
    height: 42px;
    width: 42px;
  }

  .nav-toggle span {
    background: var(--header-text);
    display: block;
    height: 2px;
    margin: 6px 0;
    width: 24px;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1,
  h2,
  h3 {
    color: var(--page-text);
    font-weight: 450;
    letter-spacing: 0;
  }

  h1 {
    color: #ffffff;
    font-size: clamp(2.75rem, 6.8vw, 5.6rem);
    line-height: 1.02;
    margin-bottom: 24px;
  }

  h2 {
    font-size: clamp(2rem, 4.1vw, 3.4rem);
    line-height: 1.05;
    margin-bottom: 18px;
  }

  h3 {
    font-size: 1.18rem;
    font-weight: 750;
    line-height: 1.2;
  }

  p {
    color: var(--page-muted);
    line-height: 1.58;
  }

  .partner-hero {
    align-items: center;
    background:
      radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.28), transparent 28%),
      linear-gradient(140deg, #c982eb 0%, #8b22fb 43%, #5b11e6 100%);
    display: grid;
    min-height: 610px;
    padding: 74px clamp(20px, 5vw, 64px);
    text-align: center;
  }

  .hero-inner {
    margin: 0 auto;
    max-width: 980px;
  }

  .partner-hero p {
    color: rgba(255, 255, 255, 0.82);
    font-size: 1.02rem;
    margin: 0 auto;
    max-width: 760px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-top: 28px;
  }

  .intro-split,
  .type-row {
    align-items: center;
    background: #ffffff;
    display: grid;
    gap: clamp(28px, 5vw, 72px);
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    padding: clamp(58px, 7vw, 92px) clamp(20px, 5vw, 64px);
  }

  .intro-split img,
  .type-row img {
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    display: block;
    height: auto;
    object-fit: cover;
    width: 100%;
  }

  .intro-split div,
  .type-row div {
    max-width: 640px;
  }

  .community-section,
  .solutions-band,
  .portal-band,
  .ecosystem-section,
  .ready-section {
    padding: clamp(58px, 7vw, 92px) clamp(20px, 5vw, 64px);
  }

  .community-section {
    background: radial-gradient(circle at 50% 76%, rgba(249, 218, 145, 0.32), transparent 28%), #ffffff;
  }

  .section-heading {
    margin: 0 auto;
    max-width: 1120px;
    text-align: center;
  }

  .program-grid {
    display: grid;
    gap: 28px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: 48px auto 0;
    max-width: 1120px;
  }

  .program-grid article {
    background: linear-gradient(180deg, #ffffff, #f1f1f2);
    border-radius: 8px;
    min-height: 205px;
    padding: 28px;
  }

  .program-grid p {
    font-size: 0.94rem;
    margin: 0;
  }

  .solutions-band {
    background: #ffffff;
    text-align: center;
  }

  .solutions-band h2,
  .solutions-band p {
    margin-inline: auto;
    max-width: 980px;
  }

  .portal-band {
    background: linear-gradient(100deg, #cfe2ff, #fff3ee);
    text-align: center;
  }

  .partner-types {
    background: #ffffff;
  }

  .type-row {
    padding-bottom: 42px;
    padding-top: 42px;
  }

  .type-row.reverse {
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
  }

  .technology-row {
    display: grid;
    min-height: 360px;
    padding: 42px clamp(20px, 5vw, 64px) 104px;
  }

  .technology-row div {
    max-width: 650px;
  }

  .ecosystem-section {
    align-items: center;
    background: var(--page-soft);
    display: grid;
    min-height: 280px;
    text-align: center;
  }

  .ready-section {
    background: #ffffff;
    border-bottom: 1px solid var(--line);
    padding-bottom: 36px;
  }

  .ready-section h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin-bottom: 12px;
  }

  .partners-footer {
    background: #ffffff;
    padding: 0 clamp(20px, 5vw, 64px) 34px;
  }

  .footer-lines {
    border-bottom: 1px solid var(--line);
    margin-bottom: 30px;
  }

  .footer-lines details {
    border-top: 1px solid var(--line);
    padding: 18px 0;
  }

  .footer-lines summary {
    cursor: pointer;
    font-weight: 850;
  }

  .footer-logo {
    color: var(--purple);
    display: block;
    font-size: 1.45rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-bottom: 22px;
    text-transform: uppercase;
  }

  .partners-footer p {
    font-size: 0.92rem;
  }

  .store-row {
    display: grid;
    gap: 9px;
    margin: 28px 0;
    max-width: 150px;
  }

  .store-row span {
    background: #17131c;
    border-radius: 5px;
    color: #ffffff;
    font-size: 0.82rem;
    font-weight: 850;
    padding: 9px 14px;
  }

  .social-row {
    border-top: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    padding-top: 22px;
  }

  .social-row span {
    color: #2c2c31;
    font-size: 0.84rem;
    font-weight: 850;
  }

  .legal {
    font-size: 0.84rem;
    margin-top: 20px;
  }

  @media (max-width: 1180px) {
    .site-header {
      flex-wrap: wrap;
    }

    .site-logo {
      order: 0;
    }

    .nav-toggle {
      display: block;
      margin-left: auto;
      order: 1;
    }

    .nav-links {
      background: var(--header-bg);
      border-top: 1px solid var(--header-border);
      display: none;
      flex: 1 0 100%;
      order: 2;
      padding: 10px 0 14px;
    }

    .nav-links.open {
      align-items: stretch;
      display: grid;
    }

    .nav-links > a,
    .nav-trigger {
      justify-content: space-between;
      min-height: 48px;
      width: 100%;
    }

    .nav-item {
      display: grid;
    }

    .mega-menu {
      display: none;
      opacity: 1;
      position: static;
      transform: none;
    }

    .nav-item:hover .mega-menu,
    .nav-item:focus-within .mega-menu {
      display: none;
    }

    .nav-item.is-open .mega-menu {
      display: block;
    }

    .mega-inner {
      box-shadow: none;
      grid-template-columns: 1fr;
      min-height: 0;
      padding: 16px;
    }

    .nav-utilities {
      align-items: stretch;
      display: flex;
      margin-left: auto;
      order: 0;
    }
  }

  @media (max-width: 900px) {
    .intro-split,
    .type-row,
    .type-row.reverse {
      grid-template-columns: 1fr;
    }

    .program-grid {
      grid-template-columns: 1fr;
    }

    .partner-hero {
      min-height: 500px;
    }
  }

  @media (max-width: 540px) {
    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .primary-button,
    .outline-button,
    .demo-button {
      width: 100%;
    }

    .intro-split,
    .type-row,
    .community-section,
    .solutions-band,
    .portal-band,
    .ecosystem-section,
    .ready-section,
    .technology-row,
    .partners-footer {
      padding-inline: 16px;
    }
  }
</style>
