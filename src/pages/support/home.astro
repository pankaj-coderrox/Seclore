---
import BaseLayout from "@layouts/BaseLayout.astro";

const quickLinks = [
  {
    title: "Solutions",
    text: "Find solutions to the most common problems",
    icon: "solution",
    href: "/support/solutions/"
  },
  {
    title: "Forums",
    text: "Discuss, debate, analyze, and give suggestions for improving Seclore",
    icon: "forum",
    href: "/support/discussions/"
  },
  {
    title: "Tickets",
    text: "Having a problem with Seclore? Get it resolved quickly by creating a ticket",
    icon: "ticket",
    href: "/support/tickets/new/"
  },
  {
    title: "Escalate Ticket",
    text: "Created a ticket and want to escalate it? Click here to get started",
    icon: "escalate",
    href: "#escalate-ticket",
    modal: true
  }
];

const iconPaths = {
  solution: [
    "M12 4a3 3 0 1 1 0 6 3 3 0 0 1 0-6Z",
    "M12 1v2m0 8v2M4.22 4.22l1.42 1.42m8.72 8.72 1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42m8.72-8.72 1.42-1.42",
    "M5 22v-5.6A8.5 8.5 0 0 1 3.5 9.2M19 22v-5.6a8.5 8.5 0 0 0 1.5-7.2",
    "M8 22v-5h8v5"
  ],
  forum: [
    "M5 7h8v7H8l-3 3v-3H3V7h2Z",
    "M13 10h8v7h-2v3l-3-3h-3v-7Z",
    "M9 4a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm8 2a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z",
    "M6 6a3 3 0 0 1 6 0m2 2a3 3 0 0 1 6 0"
  ],
  ticket: [
    "M3 5h18v14H3V5Z",
    "M6 8h12M6 11h12M6 14h8M6 17h10",
    "M3 9h18"
  ],
  escalate: [
    "M12 3 4 20h16L12 3Z",
    "M12 8v9M8 17h8",
    "M8 13h8M9.5 10h5"
  ]
};
---

<BaseLayout
  title="Seclore Support Portal"
  description="Seclore support portal home for solutions, forums, support tickets, escalation, and contact details."
>
  <main class="support-page">
    <header class="support-header" aria-label="Seclore support header">
      <a class="support-logo" href="/support/home/" aria-label="Seclore support home">
        <img src="/images/home/seclore-logo-2026.svg" alt="Seclore" loading="eager" decoding="async" />
      </a>
      <a class="contact-pill" href="mailto:support@seclore.com">Contact Us</a>
    </header>
    <section class="support-hero">
      <h1>
        Welcome to the Seclore support portal.
      </h1>
    </section>

    <nav class="portal-nav" aria-label="Support portal navigation">
      <a class="active" href="/support/home/" aria-current="page">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m3 11 9-8 9 8" />
          <path d="M5 10v10h5v-6h4v6h5V10" />
        </svg>
        Support Home
      </a>
      <span class="nav-spacer"></span>
      <div class="portal-menu">
        <button class="portal-menu-toggle" type="button" aria-label="Open support menu" aria-expanded="false" aria-controls="support-portal-menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <div class="portal-menu-panel" id="support-portal-menu" hidden>
          <a href="/support/solutions/">Solutions</a>
          <a href="/support/discussions/">Forums</a>
          <a href="/support/login/">Login</a>
          <a href="/support/tickets/new/">New Support Ticket</a>
        </div>
      </div>
    </nav>

    <section class="search-band" aria-label="Search support content">
      <form class="support-search" action="/support/search/" method="get">
        <span class="sr-only">Search Articles and Community Discussions</span>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="10.5" cy="10.5" r="6.5" />
          <path d="m16 16 5 5" />
        </svg>
        <input type="search" name="term" placeholder="Search Articles and Community Discussions.." />
        <button class="sr-only" type="submit">Search</button>
      </form>
    </section>

    <section class="quick-grid" aria-label="Support options">
      {quickLinks.map((item) => (
        <a
          class="quick-link"
          id={item.title === "Solutions" ? "solutions" : item.title === "Forums" ? "forums" : item.title === "Tickets" ? "ticket" : "escalate-ticket"}
          href={item.href}
          aria-label={`${item.title}: ${item.text}`}
          data-escalate={item.modal ? "true" : undefined}
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            {iconPaths[item.icon as keyof typeof iconPaths].map((path: string) => <path d={path} />)}
          </svg>
          <h2>{item.title}</h2>
          <p>{item.text}</p>
        </a>
      ))}
    </section>

    <button class="chat-button" type="button" aria-label="Chat with support" aria-expanded="false">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5 6h14v10H9l-4 4V6Z" />
        <path d="M8 10h8M8 13h5" />
      </svg>
    </button>

    <section class="chat-panel" aria-label="Support chat" hidden>
      <button class="chat-close" type="button" aria-label="Close chat">x</button>
      <h2>Seclore Support</h2>
      <p>Tell us what you need help with. For urgent issues, create a support ticket.</p>
      <a href="/support/tickets/new/">New Support Ticket</a>
    </section>

    <div class="modal-backdrop" data-modal-backdrop hidden></div>
    <section
      class="escalate-modal"
      aria-modal="true"
      aria-labelledby="escalate-title"
      role="dialog"
      hidden
    >
      <button class="modal-close" type="button" aria-label="Close escalation dialog">×</button>
      <h2 id="escalate-title">Escalate Ticket</h2>
      <p>
        Anyone can escalate a ticket by sending an email to
        <a href="mailto:supportescalation@seclore.com">supportescalation@seclore.com</a>. This
        will open a ticket in our support system for tracking and the support management will be
        notified along with the Seclore leadership team.
      </p>
      <a class="continue-button" href="mailto:supportescalation@seclore.com">Continue</a>
    </section>

    <script>
      const escalateModal = document.querySelector(".escalate-modal");
      const modalBackdrop = document.querySelector("[data-modal-backdrop]");
      const chatButton = document.querySelector(".chat-button");
      const chatPanel = document.querySelector(".chat-panel");
      const portalMenu = document.querySelector(".portal-menu");
      const portalMenuButton = document.querySelector(".portal-menu-toggle");
      const portalMenuPanel = document.querySelector(".portal-menu-panel");

      function setPortalMenuOpen(open: boolean) {
        if (portalMenuButton instanceof HTMLButtonElement && portalMenuPanel instanceof HTMLElement) {
          portalMenuButton.setAttribute("aria-expanded", String(open));
          portalMenuPanel.hidden = !open;
        }
      }

      function setModalOpen(open: boolean) {
        if (escalateModal instanceof HTMLElement && modalBackdrop instanceof HTMLElement) {
          escalateModal.hidden = !open;
          modalBackdrop.hidden = !open;
          document.body.classList.toggle("modal-open", open);
        }
      }

      document.querySelectorAll("[data-escalate]").forEach((link) => {
        link.addEventListener("click", (event) => {
          event.preventDefault();
          history.replaceState(null, "", "#escalate-ticket");
          setModalOpen(true);
        });
      });

      function closeEscalateModal() {
        setModalOpen(false);
        if (location.hash === "#escalate-ticket") {
          history.replaceState(null, "", location.pathname + location.search);
        }
      }

      if (location.hash === "#escalate-ticket") {
        setModalOpen(true);
      }

      window.addEventListener("hashchange", () => {
        setModalOpen(location.hash === "#escalate-ticket");
      });

      document.querySelector(".modal-close")?.addEventListener("click", closeEscalateModal);
      modalBackdrop?.addEventListener("click", closeEscalateModal);
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeEscalateModal();
          setPortalMenuOpen(false);
          if (chatPanel instanceof HTMLElement && chatButton instanceof HTMLElement) {
            chatPanel.hidden = true;
            chatButton.setAttribute("aria-expanded", "false");
          }
        }
      });

      portalMenuButton?.addEventListener("click", () => {
        if (portalMenuButton instanceof HTMLButtonElement) {
          setPortalMenuOpen(portalMenuButton.getAttribute("aria-expanded") !== "true");
        }
      });

      document.addEventListener("click", (event) => {
        if (portalMenu instanceof HTMLElement && event.target instanceof Node && !portalMenu.contains(event.target)) {
          setPortalMenuOpen(false);
        }
      });

      chatButton?.addEventListener("click", () => {
        if (chatPanel instanceof HTMLElement && chatButton instanceof HTMLElement) {
          const nextOpen = chatPanel.hidden;
          chatPanel.hidden = !nextOpen;
          chatButton.setAttribute("aria-expanded", String(nextOpen));
        }
      });

      document.querySelector(".chat-close")?.addEventListener("click", () => {
        if (chatPanel instanceof HTMLElement && chatButton instanceof HTMLElement) {
          chatPanel.hidden = true;
          chatButton.setAttribute("aria-expanded", "false");
        }
      });
    </script>
  </main>
</BaseLayout>

<style>
  :global(body) {
    background: #ffffff;
    color: #08010f;
    font-family: Arial, Helvetica, sans-serif;
    margin: 0;
  }

  :global(body::before) {
    display: none;
  }

  :global(body.modal-open) {
    overflow: hidden;
  }

  .support-page {
    --purple: #5f3fd6;
    --deep-purple: #25007d;
    --accent: #4d2dcc;
    --soft: #e8ddff;
    --line: #d8c8ff;
    background: #ffffff;
    min-height: 100vh;
    overflow-x: hidden;
  }

  .support-page,
  .support-page * {
    box-sizing: border-box;
  }

  .support-header {
    align-items: center;
    background: #ffffff;
    display: flex;
    justify-content: space-between;
    min-height: 108px;
    padding: 18px clamp(22px, 4.8vw, 64px);
  }

  .support-logo {
    display: inline-flex;
    line-height: 1;
  }

  .support-logo img {
    display: block;
    height: auto;
    width: clamp(260px, 38vw, 520px);
  }

  .contact-pill,
  .ticket-button {
    align-items: center;
    border-radius: 999px;
    display: inline-flex;
    font-weight: 700;
    justify-content: center;
    white-space: nowrap;
  }

  .contact-pill {
    background: var(--purple);
    color: #ffffff;
    font-size: 1.02rem;
    min-height: 47px;
    padding: 0 27px;
    text-decoration: none;
  }

  .support-hero {
    align-items: center;
    background:
      radial-gradient(circle at 24% 65%, rgba(212, 142, 255, 0.55), transparent 30%),
      linear-gradient(120deg, #882bff 0%, #a64ef0 37%, #7200cc 68%, #130071 100%);
    display: flex;
    justify-content: center;
    min-height: 372px;
    padding: 72px 24px 66px;
    text-align: center;
  }

  .support-hero h1 {
    color: #ffffff;
    font-size: clamp(2.1rem, 4.4vw, 3.35rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.16;
    margin: 0;
    max-width: 960px;
  }

  .support-hero span {
    display: block;
    font-size: clamp(2rem, 4.8vw, 3.6rem);
    font-weight: 700;
    line-height: 1.08;
    margin-top: 14px;
  }

  .portal-nav {
    align-items: center;
    background: var(--purple);
    color: #ffffff;
    display: flex;
    gap: 0;
    min-height: 67px;
    padding: 0 6px 0 0;
  }

  .portal-nav a {
    align-items: center;
    color: #ffffff;
    display: inline-flex;
    font-size: 1.3rem;
    font-weight: 600;
    gap: 10px;
    min-height: 67px;
    padding: 0 20px;
    text-decoration: none;
  }

  .portal-nav a.active {
    background: transparent;
    color: #ffffff;
  }

  .portal-nav a.active svg {
    opacity: 1;
  }

  .portal-menu {
    align-self: stretch;
    display: inline-flex;
    margin-left: auto;
    position: relative;
  }

  .portal-menu-toggle {
    align-items: center;
    align-self: stretch;
    background: transparent;
    border: 0;
    color: #ffffff;
    cursor: pointer;
    display: inline-flex;
    flex-direction: column;
    gap: 5px;
    justify-content: center;
    min-height: 67px;
    padding: 0 22px;
  }

  .portal-menu-toggle span {
    background: currentColor;
    border-radius: 999px;
    display: block;
    height: 2px;
    width: 25px;
  }

  .portal-menu-toggle:hover,
  .portal-menu-toggle[aria-expanded="true"] {
    background: #4a2abd;
  }

  .portal-menu-panel {
    background: var(--purple);
    box-shadow: 0 16px 32px rgba(20, 11, 72, 0.2);
    min-width: 220px;
    padding: 8px 0;
    position: absolute;
    right: 0;
    top: 100%;
    z-index: 20;
  }

  .portal-menu-panel[hidden] {
    display: none;
  }

  .portal-menu-panel a {
    color: #ffffff;
    font-size: 1rem;
    min-height: 44px;
    padding: 0 18px;
    white-space: nowrap;
  }

  .portal-menu-panel a:hover {
    background: #4a2abd;
  }

  .portal-nav svg,
  .support-search svg,
  .chat-button svg,
  .contact-block svg {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .portal-nav svg {
    height: 23px;
    opacity: 0.55;
    width: 23px;
  }

  .nav-spacer {
    flex: 1 1 auto;
  }

  .ticket-button {
    background: #ffffff;
    color: var(--purple);
    margin-left: 12px;
    min-height: 51px;
    padding: 0 26px;
  }

  .search-band {
    background: #ffffff;
    border-left: 1px solid #140817;
    border-top: 1px solid #16091a;
    padding: 25px 6px;
  }

  .support-search {
    align-items: center;
    border: 2px solid var(--line);
    color: #9d7cf0;
    display: flex;
    gap: 16px;
    min-height: 66px;
    padding: 0 24px;
  }

  .support-search svg {
    color: #623ee0;
    flex: 0 0 auto;
    height: 27px;
    width: 27px;
  }

  .support-search input {
    border: 0;
    color: #5b38d2;
    font-size: 1.45rem;
    min-width: 0;
    outline: 0;
    width: 100%;
  }

  .support-search input::placeholder {
    color: #9d7cf0;
    opacity: 1;
  }

  .quick-grid {
    background: var(--soft);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    min-height: 537px;
    padding: 38px clamp(28px, 12vw, 250px) 43px;
    row-gap: 74px;
  }

  .quick-link {
    color: #07000c;
    cursor: pointer;
    display: grid;
    justify-items: center;
    padding: 14px 18px 18px;
    text-decoration: none;
    text-align: center;
    transition:
      background-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .quick-link:hover,
  .quick-link:focus-visible {
    background: rgba(255, 255, 255, 0.42);
    box-shadow: 0 16px 32px rgba(69, 36, 158, 0.12);
    outline: none;
    transform: translateY(-2px);
  }

  .quick-link svg {
    color: #6641f3;
    fill: none;
    height: 62px;
    margin-bottom: 10px;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.3;
    width: 62px;
  }

  .quick-link h2 {
    color: var(--purple);
    font-size: clamp(1.7rem, 2.8vw, 2rem);
    line-height: 1.1;
    margin: 0 0 6px;
  }

  .quick-link p {
    color: #050007;
    font-size: clamp(1.28rem, 2.15vw, 1.55rem);
    line-height: 1.08;
    margin: 0;
    max-width: 360px;
  }

  .chat-button {
    align-items: center;
    background: var(--accent);
    border: 0;
    border-radius: 22px;
    bottom: 32px;
    box-shadow: 0 5px 12px rgba(23, 7, 80, 0.35);
    color: #ffffff;
    cursor: pointer;
    display: inline-flex;
    height: 76px;
    justify-content: center;
    position: fixed;
    right: 6px;
    width: 76px;
    z-index: 5;
  }

  .chat-button svg {
    height: 34px;
    width: 34px;
  }

  .chat-panel {
    background: #ffffff;
    border: 1px solid #d9d0f4;
    border-radius: 8px;
    bottom: 118px;
    box-shadow: 0 12px 34px rgba(34, 18, 92, 0.28);
    color: #1c1633;
    padding: 22px;
    position: fixed;
    right: 18px;
    width: min(340px, calc(100vw - 36px));
    z-index: 7;
  }

  .chat-panel h2 {
    color: var(--purple);
    font-size: 1.18rem;
    margin: 0 0 8px;
  }

  .chat-panel p {
    color: #29223d;
    font-size: 0.98rem;
    line-height: 1.45;
    margin: 0 0 16px;
  }

  .chat-panel a {
    background: var(--accent);
    border-radius: 999px;
    color: #ffffff;
    display: inline-flex;
    font-weight: 700;
    min-height: 40px;
    padding: 10px 16px;
  }

  .chat-close,
  .modal-close {
    background: transparent;
    border: 0;
    color: inherit;
    cursor: pointer;
    font-size: 1.8rem;
    font-weight: 300;
    line-height: 1;
    padding: 0;
    position: absolute;
    right: 16px;
    top: 12px;
  }

  .modal-backdrop {
    background: rgba(17, 10, 46, 0.5);
    inset: 0;
    position: fixed;
    z-index: 30;
  }

  .escalate-modal {
    background: #ffffff;
    border-radius: 3px;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.26);
    color: #252525;
    left: 50%;
    max-width: 560px;
    padding: 30px 32px 32px;
    position: fixed;
    top: 50%;
    transform: translate(-50%, -50%);
    width: calc(100vw - 40px);
    z-index: 31;
  }

  .escalate-modal h2 {
    color: #252525;
    font-size: 1.65rem;
    line-height: 1.2;
    margin: 0 32px 18px 0;
  }

  .escalate-modal p {
    color: #333333;
    font-size: 1rem;
    line-height: 1.55;
    margin: 0 0 22px;
  }

  .escalate-modal p a {
    color: var(--accent);
    font-weight: 700;
  }

  .continue-button {
    background: var(--accent);
    border-radius: 3px;
    color: #ffffff;
    display: inline-flex;
    font-weight: 700;
    min-height: 42px;
    padding: 10px 24px;
    text-decoration: none;
  }

  .support-footer {
    background: var(--purple);
    color: #ffffff;
    padding: 46px 30px 88px;
  }

  .footer-rule {
    border-top: 1px solid rgba(255, 255, 255, 0.28);
    margin-bottom: 38px;
  }

  .contact-block {
    display: grid;
    justify-items: start;
    max-width: 720px;
  }

  .contact-block h2 {
    font-size: 1.12rem;
    margin: 0 0 15px;
  }

  .contact-block p {
    color: #ffffff;
    font-size: 1.04rem;
    line-height: 1.35;
    margin: 0 0 7px;
  }

  .contact-block a {
    align-items: center;
    display: inline-flex;
    font-size: 1.12rem;
    font-weight: 600;
    gap: 12px;
    margin: 0 0 30px;
  }

  .contact-block svg {
    height: 25px;
    width: 25px;
  }

  .connect-title {
    margin-top: 10px;
  }

  .social-links {
    display: flex;
    gap: 28px;
    margin: 4px 0 26px;
  }

  .social-links a {
    align-items: center;
    display: inline-flex;
    font-size: 1.6rem;
    font-weight: 900;
    height: 26px;
    justify-content: center;
    margin: 0;
    width: 26px;
  }

  .copyright {
    font-size: 1.28rem;
    letter-spacing: 0;
    margin-top: 4px;
  }

  .sr-only {
    clip: rect(0, 0, 0, 0);
    clip-path: inset(50%);
    height: 1px;
    margin: -1px;
    overflow: hidden;
    padding: 0;
    position: absolute;
    width: 1px;
  }

  @media (max-width: 820px) {
    .support-header,
    .portal-nav {
      padding-inline: 18px;
    }

    .support-header {
      min-height: 82px;
      padding-block: 14px;
    }

    .support-header .contact-pill {
      display: none;
    }

    .support-logo img {
      width: clamp(220px, 58vw, 360px);
    }

    .support-hero {
      min-height: 310px;
    }

    .portal-nav {
      align-items: stretch;
      flex-wrap: wrap;
      padding-block: 8px;
    }

    .portal-nav a {
      font-size: 1rem;
      min-height: 45px;
      padding: 0 12px;
    }

    .portal-menu-toggle {
      min-height: 45px;
      padding-inline: 16px;
    }

    .portal-menu-panel {
      min-width: 205px;
    }

    .nav-spacer {
      display: none;
    }

    .ticket-button {
      margin-left: 0;
    }

    .support-search input {
      font-size: 1rem;
    }

    .quick-grid {
      grid-template-columns: 1fr;
      padding: 42px 20px;
      row-gap: 48px;
    }

    .quick-link p {
      line-height: 1.25;
    }

    .chat-button {
      border-radius: 18px;
      height: 58px;
      width: 58px;
    }
  }

  @media (max-width: 520px) {
    .support-header {
      align-items: center;
      justify-content: center;
      min-height: 72px;
      padding: 12px 16px;
    }

    .support-logo {
      max-width: 100%;
      width: min(82vw, 300px);
    }

    .support-logo img {
      width: 100%;
    }

    .support-hero h1 {
      font-size: 2rem;
    }

    .search-band {
      padding: 16px 0;
    }

    .support-search {
      min-height: 58px;
      padding: 0 16px;
    }

    .support-footer {
      padding-inline: 20px;
    }

    .copyright {
      font-size: 1rem;
    }
  }
</style>
