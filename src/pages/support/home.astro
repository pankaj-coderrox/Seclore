---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const quickLinks = [
  {
    title: "Solutions",
    text: "Find solutions to the most common problems",
    icon: "solution",
    href: "/support/solutions/"
  },
  {
    title: "Forums",
    text: "Discuss, debate, analyze, and give suggestions for improving Seclore",
    icon: "forum",
    href: "/support/discussions/"
  },
  {
    title: "Tickets",
    text: "Having a problem with Seclore? Get it resolved quickly by creating a ticket",
    icon: "ticket",
    href: "/support/tickets/new/"
  },
  {
    title: "Escalate Ticket",
    text: "Created a ticket and want to escalate it? Click here to get started",
    icon: "escalate",
    href: "#escalate-ticket",
    modal: true
  }
];

const iconPaths = {
  solution: [
    "M12 4a3 3 0 1 1 0 6 3 3 0 0 1 0-6Z",
    "M12 1v2m0 8v2M4.22 4.22l1.42 1.42m8.72 8.72 1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42m8.72-8.72 1.42-1.42",
    "M5 22v-5.6A8.5 8.5 0 0 1 3.5 9.2M19 22v-5.6a8.5 8.5 0 0 0 1.5-7.2",
    "M8 22v-5h8v5"
  ],
  forum: [
    "M5 7h8v7H8l-3 3v-3H3V7h2Z",
    "M13 10h8v7h-2v3l-3-3h-3v-7Z",
    "M9 4a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm8 2a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z",
    "M6 6a3 3 0 0 1 6 0m2 2a3 3 0 0 1 6 0"
  ],
  ticket: [
    "M3 5h18v14H3V5Z",
    "M6 8h12M6 11h12M6 14h8M6 17h10",
    "M3 9h18"
  ],
  escalate: [
    "M12 3 4 20h16L12 3Z",
    "M12 8v9M8 17h8",
    "M8 13h8M9.5 10h5"
  ]
};
---

<BaseLayout
  title="Seclore Support Portal"
  description="Seclore support portal home for solutions, forums, support tickets, escalation, and contact details."
>
  <main class="support-page">
    <Nav />
    <header class="support-header">
      <a class="support-logo" href="/" aria-label="Seclore home">
        SECL<span>ORE</span><sup>TM</sup>
      </a>
      <a class="contact-pill" href="#contact">Contact Us</a>
    </header>

    <section class="support-hero">
      <h1>
        Welcome to the Seclore Support Portal
        <span>How can we help?</span>
      </h1>
    </section>

    <nav class="portal-nav" aria-label="Support portal navigation">
      <a class="active" href="/support/home/" aria-current="page">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m3 11 9-8 9 8" />
          <path d="M5 10v10h5v-6h4v6h5V10" />
        </svg>
        Support Home
      </a>
      <a href="/support/solutions/">Solutions</a>
      <a href="/support/discussions/">Forums</a>
      <span class="nav-spacer"></span>
      <a href="/support/login/">Login</a>
      <a class="ticket-button" href="/support/tickets/new/">New Support Ticket</a>
    </nav>

    <section class="search-band" aria-label="Search support content">
      <form class="support-search" action="/support/search/" method="get">
        <span class="sr-only">Search Articles and Community Discussions</span>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="10.5" cy="10.5" r="6.5" />
          <path d="m16 16 5 5" />
        </svg>
        <input type="search" name="term" placeholder="Search Articles and Community Discussions.." />
        <button class="sr-only" type="submit">Search</button>
      </form>
    </section>

    <section class="quick-grid" aria-label="Support options">
      {quickLinks.map((item) => (
        <a
          class="quick-link"
          id={item.title === "Solutions" ? "solutions" : item.title === "Forums" ? "forums" : item.title === "Tickets" ? "ticket" : "escalate-ticket"}
          href={item.href}
          data-escalate={item.modal ? "true" : undefined}
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            {iconPaths[item.icon as keyof typeof iconPaths].map((path: string) => <path d={path} />)}
          </svg>
          <h2>{item.title}</h2>
          <p>{item.text}</p>
        </a>
      ))}
    </section>

    <button class="chat-button" type="button" aria-label="Chat with support" aria-expanded="false">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5 6h14v10H9l-4 4V6Z" />
        <path d="M8 10h8M8 13h5" />
      </svg>
    </button>

    <section class="chat-panel" aria-label="Support chat" hidden>
      <button class="chat-close" type="button" aria-label="Close chat">x</button>
      <h2>Seclore Support</h2>
      <p>Tell us what you need help with. For urgent issues, create a support ticket.</p>
      <a href="/support/tickets/new/">New Support Ticket</a>
    </section>

    <div class="modal-backdrop" data-modal-backdrop hidden></div>
    <section
      class="escalate-modal"
      aria-modal="true"
      aria-labelledby="escalate-title"
      role="dialog"
      hidden
    >
      <button class="modal-close" type="button" aria-label="Close escalation dialog">x</button>
      <h2 id="escalate-title">Escalate Ticket</h2>
      <p>
        Anyone can escalate a ticket by sending an email to
        <a href="mailto:supportescalation@seclore.com">supportescalation@seclore.com</a>. This
        will open a ticket in our support system for tracking and the support management will be
        notified along with the Seclore leadership team.
      </p>
      <a class="continue-button" href="mailto:supportescalation@seclore.com">Continue</a>
    </section>

    <script>
      const escalateModal = document.querySelector(".escalate-modal");
      const modalBackdrop = document.querySelector("[data-modal-backdrop]");
      const chatButton = document.querySelector(".chat-button");
      const chatPanel = document.querySelector(".chat-panel");

      function setModalOpen(open: boolean) {
        if (escalateModal instanceof HTMLElement && modalBackdrop instanceof HTMLElement) {
          escalateModal.hidden = !open;
          modalBackdrop.hidden = !open;
          document.body.classList.toggle("modal-open", open);
        }
      }

      document.querySelectorAll("[data-escalate]").forEach((link) => {
        link.addEventListener("click", (event) => {
          event.preventDefault();
          setModalOpen(true);
        });
      });

      document.querySelector(".modal-close")?.addEventListener("click", () => setModalOpen(false));
      modalBackdrop?.addEventListener("click", () => setModalOpen(false));
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          setModalOpen(false);
          if (chatPanel instanceof HTMLElement && chatButton instanceof HTMLElement) {
            chatPanel.hidden = true;
            chatButton.setAttribute("aria-expanded", "false");
          }
        }
      });

      chatButton?.addEventListener("click", () => {
        if (chatPanel instanceof HTMLElement && chatButton instanceof HTMLElement) {
          const nextOpen = chatPanel.hidden;
          chatPanel.hidden = !nextOpen;
          chatButton.setAttribute("aria-expanded", String(nextOpen));
        }
      });

      document.querySelector(".chat-close")?.addEventListener("click", () => {
        if (chatPanel instanceof HTMLElement && chatButton instanceof HTMLElement) {
          chatPanel.hidden = true;
          chatButton.setAttribute("aria-expanded", "false");
        }
      });
    </script>
  </main>
</BaseLayout>

<style>
  :global(body) {
    background: #ffffff;
    color: #08010f;
    font-family: Arial, Helvetica, sans-serif;
  }

  :global(body::before) {
    display: none;
  }

  :global(body.modal-open) {
    overflow: hidden;
  }

  .support-page {
    --purple: #5f3fd6;
    --deep-purple: #25007d;
    --accent: #4d2dcc;
    --soft: #e8ddff;
    --line: #d8c8ff;
    background: #ffffff;
    min-height: 100vh;
    overflow-x: hidden;
  }

  .support-header {
    align-items: center;
    background: #ffffff;
    display: flex;
    justify-content: space-between;
    min-height: 95px;
    padding: 22px clamp(24px, 4.4vw, 54px);
  }

  .support-logo {
    color: var(--accent);
    display: inline-flex;
    font-size: clamp(2.2rem, 5vw, 4.1rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.78;
  }

  .support-logo span {
    color: inherit;
  }

  .support-logo sup {
    font-size: 0.18em;
    font-weight: 500;
    line-height: 1;
    margin-left: 5px;
    transform: translateY(-0.25em);
  }

  .contact-pill,
  .ticket-button {
    align-items: center;
    border-radius: 999px;
    display: inline-flex;
    font-weight: 700;
    justify-content: center;
    white-space: nowrap;
  }

  .contact-pill {
    background: var(--purple);
    color: #ffffff;
    font-size: 1.02rem;
    min-height: 47px;
    padding: 0 27px;
  }

  .support-hero {
    align-items: center;
    background:
      radial-gradient(circle at 24% 65%, rgba(212, 142, 255, 0.55), transparent 30%),
      linear-gradient(120deg, #882bff 0%, #a64ef0 37%, #7200cc 68%, #130071 100%);
    display: flex;
    justify-content: center;
    min-height: 439px;
    padding: 64px 24px;
    text-align: center;
  }

  .support-hero h1 {
    color: #ffffff;
    font-size: clamp(2.5rem, 5vw, 4.1rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.04;
    margin: 0;
    max-width: 1120px;
  }

  .support-hero span {
    display: block;
  }

  .portal-nav {
    align-items: center;
    background: var(--purple);
    color: #ffffff;
    display: flex;
    gap: 0;
    min-height: 67px;
    padding: 0 6px 0 24px;
  }

  .portal-nav a {
    align-items: center;
    display: inline-flex;
    font-size: 1.3rem;
    font-weight: 600;
    gap: 10px;
    min-height: 67px;
    padding: 0 20px;
  }

  .portal-nav a.active {
    background: #4a2abd;
  }

  .portal-nav svg,
  .support-search svg,
  .chat-button svg,
  .contact-block svg {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .portal-nav svg {
    height: 23px;
    opacity: 0.55;
    width: 23px;
  }

  .nav-spacer {
    flex: 1 1 auto;
  }

  .ticket-button {
    background: #ffffff;
    color: var(--purple);
    margin-left: 12px;
    min-height: 51px;
    padding: 0 26px;
  }

  .search-band {
    background: #ffffff;
    border-left: 1px solid #140817;
    border-top: 1px solid #16091a;
    padding: 25px 6px;
  }

  .support-search {
    align-items: center;
    border: 2px solid var(--line);
    color: #9d7cf0;
    display: flex;
    gap: 16px;
    min-height: 66px;
    padding: 0 24px;
  }

  .support-search svg {
    color: #623ee0;
    flex: 0 0 auto;
    height: 27px;
    width: 27px;
  }

  .support-search input {
    border: 0;
    color: #5b38d2;
    font-size: 1.45rem;
    min-width: 0;
    outline: 0;
    width: 100%;
  }

  .support-search input::placeholder {
    color: #9d7cf0;
    opacity: 1;
  }

  .quick-grid {
    background: var(--soft);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    min-height: 537px;
    padding: 38px clamp(28px, 12vw, 250px) 43px;
    row-gap: 74px;
  }

  .quick-link {
    color: #07000c;
    display: grid;
    justify-items: center;
    text-align: center;
  }

  .quick-link svg {
    color: #6641f3;
    fill: none;
    height: 62px;
    margin-bottom: 10px;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.3;
    width: 62px;
  }

  .quick-link h2 {
    color: var(--purple);
    font-size: clamp(1.7rem, 2.8vw, 2rem);
    line-height: 1.1;
    margin: 0 0 6px;
  }

  .quick-link p {
    color: #050007;
    font-size: clamp(1.28rem, 2.15vw, 1.55rem);
    line-height: 1.08;
    margin: 0;
    max-width: 360px;
  }

  .chat-button {
    align-items: center;
    background: var(--accent);
    border: 0;
    border-radius: 22px;
    bottom: 32px;
    box-shadow: 0 5px 12px rgba(23, 7, 80, 0.35);
    color: #ffffff;
    cursor: pointer;
    display: inline-flex;
    height: 76px;
    justify-content: center;
    position: fixed;
    right: 6px;
    width: 76px;
    z-index: 5;
  }

  .chat-button svg {
    height: 34px;
    width: 34px;
  }

  .chat-panel {
    background: #ffffff;
    border: 1px solid #d9d0f4;
    border-radius: 8px;
    bottom: 118px;
    box-shadow: 0 12px 34px rgba(34, 18, 92, 0.28);
    color: #1c1633;
    padding: 22px;
    position: fixed;
    right: 18px;
    width: min(340px, calc(100vw - 36px));
    z-index: 7;
  }

  .chat-panel h2 {
    color: var(--purple);
    font-size: 1.18rem;
    margin: 0 0 8px;
  }

  .chat-panel p {
    color: #29223d;
    font-size: 0.98rem;
    line-height: 1.45;
    margin: 0 0 16px;
  }

  .chat-panel a {
    background: var(--accent);
    border-radius: 999px;
    color: #ffffff;
    display: inline-flex;
    font-weight: 700;
    min-height: 40px;
    padding: 10px 16px;
  }

  .chat-close,
  .modal-close {
    background: transparent;
    border: 0;
    color: inherit;
    cursor: pointer;
    font-size: 1.2rem;
    line-height: 1;
    padding: 0;
    position: absolute;
    right: 16px;
    top: 14px;
  }

  .modal-backdrop {
    background: rgba(17, 10, 46, 0.5);
    inset: 0;
    position: fixed;
    z-index: 30;
  }

  .escalate-modal {
    background: #ffffff;
    border-radius: 4px;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.26);
    color: #252525;
    left: 50%;
    max-width: 520px;
    padding: 28px 30px 30px;
    position: fixed;
    top: 50%;
    transform: translate(-50%, -50%);
    width: calc(100vw - 40px);
    z-index: 31;
  }

  .escalate-modal h2 {
    color: #252525;
    font-size: 1.65rem;
    line-height: 1.2;
    margin: 0 32px 18px 0;
  }

  .escalate-modal p {
    color: #333333;
    font-size: 1rem;
    line-height: 1.55;
    margin: 0 0 22px;
  }

  .escalate-modal p a {
    color: var(--accent);
    font-weight: 700;
  }

  .continue-button {
    background: var(--accent);
    border-radius: 999px;
    color: #ffffff;
    display: inline-flex;
    font-weight: 700;
    min-height: 42px;
    padding: 10px 22px;
  }

  .support-footer {
    background: var(--purple);
    color: #ffffff;
    padding: 46px 30px 88px;
  }

  .footer-rule {
    border-top: 1px solid rgba(255, 255, 255, 0.28);
    margin-bottom: 38px;
  }

  .contact-block {
    display: grid;
    justify-items: start;
    max-width: 720px;
  }

  .contact-block h2 {
    font-size: 1.12rem;
    margin: 0 0 15px;
  }

  .contact-block p {
    color: #ffffff;
    font-size: 1.04rem;
    line-height: 1.35;
    margin: 0 0 7px;
  }

  .contact-block a {
    align-items: center;
    display: inline-flex;
    font-size: 1.12rem;
    font-weight: 600;
    gap: 12px;
    margin: 0 0 30px;
  }

  .contact-block svg {
    height: 25px;
    width: 25px;
  }

  .connect-title {
    margin-top: 10px;
  }

  .social-links {
    display: flex;
    gap: 28px;
    margin: 4px 0 26px;
  }

  .social-links a {
    align-items: center;
    display: inline-flex;
    font-size: 1.6rem;
    font-weight: 900;
    height: 26px;
    justify-content: center;
    margin: 0;
    width: 26px;
  }

  .copyright {
    font-size: 1.28rem;
    letter-spacing: 0;
    margin-top: 4px;
  }

  .sr-only {
    clip: rect(0, 0, 0, 0);
    clip-path: inset(50%);
    height: 1px;
    margin: -1px;
    overflow: hidden;
    padding: 0;
    position: absolute;
    width: 1px;
  }

  @media (max-width: 820px) {
    .support-header,
    .portal-nav {
      padding-inline: 18px;
    }

    .support-header {
      min-height: 82px;
    }

    .contact-pill {
      font-size: 0.92rem;
      min-height: 42px;
      padding: 0 18px;
    }

    .support-hero {
      min-height: 310px;
    }

    .portal-nav {
      align-items: stretch;
      flex-wrap: wrap;
      padding-block: 8px;
    }

    .portal-nav a {
      font-size: 1rem;
      min-height: 45px;
      padding: 0 12px;
    }

    .nav-spacer {
      display: none;
    }

    .ticket-button {
      margin-left: 0;
    }

    .support-search input {
      font-size: 1rem;
    }

    .quick-grid {
      grid-template-columns: 1fr;
      padding: 42px 20px;
      row-gap: 48px;
    }

    .quick-link p {
      line-height: 1.25;
    }

    .chat-button {
      border-radius: 18px;
      height: 58px;
      width: 58px;
    }
  }

  @media (max-width: 520px) {
    .support-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 16px;
    }

    .support-logo {
      font-size: 2rem;
    }

    .support-hero h1 {
      font-size: 2rem;
    }

    .search-band {
      padding: 16px 0;
    }

    .support-search {
      min-height: 58px;
      padding: 0 16px;
    }

    .support-footer {
      padding-inline: 20px;
    }

    .copyright {
      font-size: 1rem;
    }
  }
</style>
