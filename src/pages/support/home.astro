---
import BaseLayout from "@layouts/BaseLayout.astro";

const portalCards = [
  {
    id: "solutions",
    title: "Solutions",
    text: "Find solutions to the most common problems",
    href: "/support/solutions/"
  },
  {
    id: "forums",
    title: "Forums",
    text: "Discuss, debate, analyze, and give suggestions for improving Seclore",
    href: "/support/discussions/"
  },
  {
    id: "tickets",
    title: "Tickets",
    text: "Having a problem with Seclore? Get it resolved quickly by creating a ticket",
    href: "/support/tickets/new/"
  },
  {
    id: "escalate",
    title: "Escalate Ticket",
    text: "Created a ticket and want to escalate it? Click here to get started",
    href: "#escalate-ticket"
  }
];

const socialLinks = [
  ["LinkedIn", "https://www.linkedin.com/company/seclore", "in"],
  ["Facebook", "https://www.facebook.com/Seclore", "f"],
  ["X", "https://x.com/seclore", "x"],
  ["YouTube", "https://www.youtube.com/@Seclore", "play"]
];
---

<BaseLayout
  title="Seclore Support Portal"
  description="Search Seclore support articles, browse solutions, join forums, create tickets, and contact Seclore support."
  hideFooter={true}
>
  <main class="support-home-page">
    <header class="support-header" aria-label="Seclore support header">
      <a class="support-logo" href="/support/home/" aria-label="Seclore support home">
        <img src="/images/home/seclore-logo-2026.svg" alt="Seclore" loading="eager" decoding="async" />
      </a>
      <a class="contact-pill" href="#contact">Contact Us</a>
    </header>

    <section class="support-hero" aria-labelledby="support-hero-title">
      <div class="support-hero-inner">
        <h1 id="support-hero-title">Welcome to the Seclore Support Portal</h1>
      </div>
    </section>

    <nav class="portal-nav" aria-label="Support portal navigation">
      <a class="support-home-link active" href="/support/home/" aria-current="page">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 11.5 12 4l9 7.5v8a1 1 0 0 1-1 1h-5.5v-6h-5v6H4a1 1 0 0 1-1-1v-8Z" /></svg>
        Support Home
      </a>

      <button class="portal-menu-toggle" type="button" aria-label="Open support menu" aria-expanded="false" aria-controls="support-menu">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <div class="portal-links" id="support-menu">
        <a href="/support/solutions/">Solutions</a>
        <a href="/support/discussions/">Forums</a>
        <a class="login-link" href="/support/login/">Login</a>
        <a class="ticket-pill" href="/support/tickets/new/">New Support Ticket</a>
      </div>
    </nav>

    <section class="search-band" aria-label="Search support content">
      <form class="support-search" action="/support/search/" method="get">
        <label class="sr-only" for="support-search-input">Search support articles and community discussions</label>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m20 20-4.4-4.4M10.8 18a7.2 7.2 0 1 1 0-14.4 7.2 7.2 0 0 1 0 14.4Z" /></svg>
        <input id="support-search-input" name="term" type="search" placeholder="Search Articles and Community Discussions.." autocomplete="off" />
      </form>
    </section>

    <section class="portal-cards" aria-label="Support portal options">
      <div class="portal-card-grid">
        {portalCards.map((card) => (
          <a
            class={`portal-card ${card.id}`}
            href={card.href}
            data-escalate-ticket={card.id === "escalate" ? "true" : undefined}
            aria-haspopup={card.id === "escalate" ? "dialog" : undefined}
          >
            <span class={`portal-card-icon icon-${card.id}`} aria-hidden="true"></span>
            <strong>{card.title}</strong>
            <span>{card.text}</span>
          </a>
        ))}
      </div>
    </section>

    <footer class="support-footer" id="contact" aria-labelledby="support-contact-title">
      <div class="footer-inner">
        <h2 id="support-contact-title">Contact Us</h2>
        <div class="contact-list">
          <p>
            <span>North America</span>
            <a href="tel:+18552732505">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.6 10.8c1.7 3.3 3.3 4.9 6.6 6.6l2.2-2.2c.3-.3.8-.4 1.2-.3 1.3.4 2.6.6 4 .6.7 0 1.2.5 1.2 1.2v3.6c0 .7-.5 1.2-1.2 1.2C10.8 22 2 13.2 2 2.4 2 1.7 2.5 1.2 3.2 1.2h3.6c.7 0 1.2.5 1.2 1.2 0 1.4.2 2.7.6 4 .1.4 0 .9-.3 1.2l-1.7 3.2Z" /></svg>
              +1-855-273-2505
            </a>
          </p>
          <p>
            <span>India &amp; Rest of the World</span>
            <a href="tel:+912261304242">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.6 10.8c1.7 3.3 3.3 4.9 6.6 6.6l2.2-2.2c.3-.3.8-.4 1.2-.3 1.3.4 2.6.6 4 .6.7 0 1.2.5 1.2 1.2v3.6c0 .7-.5 1.2-1.2 1.2C10.8 22 2 13.2 2 2.4 2 1.7 2.5 1.2 3.2 1.2h3.6c.7 0 1.2.5 1.2 1.2 0 1.4.2 2.7.6 4 .1.4 0 .9-.3 1.2l-1.7 3.2Z" /></svg>
              +91-22-61304242 / 61434848
            </a>
          </p>
          <p>
            <span>Email</span>
            <a href="mailto:support@seclore.com">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 5h18v14H3V5Zm2 3 7 5 7-5" /></svg>
              support@seclore.com
            </a>
          </p>
        </div>

        <div class="social-block">
          <h3>Connect with us</h3>
          <div class="social-links">
            {socialLinks.map(([label, href, glyph]) => (
              <a href={href} target="_blank" rel="noreferrer" aria-label={label}>
                {glyph === "play" ? (
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 6v12l10-6-10-6Z" /></svg>
                ) : (
                  <span>{glyph}</span>
                )}
              </a>
            ))}
          </div>
        </div>

        <div class="footer-bottom">
          <p>&copy; 2026 SECLORE. ALL RIGHTS RESERVED. <a href="/privacy/">PRIVACY STATEMENT</a>.</p>
        </div>
      </div>
    </footer>

    <button class="chat-button" type="button" aria-label="Chat with support" aria-expanded="false">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5 6h14v10H9l-4 4V6Z" />
        <path d="M8 10h8M8 13h5" />
      </svg>
    </button>

    <section class="chat-panel" aria-label="Support chat" hidden>
      <button class="chat-close" type="button" aria-label="Close chat">x</button>
      <h2>Seclore Support</h2>
      <p>Tell us what you need help with. The support team will help you track the request.</p>
      <a href="mailto:support@seclore.com">Email Support</a>
    </section>

    <section class="escalate-modal" role="dialog" aria-modal="true" aria-labelledby="escalate-ticket-title" hidden>
      <button class="escalate-modal-backdrop" type="button" aria-label="Close escalation dialog" data-escalate-close></button>
      <div class="escalate-modal-card" tabindex="-1">
        <div class="escalate-modal-header">
          <h2 id="escalate-ticket-title">Escalate Ticket</h2>
          <button class="escalate-modal-close" type="button" aria-label="Close escalation dialog" data-escalate-close>x</button>
        </div>
        <p>
          Anyone can escalate a ticket by sending an email to <a href="mailto:supportescalation@seclore.com">supportescalation@seclore.com</a>.
          This will open a ticket in our support system for tracking, and the support management will be notified along with the Seclore leadership team.
        </p>
        <a class="escalate-continue" href="mailto:supportescalation@seclore.com?subject=Escalate%20Support%20Ticket">Continue</a>
      </div>
    </section>

    <script>
      const menuButton = document.querySelector(".portal-menu-toggle");
      const portalNav = document.querySelector(".portal-nav");
      const chatButton = document.querySelector(".chat-button");
      const chatPanel = document.querySelector(".chat-panel");
      const chatClose = document.querySelector(".chat-close");
      const escalateTriggers = document.querySelectorAll("[data-escalate-ticket]");
      const escalateModal = document.querySelector(".escalate-modal");
      const escalateDialog = document.querySelector(".escalate-modal-card");
      const escalateCloseButtons = document.querySelectorAll("[data-escalate-close]");
      let lastEscalateFocus = null;

      const openEscalateModal = () => {
        if (!(escalateModal instanceof HTMLElement)) {
          return;
        }
        lastEscalateFocus = document.activeElement;
        escalateModal.hidden = false;
        document.body.style.overflow = "hidden";
        if (escalateDialog instanceof HTMLElement) {
          escalateDialog.focus();
        }
      };

      const closeEscalateModal = () => {
        if (!(escalateModal instanceof HTMLElement) || escalateModal.hidden) {
          return;
        }
        escalateModal.hidden = true;
        document.body.style.overflow = "";
        if (lastEscalateFocus instanceof HTMLElement) {
          lastEscalateFocus.focus();
        }
      };

      menuButton?.addEventListener("click", () => {
        if (!(menuButton instanceof HTMLButtonElement) || !(portalNav instanceof HTMLElement)) {
          return;
        }
        const open = menuButton.getAttribute("aria-expanded") !== "true";
        menuButton.setAttribute("aria-expanded", String(open));
        portalNav.classList.toggle("is-open", open);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key !== "Escape") {
          return;
        }
        if (menuButton instanceof HTMLButtonElement && portalNav instanceof HTMLElement) {
          menuButton.setAttribute("aria-expanded", "false");
          portalNav.classList.remove("is-open");
        }
        if (chatPanel instanceof HTMLElement && chatButton instanceof HTMLButtonElement) {
          chatPanel.hidden = true;
          chatButton.setAttribute("aria-expanded", "false");
        }
        closeEscalateModal();
      });

      escalateTriggers.forEach((trigger) => {
        trigger.addEventListener("click", (event) => {
          event.preventDefault();
          openEscalateModal();
        });
      });

      escalateCloseButtons.forEach((button) => {
        button.addEventListener("click", closeEscalateModal);
      });

      chatButton?.addEventListener("click", () => {
        if (!(chatButton instanceof HTMLButtonElement) || !(chatPanel instanceof HTMLElement)) {
          return;
        }
        const open = chatPanel.hidden;
        chatPanel.hidden = !open;
        chatButton.setAttribute("aria-expanded", String(open));
      });

      chatClose?.addEventListener("click", () => {
        if (chatPanel instanceof HTMLElement && chatButton instanceof HTMLButtonElement) {
          chatPanel.hidden = true;
          chatButton.setAttribute("aria-expanded", "false");
        }
      });
    </script>
  </main>
</BaseLayout>

<style is:global>
  :root {
    --support-purple: #633dde;
    --support-purple-dark: #4d25cd;
    --support-purple-deep: #260085;
    --support-lilac: #e9dcff;
    --support-text: #121019;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: #fff;
    color: var(--support-text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a { color: inherit; text-decoration: none; }
  button, input { font: inherit; }

  .support-home-page {
    color: var(--support-text);
    font-family: Inter, "Segoe UI", Roboto, Arial, sans-serif;
    font-weight: 400;
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
    text-rendering: geometricPrecision;
    -webkit-font-smoothing: antialiased;
  }

  .support-header {
    align-items: center;
    background: #fff;
    border-top: 1px solid #dedede;
    display: flex;
    justify-content: flex-start;
    min-height: 95px;
    padding: 18px clamp(22px, 4.4vw, 54px);
    position: relative;
  }

  .support-logo {
    display: inline-flex;
    line-height: 0;
  }

  .support-logo img {
    display: block;
    height: auto;
    filter: contrast(1.12) saturate(1.08);
    transform: scaleX(1.03);
    transform-origin: center;
    width: clamp(300px, 34vw, 410px);
  }

  .contact-pill {
    align-items: center;
    background: var(--support-purple);
    border-radius: 999px;
    color: #fff;
    display: inline-flex;
    font-size: 1.05rem;
    font-weight: 850;
    justify-content: center;
    min-height: 48px;
    padding: 0 28px;
    position: absolute;
    right: clamp(22px, 4.4vw, 54px);
    white-space: nowrap;
  }

  .ticket-pill {
    align-items: center;
    background: var(--support-purple);
    border-radius: 999px;
    color: #fff;
    display: inline-flex;
    font-size: 1.05rem;
    font-weight: 850;
    justify-content: center;
    min-height: 48px;
    padding: 0 28px;
    white-space: nowrap;
  }

  .support-hero {
    align-items: center;
    background:
      radial-gradient(circle at 28% 90%, rgba(236, 180, 255, 0.75), transparent 34%),
      linear-gradient(115deg, #8d37ff 0%, #7c2de8 42%, #2d008a 100%);
    color: #fff;
    display: flex;
    min-height: 438px;
    padding: 86px 24px;
    text-align: center;
  }

  .support-hero-inner {
    margin: 0 auto;
    max-width: 1040px;
  }

  .support-hero h1 {
    color: #fff;
    font-size: clamp(2.6rem, 4.9vw, 4.25rem);
    font-weight: 750;
    letter-spacing: 0;
    line-height: 1.04;
    margin: 0;
    text-shadow: 0 2px 10px rgba(28, 0, 93, 0.12);
  }

  .support-hero p {
    color: rgba(255, 255, 255, 0.96);
    font-size: clamp(1.65rem, 3vw, 2.35rem);
    font-weight: 500;
    line-height: 1.2;
    margin: 42px 0 0;
  }

  .portal-nav {
    align-items: center;
    background: var(--support-purple);
    color: #fff;
    display: flex;
    min-height: 67px;
    position: relative;
    z-index: 5;
  }

  .support-home-link,
  .portal-links a {
    align-items: center;
    display: inline-flex;
    font-size: 1.2rem;
    font-weight: 650;
    min-height: 67px;
    padding: 0 clamp(18px, 2.2vw, 26px);
  }

  .support-home-link {
    background: var(--support-purple-dark);
    gap: 10px;
    font-weight: 800;
  }

  .support-home-link svg {
    fill: none;
    height: 24px;
    stroke: rgba(255, 255, 255, 0.75);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
    width: 24px;
  }

  .portal-links {
    align-items: center;
    display: flex;
    flex: 1;
  }

  .portal-links .login-link {
    margin-left: auto;
  }

  .portal-links .ticket-pill {
    background: #fff;
    color: var(--support-purple);
    font-weight: 850;
    margin-right: 7px;
    min-height: 50px;
    padding-inline: 28px;
  }

  .portal-menu-toggle {
    align-items: center;
    background: transparent;
    border: 0;
    display: none;
    flex-direction: column;
    gap: 5px;
    height: 48px;
    justify-content: center;
    margin-left: auto;
    width: 54px;
  }

  .portal-menu-toggle span {
    background: #fff;
    border-radius: 999px;
    display: block;
    height: 2px;
    width: 24px;
  }

  .search-band {
    background: #fff;
    border-left: 1px solid #0f0f0f;
    border-right: 1px solid #0f0f0f;
    padding: 25px 6px;
  }

  .support-search {
    align-items: center;
    border: 1px solid #d9c7ff;
    display: flex;
    gap: 16px;
    min-height: 67px;
    padding: 0 24px;
    width: 100%;
  }

  .support-search svg {
    fill: none;
    flex: 0 0 auto;
    height: 28px;
    stroke: var(--support-purple);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.4;
    width: 28px;
  }

  .support-search input {
    border: 0;
    color: var(--support-purple-dark);
    flex: 1;
    font-size: 1.35rem;
    font-weight: 500;
    min-width: 0;
    outline: none;
  }

  .support-search input::placeholder {
    color: #835dea;
    opacity: 1;
  }

  .portal-cards {
    background: var(--support-lilac);
    padding: 40px 24px 55px;
  }

  .portal-card-grid {
    display: grid;
    gap: 74px clamp(52px, 14vw, 180px);
    grid-template-columns: repeat(2, minmax(220px, 360px));
    justify-content: center;
    margin: 0 auto;
    max-width: 1040px;
  }

  .portal-card {
    align-items: center;
    border-radius: 18px;
    color: #1b1029;
    display: grid;
    justify-items: center;
    min-height: 198px;
    padding: 0 16px;
    text-align: center;
    transition: transform 180ms ease, background 180ms ease;
  }

  .portal-card:hover,
  .portal-card:focus-visible {
    background: rgba(255, 255, 255, 0.36);
    outline: none;
    transform: translateY(-3px);
  }

  .portal-card strong {
    color: var(--support-purple-dark);
    font-size: 1.9rem;
    font-weight: 850;
    line-height: 1.05;
    margin-top: 10px;
  }

  .portal-card span:not(.portal-card-icon) {
    color: #12091d;
    font-size: 1.42rem;
    font-weight: 500;
    line-height: 1.18;
    max-width: 360px;
  }

  .portal-card-icon {
    color: var(--support-purple);
    display: block;
    height: 60px;
    position: relative;
    width: 68px;
  }

  .portal-card-icon::before,
  .portal-card-icon::after {
    content: "";
    position: absolute;
  }

  .icon-solutions::before {
    border: 2px solid currentColor;
    border-radius: 50%;
    height: 30px;
    left: 19px;
    top: 3px;
    width: 30px;
  }

  .icon-solutions::after {
    border: 2px solid currentColor;
    border-top: 0;
    height: 38px;
    left: 8px;
    top: 16px;
    width: 52px;
    clip-path: polygon(0 20%, 32% 0, 68% 0, 100% 20%, 100% 100%, 0 100%);
  }

  .icon-forums::before {
    border: 2px solid currentColor;
    border-radius: 4px;
    box-shadow: 24px 0 0 -2px var(--support-lilac), 24px 0 0 0 currentColor, 12px 24px 0 -2px var(--support-lilac), 12px 24px 0 0 currentColor;
    height: 18px;
    left: 6px;
    top: 7px;
    width: 22px;
  }

  .icon-forums::after {
    border-left: 2px solid currentColor;
    border-top: 2px solid currentColor;
    height: 8px;
    left: 22px;
    top: 31px;
    transform: rotate(45deg);
    width: 8px;
  }

  .icon-tickets::before {
    border: 2px solid currentColor;
    height: 50px;
    left: 7px;
    top: 3px;
    width: 54px;
  }

  .icon-tickets::after {
    background: repeating-linear-gradient(to bottom, currentColor 0 2px, transparent 2px 8px);
    height: 31px;
    left: 17px;
    top: 16px;
    width: 34px;
  }

  .icon-escalate::before {
    border-bottom: 2px solid currentColor;
    border-left: 2px solid transparent;
    border-right: 2px solid transparent;
    height: 56px;
    left: 14px;
    top: 0;
    transform: skewX(-20deg);
    width: 36px;
  }

  .icon-escalate::after {
    background: repeating-linear-gradient(to bottom, currentColor 0 2px, transparent 2px 8px);
    height: 48px;
    left: 31px;
    top: 8px;
    width: 2px;
  }

  .support-footer {
    background: var(--support-purple);
    color: #fff;
    padding: 46px 30px 82px;
  }

  .footer-inner {
    border-top: 1px solid rgba(255, 255, 255, 0.32);
    margin: 0 auto;
    max-width: 1168px;
    padding-top: 40px;
  }

  .support-footer h2,
  .support-footer h3,
  .support-footer p {
    margin: 0;
  }

  .support-footer h2,
  .support-footer h3 {
    font-size: 1.05rem;
    font-weight: 850;
  }

  .contact-list {
    display: grid;
    gap: 18px;
    margin-top: 14px;
    max-width: 520px;
  }

  .contact-list p,
  .contact-list a {
    display: grid;
    gap: 6px;
  }

  .contact-list span {
    color: #fff;
    font-size: 1.02rem;
    font-weight: 650;
    line-height: 1.3;
  }

  .contact-list a {
    align-items: center;
    color: #fff;
    display: flex;
    font-size: 1.12rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .contact-list svg {
    fill: #fff;
    height: 24px;
    margin-right: 14px;
    width: 24px;
  }

  .social-block {
    margin-top: 36px;
  }

  .social-links {
    display: flex;
    gap: 30px;
    margin-top: 20px;
  }

  .social-links a {
    align-items: center;
    color: #fff;
    display: inline-flex;
    font-size: 1.45rem;
    font-weight: 900;
    height: 24px;
    justify-content: center;
    width: 26px;
  }

  .social-links svg {
    fill: currentColor;
    height: 28px;
    width: 28px;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.34);
    margin-top: 34px;
    padding-top: 24px;
  }

  .footer-bottom p,
  .footer-bottom a {
    color: #fff;
    font-size: 1.18rem;
    font-weight: 650;
    letter-spacing: 0.01em;
  }

  .chat-button {
    align-items: center;
    background: var(--support-purple-dark);
    border: 0;
    border-radius: 24px;
    bottom: 32px;
    box-shadow: 0 12px 28px rgba(25, 0, 80, 0.24);
    color: #fff;
    cursor: pointer;
    display: flex;
    height: 74px;
    justify-content: center;
    position: fixed;
    right: 20px;
    width: 74px;
    z-index: 20;
  }

  .chat-button svg {
    fill: none;
    height: 34px;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    width: 34px;
  }

  .chat-panel {
    background: #fff;
    border-radius: 18px;
    bottom: 118px;
    box-shadow: 0 18px 48px rgba(22, 7, 56, 0.28);
    color: #24143d;
    padding: 24px;
