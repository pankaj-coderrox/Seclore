---
import BaseLayout from "@layouts/BaseLayout.astro";

const socialLinks = [
  ["LinkedIn", "https://www.linkedin.com/company/seclore", "in"],
  ["Facebook", "https://www.facebook.com/Seclore", "f"],
  ["X", "https://x.com/seclore", "x"],
  ["YouTube", "https://www.youtube.com/@Seclore", "play"]
];
---

<BaseLayout
  title="Submit a Ticket | Seclore Support"
  description="Submit a support ticket to the Seclore support portal."
>
  <main class="support-ticket-page">
    <header class="support-header" aria-label="Seclore support header">
      <a class="support-logo" href="/support/home/" aria-label="Seclore support home">
        <img src="/images/home/seclore-logo-2026.svg" alt="Seclore" loading="eager" decoding="async" />
      </a>
    </header>

    <nav class="portal-nav" aria-label="Support portal navigation">
      <a class="support-home-link" href="/support/home/" aria-current="page">Support Home</a>
      <div class="portal-menu">
        <button class="portal-menu-toggle" type="button" aria-label="Open support menu" aria-expanded="false" aria-controls="support-portal-menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <div class="portal-menu-panel" id="support-portal-menu" hidden>
          <a href="/support/home/">Support Home</a>
          <a href="/support/solutions/">Solutions</a>
          <a href="/support/discussions/">Forums</a>
          <a href="/support/tickets/new/">Login</a>
        </div>
      </div>
    </nav>

    <section class="ticket-form-section" aria-labelledby="ticket-title">
      <form class="ticket-form" id="support-ticket-form" novalidate>
        <h1 id="ticket-title">Submit a ticket</h1>

        <label class="field">
          <span>Requester <strong>*</strong></span>
          <input name="requester" type="email" placeholder="Email" autocomplete="email" required />
        </label>

        <label class="field">
          <span>Subject <strong>*</strong></span>
          <input name="subject" type="text" required />
        </label>

        <label class="field">
          <span>Description <strong>*</strong></span>
          <textarea name="description" rows="6" required></textarea>
        </label>

        <div class="attach-row">
          <label for="ticket-attachment">Attach</label>
          <button class="attach-toggle" type="button" aria-label="Open attachment picker"></button>
          <input id="ticket-attachment" name="attachment" type="file" hidden />
          <span class="attachment-name" data-attachment-name hidden></span>
        </div>

        <button class="recaptcha-box" type="button" aria-pressed="false" data-recaptcha>
          <span class="recaptcha-check" aria-hidden="true"></span>
          <span class="recaptcha-copy">
            <strong>I'm not a robot</strong>
            <small>For site owner: v1beta1 is deprecated.<br />Take action.</small>
          </span>
          <span class="recaptcha-brand" aria-hidden="true">
            <img src="/images/support/recaptcha-logo.svg" alt="" loading="lazy" decoding="async" />
            <small>reCAPTCHA</small>
          </span>
        </button>

        <p class="form-message error" data-ticket-error hidden>Please complete all required fields and confirm reCAPTCHA.</p>
        <p class="form-message success" data-ticket-success hidden>Your support ticket details are ready to submit.</p>

        <div class="form-actions">
          <button class="submit-button" type="submit">SUBMIT</button>
          <button class="cancel-button" type="reset">CANCEL</button>
        </div>
      </form>
    </section>

    <footer class="support-footer" id="contact" aria-labelledby="support-contact-title">
      <div class="footer-inner">
        <h2 id="support-contact-title">Contact Us</h2>
        <div class="contact-list">
          <p>
            <span>North America</span>
            <a href="tel:+18552732505">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.6 10.8c1.7 3.3 3.3 4.9 6.6 6.6l2.2-2.2c.3-.3.8-.4 1.2-.3 1.3.4 2.6.6 4 .6.7 0 1.2.5 1.2 1.2v3.6c0 .7-.5 1.2-1.2 1.2C10.8 22 2 13.2 2 2.4 2 1.7 2.5 1.2 3.2 1.2h3.6c.7 0 1.2.5 1.2 1.2 0 1.4.2 2.7.6 4 .1.4 0 .9-.3 1.2l-1.7 3.2Z" /></svg>
              +1-855-273-2505
            </a>
          </p>
          <p>
            <span>India &amp; Rest of the World</span>
            <a href="tel:+912261304242">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.6 10.8c1.7 3.3 3.3 4.9 6.6 6.6l2.2-2.2c.3-.3.8-.4 1.2-.3 1.3.4 2.6.6 4 .6.7 0 1.2.5 1.2 1.2v3.6c0 .7-.5 1.2-1.2 1.2C10.8 22 2 13.2 2 2.4 2 1.7 2.5 1.2 3.2 1.2h3.6c.7 0 1.2.5 1.2 1.2 0 1.4.2 2.7.6 4 .1.4 0 .9-.3 1.2l-1.7 3.2Z" /></svg>
              +91-22-61304242 / 61434848
            </a>
          </p>
          <p>
            <span class="sr-only">Email</span>
            <a href="mailto:support@seclore.com">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 5h18v14H3V5Zm2 3 7 5 7-5" /></svg>
              support@seclore.com
            </a>
          </p>
        </div>

        <div class="social-block">
          <h3>Connect with us</h3>
          <div class="social-links">
            {socialLinks.map(([label, href, glyph]) => (
              <a href={href} target="_blank" rel="noreferrer" aria-label={label}>
                {glyph === "play" ? (
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 6v12l10-6-10-6Z" /></svg>
                ) : (
                  <span>{glyph}</span>
                )}
              </a>
            ))}
          </div>
        </div>

        <div class="footer-bottom">
          <p>&copy; 2026 SECLORE. ALL RIGHTS RESERVED.</p>
          <a href="/privacy/">PRIVACY STATEMENT</a>
        </div>
      </div>
    </footer>

    <button class="chat-button" type="button" aria-label="Chat with support" aria-expanded="false">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5 6h14v10H9l-4 4V6Z" />
        <path d="M8 10h8M8 13h5" />
      </svg>
    </button>

    <section class="chat-panel" aria-label="Support chat" hidden>
      <button class="chat-close" type="button" aria-label="Close chat">x</button>
      <h2>Seclore Support</h2>
      <p>Tell us what you need help with. The support team will help you track the request.</p>
      <a href="mailto:support@seclore.com">Email Support</a>
    </section>

    <script>
      const form = document.querySelector("#support-ticket-form");
      const recaptcha = document.querySelector("[data-recaptcha]");
      const ticketError = document.querySelector("[data-ticket-error]");
      const ticketSuccess = document.querySelector("[data-ticket-success]");
      const attachmentInput = document.querySelector("#ticket-attachment");
      const attachmentName = document.querySelector("[data-attachment-name]");
      const attachToggle = document.querySelector(".attach-toggle");
      const portalMenu = document.querySelector(".portal-menu");
      const portalMenuButton = document.querySelector(".portal-menu-toggle");
      const portalMenuPanel = document.querySelector(".portal-menu-panel");
      const chatButton = document.querySelector(".chat-button");
      const chatPanel = document.querySelector(".chat-panel");
      const chatClose = document.querySelector(".chat-close");

      function setPortalMenuOpen(open: boolean) {
        if (portalMenuButton instanceof HTMLButtonElement && portalMenuPanel instanceof HTMLElement) {
          portalMenuButton.setAttribute("aria-expanded", String(open));
          portalMenuPanel.hidden = !open;
        }
      }

      portalMenuButton?.addEventListener("click", () => {
        if (portalMenuButton instanceof HTMLButtonElement) {
          setPortalMenuOpen(portalMenuButton.getAttribute("aria-expanded") !== "true");
        }
      });

      document.addEventListener("click", (event) => {
        if (portalMenu instanceof HTMLElement && event.target instanceof Node && !portalMenu.contains(event.target)) {
          setPortalMenuOpen(false);
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          setPortalMenuOpen(false);
          if (chatPanel instanceof HTMLElement && chatButton instanceof HTMLButtonElement) {
            chatPanel.hidden = true;
            chatButton.setAttribute("aria-expanded", "false");
          }
        }
      });

      recaptcha?.addEventListener("click", () => {
        if (recaptcha instanceof HTMLButtonElement) {
          const nextState = recaptcha.getAttribute("aria-pressed") !== "true";
          recaptcha.setAttribute("aria-pressed", String(nextState));
        }
      });

      attachToggle?.addEventListener("click", () => {
        if (attachmentInput instanceof HTMLInputElement) {
          attachmentInput.click();
        }
      });

      attachmentInput?.addEventListener("change", () => {
        if (attachmentInput instanceof HTMLInputElement && attachmentName instanceof HTMLElement) {
          const file = attachmentInput.files?.[0];
          attachmentName.hidden = !file;
          attachmentName.textContent = file ? file.name : "";
        }
      });

      form?.addEventListener("submit", (event) => {
        event.preventDefault();
        if (!(form instanceof HTMLFormElement)) {
          return;
        }
        const captchaComplete = recaptcha instanceof HTMLButtonElement && recaptcha.getAttribute("aria-pressed") === "true";
        const isValid = form.checkValidity() && captchaComplete;
        form.classList.toggle("was-validated", !isValid);
        if (ticketError instanceof HTMLElement) {
          ticketError.hidden = isValid;
        }
        if (ticketSuccess instanceof HTMLElement) {
          ticketSuccess.hidden = !isValid;
        }
      });

      form?.addEventListener("reset", () => {
        window.setTimeout(() => {
          if (ticketError instanceof HTMLElement) {
            ticketError.hidden = true;
          }
          if (ticketSuccess instanceof HTMLElement) {
            ticketSuccess.hidden = true;
          }
          if (attachmentName instanceof HTMLElement) {
            attachmentName.hidden = true;
            attachmentName.textContent = "";
          }
          if (recaptcha instanceof HTMLButtonElement) {
            recaptcha.setAttribute("aria-pressed", "false");
          }
        }, 0);
      });

      chatButton?.addEventListener("click", () => {
        if (chatButton instanceof HTMLButtonElement && chatPanel instanceof HTMLElement) {
          const open = chatPanel.hidden;
          chatPanel.hidden = !open;
          chatButton.setAttribute("aria-expanded", String(open));
        }
      });

      chatClose?.addEventListener("click", () => {
        if (chatButton instanceof HTMLButtonElement && chatPanel instanceof HTMLElement) {
          chatPanel.hidden = true;
          chatButton.setAttribute("aria-expanded", "false");
        }
      });
    </script>
  </main>
</BaseLayout>

<style>
  :global(body) {
    background: #f7f7f7;
    color: #222229;
    font-family: Arial, Helvetica, sans-serif;
  }

  :global(body.modal-open) {
    overflow: hidden;
  }

  .support-ticket-page {
    --blue: #0b457b;
    --line: #e5e5ea;
    --purple: #6539dd;
    --teal: #0d7d87;
    background: #f7f7f7;
    min-height: 100vh;
    overflow-x: hidden;
  }

  .support-ticket-page,
  .support-ticket-page * {
    box-sizing: border-box;
  }

  .support-header {
    align-items: center;
    background: #ffffff;
    display: flex;
    justify-content: center;
    min-height: 84px;
    padding: 14px 20px;
  }

  .support-logo {
    display: inline-flex;
    line-height: 1;
  }

  .support-logo img {
    display: block;
    width: clamp(260px, 62vw, 380px);
  }

  .portal-nav {
    align-items: center;
    background: var(--purple);
    color: #ffffff;
    display: flex;
    min-height: 52px;
    padding: 0 clamp(20px, 5vw, 44px);
    position: relative;
    z-index: 3;
  }

  .support-home-link {
    color: #ffffff;
    font-size: 0.92rem;
    font-weight: 500;
    text-decoration: none;
  }

  .portal-menu {
    margin-left: auto;
    position: relative;
  }

  .portal-menu-toggle {
    align-items: center;
    background: transparent;
    border: 0;
    cursor: pointer;
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    height: 44px;
    justify-content: center;
    padding: 0;
    width: 44px;
  }

  .portal-menu-toggle span {
    background: rgba(255, 255, 255, 0.72);
    border-radius: 999px;
    display: block;
    height: 2px;
    transition: transform 180ms ease, opacity 180ms ease;
    width: 17px;
  }

  .portal-menu-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .portal-menu-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }

  .portal-menu-toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .portal-menu-panel {
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.12);
    box-shadow: 0 18px 42px rgba(15, 23, 42, 0.16);
    display: grid;
    min-width: 220px;
    padding: 8px;
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
  }

  .portal-menu-panel[hidden] {
    display: none;
  }

  .portal-menu-panel a {
    color: #202027;
    font-size: 0.94rem;
    padding: 11px 12px;
    text-decoration: none;
  }

  .portal-menu-panel a:hover {
    background: #f1ecff;
    color: var(--purple);
  }

  .ticket-form-section {
    background: #f7f7f7;
    min-height: 690px;
    padding: clamp(30px, 7vw, 58px) 20px clamp(62px, 8vw, 92px);
  }

  .ticket-form {
    display: grid;
    gap: 22px;
    margin: 0 auto;
    max-width: 720px;
    padding: 0 clamp(12px, 4vw, 30px);
  }

  .ticket-form h1 {
    color: #2b2b32;
    font-size: clamp(1.08rem, 2.6vw, 1.28rem);
    font-weight: 400;
    line-height: 1.25;
    margin: 0 0 6px;
    white-space: nowrap;
  }

  .field {
    display: grid;
    gap: 9px;
  }

  .field span {
    color: #25252c;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .field strong {
    color: #e02d43;
    font-size: 1.1em;
  }

  .field input,
  .field textarea {
    background: #ffffff;
    border: 1px solid #c8c8cf;
    border-radius: 0;
    color: #202027;
    font: inherit;
    font-size: 0.9rem;
    width: 100%;
  }

  .field input {
    height: 42px;
    padding: 0 12px;
  }

  .field textarea {
    min-height: 154px;
    padding: 12px;
    resize: vertical;
  }

  .field input:focus,
  .field textarea:focus {
    border-color: #263747;
    box-shadow: 0 0 0 1px #263747;
    outline: none;
  }

  .field input::placeholder {
    color: #8d8d95;
    font-size: 0.9rem;
  }

  .attach-row {
    align-items: center;
    display: flex;
    gap: 8px;
    margin-top: -18px;
    min-height: 22px;
  }

  .attach-row label {
    color: var(--teal);
    cursor: pointer;
    font-size: 0.92rem;
    font-weight: 600;
  }

  .attach-toggle {
    background: transparent;
    border: 0;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid #34343c;
    cursor: pointer;
    height: 0;
    padding: 0;
    width: 0;
  }

  .attachment-name {
    color: #56565e;
    font-size: 0.86rem;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .recaptcha-box {
    align-items: center;
    background: #ffffff;
    border: 1px solid #d7d7dc;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.08);
    color: #202027;
    cursor: pointer;
    display: grid;
    gap: 12px;
    grid-template-columns: 34px minmax(0, 1fr) auto;
    margin-top: 4px;
    max-width: 430px;
    min-height: 78px;
    padding: 12px 14px;
    text-align: left;
    width: 100%;
  }

  .recaptcha-check {
    align-items: center;
    border: 3px solid #7f7f86;
    display: inline-flex;
    height: 32px;
    justify-content: center;
    width: 32px;
  }

  .recaptcha-box[aria-pressed="true"] .recaptcha-check::after {
    border-bottom: 3px solid #167c2f;
    border-right: 3px solid #167c2f;
    content: "";
    height: 16px;
    transform: rotate(45deg) translate(-1px, -2px);
    width: 8px;
  }

  .recaptcha-copy {
    display: grid;
    gap: 5px;
  }

  .recaptcha-copy strong {
    font-size: 0.9rem;
    font-weight: 500;
  }

  .recaptcha-copy small {
    color: #6f6f76;
    font-size: 0.7rem;
    line-height: 1.05;
  }

  .recaptcha-brand {
    align-items: center;
    display: grid;
    gap: 3px;
    justify-items: center;
  }

  .recaptcha-brand img {
    display: block;
    height: 36px;
    width: 36px;
  }

  .recaptcha-brand small {
    color: #56565e;
    font-size: 0.74rem;
  }

  .form-message {
    border-radius: 5px;
    font-size: 0.92rem;
    line-height: 1.35;
    margin: -2px 0 0;
    padding: 10px 12px;
  }

  .form-message.error {
    background: #fff0f0;
    color: #9b1c1c;
  }

  .form-message.success {
    background: #eefaf4;
    color: #0b6b45;
  }

  .form-actions {
    border-top: 1px solid var(--line);
    display: flex;
    gap: 14px;
    margin-top: 8px;
    padding-top: 26px;
  }

  .submit-button,
  .cancel-button {
    border: 0;
    border-radius: 5px;
    cursor: pointer;
    font-size: 0.78rem;
    font-weight: 700;
    height: 38px;
    letter-spacing: 0.12em;
    min-width: 126px;
    padding: 0 22px;
    transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease;
  }

  .submit-button {
    background: var(--blue);
    color: #ffffff;
  }

  .cancel-button {
    background: #f5f5f7;
    box-shadow: inset 0 0 0 1px #dedee4, 0 2px 8px rgba(15, 23, 42, 0.07);
    color: #55555c;
  }

  .submit-button:hover,
  .cancel-button:hover {
    transform: translateY(-1px);
  }

  .submit-button:hover {
    background: #073a68;
    box-shadow: 0 10px 20px rgba(11, 69, 123, 0.22);
  }

  .cancel-button:hover {
    box-shadow: inset 0 0 0 1px #d3d3db, 0 10px 20px rgba(15, 23, 42, 0.1);
  }

  .support-footer {
    background: var(--purple);
    color: #ffffff;
    padding: clamp(42px, 8vw, 72px) 20px 34px;
  }

  .footer-inner {
    margin: 0 auto;
    max-width: 720px;
    padding: 0 clamp(0px, 4vw, 30px);
  }

  .support-footer h2,
  .support-footer h3,
  .support-footer p {
    margin: 0;
  }

  .support-footer h2,
  .support-footer h3 {
    font-size: 0.9rem;
    font-weight: 700;
  }

  .contact-list {
    display: grid;
    gap: 22px;
    margin-top: 16px;
  }

  .contact-list p {
    display: grid;
    gap: 8px;
  }

  .contact-list span {
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.9rem;
  }

  .contact-list a {
    align-items: center;
    color: #ffffff;
    display: inline-flex;
    gap: 14px;
    font-size: 0.92rem;
    line-height: 1.35;
    text-decoration: none;
  }

  .contact-list svg {
    fill: currentColor;
    height: 22px;
    flex: 0 0 auto;
    width: 22px;
  }

  .social-block {
    margin-top: 32px;
  }

  .social-links {
    align-items: center;
    display: flex;
    gap: clamp(30px, 11vw, 58px);
    margin-top: 20px;
  }

  .social-links a {
    align-items: center;
    color: #ffffff;
    display: inline-flex;
    font-size: 1.35rem;
    font-weight: 700;
    height: 26px;
    justify-content: center;
    text-decoration: none;
    width: 26px;
  }

  .social-links span {
    line-height: 1;
  }

  .social-links svg {
    fill: currentColor;
    height: 24px;
    width: 24px;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    display: grid;
    gap: 4px;
    margin-top: 44px;
    padding-top: 24px;
  }

  .footer-bottom p,
  .footer-bottom a {
    color: #ffffff;
    font-size: clamp(0.82rem, 3.4vw, 0.98rem);
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1.25;
    text-decoration: none;
  }

  .chat-button {
    align-items: center;
    background: #5532c9;
    border: 0;
    border-radius: 50%;
    bottom: 20px;
    box-shadow: 0 12px 28px rgba(44, 25, 120, 0.28);
    color: #ffffff;
    cursor: pointer;
    display: inline-flex;
    height: 58px;
    justify-content: center;
    position: fixed;
    right: 20px;
    width: 58px;
    z-index: 20;
  }

  .chat-button svg {
    fill: none;
    height: 28px;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    width: 28px;
  }

  .chat-panel {
    background: #ffffff;
    border-radius: 8px;
    bottom: 90px;
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.2);
    color: #1f1f26;
    max-width: min(320px, calc(100vw - 32px));
    padding: 24px;
    position: fixed;
    right: 18px;
    z-index: 19;
  }

  .chat-panel[hidden] {
    display: none;
  }

  .chat-panel h2 {
    font-size: 1.1rem;
    margin: 0 0 8px;
  }

  .chat-panel p {
    color: #60606a;
    line-height: 1.5;
    margin: 0 0 16px;
  }

  .chat-panel a {
    color: var(--purple);
    font-weight: 700;
    text-decoration: none;
  }

  .chat-close {
    background: transparent;
    border: 0;
    color: #33333b;
    cursor: pointer;
    font-size: 1.2rem;
    position: absolute;
    right: 12px;
    top: 10px;
  }

  .sr-only {
    clip: rect(0 0 0 0);
    border: 0;
    height: 1px;
    margin: -1px;
    overflow: hidden;
    padding: 0;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }

  @media (max-width: 640px) {
    .support-header {
      min-height: 74px;
