---
import BaseLayout from "@layouts/BaseLayout.astro";

const releaseTopics = [
  {
    title: "Seclore 3.27.1.0 (May 01, 2023)",
    count: 3,
    posts: ["Seclore for Windows 3.19.1.0", "Seclore for Mac 3.8.1.0", "Seclore for O365 3.8.4.0"]
  },
  {
    title: "Seclore 3.27.0.0 (April 01, 2023)",
    count: 7,
    posts: ["Seclore for Windows 3.19.0.0", "Seclore for Mac 3.8.0.0", "Policy Server 3.16.0.0", "Seclore Online 3.6.4.0", "Seclore for SharePoint Server 3.1.0.0"]
  },
  {
    title: "Seclore 3.26.2.0 (March 01, 2023)",
    count: 6,
    posts: ["Seclore for Windows 3.18.7.0", "Seclore for Mac 3.7.8.0", "Seclore Online 3.6.3.0", "Hot Folder 3.2.7.0", "Seclore for O365 3.8.3.0"]
  },
  {
    title: "Seclore 3.26.1.0 (February 01, 2023)",
    count: 1,
    posts: ["Seclore for Mac 3.7.7.0"]
  }
];
---

<BaseLayout
  title="Forums | Seclore Support"
  description="Seclore support community forums for release announcements and product discussions."
>
  <main class="forums-page">
    <header class="support-header" aria-label="Seclore support header">
      <a class="support-logo" href="/support/home/" aria-label="Seclore support home">
        <img src="/images/home/seclore-logo-2026.svg" alt="Seclore" loading="eager" decoding="async" />
      </a>
      <a class="contact-pill" href="mailto:support@seclore.com">Contact Us</a>
    </header>

    <nav class="portal-nav" aria-label="Support portal navigation">
      <a class="support-home-link" href="/support/home/">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m3 11 9-8 9 8" />
          <path d="M5 10v10h5v-6h4v6h5V10" />
        </svg>
        Support Home
      </a>
      <span class="nav-spacer"></span>
      <div class="portal-menu">
        <button class="portal-menu-toggle" type="button" aria-label="Open support menu" aria-expanded="false" aria-controls="support-portal-menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <div class="portal-menu-panel" id="support-portal-menu" hidden>
          <a href="/support/solutions/">Solutions</a>
          <a class="active" href="/support/discussions/" aria-current="page">Forums</a>
          <a href="/support/tickets/new/">New Support Ticket</a>
        </div>
      </div>
    </nav>

    <section class="search-band" aria-label="Search support content">
      <form class="support-search" action="/support/search/" method="get">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="10.5" cy="10.5" r="6.5" />
          <path d="m16 16 5 5" />
        </svg>
        <input type="search" name="term" placeholder="Enter your search term here..." />
        <button type="submit">Search</button>
      </form>
    </section>

    <section class="forums-content" aria-label="Community forums">
      <div class="forums-heading">
        <h1>Community forums</h1>
        <p>Showing recent updates</p>
      </div>

      <article class="forum-section">
        <h2><a href="/home/release-notes/">Seclore Release Announcements</a></h2>
        {releaseTopics.map((topic) => (
          <div class="forum-topic">
            <h3>
              <a href="/home/release-notes/">{topic.title} <span>{topic.count}</span></a>
            </h3>
            <ul>
              {topic.posts.map((post) => (
                <li>
                  <a href="/home/release-notes/">{post}</a>
                  <small>Posted by Product Management Team, about 1 year ago</small>
                  <small>Last Reply by Product Management Team, about 1 year ago</small>
                </li>
              ))}
            </ul>
            <a class="see-all" href="/home/release-notes/">See all {topic.count} topics</a>
          </div>
        ))}
      </article>
    </section>

    <script>
      const portalMenu = document.querySelector(".portal-menu");
      const portalMenuButton = document.querySelector(".portal-menu-toggle");
      const portalMenuPanel = document.querySelector(".portal-menu-panel");

      function setPortalMenuOpen(open: boolean) {
        if (portalMenuButton instanceof HTMLButtonElement && portalMenuPanel instanceof HTMLElement) {
          portalMenuButton.setAttribute("aria-expanded", String(open));
          portalMenuPanel.hidden = !open;
        }
      }

      portalMenuButton?.addEventListener("click", () => {
        if (portalMenuButton instanceof HTMLButtonElement) {
          setPortalMenuOpen(portalMenuButton.getAttribute("aria-expanded") !== "true");
        }
      });

      document.addEventListener("click", (event) => {
        if (portalMenu instanceof HTMLElement && event.target instanceof Node && !portalMenu.contains(event.target)) {
          setPortalMenuOpen(false);
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          setPortalMenuOpen(false);
        }
      });
    </script>
  </main>
</BaseLayout>

<style>
  :global(body) {
    background: #f6f6f6;
    color: #161616;
    font-family: Arial, Helvetica, sans-serif;
    margin: 0;
  }

  :global(body::before) {
    display: none;
  }

  .forums-page {
    --purple: #5f3fd6;
    --line: #d8c8ff;
    background: #f6f6f6;
    min-height: 100vh;
    overflow-x: hidden;
  }

  .forums-page,
  .forums-page * {
    box-sizing: border-box;
  }

  .support-header {
    align-items: center;
    background: #ffffff;
    display: flex;
    justify-content: space-between;
    min-height: 108px;
    padding: 18px clamp(22px, 4.8vw, 64px);
  }

  .support-logo {
    display: inline-flex;
    line-height: 1;
  }

  .support-logo img {
    display: block;
    height: auto;
    width: clamp(260px, 38vw, 520px);
  }

  .contact-pill {
    align-items: center;
    background: var(--purple);
    border-radius: 999px;
    color: #ffffff;
    display: inline-flex;
    font-size: 1.02rem;
    font-weight: 700;
    justify-content: center;
    min-height: 47px;
    padding: 0 27px;
    text-decoration: none;
    white-space: nowrap;
  }

  .portal-nav svg,
  .support-search svg {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .portal-nav {
    align-items: center;
    background: var(--purple);
    color: #ffffff;
    display: flex;
    gap: 0;
    min-height: 67px;
    padding: 0 6px 0 0;
  }

  .portal-nav a {
    align-items: center;
    color: #ffffff;
    display: inline-flex;
    font-size: 1.3rem;
    font-weight: 600;
    gap: 10px;
    min-height: 67px;
    padding: 0 20px;
    text-decoration: none;
  }

  .portal-nav a.active {
    background: #4a2abd;
  }

  .portal-nav > a {
    background: transparent;
  }

  .portal-nav svg {
    height: 23px;
    opacity: 0.8;
    width: 23px;
  }

  .nav-spacer {
    flex: 1 1 auto;
  }

  .portal-menu {
    align-self: stretch;
    display: inline-flex;
    margin-left: auto;
    position: relative;
  }

  .portal-menu-toggle {
    align-items: center;
    align-self: stretch;
    background: transparent;
    border: 0;
    color: #ffffff;
    cursor: pointer;
    display: inline-flex;
    flex-direction: column;
    gap: 5px;
    justify-content: center;
    min-height: 67px;
    padding: 0 22px;
  }

  .portal-menu-toggle span {
    background: currentColor;
    border-radius: 999px;
    display: block;
    height: 2px;
    width: 25px;
  }

  .portal-menu-toggle:hover,
  .portal-menu-toggle[aria-expanded="true"] {
    background: #4a2abd;
  }

  .portal-menu-panel {
    background: var(--purple);
    box-shadow: 0 16px 32px rgba(20, 11, 72, 0.2);
    min-width: 220px;
    padding: 8px 0;
    position: absolute;
    right: 0;
    top: 100%;
    z-index: 20;
  }

  .portal-menu-panel[hidden] {
    display: none;
  }

  .portal-menu-panel a {
    color: #ffffff;
    font-size: 1rem;
    min-height: 44px;
    padding: 0 18px;
    white-space: nowrap;
  }

  .portal-menu-panel a:hover {
    background: #4a2abd;
  }

  .search-band {
    background: #ffffff;
    border-top: 1px solid #140817;
    padding: 24px clamp(20px, 4vw, 48px);
  }

  .support-search {
    align-items: center;
    border: 2px solid var(--line);
    color: #623ee0;
    display: flex;
    gap: 16px;
    margin: 0 auto;
    max-width: 1160px;
    min-height: 64px;
    padding: 0 20px;
  }

  .support-search svg {
    flex: 0 0 auto;
    height: 26px;
    width: 26px;
  }

  .support-search input {
    background: transparent;
    border: 0;
    color: #4e2ed0;
    flex: 1;
    font-size: 1.25rem;
    min-width: 0;
    outline: 0;
  }

  .support-search input::placeholder {
    color: #9d7cf0;
    opacity: 1;
  }

  .support-search button {
    background: transparent;
    border: 0;
    color: var(--purple);
    cursor: pointer;
    font-size: 1rem;
    font-weight: 700;
  }

  .forums-content {
    background: #ffffff;
    margin: 0 auto;
    max-width: 980px;
    padding: 34px 24px 80px;
  }

  .forums-heading {
    margin: 0 0 28px;
  }

  .forums-heading h1 {
    color: #151515;
    font-size: clamp(1.65rem, 3vw, 2.15rem);
    font-weight: 500;
    line-height: 1.18;
    margin: 0 0 8px;
  }

  .forums-heading p {
    color: #5f3fd6;
    font-size: clamp(1rem, 1.7vw, 1.18rem);
    font-weight: 700;
    line-height: 1.45;
    margin: 0;
  }

  .forum-section {
    border-bottom: 1px solid #e4e4e4;
    padding-bottom: 28px;
  }

  .forum-section h2 {
    border-bottom: 1px solid #dfdfdf;
    color: #252525;
    font-size: 1.18rem;
    font-weight: 700;
    margin: 0 0 22px;
    padding-bottom: 16px;
  }

  .forum-section h2 a,
  .forum-topic h3 a,
  .forum-topic li a,
  .see-all {
    color: #333333;
    text-decoration: none;
  }

  .forum-topic {
    margin-bottom: 24px;
  }

  .forum-topic h3 {
    font-size: 1.08rem;
    margin: 0 0 12px;
  }

  .forum-topic h3 span {
    color: #777777;
    font-weight: 600;
  }

  .forum-topic ul {
    display: grid;
    gap: 13px;
    list-style: none;
    margin: 0 0 14px;
    padding: 0;
  }

  .forum-topic li {
    display: grid;
    gap: 3px;
    line-height: 1.45;
    padding-left: 18px;
    position: relative;
  }

  .forum-topic li::before {
    background: #bdbdbd;
    border-radius: 50%;
    content: "";
    height: 5px;
    left: 3px;
    position: absolute;
    top: 0.62em;
    width: 5px;
  }

  .forum-topic small {
    color: #777777;
    font-size: 0.88rem;
  }

  .forum-section h2 a:hover,
  .forum-topic h3 a:hover,
  .forum-topic li a:hover,
  .see-all:hover {
    color: var(--purple);
    text-decoration: underline;
  }

  .see-all {
    display: inline-flex;
    font-size: 0.95rem;
    font-weight: 700;
  }

  @media (max-width: 780px) {
    .support-header,
    .portal-nav {
      padding-inline: 18px;
    }

    .support-header {
      min-height: 82px;
      padding-block: 14px;
    }

    .support-header .contact-pill {
      display: none;
    }

    .support-logo img {
      width: clamp(220px, 58vw, 360px);
    }

    .portal-nav {
      min-height: 64px;
    }

    .portal-nav a {
      font-size: 1.18rem;
      min-height: 64px;
      padding: 0 18px;
    }

    .search-band {
      padding: 18px 16px;
    }

    .support-search {
      gap: 12px;
      min-height: 58px;
      padding: 0 14px;
    }

    .support-search input {
      font-size: 1rem;
    }

    .forums-content {
      padding: 28px 18px 60px;
    }
  }

  @media (max-width: 460px) {
    .support-header {
      align-items: center;
      justify-content: center;
      min-height: 72px;
      padding: 12px 16px;
    }

    .support-logo {
      max-width: 100%;
      width: min(82vw, 300px);
    }

    .support-logo img {
      width: 100%;
    }

    .portal-nav a {
      padding-left: 18px;
      padding-right: 12px;
    }

    .portal-menu-toggle {
      padding: 0 18px;
    }

    .support-search button {
      display: none;
    }
  }
</style>
