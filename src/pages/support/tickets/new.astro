---
import BaseLayout from "@layouts/BaseLayout.astro";

const footerSocials = [
  ["LinkedIn", "https://www.linkedin.com/company/seclore", "in"],
  ["Facebook", "https://www.facebook.com/Seclore", "f"],
  ["X", "https://x.com/seclore", "x"],
  ["YouTube", "https://www.youtube.com/@Seclore", "▶"]
];
---

<BaseLayout
  title="Login to Support Portal | Seclore Support"
  description="Login to the Seclore support portal before creating a new support ticket."
>
  <main class="ticket-login-page">
    <header class="support-header" aria-label="Seclore support header">
      <a class="support-logo" href="/support/home/" aria-label="Seclore support home">
        <img src="/images/home/seclore-logo-2026.svg" alt="Seclore" loading="eager" decoding="async" />
      </a>
    </header>

    <nav class="portal-nav" aria-label="Support portal navigation">
      <a class="support-home-link" href="/support/home/">Support Home</a>
      <div class="portal-menu">
        <button class="portal-menu-toggle" type="button" aria-label="Open support menu" aria-expanded="false" aria-controls="support-portal-menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <div class="portal-menu-panel" id="support-portal-menu" hidden>
          <a href="/support/home/">Support Home</a>
          <a href="/support/solutions/">Solutions</a>
          <a href="/support/discussions/">Forums</a>
          <a href="/support/login/">Login</a>
        </div>
      </div>
    </nav>

    <section class="login-alert" data-login-alert role="status" aria-live="polite">
      <p>You must be logged in to access this page</p>
      <button type="button" data-close-alert aria-label="Close notice">x</button>
    </section>

    <section class="login-shell" aria-labelledby="support-login-title">
      <div class="login-column">
        <form class="portal-login-form" id="support-login-form" novalidate>
          <h1 id="support-login-title">Login to the support portal</h1>
          <p>Enter the details below</p>

          <label>
            <span>Your e-mail address</span>
            <input name="email" type="email" autocomplete="email" placeholder="Your e-mail address" required />
          </label>

          <label>
            <span>Password</span>
            <input name="password" type="password" autocomplete="current-password" placeholder="Password" required />
          </label>

          <label class="remember-row">
            <input name="remember" type="checkbox" checked />
            <span>Remember me on this computer</span>
          </label>

          <a class="forgot-link" href="/support/login/?forgot=password">Forgot your password?</a>
          <p class="form-error" data-login-error hidden>Please enter your email address and password.</p>
          <p class="form-success" data-login-success hidden>Login details captured for this demo. Please connect the live support portal to authenticate.</p>
          <button class="login-button" type="submit">LOGIN</button>
        </form>

        <div class="agent-box">
          <span class="agent-icon" aria-hidden="true">🎧</span>
          <strong>Are you an agent?</strong>
          <a href="/support/login/">Login here</a>
        </div>
      </div>

      <div class="alternate-login" aria-label="Alternative login options">
        <div class="divider" aria-hidden="true"></div>
        <p>...or login using</p>
        <button class="social-button" type="button" data-provider="Google" aria-label="Login using Google">g</button>
        <button class="social-button" type="button" data-provider="Facebook" aria-label="Login using Facebook">f</button>
        <p class="social-status" data-social-status hidden></p>
      </div>

      <aside class="signup-panel">
        <h2>Sign up</h2>
        <p>
          Once you sign up, you will have complete access to our self service portal and you can use your account to
          raise support tickets and track their status.
        </p>
        <a class="signup-button" href="/support/login/?signup=true">SIGN UP WITH US</a>
      </aside>
    </section>

    <footer class="support-footer" id="contact" aria-labelledby="support-contact-title">
      <div class="footer-inner">
        <section class="footer-contact">
          <h2 id="support-contact-title">Contact Us</h2>
          <p>
            <span>North America</span>
            <a href="tel:+18552732505">+1-855-273-2505</a>
          </p>
          <p>
            <span>India &amp; Rest of the World</span>
            <a href="tel:+912261304242">+91-22-61304242 / 61434848</a>
          </p>
          <p>
            <span>Email</span>
            <a href="mailto:support@seclore.com">support@seclore.com</a>
          </p>
        </section>

        <section class="footer-social" aria-label="Connect with Seclore">
          <h2>Connect with us</h2>
          <div>
            {footerSocials.map(([label, href, icon]) => (
              <a href={href} target="_blank" rel="noreferrer" aria-label={label}>{icon}</a>
            ))}
          </div>
        </section>

        <p class="copyright">
          &copy; 2026 SECLORE. ALL RIGHTS RESERVED.
          <a href="https://license.seclore.com/licensingportal/static/html/privacy.html" target="_blank" rel="noreferrer">PRIVACY STATEMENT</a>
        </p>
      </div>
    </footer>

    <button class="chat-button" type="button" aria-label="Chat with support">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5 6h14v10H9l-4 4V6Z" />
        <path d="M8 10h8M8 13h5" />
      </svg>
    </button>

    <script>
      const alertBox = document.querySelector("[data-login-alert]");
      const closeAlert = document.querySelector("[data-close-alert]");
      const form = document.querySelector("#support-login-form");
      const loginError = document.querySelector("[data-login-error]");
      const loginSuccess = document.querySelector("[data-login-success]");
      const socialStatus = document.querySelector("[data-social-status]");
      const portalMenu = document.querySelector(".portal-menu");
      const portalMenuButton = document.querySelector(".portal-menu-toggle");
      const portalMenuPanel = document.querySelector(".portal-menu-panel");

      function setPortalMenuOpen(open: boolean) {
        if (portalMenuButton instanceof HTMLButtonElement && portalMenuPanel instanceof HTMLElement) {
          portalMenuButton.setAttribute("aria-expanded", String(open));
          portalMenuPanel.hidden = !open;
        }
      }

      portalMenuButton?.addEventListener("click", () => {
        if (portalMenuButton instanceof HTMLButtonElement) {
          setPortalMenuOpen(portalMenuButton.getAttribute("aria-expanded") !== "true");
        }
      });

      document.addEventListener("click", (event) => {
        if (portalMenu instanceof HTMLElement && event.target instanceof Node && !portalMenu.contains(event.target)) {
          setPortalMenuOpen(false);
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          setPortalMenuOpen(false);
        }
      });

      closeAlert?.addEventListener("click", () => {
        if (alertBox instanceof HTMLElement) {
          alertBox.classList.add("is-closing");
          window.setTimeout(() => {
            alertBox.hidden = true;
          }, 260);
        }
      });

      form?.addEventListener("submit", (event) => {
        event.preventDefault();
        if (!(form instanceof HTMLFormElement)) {
          return;
        }
        const isValid = form.checkValidity();
        form.classList.toggle("was-validated", !isValid);
        if (loginError instanceof HTMLElement) {
          loginError.hidden = isValid;
        }
        if (loginSuccess instanceof HTMLElement) {
          loginSuccess.hidden = !isValid;
        }
      });

      document.querySelectorAll("[data-provider]").forEach((button) => {
        button.addEventListener("click", () => {
          if (button instanceof HTMLElement && socialStatus instanceof HTMLElement) {
            socialStatus.hidden = false;
            socialStatus.textContent = `${button.dataset.provider} login is ready for live portal connection.`;
          }
        });
      });
    </script>
  </main>
</BaseLayout>

<style>
  :global(body) {
    background: #ffffff;
    color: #1c1c22;
    font-family: Arial, Helvetica, sans-serif;
    margin: 0;
  }

  :global(body::before) {
    display: none;
  }

  .ticket-login-page {
    --purple: #6737d8;
    --dark-blue: #0c3f73;
    --muted: #6d6d75;
    --line: #e5e5eb;
    background: #ffffff;
    min-height: 100vh;
    overflow-x: hidden;
  }

  .ticket-login-page,
  .ticket-login-page * {
    box-sizing: border-box;
  }

  .support-header {
    align-items: center;
    background: #ffffff;
    display: flex;
    justify-content: center;
    min-height: 88px;
    padding: 14px clamp(16px, 4vw, 34px);
  }

  .support-logo {
    display: inline-flex;
    line-height: 1;
  }

  .support-logo img {
    display: block;
    width: clamp(232px, 32vw, 390px);
  }

  .portal-nav {
    align-items: center;
    background: var(--purple);
    color: #ffffff;
    display: flex;
    justify-content: space-between;
    min-height: 50px;
    padding: 0 clamp(12px, 4vw, 24px);
    position: relative;
    z-index: 2;
  }

  .support-home-link {
    color: #ffffff;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
  }

  .portal-menu {
    margin-left: auto;
    position: relative;
  }

  .portal-menu-toggle {
    align-items: center;
    background: transparent;
    border: 0;
    cursor: pointer;
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    height: 44px;
    justify-content: center;
    padding: 0 4px;
    width: 44px;
  }

  .portal-menu-toggle span {
    background: #ffffff;
    border-radius: 999px;
    display: block;
    height: 2px;
    width: 18px;
  }

  .portal-menu-panel {
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.12);
    box-shadow: 0 18px 42px rgba(15, 23, 42, 0.16);
    display: grid;
    min-width: 210px;
    padding: 8px;
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
  }

  .portal-menu-panel[hidden] {
    display: none;
  }

  .portal-menu-panel a {
    color: #1c1c22;
    font-size: 0.92rem;
    padding: 10px 12px;
    text-decoration: none;
  }

  .portal-menu-panel a:hover {
    background: #f1ecff;
    color: var(--purple);
  }

  .login-alert {
    align-items: start;
    background: #e2fad7;
    color: #4e6250;
    display: flex;
    justify-content: space-between;
    min-height: 58px;
    opacity: 1;
    overflow: hidden;
    padding: 13px clamp(14px, 4vw, 24px);
    transform: translateY(0);
    transition: opacity 220ms ease, min-height 260ms ease, padding 260ms ease, transform 260ms ease;
  }

  .login-alert.is-closing {
    min-height: 0;
    opacity: 0;
    padding-bottom: 0;
    padding-top: 0;
    transform: translateY(-4px);
  }

  .login-alert[hidden] {
    display: none;
  }

  .login-alert p {
    font-size: 0.98rem;
    line-height: 1.25;
    margin: 0;
  }

  .login-alert button {
    background: transparent;
    border: 0;
    color: #1c1c22;
    cursor: pointer;
    font-size: 1.1rem;
    font-weight: 700;
    height: 24px;
    line-height: 1;
    margin-left: 16px;
    padding: 0;
    width: 24px;
  }

  .login-shell {
    align-items: start;
    display: grid;
    gap: clamp(28px, 5vw, 68px);
    grid-template-columns: minmax(280px, 0.78fr) auto minmax(220px, 0.42fr);
    margin: 0 auto;
    max-width: 1140px;
    padding: clamp(50px, 8vw, 76px) clamp(24px, 6vw, 72px) clamp(64px, 9vw, 110px);
  }

  .login-column {
    display: grid;
    gap: 62px;
    min-width: 0;
  }

  .portal-login-form {
    display: grid;
    gap: 20px;
    max-width: 430px;
  }

  .portal-login-form h1 {
    color: #17151b;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 500;
    line-height: 1.1;
    margin: 0;
  }

  .portal-login-form > p {
    color: #17151b;
    font-size: 1rem;
    margin: -12px 0 10px;
  }

  .portal-login-form label {
    display: grid;
    gap: 8px;
  }

  .portal-login-form label > span {
    color: transparent;
    font-size: 0;
    height: 0;
    overflow: hidden;
  }

  .portal-login-form input[type="email"],
  .portal-login-form input[type="password"] {
    background: #ffffff;
    border: 1px solid #9b9ba4;
    border-radius: 0;
    color: #1c1c22;
    font-size: 0.95rem;
    min-height: 58px;
    padding: 0 20px;
    width: 100%;
  }

  .portal-login-form input::placeholder {
    color: #55555c;
    font-size: 0.82rem;
    font-weight: 400;
  }

  .remember-row {
    align-items: center;
    display: flex !important;
    gap: 8px !important;
  }

  .remember-row input {
    accent-color: #168fe3;
    height: 16px;
    width: 16px;
  }

  .remember-row span {
    color: #303038 !important;
    font-size: 0.94rem !important;
    height: auto !important;
    overflow: visible !important;
  }

  .forgot-link {
    color: #2a2a30;
    font-weight: 700;
    margin-top: 6px;
    text-decoration: none;
  }

  .agent-box a {
    color: #008466;
    font-weight: 700;
    text-decoration: none;
  }

  .login-button,
  .signup-button {
    align-items: center;
    background: var(--dark-blue);
    border: 0;
    border-radius: 5px;
    color: #ffffff;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.86rem;
    font-weight: 700;
    justify-content: center;
    letter-spacing: 0.03em;
    min-height: 32px;
    text-decoration: none;
    transition: background-color 180ms ease, transform 180ms ease;
  }

  .login-button {
    width: 100%;
  }

  .login-button:hover,
  .signup-button:hover {
    background: #082f58;
    transform: translateY(-1px);
  }

  .form-error,
  .form-success,
  .social-status {
    border-radius: 6px;
    font-size: 0.9rem;
    line-height: 1.35;
    margin: 0;
    padding: 10px 12px;
  }

  .form-error {
    background: #fff0f0;
    color: #9b1c1c;
  }

  .form-success,
  .social-status {
    background: #ecfbf4;
    color: #0d6d55;
  }

  .agent-box {
    border-top: 1px solid var(--line);
    display: grid;
    gap: 8px;
    padding-top: 28px;
  }

  .agent-icon {
    align-items: center;
    background: #ffffff;
    border: 1px solid #dfe1e7;
    border-radius: 50%;
    display: inline-flex;
    height: 36px;
    justify-content: center;
    width: 36px;
  }

  .agent-box strong {
    color: #17151b;
    font-size: 0.98rem;
  }

  .alternate-login {
    align-items: center;
    display: grid;
    gap: 28px;
    justify-items: center;
    min-height: 520px;
    position: relative;
  }

  .alternate-login .divider {
    background: #e5e5eb;
    bottom: 0;
    left: 50%;
    position: absolute;
    top: 0;
    width: 1px;
  }

  .alternate-login p {
    background: #ffffff;
    color: #17151b;
    font-size: clamp(1rem, 1.7vw, 1.25rem);
    line-height: 1.3;
    margin: 0;
    max-width: 120px;
    padding: 6px 8px;
    position: relative;
    z-index: 1;
  }

  .social-button {
    align-items: center;
    background: #ffffff;
    border: 1px solid #e2e2e8;
    border-radius: 50%;
    box-shadow: 0 10px 28px rgba(20, 20, 26, 0.08);
    color: #54545c;
    cursor: pointer;
    display: inline-flex;
    font-size: 1.25rem;
    font-weight: 700;
    height: 58px;
    justify-content: center;
    position: relative;
    text-transform: lowercase;
    width: 58px;
    z-index: 1;
  }

  .social-status {
    max-width: 190px;
    position: relative;
    z-index: 1;
  }

  .signup-panel {
    display: grid;
    gap: 10px;
    max-width: 260px;
    padding-top: 238px;
  }

  .signup-panel h2 {
    color: #17151b;
    font-size: clamp(1.35rem, 2.4vw, 1.9rem);
    font-weight: 600;
    line-height: 1.1;
    margin: 0;
  }

  .signup-panel p {
    color: #6f6f77;
    font-size: 1rem;
    line-height: 1.35;
    margin: 0 0 10px;
  }

  .signup-button {
    max-width: none;
    min-height: 38px;
    padding: 0 18px;
    text-align: center;
    white-space: nowrap;
    width: fit-content;
  }

  .support-footer {
    background: var(--purple);
    color: #ffffff;
    padding: clamp(42px, 7vw, 72px) clamp(20px, 5vw, 64px) 44px;
  }

  .footer-inner {
    margin: 0 auto;
    max-width: 1120px;
  }

  .footer-contact {
    display: grid;
    gap: 16px;
  }

  .footer-contact h2,
  .footer-social h2 {
    color: #ffffff;
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0;
  }

  .footer-contact p {
    color: #ffffff;
    display: grid;
    gap: 4px;
    margin: 0;
  }

  .footer-contact span {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.95rem;
  }

  .footer-contact a {
    color: #ffffff;
    font-size: 1.02rem;
    text-decoration: none;
  }

  .footer-social {
    display: grid;
    gap: 14px;
    margin-top: 30px;
  }

  .footer-social div {
    align-items: center;
    display: flex;
    gap: clamp(22px, 4vw, 46px);
  }

  .footer-social a {
    align-items: center;
    color: #ffffff;
    display: inline-flex;
    font-size: 1.1rem;
    font-weight: 800;
    height: 28px;
    justify-content: center;
    text-decoration: none;
    width: 28px;
  }

  .copyright {
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    color: #ffffff;
    font-size: 0.95rem;
    line-height: 1.45;
    margin: 38px 0 0;
    padding-top: 28px;
  }

  .copyright a {
    color: #ffffff;
    display: inline-flex;
    margin-left: 6px;
  }

  .chat-button {
    align-items: center;
    background: #5b2bd7;
    border: 0;
    border-radius: 18px;
    bottom: 18px;
    box-shadow: 0 14px 30px rgba(32, 15, 100, 0.25);
    color: #ffffff;
    cursor: pointer;
    display: inline-flex;
    height: 58px;
    justify-content: center;
    position: fixed;
    right: 18px;
    width: 58px;
    z-index: 20;
  }

  .chat-button svg {
    fill: none;
    height: 26px;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    width: 26px;
  }

  @media (max-width: 860px) {
    .support-header {
      min-height: 72px;
      padding: 10px 16px;
    }

    .support-logo img {
      width: min(86vw, 320px);
    }

    .login-shell {
      gap: 34px;
      grid-template-columns: 1fr;
      padding: 48px 26px 70px;
    }

    .portal-login-form {
      max-width: 100%;
    }

    .login-column {
      gap: 54px;
    }

    .alternate-login {
      gap: 22px;
      grid-template-columns: 1fr;
      min-height: auto;
      padding: 24px 0;
    }

    .alternate-login .divider {
      bottom: auto;
      height: 1px;
      left: 0;
      right: 0;
      top: 50%;
      width: auto;
    }

    .alternate-login p {
      max-width: none;
      text-align: center;
    }

    .signup-panel {
      border-top: 1px solid var(--line);
      max-width: 100%;
      padding-top: 30px;
    }
  }

  @media (min-width: 861px) {
    .footer-contact {
      grid-template-columns: 1fr 1fr;
    }

    .footer-contact h2 {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .login-alert {
      padding-inline: 12px;
    }

    .login-shell {
      padding: 44px 24px 62px;
    }

    .portal-login-form input[type="email"],
    .portal-login-form input[type="password"] {
      min-height: 56px;
    }

    .social-button {
      height: 52px;
      width: 52px;
    }

    .support-footer {
      padding: 42px 18px 40px;
    }

    .copyright a {
      display: block;
      margin-left: 0;
    }
  }
</style>
