---
import BaseLayout from "@layouts/BaseLayout.astro";

const footerSocials = [
  ["LinkedIn", "https://www.linkedin.com/company/seclore", "in"],
  ["Facebook", "https://www.facebook.com/Seclore", "f"],
  ["X", "https://x.com/seclore", "x"],
  ["YouTube", "https://www.youtube.com/@Seclore", "play"]
];
---

<BaseLayout
  title="Submit a Ticket | Seclore Support"
  description="Submit a support ticket to Seclore support."
  hideFooter={true}
>
  <main class="support-ticket-page">
    <header class="support-header" aria-label="Seclore support header">
      <a class="support-logo" href="/support/home/" aria-label="Seclore support home">
        <img src="/images/home/seclore-logo-2026.svg" alt="Seclore" loading="eager" decoding="async" />
      </a>
      <a class="contact-pill" href="#contact">Contact Us</a>
    </header>

    <nav class="portal-nav" aria-label="Support portal navigation">
      <div class="portal-left">
        <a class="support-home-link" href="/support/home/">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 11.5 12 4l9 7.5v8a1 1 0 0 1-1 1h-5.5v-6h-5v6H4a1 1 0 0 1-1-1v-8Z" /></svg>
          Support Home
        </a>
        <a href="/support/solutions/">Solutions</a>
        <a href="/support/discussions/">Forums</a>
      </div>

      <button class="portal-menu-toggle" type="button" aria-label="Open support menu" aria-expanded="false" aria-controls="support-ticket-menu">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <div class="portal-right" id="support-ticket-menu">
        <a class="login-link" href="/support/login/">Login</a>
        <a class="ticket-pill active" href="/support/tickets/new/" aria-current="page">New Support Ticket</a>
      </div>
    </nav>

    <section class="ticket-shell" aria-labelledby="ticket-title">
      <form class="ticket-form" id="support-ticket-form" novalidate>
        <h1 id="ticket-title">Submit a ticket</h1>

        <div class="form-row">
          <label for="requester">Requester <span aria-hidden="true">*</span></label>
          <input id="requester" name="requester" type="email" placeholder="Email" autocomplete="email" required />
        </div>

        <div class="form-row">
          <label for="subject">Subject <span aria-hidden="true">*</span></label>
          <input id="subject" name="subject" type="text" required />
        </div>

        <div class="form-row description-row">
          <label for="description">Description <span aria-hidden="true">*</span></label>
          <div class="editor-box">
            <div class="editor-toolbar" aria-hidden="true">
              <b>B</b>
              <i>I</i>
              <span class="underlined">U</span>
              <span class="list-icon"></span>
              <span class="list-icon ordered"></span>
              <span class="text-icon">A</span>
              <span class="text-icon filled">A</span>
              <span class="link-icon"></span>
              <span class="image-icon"></span>
            </div>
            <textarea id="description" name="description" required></textarea>
          </div>
        </div>

        <div class="form-row attach-row">
          <span></span>
          <button class="attach-button" type="button" aria-expanded="false">
            Attach
            <span aria-hidden="true"></span>
          </button>
        </div>

        <div class="form-row captcha-row">
          <span></span>
          <div class="recaptcha-box" role="group" aria-label="reCAPTCHA verification">
            <label class="recaptcha-check">
              <input type="checkbox" required />
              <span></span>
              <strong>I'm not a robot</strong>
            </label>
            <div class="recaptcha-brand" aria-hidden="true">
              <img class="recaptcha-logo" src="/images/support/recaptcha-logo.svg" alt="" loading="lazy" decoding="async" />
              <small>reCAPTCHA</small>
            </div>
            <p>For site owner: v1beta1 is deprecated.<br /><a href="#">Take action.</a></p>
          </div>
        </div>

        <p class="form-status" data-ticket-status hidden></p>

        <div class="form-actions">
          <span></span>
          <div>
            <button class="submit-button" type="submit">SUBMIT</button>
            <button class="cancel-button" type="reset">CANCEL</button>
          </div>
        </div>
      </form>
    </section>

    <footer class="support-footer" id="contact" aria-labelledby="support-contact-title">
      <div class="footer-inner">
        <section class="footer-contact">
          <h2 id="support-contact-title">Contact Us</h2>
          <p>
            <span>North America</span>
            <a href="tel:+18552732505">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.6 10.8c1.7 3.3 3.3 4.9 6.6 6.6l2.2-2.2c.3-.3.8-.4 1.2-.3 1.3.4 2.6.6 4 .6.7 0 1.2.5 1.2 1.2v3.6c0 .7-.5 1.2-1.2 1.2C10.8 22 2 13.2 2 2.4 2 1.7 2.5 1.2 3.2 1.2h3.6c.7 0 1.2.5 1.2 1.2 0 1.4.2 2.7.6 4 .1.4 0 .9-.3 1.2l-1.7 3.2Z" /></svg>
              +1-855-273-2505
            </a>
          </p>
          <p>
            <span>India &amp; Rest of the World</span>
            <a href="tel:+912261304242">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.6 10.8c1.7 3.3 3.3 4.9 6.6 6.6l2.2-2.2c.3-.3.8-.4 1.2-.3 1.3.4 2.6.6 4 .6.7 0 1.2.5 1.2 1.2v3.6c0 .7-.5 1.2-1.2 1.2C10.8 22 2 13.2 2 2.4 2 1.7 2.5 1.2 3.2 1.2h3.6c.7 0 1.2.5 1.2 1.2 0 1.4.2 2.7.6 4 .1.4 0 .9-.3 1.2l-1.7 3.2Z" /></svg>
              +91-22-61304242 / 61434848
            </a>
          </p>
          <p>
            <span>Email</span>
            <a href="mailto:support@seclore.com">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 5h18v14H3V5Zm2 3 7 5 7-5" /></svg>
              support@seclore.com
            </a>
          </p>
        </section>

        <section class="footer-social" aria-label="Connect with Seclore">
          <h2>Connect with us</h2>
          <div>
            {footerSocials.map(([label, href, icon]) => (
              <a href={href} target="_blank" rel="noreferrer" aria-label={label}>
                {icon === "play" ? (
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 6v12l10-6-10-6Z" /></svg>
                ) : (
                  <span>{icon}</span>
                )}
              </a>
            ))}
          </div>
        </section>

        <p class="copyright">
          &copy; 2026 SECLORE. ALL RIGHTS RESERVED. <a href="https://license.seclore.com/licensingportal/static/html/privacy.html" target="_blank" rel="noreferrer">PRIVACY STATEMENT</a>.
        </p>
      </div>
    </footer>

    <button class="chat-button" type="button" aria-label="Chat with support" aria-expanded="false">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5 6h14v10H9l-4 4V6Z" />
        <path d="M8 10h8M8 13h5" />
      </svg>
    </button>

    <script>
      const menuButton = document.querySelector(".portal-menu-toggle");
      const menuPanel = document.querySelector(".portal-right");
      const form = document.querySelector("#support-ticket-form");
      const status = document.querySelector("[data-ticket-status]");

      function setMenuOpen(open) {
        if (menuButton instanceof HTMLButtonElement && menuPanel instanceof HTMLElement) {
          menuButton.setAttribute("aria-expanded", String(open));
          menuPanel.classList.toggle("is-open", open);
        }
      }

      menuButton?.addEventListener("click", () => {
        if (menuButton instanceof HTMLButtonElement) {
          setMenuOpen(menuButton.getAttribute("aria-expanded") !== "true");
        }
      });

      document.addEventListener("click", (event) => {
        if (
          event.target instanceof Node &&
          menuPanel instanceof HTMLElement &&
          menuButton instanceof HTMLElement &&
          !menuPanel.contains(event.target) &&
          !menuButton.contains(event.target)
        ) {
          setMenuOpen(false);
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          setMenuOpen(false);
        }
      });

      form?.addEventListener("submit", (event) => {
        event.preventDefault();
        if (!(form instanceof HTMLFormElement) || !(status instanceof HTMLElement)) {
          return;
        }
        if (!form.checkValidity()) {
          form.classList.add("was-validated");
          status.hidden = false;
          status.className = "form-status error";
          status.textContent = "Please complete the required fields and reCAPTCHA.";
          return;
        }
        form.classList.remove("was-validated");
        status.hidden = false;
        status.className = "form-status success";
        status.textContent = "Support ticket details received.";
      });
    </script>
  </main>
</BaseLayout>

<style>
  :global(body) {
    background: #ffffff;
    color: #222228;
    font-family: Arial, Helvetica, sans-serif;
    margin: 0;
  }

  :global(body::before) {
    display: none;
  }

  .support-ticket-page {
    --purple: #673bdc;
    --purple-dark: #4f28c9;
    --blue: #0b3f76;
    --line: #d7d7dc;
    --text: #24242a;
    background: #f7f7f8;
    min-height: 100vh;
    overflow-x: hidden;
  }

  .support-ticket-page,
  .support-ticket-page * {
    box-sizing: border-box;
  }

  .support-header {
    align-items: center;
    background: #ffffff;
    display: flex;
    justify-content: space-between;
    min-height: 94px;
    padding: 18px clamp(24px, 4.6vw, 54px);
  }

  .support-logo {
    display: inline-flex;
    line-height: 1;
  }

  .support-logo img {
    display: block;
    width: clamp(260px, 32vw, 380px);
  }

  .contact-pill,
  .ticket-pill {
    align-items: center;
    border-radius: 999px;
    display: inline-flex;
    font-weight: 700;
    justify-content: center;
    min-height: 48px;
    padding: 0 26px;
    text-decoration: none;
    white-space: nowrap;
  }

  .contact-pill {
    background: var(--purple);
    color: #ffffff;
    font-size: 1.02rem;
  }

  .portal-nav {
    align-items: center;
    background: var(--purple);
    color: #ffffff;
    display: flex;
    justify-content: space-between;
    min-height: 68px;
    padding: 0 6px 0 clamp(22px, 3vw, 44px);
    position: relative;
    z-index: 5;
  }

  .portal-left,
  .portal-right {
    align-items: center;
    display: flex;
    gap: clamp(28px, 4vw, 48px);
  }

  .portal-nav a {
    color: #ffffff;
    font-size: 1.25rem;
    font-weight: 500;
    text-decoration: none;
  }

  .support-home-link {
    align-items: center;
    display: inline-flex;
    gap: 9px;
  }

  .support-home-link svg {
    fill: none;
    height: 23px;
    stroke: rgba(255, 255, 255, 0.62);
    stroke-linejoin: round;
    stroke-width: 1.8;
    width: 23px;
  }

  .ticket-pill {
    background: #ffffff;
    color: var(--purple) !important;
    font-size: 1.18rem !important;
    min-height: 50px;
    padding-inline: clamp(24px, 3.4vw, 36px);
  }

  .portal-menu-toggle {
    align-items: center;
    background: transparent;
    border: 0;
    cursor: pointer;
    display: none;
    flex-direction: column;
    gap: 4px;
    height: 46px;
    justify-content: center;
    width: 46px;
  }

  .portal-menu-toggle span {
    background: #ffffff;
    border-radius: 999px;
    display: block;
    height: 2px;
    width: 21px;
  }

  .ticket-shell {
    background: #f7f7f8;
    border-top: 1px solid rgba(25, 25, 30, 0.03);
    min-height: 826px;
    padding: 34px clamp(20px, 4vw, 26px) 76px;
  }

  .ticket-form {
    max-width: 790px;
  }

  .ticket-form h1 {
    color: var(--text);
    font-size: clamp(1.75rem, 2.5vw, 2.05rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.18;
    margin: 0 0 34px;
  }

  .form-row,
  .form-actions {
    align-items: start;
    display: grid;
    gap: 28px;
    grid-template-columns: 172px minmax(0, 573px);
    margin-bottom: 37px;
  }

  .form-row label {
    color: #000000;
    font-size: 1.02rem;
    line-height: 40px;
  }

  .form-row label span {
    color: #ff0000;
    font-weight: 700;
  }

  .ticket-form input[type="email"],
  .ticket-form input[type="text"] {
    background: #ffffff;
    border: 1px solid #c6c6ca;
    border-radius: 0;
    color: var(--text);
    font-size: 1.03rem;
    height: 40px;
    padding: 0 6px;
    width: 100%;
  }

  .ticket-form input::placeholder {
    color: #9a9aa2;
  }

  .editor-box {
    background: #ffffff;
    border: 1px solid #c6c6ca;
    border-radius: 5px;
    overflow: hidden;
  }

  .editor-toolbar {
    align-items: center;
    background: linear-gradient(#fbfbfc, #eeeeef);
    border-bottom: 1px solid #d2d2d6;
    display: flex;
    height: 40px;
  }

  .editor-toolbar > * {
    align-items: center;
    border-right: 1px solid #d2d2d6;
    color: #66666c;
    display: inline-flex;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.06rem;
    height: 40px;
    justify-content: center;
    min-width: 30px;
    padding: 0 8px;
  }

  .underlined {
    text-decoration: underline;
  }

  .list-icon,
  .link-icon,
  .image-icon {
    position: relative;
  }

  .list-icon::before {
    background: repeating-linear-gradient(to bottom, #62626a 0 2px, transparent 2px 6px);
    content: "";
    height: 18px;
    width: 18px;
  }

  .list-icon.ordered::before {
    width: 20px;
  }

  .text-icon.filled {
    background: #85858b;
    color: #ffffff;
  }

  .link-icon::before {
    border: 2px solid #66666c;
    border-left: 0;
    border-radius: 8px;
    content: "";
    height: 7px;
    width: 16px;
  }

  .image-icon::before {
    border: 2px solid #66666c;
    content: "";
    height: 16px;
    width: 18px;
  }

  .image-icon::after {
    border-bottom: 6px solid #66666c;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    bottom: 10px;
    content: "";
    position: absolute;
  }

  textarea {
    border: 0;
    display: block;
    font: inherit;
    height: 178px;
    padding: 10px;
    resize: vertical;
    width: 100%;
  }

  .attach-row {
    margin-bottom: 30px;
  }

  .attach-button {
    align-items: center;
    background: transparent;
    border: 0;
    color: #0c95df;
    cursor: pointer;
    display: inline-flex;
    font-size: 1.1rem;
    gap: 7px;
    justify-self: start;
    padding: 0 0 0 15px;
  }

  .attach-button span {
    border-bottom: 5px solid #111111;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    display: inline-block;
    height: 0;
    margin-top: 8px;
    width: 0;
  }

  .captcha-row {
    margin-bottom: 28px;
  }

  .recaptcha-box {
    background: #ffffff;
    border: 1px solid #d4d4d8;
    border-radius: 5px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    display: grid;
    grid-template-areas:
      "check brand"
      "note brand";
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    min-height: 96px;
    padding: 17px 15px 8px 13px;
    width: min(100%, 377px);
  }

  .recaptcha-check {
    align-items: center;
    display: flex;
    gap: 17px;
    grid-area: check;
    line-height: 1 !important;
  }

  .recaptcha-check input {
    opacity: 0;
    position: absolute;
  }

  .recaptcha-check > span {
    background: #ffffff;
    border: 2px solid #56565c;
    display: block;
    flex: 0 0 auto;
    height: 34px;
    width: 34px;
  }

  .recaptcha-check input:checked + span {
    background: #ffffff;
    border-color: #2f75d8;
    position: relative;
  }

  .recaptcha-check input:checked + span::after {
    border-bottom: 3px solid #2f75d8;
    border-right: 3px solid #2f75d8;
    content: "";
    height: 18px;
    left: 10px;
    position: absolute;
    top: 4px;
    transform: rotate(45deg);
    width: 9px;
  }

  .recaptcha-check strong {
    color: #222228;
    font-size: 1.02rem;
    font-weight: 400;
  }

  .recaptcha-brand {
    align-items: center;
    display: grid;
    grid-area: brand;
    justify-items: center;
    margin-left: 18px;
  }

  .recaptcha-logo {
    display: block;
    height: 42px;
    object-fit: contain;
    width: 42px;
  }

  .recaptcha-brand small {
    color: #55555c;
    font-size: 0.72rem;
  }

  .recaptcha-box p {
    color: #6e6e75;
    font-size: 0.63rem !important;
    grid-area: note;
    left: 8px;
    line-height: 1.05 !important;
    margin: 2px 0 0;
    padding: 0 !important;
  }

  .recaptcha-box a {
    color: #4d4d52;
    font-size: inherit !important;
    line-height: inherit !important;
  }

  .form-status {
    border-radius: 6px;
    font-size: 0.95rem;
    margin: -10px 0 24px 200px;
    max-width: 573px;
    padding: 10px 12px;
  }

  .form-status.error {
    background: #fff0f0;
    color: #9c1616;
  }

  .form-status.success {
    background: #eefaf3;
    color: #126b3d;
  }

  .form-actions {
    border-top: 1px solid #e1e1e4;
    margin-bottom: 0;
    padding-top: 15px;
  }

  .form-actions > div {
    display: flex;
    gap: 6px;
  }

  .submit-button,
  .cancel-button {
    align-items: center;
    border: 0;
    border-radius: 5px;
    cursor: pointer;
    display: inline-flex;
    font-size: 1rem;
    justify-content: center;
    letter-spacing: 0.12em;
    min-height: 38px;
    min-width: 129px;
    padding: 0 26px;
  }

  .submit-button {
    background: var(--blue);
    color: #ffffff;
  }

  .cancel-button {
    background: linear-gradient(#ffffff, #eeeeef);
    border: 1px solid #d8d8dc;
    color: #3f3f45;
  }

  .ticket-form.was-validated input:invalid,
  .ticket-form.was-validated textarea:invalid {
    border-color: #d52828;
    outline: 1px solid #d52828;
  }

  .support-footer {
    background: var(--purple);
    color: #ffffff;
    padding: 39px clamp(22px, 4vw, 30px) 58px !important;
  }

  .footer-inner {
    margin: 0 auto;
    max-width: 1140px;
  }

  .footer-contact {
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    display: grid;
    gap: 20px;
    max-width: 410px;
    padding: 29px 0 0 !important;
  }

  .footer-contact h2,
  .footer-social h2 {
    color: #ffffff;
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
  }

  .footer-contact p {
    color: #ffffff;
    display: grid;
    gap: 7px;
    margin: 0;
  }

  .footer-contact span {
    color: #ffffff;
    font-size: 1rem;
    line-height: 1.25;
  }

  .footer-contact a {
    align-items: center;
    color: #ffffff;
    display: inline-flex;
    font-size: 1.06rem;
    gap: 12px;
    line-height: 1.3;
    text-decoration: none;
  }

  .footer-contact svg {
    fill: currentColor;
    height: 24px;
    width: 24px;
  }

  .footer-social {
    display: grid;
    gap: 14px;
    margin-top: 34px;
    max-width: 410px;
    padding: 0 !important;
  }

  .footer-social div {
    align-items: center;
    display: flex;
    gap: 35px;
  }

  .footer-social a {
    align-items: center;
    color: #ffffff;
    display: inline-flex;
    font-size: 1.24rem;
    font-weight: 800;
    height: 28px;
    justify-content: center;
    text-decoration: none;
    width: 28px;
  }

  .footer-social svg {
    fill: currentColor;
    height: 25px;
    width: 25px;
  }

  .copyright {
    color: #ffffff;
    font-size: 1.02rem;
    line-height: 1.45;
    margin: 31px 0 0;
    max-width: 720px;
  }

  .copyright a {
    color: #ffffff;
    text-decoration: none;
  }

  .chat-button {
    align-items: center;
    background: #4e27cf;
    border: 0;
    border-radius: 18px;
    bottom: 96px;
    box-shadow: 0 12px 28px rgba(38, 14, 120, 0.25);
    color: #ffffff;
    cursor: pointer;
    display: inline-flex;
    height: 75px;
    justify-content: center;
    position: fixed;
    right: 7px;
    width: 75px;
    z-index: 20;
  }

  .chat-button svg {
    fill: none;
    height: 32px;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    width: 32px;
  }

  @media (max-width: 900px) {
    .support-header {
      justify-content: center;
      min-height: 74px;
      padding: 12px 18px;
      position: relative;
    }

    .support-logo img {
      width: min(82vw, 320px);
    }

    .contact-pill {
      display: none;
    }

    .portal-nav {
      min-height: 52px;
      padding: 0 14px;
    }

    .portal-left a:not(.support-home-link) {
      display: none;
    }

    .portal-left,
    .portal-right {
      gap: 0;
    }

    .portal-nav a {
      font-size: 0.92rem;
    }

    .support-home-link svg {
      display: none;
    }

    .portal-menu-toggle {
      display: inline-flex;
      margin-left: auto;
    }

    .portal-right {
      background: #ffffff;
      border: 1px solid rgba(15, 23, 42, 0.12);
      box-shadow: 0 16px 36px rgba(15, 23, 42, 0.18);
      display: grid;
      min-width: 225px;
