  select {
    font: inherit;
  }

  .press-release-page .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .press-release-page .site-logo {
    color: var(--purple);
    font-size: 1.35rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .press-release-page .nav-links,
  .press-release-page .nav-utilities {
    align-items: center;
    display: flex;
  }

  .press-release-page .nav-links {
    flex: 1 1 auto;
    gap: clamp(18px, 2.2vw, 34px);
    justify-content: center;
    min-width: 0;
  }

  .press-release-page .nav-links > a,
  .press-release-page .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .press-release-page .nav-links > a:hover,
  .press-release-page .nav-trigger:hover,
  .press-release-page .nav-item:hover .nav-trigger,
  .press-release-page .nav-item:focus-within .nav-trigger {
    color: var(--header-text);
  }

  .press-release-page .nav-item {
    position: static;
  }

  .press-release-page .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .press-release-page .nav-item:hover .nav-caret,
  .press-release-page .nav-item:focus-within .nav-caret,
  .press-release-page .nav-item.is-open .nav-caret {
    transform: rotate(225deg) translateY(-1px);
  }

  .press-release-page .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .press-release-page .nav-item:hover .mega-menu,
  .press-release-page .nav-item:focus-within .mega-menu,
  .press-release-page .nav-item.is-open .mega-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .press-release-page .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .press-release-page .mega-columns {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .press-release-page .mega-column,
  .press-release-page .mega-sublinks {
    display: grid;
  }

  .press-release-page .mega-column {
    gap: 10px;
  }

  .press-release-page .mega-title {
    color: var(--dropdown-title);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .press-release-page .mega-link,
  .press-release-page .mega-link-group {
    border: 1px solid transparent;
    border-radius: 8px;
  }

  .press-release-page .mega-link {
    display: grid;
    gap: 5px;
    padding: 13px;
  }

  .press-release-page .mega-link strong {
    color: var(--dropdown-text);
  }

