    color: var(--dropdown-muted);
  }

  .press-release-page .mega-link:hover,
  .press-release-page .mega-link-group:hover {
    background: var(--dropdown-link-hover);
    border-color: var(--dropdown-link-border);
  }

  .press-release-page .mega-link-group {
    display: grid;
