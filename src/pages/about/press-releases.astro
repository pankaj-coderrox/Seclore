---

<BaseLayout
  title="Seclore Press Releases | Latest Company News"
  description="Read the latest Seclore press releases and company announcements."
>
  <main id="top" class="press-release-page">
    <Nav />

    <section class="press-hero">
      <span>Seclore News</span>
      <h1>Latest Press Releases</h1>
      <div class="hero-actions">
        <a class="primary-button" href="#demo">Schedule Demo</a>
        <a class="outline-button" href="mailto:press@seclore.com">Press Inquiry</a>
      </div>
    </section>

    <section class="release-section" aria-labelledby="release-heading">
      <h2 id="release-heading" class="sr-only">Press releases</h2>
      <div class="release-grid">
        {releases.map((release) => (
          <article class="release-card" data-year={release.year} data-title={release.title.toLowerCase()}>
            <a
              class:list={["release-image", { "is-placeholder": release.image.includes("social-share-thumbnail") }]}
              href={release.link}
              target="_blank"
              rel="noreferrer"
              style={release.image.includes("social-share-thumbnail")
                ? "--release-image-height: 150px; --release-image-mobile-height: 96px;"
                : undefined}
            >
              <img src={release.image} alt="" loading="lazy" />
            </a>
            <div class="release-body">
              <span>{release.date}</span>
              <h3>{release.title}</h3>
              <a href={release.link} target="_blank" rel="noreferrer">View press release -></a>
            </div>
          </article>
        ))}
      </div>

      <p class="empty-state" hidden>No press releases match your filters.</p>

      <nav class="pagination" aria-label="Press release pages">
        <button class="current" type="button" data-page-button="1">1</button>
        <button type="button" data-page-button="2">2</button>
        <button type="button" data-page-button="3">3</button>
        <span>...</span>
        <button type="button" data-page-button="11">11</button>
        <button type="button" data-next-page>Next</button>
      </nav>
    </section>

    <section class="learn-section">
      <h2>Learn more about Seclore</h2>
      <a
        class="primary-button learn-more-button"
        href="/about/why-seclore/"
        style="align-items: center !important; background: #32373c !important; border-radius: 7.5px !important; color: #ffffff !important; display: inline-flex !important; font-size: 15px !important; font-weight: 500 !important; justify-content: center !important; line-height: 1 !important; margin: 0 auto !important; min-height: 39px !important; padding: 0 30px !important; width: fit-content !important;"
      >
        Learn More
      </a>
      <div class="learn-grid">
        {learnCards.map(([title, text, href, icon]) => (
          <a class="learn-card" href={href}>
            <span class={`icon-badge ${icon}`} aria-hidden="true"></span>
            <h3>{title}</h3>
            <p>{text} -></p>
          </a>
        ))}
      </div>
    </section>

  </main>
</BaseLayout>

<script is:inline>
  const cards = Array.from(document.querySelectorAll(".release-card"));
  const pageButtons = Array.from(document.querySelectorAll("[data-page-button]"));
  const nextButton = document.querySelector("[data-next-page]");
  const emptyState = document.querySelector(".empty-state");
  const perPage = 12;
  let activePage = 1;

  function getMatches() {
    return cards;
  }

  function renderCards() {
    const matches = getMatches();
    const maxPage = Math.max(1, Math.ceil(matches.length / perPage));
    activePage = Math.min(activePage, maxPage);
    const start = (activePage - 1) * perPage;
    const visible = new Set(matches.slice(start, start + perPage));

    cards.forEach((card) => {
      card.hidden = !visible.has(card);
    });

    pageButtons.forEach((button) => {
      const buttonPage = Number(button.dataset.pageButton);
      button.classList.toggle("current", buttonPage === activePage);
      button.disabled = buttonPage > maxPage;
    });

    if (emptyState) {
      emptyState.hidden = matches.length > 0;
    }
  }

  pageButtons.forEach((button) => {
    button.addEventListener("click", () => {
      activePage = Number(button.dataset.pageButton);
      renderCards();
    });
  });

  nextButton?.addEventListener("click", () => {
    const matches = getMatches();
    const maxPage = Math.max(1, Math.ceil(matches.length / perPage));
    activePage = activePage >= maxPage ? 1 : activePage + 1;
    renderCards();
  });

  renderCards();
</script>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f0f1f3;
