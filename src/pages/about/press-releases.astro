    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--ink);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
