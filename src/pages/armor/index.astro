---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const promiseCards = [
  {
    title: "Enable AI",
    text: "ARMOR enables safe AI adoption by ensuring the data AI uses is trusted, understood, and controlled.",
    icon: "magic"
  },
  {
    title: "Continuous Control",
    text: "ARMOR maintains control as data moves across users, applications, clouds, partners, and AI agents.",
    icon: "handshake"
  },
  {
    title: "Less Risk, No Friction",
    text: "ARMOR adapts security to context and intent, protecting sensitive data without disrupting work.",
    icon: "shield"
  },
  {
    title: "Always Ready",
    text: "ARMOR actively remediates risk, not just reveals it, so organizations stay ready as conditions change.",
    icon: "loop"
  }
];

const steps = [
  {
    title: "Discover",
    text: "Discover what data exists and where it lives",
    open: true
  },
  {
    title: "Context",
    text: "Understand sensitivity, business value, usage, and regulatory obligations"
  },
  {
    title: "Enforce",
    text: "Apply classification, protection, and access controls automatically"
  },
  {
    title: "Prove",
    text: "Create evidence that shows data is controlled and compliant"
  }
];

const components = [
  {
    title: "AI Discovery",
    text: "Identifies where AI systems and agents access, generate, and use enterprise data, giving organizations visibility into AI-driven data activity so AI can be adopted safely and with confidence."
  },
  {
    title: "Classification",
    text: "Understands what data is, its sensitivity, and its business value, enabling automatic, context-aware controls that guide how data is accessed, shared, and used."
  },
  {
    title: "EDRM",
    text: "Applies persistent, data-centric controls that stay with sensitive information, ensuring it is accessed and used appropriately wherever it moves, across people, applications, and AI."
  },
  {
    title: "Data Insights Framework",
    text: "Applies persistent, data-centric controls that stay with sensitive information, ensuring it is accessed and used appropriately wherever it moves, across people, applications, and AI."
  }
];

const resources = [
  {
    type: "Blog Post",
    tag: "AI, Company, Data Security",
    title: "The Debate About AI in the Enterprise Is Over. Here Is the Only Question That Matters.",
    cta: "View Blog Post",
    href: "/blog/the-debate-about-ai-in-the-enterprise-is-over/",
    image: "/images/armor/debate-ai-enterprise.png",
    alt: "Enterprise AI and data security discussion"
  },
  {
    type: "Blog Post",
    tag: "AI Risk, Data Security",
    title: "The Missing Link in Enterprise AI: Why Context and Behavior Are the New Security Perimeter",
    cta: "View Blog Post",
    href: "/blog/the-missing-link-in-enterprise-ai/",
    image: "/images/armor/missing-link-enterprise-ai.png",
    alt: "The Missing Link in Enterprise AI blog visual"
  },
  {
    type: "Blog Post",
    tag: "AI Risk, Data Security",
    title: "ChatGPT Read 400 Internal Company Files In 42 Milliseconds. Security Stacks Saw Nothing",
    cta: "View Blog Post",
    href: "/blog/chatgpt-read-400-internal-company-files/",
    image: "/images/armor/chatgpt-internal-files.png",
    alt: "Laptop showing ChatGPT while a person types"
  }
];
---

<BaseLayout
  title="ARMOR | Seclore"
  description="Seclore ARMOR is a unified data security intelligence platform that helps organizations trust and control data wherever people and AI work."
>
  <main id="top" class="armor-page">
    <Nav />

    <section class="armor-hero">
      <div class="hero-copy">
        <div class="armor-lockup" aria-label="ARMOR">
          <img class="armor-mark" src="/images/armor/seclore-armor-logo.png" alt="" loading="eager" decoding="async" />
          <strong>ARMOR</strong>
        </div>
        <h1>
          <span>Turn Risk into</span>
          <span>Readiness</span>
        </h1>
        <p>
          A unified Data Security Intelligence platform that helps organizations trust and control
          their data wherever people and AI work.
        </p>
        <a class="primary-button" href="#demo">Book a Demo</a>
        <div class="trust-strip">
          <p>Trusted by industry-leading enterprises</p>
          <div class="logo-row" aria-label="Customer logos">
            <div class="logo-track">
              <div class="logo-group">
                <span>SUZUKI</span>
                <span>Linde</span>
                <span>HD</span>
                <span>American Express</span>
                <span>STC</span>
                <span>Skyworks</span>
                <span>QIB</span>
                <span>Adani</span>
                <span>aramco</span>
                <span>FLEX</span>
              </div>
              <div class="logo-group" aria-hidden="true">
                <span>SUZUKI</span>
                <span>Linde</span>
                <span>HD</span>
                <span>American Express</span>
                <span>STC</span>
                <span>Skyworks</span>
                <span>QIB</span>
                <span>Adani</span>
                <span>aramco</span>
                <span>FLEX</span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="hero-dashboard">
        <img src="/images/armor/armor-dashboard.png" alt="ARMOR data catalog dashboard" loading="eager" />
      </div>
    </section>

    <section class="promise-section">
      <div class="section-heading centered">
        <h2>Enable AI everywhere through context-aware intelligence without losing control.</h2>
        <p>
          Seclore ARMOR is the data security intelligence platform for enterprise AI. It brings
          together AI-discovery, classification, persistent protection, and insights into a unified
          approach.
        </p>
      </div>
      <div class="promise-grid">
        {promiseCards.map((card) => (
          <article class="promise-card">
            <div class={`line-icon ${card.icon}`} aria-hidden="true"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="works-section">
      <span class="eyebrow">How It Works</span>
      <h2>Discover &rarr; Context &rarr; Enforce &rarr; Prove</h2>
      <p>ARMOR applies Data Security Intelligence through a continuous, data-centric control loop</p>
      <div class="works-grid">
        <div class="repository-card">
          <img src="/images/armor/armor-data-repository.png" alt="ARMOR data repository detail" loading="lazy" />
        </div>
        <div class="step-list">
          {steps.map((step) => (
            <article class={step.open ? "step-card open" : "step-card"}>
              <div>
                <h3>{step.title}</h3>
                <span>{step.open ? "×" : "+"}</span>
              </div>
              {step.open && <p>{step.text}</p>}
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="components-section">
      <div class="section-heading centered">
        <h2>Key Components</h2>
      </div>
      <div class="component-grid">
        {components.map((component) => (
          <article class="component-card">
            <h3>{component.title}</h3>
            <p>{component.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="resources-section" id="resources">
      <div class="resource-heading">
        <h2>Insights on AI, data security, and trust</h2>
        <a href="/resources/">View All Resources</a>
      </div>
      <div class="resource-grid">
        {resources.map((resource) => (
          <a class="resource-card" href={resource.href} aria-label={`View blog post: ${resource.title}`}>
            <figure class="resource-image">
              <img src={resource.image} alt={resource.alt} loading="lazy" />
            </figure>
            <div class="resource-body">
              <span>{resource.type}</span>
              <strong>{resource.tag}</strong>
              <h3>{resource.title}</h3>
              <span class="resource-cta">{resource.cta} <span aria-hidden="true">&rarr;</span></span>
            </div>
          </a>
        ))}
      </div>
      <div class="resource-controls" aria-label="Resource carousel controls">
        <button type="button" aria-label="Previous resources">&larr;</button>
        <button type="button" aria-label="Next resources">&rarr;</button>
      </div>
    </section>

    <section class="demo-band" id="demo">
      <div class="demo-copy">
        <h2>Get a Personalized Demo</h2>
        <p>See Seclore ARMOR in action! Learn how to enable safe use of Data and AI.</p>
      </div>
      <form class="demo-form">
        <h3>Request a Demo</h3>
        <label>Email<span>*</span><input name="email" type="email" required /></label>
        <label>First Name<span>*</span><input name="firstName" required /></label>
        <label>Last Name<span>*</span><input name="lastName" required /></label>
        <label>Company name<span>*</span><input name="company" required /></label>
        <label>Job title<span>*</span><input name="role" required /></label>
        <label>Phone number<span>*</span><input name="phone" required /></label>
        <label>Country<span>*</span><select name="country" required><option value="">Please Select</option><option>United States</option><option>India</option><option>United Kingdom</option></select></label>
        <button class="primary-button demo-submit" type="submit">Schedule A Demo</button>
      </form>
    </section>

  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #ffffff;
    --page-text: #24182f;
    --page-muted: #51475a;
    --purple: #562bd4;
    --purple-dark: #3c16b0;
    --soft: #f7f6f8;
    --line: #dedee5;
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: #ffffff;
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a { color: inherit; text-decoration: none; }
  button,
  input,
  select { font: inherit; }

  .armor-page h1,
  .armor-page h2,
  .armor-page h3,
  .armor-page p { margin: 0; }

  .armor-page { background: #fff; }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo { color: var(--purple); font-size: 1.35rem; font-weight: 950; letter-spacing: 0.04em; margin-right: clamp(14px, 2vw, 28px); text-transform: uppercase; }
  .nav-links, .nav-utilities { align-items: center; display: flex; }
  .nav-links { flex: 1 1 auto; gap: clamp(18px, 2.2vw, 34px); justify-content: center; min-width: 0; }
  .nav-links > a, .nav-trigger { align-items: center; background: transparent; border: 0; color: var(--header-muted); cursor: pointer; display: inline-flex; font-size: 0.98rem; font-weight: 800; gap: 8px; min-height: 68px; padding: 0; }
  .nav-links > a:hover, .nav-trigger:hover, .nav-item:hover .nav-trigger, .nav-item:focus-within .nav-trigger { color: var(--header-text); }
  .nav-item { position: static; }
  .nav-caret { border-bottom: 2px solid currentColor; border-right: 2px solid currentColor; display: inline-block; height: 8px; transform: rotate(45deg) translateY(-2px); transition: transform 180ms ease; width: 8px; }
  .nav-item:hover .nav-caret, .nav-item:focus-within .nav-caret, .nav-item.is-open .nav-caret { transform: rotate(225deg) translateY(-1px); }
  .mega-menu { left: 22px; opacity: 0; pointer-events: none; position: absolute; right: clamp(20px, 4vw, 42px); top: calc(100% - 1px); transform: translateY(12px); transition: opacity 180ms ease, transform 180ms ease; }
  .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu, .nav-item.is-open .mega-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .mega-inner { background: var(--dropdown-bg); border: 1px solid var(--dropdown-border); border-radius: 8px; box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2); display: grid; gap: 24px; grid-template-columns: minmax(0, 1fr) 320px; min-height: 320px; overflow: hidden; padding: 26px; }
  .mega-columns { display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .mega-column, .mega-sublinks { display: grid; }
  .mega-column { gap: 10px; }
  .mega-title { color: var(--dropdown-title); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .mega-link, .mega-link-group { border: 1px solid transparent; border-radius: 8px; }
  .mega-link { display: grid; gap: 5px; padding: 13px; }
  .mega-link strong { color: var(--dropdown-text); }
  .mega-link small, .mega-sublinks a { color: var(--dropdown-muted); }
  .mega-link:hover, .mega-link-group:hover { background: var(--dropdown-link-hover); border-color: var(--dropdown-link-border); }
  .mega-link-group { display: grid; gap: 4px; padding: 4px; }
  .mega-sublinks { gap: 2px; padding: 0 9px 8px 22px; }
  .mega-sublinks a { font-size: 0.84rem; padding: 5px 0; }
  .mega-feature { align-content: end; background: var(--dropdown-feature-bg); border: 1px solid var(--dropdown-feature-border); border-radius: 8px; display: grid; min-height: 268px; padding: 24px; }
  .mega-feature span, .mega-feature em { color: var(--dropdown-title); }
  .mega-feature strong { color: var(--dropdown-text); font-size: 1.35rem; line-height: 1.18; margin-top: auto; }
  .nav-utilities { flex: 0 0 auto; gap: clamp(12px, 1.5vw, 20px); margin-left: clamp(12px, 2vw, 28px); }
  .utility-link, .language-button, .utility-icon, .theme-toggle { color: var(--header-muted); display: none; font-size: 0.88rem; font-weight: 750; }
  .demo-button,
  .primary-button {
    align-items: center;
    background: linear-gradient(135deg, var(--purple), var(--purple-dark));
    border: 0;
    border-radius: 7px;
    box-shadow: 0 10px 22px rgba(86, 43, 212, 0.16);
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.94rem;
    font-weight: 850;
    justify-content: center;
    line-height: 1;
    min-height: 46px;
    padding: 0 24px;
    text-align: center;
    transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
    white-space: nowrap;
    width: max-content;
  }
  .demo-button:hover,
  .primary-button:hover { box-shadow: 0 14px 28px rgba(86, 43, 212, 0.22); transform: translateY(-1px); }
  .nav-toggle { background: transparent; border: 0; display: none; height: 42px; width: 42px; }
  .nav-toggle span { background: var(--header-text); display: block; height: 2px; margin: 6px 0; width: 24px; }

  .armor-hero {
    align-items: center;
    display: grid;
    gap: clamp(2.2rem, 4vw, 4.2rem);
    grid-template-columns: minmax(0, 0.9fr) minmax(360px, 1.08fr);
    margin: 0 auto;
    max-width: 1190px;
    padding: 68px 24px 104px;
  }

  .hero-copy,
  .hero-dashboard {
    min-width: 0;
  }

  .armor-lockup { align-items: center; color: var(--purple); display: flex; gap: 18px; margin-bottom: 28px; }
  .armor-lockup strong { font-size: clamp(4rem, 8vw, 7.3rem); font-weight: 800; letter-spacing: 0.03em; line-height: 0.8; }
  .armor-mark { display: block; flex: 0 0 auto; height: clamp(62px, 8vw, 90px); width: clamp(62px, 8vw, 90px); }
  .hero-copy h1 { font-size: clamp(3.2rem, 6.7vw, 6.55rem); font-weight: 500; line-height: 0.98; letter-spacing: 0; }
  .hero-copy h1 span { display: inline; }
  .hero-copy > p { color: var(--page-text); font-size: 1.25rem; line-height: 1.55; margin-top: 1.5rem; max-width: 620px; }
  .hero-copy .primary-button { margin-top: 1.45rem; min-height: 48px; min-width: 132px; padding-inline: 28px; }
  .hero-dashboard { border-radius: 22px; overflow: hidden; }
  .hero-dashboard img { display: block; width: 100%; }

  .trust-strip { margin-top: 56px; max-width: min(920px, 100vw - 40px); min-width: 0; overflow: hidden; padding-bottom: 16px; width: 100%; }
  .trust-strip p { color: var(--page-text); font-size: 1.18rem; }
  .logo-row { margin-top: 24px; overflow: hidden; width: 100%; }
  .logo-track { align-items: center; display: flex; width: max-content; animation: armorLogoMarquee 26s linear infinite; }
  .logo-group { align-items: center; display: flex; flex-shrink: 0; gap: clamp(48px, 7vw, 96px); padding-right: clamp(48px, 7vw, 96px); }
  .logo-row span { color: #6f6f78; display: inline-flex; font-size: clamp(1.08rem, 1.8vw, 1.42rem); font-weight: 900; line-height: 1; opacity: 0.88; text-transform: none; white-space: nowrap; }
  .logo-row span:nth-child(1),
  .logo-row span:nth-child(3),
  .logo-row span:nth-child(5),
  .logo-row span:nth-child(6),
  .logo-row span:nth-child(7),
  .logo-row span:nth-child(10) { letter-spacing: 0.04em; text-transform: uppercase; }

  @keyframes armorLogoMarquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (min-width: 641px) {
    .hero-copy h1 {
      display: grid;
      gap: 0.06em;
      max-width: 640px;
    }

    .hero-copy h1 span {
      display: block;
    }

    .hero-copy > p {
      max-width: 540px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-track { animation-duration: 60s; }
  }

  .promise-section,
  .works-section,
  .components-section,
  .resources-section {
    padding: 56px 24px;
  }

  .section-heading.centered { margin: 0 auto; max-width: 1120px; text-align: center; }
  .section-heading h2 { color: var(--purple); font-size: clamp(2.7rem, 5vw, 5.05rem); font-weight: 500; line-height: 1.02; }
  .section-heading p { color: #1f1828; font-size: clamp(1.08rem, 1.7vw, 1.34rem); line-height: 1.5; margin: 1.25rem auto 0; max-width: 1040px; }

  .promise-grid { display: grid; gap: 22px; grid-template-columns: repeat(4, minmax(0, 1fr)); margin: 36px auto 0; max-width: 1190px; }
  .promise-card { background: var(--soft); border-radius: 18px; min-height: 292px; padding: 30px 28px; }
  .promise-card h3 { color: #050309; font-size: 1.7rem; font-weight: 500; line-height: 1.1; margin-top: 1.8rem; }
  .promise-card p { color: #1f1a25; font-size: 1.02rem; line-height: 1.52; margin-top: 1.35rem; }

  .line-icon { height: 46px; position: relative; width: 46px; }
  .line-icon::before,
  .line-icon::after { content: ""; position: absolute; }
  .line-icon.magic::before { border-bottom: 4px solid var(--purple); border-left: 4px solid var(--purple); height: 30px; left: 11px; top: 5px; transform: rotate(-45deg); width: 10px; }
  .line-icon.magic::after { background: #ef8d29; border-radius: 50%; box-shadow: 16px -8px 0 #ef8d29, 21px 12px 0 var(--purple); height: 6px; left: 7px; top: 7px; width: 6px; }
  .line-icon.handshake::before { border: 4px solid var(--purple); border-radius: 18px; height: 18px; left: 4px; top: 13px; transform: rotate(-28deg); width: 28px; }
  .line-icon.handshake::after { border: 4px solid #ef8d29; border-radius: 18px; height: 18px; left: 17px; top: 13px; transform: rotate(28deg); width: 28px; }
  .line-icon.shield::before { border: 4px solid var(--purple); border-radius: 20px 20px 14px 14px; height: 34px; left: 8px; top: 5px; width: 28px; }
  .line-icon.shield::after { border-bottom: 4px solid #ef8d29; border-right: 4px solid #ef8d29; height: 13px; left: 18px; top: 14px; transform: rotate(45deg); width: 8px; }
  .line-icon.loop::before { border: 4px solid var(--purple); border-right-color: transparent; border-radius: 50%; height: 23px; left: 0; top: 9px; width: 23px; }
  .line-icon.loop::after { border: 4px solid #ef8d29; border-left-color: transparent; border-radius: 50%; height: 23px; right: 0; top: 9px; width: 23px; }

  .works-section { padding-top: 50px; }
  .eyebrow { color: var(--purple); display: block; font-size: 1rem; font-weight: 850; margin: 0 auto 18px; max-width: 1190px; }
  .works-section > h2,
  .works-section > p { margin-left: auto; margin-right: auto; max-width: 1190px; }
  .works-section > h2 { color: #06050a; font-size: clamp(3rem, 5vw, 5.3rem); font-weight: 500; line-height: 1.02; }
  .works-section > p { color: #211b29; font-size: 1.08rem; line-height: 1.5; margin-top: 1.2rem; }
  .works-grid { align-items: start; display: grid; gap: 32px; grid-template-columns: minmax(300px, 0.95fr) minmax(300px, 1fr); margin: 34px auto 0; max-width: 1190px; }
  .repository-card { background: linear-gradient(140deg, #fbecff, #eff8ff 70%, #ffeef4); border-radius: 18px; overflow: hidden; }
  .repository-card img { display: block; width: 100%; }
  .step-list { display: grid; gap: 22px; }
  .step-card { background: linear-gradient(135deg, #fff6fa, #f8fdff); border: 1px solid #f0bfd5; border-radius: 10px; padding: 26px 32px; }
  .step-card div { align-items: center; display: flex; justify-content: space-between; }
  .step-card h3 { color: #1d1624; font-size: 2rem; font-weight: 650; }
  .step-card span { font-size: 2rem; font-weight: 800; }
  .step-card p { color: #241d2c; font-size: 1.08rem; line-height: 1.5; margin-top: 1.35rem; max-width: 420px; }

  .components-section { padding-top: 50px; }
  .components-section .section-heading h2 { color: #291d34; }
  .component-grid { display: grid; gap: 22px; grid-template-columns: repeat(2, minmax(250px, 1fr)); margin: 34px auto 0; max-width: 1190px; }
  .component-card { background: linear-gradient(180deg, #fff, #f3f5f9); border: 1px solid #f1bfd7; border-radius: 18px; min-height: 270px; padding: 30px 30px; }
  .component-card h3 { color: #060409; font-size: 1.8rem; font-weight: 800; line-height: 1.08; }
  .component-card p { color: #0f0b15; font-size: 1.08rem; line-height: 1.52; margin-top: 1.35rem; }

  .resources-section { background: #fff; padding: 56px clamp(20px, 4vw, 52px) 44px; }
  .resource-heading { align-items: center; display: flex; gap: 24px; justify-content: space-between; margin: 0 auto; max-width: 1190px; }
  .resource-heading h2 { color: #050408; font-size: clamp(2.6rem, 4.6vw, 4.7rem); font-weight: 500; line-height: 1.05; }
