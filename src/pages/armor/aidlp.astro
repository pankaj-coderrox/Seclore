---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL || (import.meta.env.DEV ? "http://127.0.0.1:5000" : "");

const interactionModes = [
  {
    title: "AI Chat Protection",
    visualIn: "Customer SSN: 468-92-1284",
    visualOut: "Customer SSN: [masked]",
    heading: "Protect AI chat interactions before sensitive data leaves the enterprise.",
    paragraphs: [
      "Employees access public AI tools through the ARMOR AI-DLP Portal. Sensitive data such as PII, PHI, financial records, IP, source material, and credentials is masked before it reaches an AI service.",
      "Productivity is preserved while enterprise policies, privacy controls, and evidence stay intact."
    ]
  },
  {
    title: "Internal AI Systems Protection",
    visualIn: "Quarterly forecast and customer list",
    visualOut: "Policy-safe business context",
    heading: "Secure internal AI systems without slowing teams down.",
    paragraphs: [
      "ARMOR AI-DLP applies data-aware controls inside approved enterprise AI systems, copilots, and private models so internal teams can keep using AI safely.",
      "Sensitive context is classified, masked, governed, and tracked across the full AI workflow."
    ]
  },
  {
    title: "AI App Data Redaction",
    visualIn: "Prompt + file attachment",
    visualOut: "Redacted prompt package",
    heading: "Redact sensitive data before AI applications process it.",
    paragraphs: [
      "Applications and agents can call ARMOR AI-DLP to sanitize prompts, files, and generated responses before they reach an LLM or downstream automation.",
      "The result is a privacy-preserving AI experience with policy proof for audits and investigations."
    ]
  },
  {
    title: "Data Sovereignty for AI",
    visualIn: "Regional customer record",
    visualOut: "Tokenized regional data",
    heading: "Keep regulated data protected across AI services and geographies.",
    paragraphs: [
      "ARMOR AI-DLP helps enforce sovereignty and privacy expectations by protecting regulated data before it travels into AI tools, models, or agents.",
      "Teams can adopt AI while retaining control of where real values are exposed, stored, and audited."
    ]
  }
];

const platformCards = [
  {
    title: "AI Privacy and Security",
    intro: "Sanitize data to intelligently redact sensitive information before it leaves the enterprise.",
    items: [
      ["PII", "Names, IDs, financial data, health data, and credential signals"],
      ["Company confidential", "Internal strategy, pricing, customer records, and source material"],
      ["IP and trade secrets", "Designs, product plans, formulas, and proprietary research"],
      ["M&A patterns", "Signals, documents, and negotiation artifacts tied to sensitive corporate actions"]
    ]
  },
  {
    title: "AI Governance",
    intro: "Classify AI interactions by request context, user intent, risk level, and enterprise policy.",
    items: [
      ["Prompt risk", "Detect unsafe requests, sensitive context, and risky intent"],
      ["User, team, and role", "Apply controls based on identity, group, location, and posture"],
      ["Policy applied", "Route, redact, block, or preserve activity with evidence"],
      ["AI mode", "Support approved copilots, private AI, and public AI usage"]
    ]
  }
];

const steps = [
  ["01", "Detect", "Sensitive values, private context, and regulated data are identified in prompts, responses, and attachments."],
  ["02", "Mask", "Sensitive elements are replaced with privacy-preserving tokens before AI systems process them."],
  ["03", "Govern", "Every interaction is mapped to policy, user role, application, and AI usage mode."],
  ["04", "Enable", "Approved AI usage continues with protected data, audit evidence, and enterprise controls."]
];

const deploymentCards = [
  {
    title: "ARMOR AI-DLP Portal",
    badge: "Web chat protection",
    text: "Deploy quickly to protect users as they work with public, private, and enterprise AI assistants.",
    bullets: ["Prompt and response masking", "Policy-aware controls", "Audit-ready AI activity", "No endpoint disruption"]
  },
  {
    title: "ARMOR AI-DLP (API)",
    badge: "Embedded AI protection",
    text: "Integrate protection directly into AI applications, agents, copilots, and internal automation flows.",
    bullets: ["Context-rich inspection", "Low-latency redaction", "Custom policy integration", "Secure LLM and agent adoption"]
  }
];

const industries = [
  {
    title: "Healthcare",
    icon: "healthcare",
    text: "Protect patient data, billing details, clinical notes, and provider information before AI interactions."
  },
  {
    title: "Financial Services",
    icon: "financial",
    text: "Safeguard account data, transaction signals, customer records, and analyst workflows."
  },
  {
    title: "Government",
    icon: "government",
    text: "Control citizen data, mission-sensitive documents, and regulated public-sector information."
  },
  {
    title: "Insurance",
    icon: "insurance",
    text: "Protect claims, policyholder information, underwriting data, and agent workflows."
  },
  {
    title: "B2B SaaS",
    icon: "saas",
    text: "Secure customer data, product telemetry, support context, and collaboration workflows."
  }
];

const industryIcons = {
  healthcare:
    '<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M24 40s-14-7.6-14-19a8 8 0 0 1 14-5.3A8 8 0 0 1 38 21c0 11.4-14 19-14 19Z"/><path d="M24 17v12M18 23h12"/></svg>',
  financial:
    '<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M8 19 24 9l16 10"/><path d="M12 20h24v18H12z"/><path d="M17 24v10M24 24v10M31 24v10"/><path d="M9 38h30"/></svg>',
  government:
    '<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M24 8 8 18h32L24 8Z"/><path d="M12 20v16M20 20v16M28 20v16M36 20v16"/><path d="M9 38h30"/></svg>',
  insurance:
    '<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M24 8 10 14v10c0 9 5.8 14 14 18 8.2-4 14-9 14-18V14L24 8Z"/><path d="M18 25h12M24 19v12"/></svg>',
  saas:
    '<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M15 32h20a8 8 0 0 0 0-16 10 10 0 0 0-19-2 9 9 0 0 0-1 18Z"/><path d="M17 32v5h14M24 32v5"/></svg>'
};

const compliance = [
  ["HIPAA", "Mask and govern protected health information in AI-assisted workflows."],
  ["GDPR", "Protect personal data before it reaches public, private, or embedded AI systems."],
  ["DPDP Act 2023", "Support consent-aware handling and data minimization for personal information."],
  ["PDPL", "Preserve privacy controls for regulated regional data interactions."],
  ["CCPA / CPRA", "Detect and protect consumer data inside prompt and response flows."]
];

const platformRows = [
  ["Discover", "Identify and classify sensitive data in real time as it enters AI interaction flows."],
  ["Context", "Understand enterprise context, user role, request purpose, and policy posture."],
  ["Enforce", "Mask, redact, block, or allow actions according to deterministic enterprise controls."],
  ["Prove", "Maintain evidence, reporting, and audit detail for AI data governance."]
];
---

<BaseLayout
  title="ARMOR AI-DLP | seclore"
  description="ARMOR AI-DLP protects sensitive enterprise data in AI prompts, responses, copilots, agents, and applications."
>
  <main id="top" class="aidlp-page">
    <Nav />

    <section class="aidlp-hero">
      <div class="hero-copy">
        <span class="eyebrow">ARMOR AI-DLP | New Generation DLP for AI</span>
        <h1>Enable AI Safely<br />Embrace AI Freely.</h1>
        <p>
          Safely adopt AI without losing control of sensitive data. ARMOR AI-DLP protects
          interactions across prompts, responses, copilots, agents, and AI applications.
        </p>
        <a class="primary-button" href="#demo">Book a Demo</a>
      </div>
      <div class="hero-visual-stack">
        <section class="trust-strip hero-trust">
          <p>Trusted by industry leading enterprises</p>
          <div class="logo-row" aria-label="Customer trust examples">
            <div class="logo-track">
              <div class="logo-group">
                <span>MANULIFE</span>
                <span>MAHINDRA</span>
                <span>BMO</span>
                <span>American Express</span>
                <span>Adani</span>
                <span>STC</span>
                <span>Skyworks</span>
                <span>QIB</span>
              </div>
              <div class="logo-group" aria-hidden="true">
                <span>MANULIFE</span>
                <span>MAHINDRA</span>
                <span>BMO</span>
                <span>American Express</span>
                <span>Adani</span>
                <span>STC</span>
                <span>Skyworks</span>
                <span>QIB</span>
              </div>
            </div>
          </div>
        </section>

        <div class="ai-dlp-diagram" aria-label="ARMOR AI-DLP masking flow">
        <div class="diagram-lane enterprise-lane">
          <span class="diagram-title">Enterprise Environment</span>
          <div class="source-card">
            <span class="source-icon">AI</span>
            <strong>Employee<br />using AI Model</strong>
          </div>
          <div class="source-card">
            <span class="source-icon">APP</span>
            <strong>Internal AI<br />Application</strong>
          </div>
          <div class="source-card">
            <span class="source-icon">RAG</span>
            <strong>RAG<br />Knowledge Base</strong>
          </div>
          <div class="source-card">
            <span class="source-icon">AGT</span>
            <strong>AI Agent</strong>
          </div>
        </div>

        <div class="flow-line in-line" aria-hidden="true"></div>

        <div class="armor-node">
          <div>
            <strong>ARMOR</strong>
            <span>AI DLP</span>
          </div>
          <i class="shield-mark" aria-hidden="true"></i>
        </div>

        <div class="flow-line out-line" aria-hidden="true"></div>

        <div class="diagram-lane masked-lane">
          <span class="diagram-title">Masked Data</span>
          <span class="token-card">[TOKENIZED_SSN]</span>
          <span class="token-card">[TOKENIZED_EMAIL]</span>
          <span class="token-card">[TOKENIZED_RECORD]</span>
          <span class="token-card">[TOKENIZED_QUERY]</span>
          <span class="secure-badge">Real values secured</span>
        </div>

        <div class="diagram-lane models-lane">
          <span class="diagram-title">AI Models</span>
          <div class="model-card">
            <span class="model-icon">LLM</span>
            <strong>Public LLM</strong>
          </div>
          <div class="model-card">
            <span class="model-icon">BOT</span>
            <strong>AI Agent</strong>
          </div>
        </div>
      </div>
      </div>
    </section>

    <style is:inline>
      .aidlp-page .trust-strip .logo-row {
        display: block;
        margin-top: 18px;
        overflow: hidden;
        width: 100%;
      }

      .aidlp-page .trust-strip .logo-track {
        align-items: center;
        animation: aidlpLogoMarquee 26s linear infinite;
        display: flex;
        width: max-content;
        will-change: transform;
      }

      .aidlp-page .trust-strip .logo-group {
        align-items: center;
        display: flex;
        flex-shrink: 0;
        gap: clamp(44px, 7vw, 88px);
        padding-right: clamp(44px, 7vw, 88px);
      }

      .aidlp-page .trust-strip .logo-row span {
        display: inline-flex;
        font-size: clamp(1rem, 1.6vw, 1.28rem);
        line-height: 1;
        white-space: nowrap;
      }

      @keyframes aidlpLogoMarquee {
        from { transform: translateX(0); }
        to { transform: translateX(-50%); }
      }
    </style>

    <section class="interactions-section">
      <div class="section-heading centered">
        <h2>Built for the Interactions That Matter Most.</h2>
      </div>
      <div class="interaction-tabs" aria-label="AI-DLP interaction modes">
        {interactionModes.map((item, index) => (
          <button
            type="button"
            class={index === 0 ? "active" : ""}
            aria-selected={index === 0 ? "true" : "false"}
            data-tab-index={index}
          >
            {item.title}
          </button>
        ))}
      </div>
      <div class="interaction-panel">
        <div class="chat-visual" aria-hidden="true">
          <div class="chat-bubble user" data-interaction-input>{interactionModes[0].visualIn}</div>
          <div class="shield-node">AI-DLP</div>
          <div class="chat-bubble safe" data-interaction-output>{interactionModes[0].visualOut}</div>
        </div>
        <div class="interaction-copy">
          <span class="interaction-kicker" data-interaction-kicker>{interactionModes[0].title}</span>
          <h3 data-interaction-heading>{interactionModes[0].heading}</h3>
          {interactionModes[0].paragraphs.map((paragraph) => (
            <p data-interaction-paragraph>{paragraph}</p>
          ))}
        </div>
      </div>
    </section>

    <script define:vars={{ interactionModes }}>
      const tabButtons = Array.from(document.querySelectorAll("[data-tab-index]"));
      const inputBubble = document.querySelector("[data-interaction-input]");
      const outputBubble = document.querySelector("[data-interaction-output]");
      const kicker = document.querySelector("[data-interaction-kicker]");
      const heading = document.querySelector("[data-interaction-heading]");
      const paragraphNodes = Array.from(document.querySelectorAll("[data-interaction-paragraph]"));

      tabButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const mode = interactionModes[Number(button.dataset.tabIndex)] || interactionModes[0];

          tabButtons.forEach((item) => {
            const isActive = item === button;
            item.classList.toggle("active", isActive);
            item.setAttribute("aria-selected", String(isActive));
          });

          if (inputBubble) inputBubble.textContent = mode.visualIn;
          if (outputBubble) outputBubble.textContent = mode.visualOut;
          if (kicker) kicker.textContent = mode.title;
          if (heading) heading.textContent = mode.heading;
          paragraphNodes.forEach((paragraph, index) => {
            paragraph.textContent = mode.paragraphs[index] || "";
          });
        });
      });
    </script>

    <section class="outcomes-section">
      <div class="section-heading centered">
        <h2>Two Outcomes. One Protection Layer.</h2>
        <p>
          ARMOR AI-DLP delivers AI privacy and AI governance in a single platform.
        </p>
      </div>
      <div class="outcome-grid">
        {platformCards.map((card) => (
          <article class="outcome-card">
            <h3>{card.title}</h3>
            <p>{card.intro}</p>
            <div class="mini-table">
              {card.items.map(([label, text]) => (
                <div>
                  <strong>{label}</strong>
                  <span>{text}</span>
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="next-gen-section">
      <div class="section-heading centered">
        <span class="eyebrow">What ARMOR AI-DLP is</span>
        <h2>A Next-Generation DLP, Built for the AI Interaction Layer.</h2>
      </div>
      <div class="next-gen-grid">
        <figure class="next-gen-visual" aria-label="ARMOR AI-DLP interaction layer preview">
          <img
            src="/images/armor/aidlp-next-gen-visual.png"
            alt="ARMOR AI-DLP AI interaction layer dashboard"
            loading="lazy"
            decoding="async"
          />
        </figure>
        <div>
          <h3>ARMOR AI-DLP enables safe AI use without blocking it.</h3>
          <p>
            Safely enabling AI means protecting prompts, responses, and under-your-control context
            before data enters AI systems.
          </p>
          <p>
            Unlike traditional DLP, ARMOR AI-DLP understands interaction context, applies policy at
            the AI layer, and keeps business teams moving.
          </p>
          <p>
            Your data stays private, controlled, and auditable without forcing teams to abandon the
            tools they already use.
          </p>
        </div>
      </div>
    </section>

    <section class="works-section">
      <div class="section-heading centered">
        <h2>How It Works</h2>
        <p>
          Sensitive information is identified, masked, governed, and enabled across every AI
          interaction.
        </p>
      </div>
      <div class="step-grid">
        {steps.map(([number, title, text]) => (
          <article class="step-card">
            <span>{number}</span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="deploy-section">
      <div class="section-heading centered">
        <h2>Two Ways to Deploy. One Protection Standard.</h2>
        <p>Same AI-directional masking engine. Same governance-grade reporting.</p>
      </div>
      <div class="deploy-grid">
        {deploymentCards.map((card) => (
          <article class="deploy-card">
            <span class="deploy-badge">{card.badge}</span>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
            <ul>
              {card.bullets.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="industry-section">
      <div class="section-heading centered">
        <h2>Built for Organizations Where Data Governance Is Not Optional.</h2>
      </div>
      <div class="industry-grid">
        {industries.map((industry) => (
          <article class="industry-card">
            <div class={`small-icon industry-icon ${industry.icon}`} set:html={industryIcons[industry.icon]}></div>
            <h3>{industry.title}</h3>
            <p>{industry.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="compliance-section">
      <div class="section-heading centered">
        <h2>Compliance Built In. Not Bolted On.</h2>
        <p>
          ARMOR AI-DLP addresses data masking and privacy requirements across major global
          regulations.
        </p>
      </div>
      <div class="compliance-grid">
        {compliance.map(([title, text]) => (
          <article>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="demo-band" id="demo">
      <div class="demo-copy">
        <h2>A New DLP for AI. See It in Action.</h2>
        <p>
          See how ARMOR AI-DLP helps enterprises safely adopt AI without losing control of sensitive
          data.
        </p>
      </div>
      <form class="aidlp-form" data-endpoint="/api/demo">
        <h3>ARMOR AI-DLP Demo</h3>
        <label>Email<input name="email" type="email" required /></label>
        <label>First Name<input name="name" required minlength="2" /></label>
        <label>Company Name<input name="company" required /></label>
        <label>Job Title<input name="role" /></label>
        <label>Phone Number<input name="phone" /></label>
        <label>Comments<textarea name="message" rows="4"></textarea></label>
        <button class="primary-button" type="submit">Schedule a Demo</button>
        <p class="form-status" role="status" aria-live="polite"></p>
      </form>
    </section>

    <section class="platform-section">
      <div class="section-heading centered">
        <h2>Part of the ARMOR Platform.</h2>
        <p>
          ARMOR AI-DLP is Seclore's entry point for protecting AI prompts, responses, and generated
          content. It works with the interaction layer between enterprise data and AI models.
        </p>
      </div>
      <div class="platform-table">
        {platformRows.map(([label, text]) => (
          <div>
            <strong>{label}</strong>
            <span>{text}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="final-cta">
      <h2>Enable Safe AI Usage Across Your Enterprise.</h2>
      <p>
        See how ARMOR AI-DLP delivers AI adoption and data protection. Book a 30-minute demo with
        the team.
      </p>
      <a class="primary-button" href="#demo">Request a Demo of ARMOR AI-DLP</a>
    </section>
  </main>

  <script is:inline define:vars={{ apiBase }}>
    document.querySelectorAll(".aidlp-form").forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const status = form.querySelector(".form-status");
        const button = form.querySelector("button[type='submit']");
        const payload = Object.fromEntries(new FormData(form).entries());

        status.textContent = "Sending...";
        status.className = "form-status";
        button.disabled = true;

        try {
          const response = await fetch(`${apiBase}${form.dataset.endpoint}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });
          const data = await response.json();
          if (!response.ok) throw new Error(data.message || "Request failed.");
          form.reset();
          status.textContent = data.message || "Submitted successfully.";
          status.classList.add("success");
        } catch (error) {
          status.textContent = error.message || "Something went wrong.";
          status.classList.add("error");
        } finally {
          button.disabled = false;
        }
      });
    });
  </script>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #ffffff;
    --page-text: #202020;
    --page-muted: #5f6670;
    --purple: #5630d6;
    --purple-dark: #4321b4;
    --violet-soft: #f7f7fb;
    --aqua: #16b8a6;
    --amber: #ffb84d;
    --rose: #e85a8a;
    --card: #ffffff;
    --line: rgba(91, 43, 215, 0.16);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: none;
    --header-text: #27242b;
    --header-muted: #27242b;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #4f2bd6;
    --demo-button-text: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  html[data-theme="dark"] {
    color-scheme: dark;
    --page-bg: #07111f;
    --page-text: #f4f0ff;
    --page-muted: #c9bedb;
    --violet-soft: #141026;
    --card: #11192a;
    --line: rgba(177, 145, 255, 0.24);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: none;
    --header-text: #27242b;
    --header-muted: #27242b;
    --dropdown-bg: linear-gradient(135deg, rgba(9, 25, 44, 0.98), rgba(5, 17, 31, 0.98));
    --dropdown-grid-line: rgba(45, 212, 255, 0.045);
    --dropdown-border: rgba(151, 190, 230, 0.18);
    --dropdown-link-hover: rgba(255, 255, 255, 0.055);
    --dropdown-link-border: rgba(45, 212, 255, 0.22);
    --dropdown-title: #7cf6c7;
    --dropdown-text: #edf7ff;
    --dropdown-muted: #9eb5ca;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(45, 212, 255, 0.18), rgba(124, 246, 199, 0.08)), rgba(255, 255, 255, 0.045);
    --dropdown-feature-border: rgba(45, 212, 255, 0.22);
    --demo-button-bg: #ffffff;
    --demo-button-text: #07111f;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: #ffffff;
    color: #202020;
  }

  .aidlp-page {
    --page-bg: #ffffff;
    --page-text: #202020;
    --page-muted: #5f6670;
    --purple: #5630d6;
    --purple-dark: #4321b4;
    --violet-soft: #f7f7fb;
    --card: #ffffff;
    --line: rgba(15, 23, 42, 0.1);
    background: #ffffff;
    color: #202020;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  .site-header {
    align-items: center;
    background: #ffffff;
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: block;
    min-height: 166px;
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
