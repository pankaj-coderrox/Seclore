---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL || (import.meta.env.DEV ? "http://127.0.0.1:5000" : "");

const meaningCards = [
  {
    title: "Communicate Risk in Business Terms",
    text: "Connect sensitive data findings to owners, workflows, behavior, and exposure so leaders see risk in the language of the business.",
    bullets: ["Faster remediation decisions", "Board-ready reporting", "Less time explaining, more time acting"]
  },
  {
    title: "Enforce Compliance and Prove It",
    text: "Turn reporting into evidence. ARMOR DSPM generates controls, audit trails, and regulator-ready proof while work continues.",
    bullets: ["Controls enforced automatically", "Evidence generated continuously", "Regulator-ready by default"]
  }
];

const generations = [
  ["Gen 1", "Pattern Matching", "Finds known patterns, but often creates noisy alerts without context."],
  ["Gen 2", "Trainable Classifiers", "Learns from examples, yet still needs long tuning cycles and manual review."],
  ["Gen 3", "LLM-Based", "Adds semantic context, but can leave remediation disconnected from controls."],
  ["ARMOR DSPM", "Intelligent DSPM", "Unifies discovery, context, policy, and proof through sovereign-ready protection flows."]
];

const layers = [
  ["Layer 1: Data Context", "Understands what the data is, what it means, and whether it contains sensitive or regulated information."],
  ["Layer 2: Enterprise Context", "Maps ownership, behavior, repositories, sharing paths, and business relevance into actionable risk."],
  ["Layer 3: Regulatory Context", "Identifies obligations across frameworks and converts compliance needs into enforceable controls."]
];

const benefits = [
  ["Intelligent Discovery", "ARMOR DSPM derives context and intent from enterprise data, not only patterns."],
  ["Sovereign-Ready Architecture", "Data remains under enterprise control while intelligence and policy decisions stay local."],
  ["From Diagnosis to Cure", "Discovery connects directly to classification, protection, masking, and audit evidence."],
  ["Zero-Configuration Value", "Start with AI-native classification and risk insight without long training projects."]
];

const steps = [
  ["01", "Detect", "Continuously ingest data across repositories and identify sensitive content with semantic context."],
  ["02", "Contextualize", "Connect data meaning to business ownership, sharing behavior, and regulatory obligations."],
  ["03", "Enforce", "Trigger classification, data-aware controls, masking, and persistent protection automatically."],
  ["04", "Prove", "Create evidence that shows who accessed what, when, why, and how policy responded."]
];

const useCases = [
  ["Data Risk Intelligence", "Maintain a continuous view of sensitive data exposure and translate signals into business risk."],
  ["AI Readiness and Governance", "Understand data before it reaches AI systems, agents, copilots, or model workflows."],
  ["Regulatory Compliance at Scale", "Identify obligations, prioritize regulated data, and generate proof across jurisdictions."],
  ["Establish Data Ownership", "Give data owners context-rich insight into meaning, usage, sensitivity, and action."]
];
---

<BaseLayout title="ARMOR DSPM | seclore">
  <main id="top" class="dspm-page">
    <Nav />

    <section class="dspm-hero">
      <div class="hero-copy">
        <span class="brand-kicker">ARMOR DSPM</span>
        <h1>Turn Risk into Readiness</h1>
        <p>
          Intelligent DSPM for the AI era. Understand what your data is, why it matters, and
          whether it is compliant, then classify, protect, and prove it.
        </p>
        <a class="primary-button" href="#demo">Get a Demo</a>
      </div>
      <figure class="dashboard-shell image-shell" aria-label="ARMOR DSPM dashboard preview">
        <img src="/images/armor/armor-dashboard.png" alt="ARMOR data security intelligence preview" loading="eager" decoding="async" />
      </figure>
    </section>

    <section class="soft-section">
      <div class="section-heading">
        <h2>What ARMOR DSPM Means for Your Organization</h2>
      </div>
      <div class="meaning-grid">
        {meaningCards.map((card) => (
          <article class="meaning-card">
            <div class="icon-box"><img src="/images/armor/seclore-armor-logo.png" alt="" loading="lazy" decoding="async" /></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
            <ul>
              {card.bullets.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="split-section">
      <div class="section-heading centered">
        <h2>Intelligent DSPM for the AI Enterprise</h2>
      </div>
      <div class="split-grid">
        <div class="ai-visual">
          <img src="/images/armor/armor-card-visual.png" alt="ARMOR powered by Seclore intelligence card" loading="lazy" decoding="async" />
        </div>
        <div>
          <h3>AI is rewriting the rules</h3>
          <p>
            Legacy discovery tools can list files, but AI-driven enterprises need live context:
            ownership, intent, exposure, compliance obligation, and the controls required to act.
          </p>
          <p>
            ARMOR DSPM connects discovery to protection so security leaders can move from signal to
            decision to proof without stitching together disconnected tools.
          </p>
          <p class="flow-line">Discover &gt; Contextualize &gt; Enforce &gt; Prove</p>
        </div>
      </div>
    </section>

    <section class="generation-section">
      <div class="section-heading centered">
        <h2>Three Generations of DSPM</h2>
        <p>ARMOR DSPM operates across multiple layers of context simultaneously.</p>
      </div>
      <div class="generation-grid">
        {generations.map(([label, title, text]) => (
          <article class={label === "ARMOR DSPM" ? "generation-card current" : "generation-card"}>
            <span>{label}</span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="layers-section">
      <div class="section-heading centered purple-title">
        <h2>Three Layers of Intelligence. One Automated Action.</h2>
      </div>
      <div class="layer-grid">
        {layers.map(([title, text]) => (
          <article class="layer-card">
            <div class="small-icon"><img src="/images/armor/seclore-armor-logo.png" alt="" loading="lazy" decoding="async" /></div>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="split-section continuous">
      <div>
        <h2>Purpose-Built for Continuous Data Intelligence</h2>
        <p>
          ARMOR DSPM establishes a living understanding of sensitive data that changes as files
          move, users collaborate, labels evolve, and business context shifts.
        </p>
        <p>
          This continuous intelligence feeds context-aware classification, AI controls, governance,
          and audit readiness.
        </p>
      </div>
      <figure class="dashboard-shell compact image-shell" aria-label="Data intelligence table preview">
        <img src="/images/armor/armor-data-repository.png" alt="ARMOR data repository risk visualization" loading="lazy" decoding="async" />
      </figure>
    </section>

    <section class="text-section">
      <h2>Beyond Traditional DSPM</h2>
      <p>
        ARMOR DSPM transforms discovery from detection into protection that leads to security
        intelligence. It does more than count files or raise alerts; it translates data signals into
        business risk, regulatory impact, and immediate remediation paths.
      </p>
      <ul>
        <li>Continuously ingests data across the enterprise</li>
        <li>Analyzes content and context through AI-native classification</li>
        <li>Connects sensitivity, business relevance, and regulation</li>
        <li>Enables remediation through classification, protection, and compliance controls</li>
      </ul>
    </section>

    <section class="compare-section">
      <div class="section-heading centered">
        <h2>Why ARMOR DSPM</h2>
        <p>Where earlier discovery stops, ARMOR continues.</p>
      </div>
      <div class="comparison-table">
        <div class="table-head">Gen 1-3 DSPMs</div>
        <div class="table-head armor">ARMOR DSPM</div>
        <div>File classification without context</div><div>Three-layer intelligence: data, enterprise, and regulatory context</div>
        <div>Static scans or months of training</div><div>AI-native classification from day one</div>
        <div>Cloud-only processing assumptions</div><div>Sovereign-ready data control</div>
        <div>Alert-only discovery</div><div>Closed-loop discover, contextualize, enforce, prove</div>
        <div>File counts and alert volumes</div><div>Business risk signals leaders can act on</div>
      </div>
    </section>

    <section class="benefits-section">
      <div class="section-heading centered">
        <h2>Key Benefits</h2>
      </div>
      <div class="benefit-grid">
        {benefits.map(([title, text]) => (
          <article class="benefit-card">
            <div class="small-icon"><img src="/images/armor/seclore-armor-logo.png" alt="" loading="lazy" decoding="async" /></div>
            <h3>{title}</h3>
            <strong>{title === "From Diagnosis to Cure" ? "Visibility is not control." : title === "Zero-Configuration Value" ? "Install. Connect. Protect." : title === "Sovereign-Ready Architecture" ? "Private and sovereign-first DSPM." : "Intelligence starts here."}</strong>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="works-section">
      <div class="section-heading centered">
        <h2>How ARMOR DSPM Works</h2>
        <p>Protection begins at discovery.</p>
      </div>
      <div class="step-grid">
        {steps.map(([number, title, text]) => (
          <article class="step-card">
            <div class="small-icon"><img src="/images/armor/seclore-armor-logo.png" alt="" loading="lazy" decoding="async" /></div>
            <span>{number}</span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="demo-band" id="demo">
      <div class="demo-copy">
        <h2>Move Beyond Discovery. Establish Data Intelligence.</h2>
        <p>See how AI discovery helps organizations understand, prioritize, and control sensitive data in AI environments.</p>
      </div>
      <form class="dspm-form" data-endpoint="/api/demo">
        <h3>Seclore Demo</h3>
        <label>Email<input name="email" type="email" required /></label>
        <label>First Name<input name="name" required minlength="2" /></label>
        <label>Company Name<input name="company" required /></label>
        <label>Job Title<input name="role" /></label>
        <label>Phone Number<input name="phone" /></label>
        <label>Comments<textarea name="message" rows="4"></textarea></label>
        <button class="primary-button" type="submit">Schedule A Demo</button>
        <p class="form-status" role="status" aria-live="polite"></p>
      </form>
    </section>

    <section class="use-section">
      <div class="section-heading centered">
        <h2>Use Cases</h2>
      </div>
      <div class="use-grid">
        {useCases.map(([title, text]) => (
          <article class="use-card">
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="final-cta">
      <h2>Move Beyond Discovery. Establish Data Security Intelligence.</h2>
      <p>See how ARMOR DSPM turns data signals into business risk, regulatory action, and proof across the board.</p>
      <a class="primary-button" href="#demo">Request a Demo of ARMOR DSPM</a>
    </section>
  </main>

  <script is:inline define:vars={{ apiBase }}>
    document.querySelectorAll(".dspm-form").forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const status = form.querySelector(".form-status");
        const button = form.querySelector("button[type='submit']");
        const payload = Object.fromEntries(new FormData(form).entries());

        status.textContent = "Sending...";
        status.className = "form-status";
        button.disabled = true;

        try {
          const response = await fetch(`${apiBase}${form.dataset.endpoint}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });
          const data = await response.json();
          if (!response.ok) throw new Error(data.message || "Request failed.");
          form.reset();
          status.textContent = data.message || "Submitted successfully.";
          status.classList.add("success");
        } catch (error) {
          status.textContent = error.message || "Something went wrong.";
          status.classList.add("error");
        } finally {
          button.disabled = false;
        }
      });
    });
  </script>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #ffffff;
    --page-text: #202020;
    --page-muted: #5f6670;
    --purple: #5630d6;
    --purple-dark: #4321b4;
    --lavender: #f7f7fb;
    --card: #ffffff;
    --line: rgba(91, 43, 215, 0.16);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: none;
    --header-text: #27242b;
    --header-muted: #27242b;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #4f2bd6;
    --demo-button-text: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  html[data-theme="dark"] {
    --page-bg: #08111f;
    --page-text: #f4f0ff;
    --page-muted: #c9bedb;
    --lavender: #141026;
    --card: #11192a;
    --line: rgba(177, 145, 255, 0.24);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: none;
    --header-text: #27242b;
    --header-muted: #27242b;
    --dropdown-bg: linear-gradient(135deg, rgba(9, 25, 44, 0.98), rgba(5, 17, 31, 0.98));
    --dropdown-grid-line: rgba(45, 212, 255, 0.045);
    --dropdown-border: rgba(151, 190, 230, 0.18);
    --dropdown-link-hover: rgba(255, 255, 255, 0.055);
    --dropdown-link-border: rgba(45, 212, 255, 0.22);
    --dropdown-title: #7cf6c7;
    --dropdown-text: #edf7ff;
    --dropdown-muted: #9eb5ca;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(45, 212, 255, 0.18), rgba(124, 246, 199, 0.08)), rgba(255, 255, 255, 0.045);
    --dropdown-feature-border: rgba(45, 212, 255, 0.22);
    --demo-button-bg: #ffffff;
    --demo-button-text: #07111f;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: #ffffff;
    color: #202020;
  }

  .dspm-page {
    --page-bg: #ffffff;
    --page-text: #202020;
    --page-muted: #5f6670;
    --purple: #5630d6;
    --purple-dark: #4321b4;
    --lavender: #f7f7fb;
    --card: #ffffff;
    --line: rgba(15, 23, 42, 0.1);
    background: #ffffff;
    color: #202020;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  .site-header {
    align-items: center;
    background: #ffffff;
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: block;
    min-height: 166px;
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    font-size: clamp(1.55rem, 2.1vw, 2rem);
    font-weight: 950;
    letter-spacing: 0.06em;
    line-height: 1;
    margin: 0;
    position: absolute;
    left: clamp(54px, 6vw, 112px);
    top: 80px;
    text-transform: uppercase;
  }

  .site-logo::after {
    content: "™";
    font-size: 0.28em;
    margin-left: 2px;
    vertical-align: top;
  }

  .nav-links,
  .nav-utilities {
    align-items: center;
    display: flex;
  }

  .nav-links {
    display: flex;
    flex: 1 1 auto;
    gap: clamp(28px, 3.5vw, 54px);
    justify-content: center;
    left: clamp(340px, 23vw, 430px);
    min-width: 0;
    position: absolute;
    right: clamp(380px, 23vw, 430px);
    top: 65px;
  }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: clamp(1rem, 1.1vw, 1.25rem);
    font-weight: 800;
    gap: 12px;
    min-height: 54px;
    padding: 0;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:hover .nav-trigger,
  .nav-item:focus-within .nav-trigger {
    color: var(--header-text);
  }

  .nav-item {
    position: static;
  }

  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 10px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 10px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret {
    transform: rotate(225deg) translateY(-1px);
  }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .mega-column,
  .mega-sublinks {
    display: grid;
  }

  .mega-column {
    gap: 10px;
  }

  .mega-title {
    color: var(--dropdown-title);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mega-link,
  .mega-link-group {
    border: 1px solid transparent;
    border-radius: 8px;
  }

  .mega-link {
    display: grid;
    gap: 5px;
    padding: 13px;
  }

  .mega-link strong {
    color: var(--dropdown-text);
  }

  .mega-link small,
  .mega-sublinks a {
    color: var(--dropdown-muted);
  }

  .mega-link:hover,
  .mega-link-group:hover {
    background: var(--dropdown-link-hover);
    border-color: var(--dropdown-link-border);
  }

  .mega-link-group {
    display: grid;
    gap: 4px;
    padding: 4px;
  }

  .mega-sublinks {
    gap: 2px;
    padding: 0 9px 8px 22px;
  }

  .mega-sublinks a {
    font-size: 0.84rem;
    padding: 5px 0;
  }

  .mega-feature {
    align-content: end;
    background: var(--dropdown-feature-bg);
    border: 1px solid var(--dropdown-feature-border);
    border-radius: 8px;
    display: grid;
    min-height: 268px;
    padding: 24px;
  }

  .mega-feature span,
  .mega-feature em {
    color: var(--dropdown-title);
  }

  .mega-feature strong {
    color: var(--dropdown-text);
    font-size: 1.35rem;
    line-height: 1.18;
    margin-top: auto;
  }

  .nav-utilities {
    display: contents;
    flex: 0 0 auto;
    margin-left: 0;
  }

  .utility-link,
  .utility-label,
  .language-button,
  .utility-icon,
  .theme-toggle {
    color: var(--header-muted);
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
  }

  .utility-link {
    position: absolute;
    right: clamp(382px, 21.5vw, 405px);
    top: 14px;
    white-space: nowrap;
  }

  .utility-label {
    display: inline-flex;
    position: absolute;
    top: 14px;
  }

  .utility-label:nth-of-type(1) {
    right: clamp(282px, 15vw, 300px);
  }

  .utility-label:nth-of-type(2) {
    right: clamp(132px, 7.2vw, 142px);
  }

  .utility-icon,
  .language-button {
    align-items: center;
    background: transparent;
    border: 0;
    cursor: pointer;
    display: inline-flex;
    gap: 8px;
    padding: 0;
  }

  .utility-icon {
    position: absolute;
    right: clamp(240px, 12.7vw, 255px);
    top: 10px;
  }

  .language-button {
    position: absolute;
    right: clamp(78px, 4.2vw, 86px);
    top: 9px;
  }

  .theme-toggle {
    display: none;
  }

  .search-icon {
    border: 2px solid currentColor;
    border-radius: 50%;
    display: inline-block;
    height: 22px;
    position: relative;
    width: 22px;
  }

  .search-icon::after {
    background: currentColor;
    content: "";
    height: 2px;
    position: absolute;
    right: -8px;
    top: 16px;
    transform: rotate(45deg);
    width: 10px;
  }

  .globe-icon {
    border: 2px solid currentColor;
    border-radius: 50%;
    display: inline-block;
    height: 26px;
    position: relative;
    width: 26px;
  }

  .globe-icon::before,
  .globe-icon::after {
    content: "";
    left: 50%;
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  .globe-icon::before {
    border-left: 2px solid currentColor;
    border-right: 2px solid currentColor;
    border-radius: 50%;
    height: 22px;
    width: 10px;
  }

  .globe-icon::after {
    border-bottom: 2px solid currentColor;
    border-top: 2px solid currentColor;
    height: 9px;
    width: 22px;
  }

  .demo-button,
  .primary-button {
    align-items: center;
    background: #5531d1;
    border: 0;
    border-radius: 7px;
    color: #ffffff;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.94rem;
    font-weight: 700;
    justify-content: center;
    line-height: 1.15;
    min-height: 42px;
    padding: 0 22px;
    text-decoration: none;
    white-space: nowrap;
  }

  .dspm-page .hero-copy > .primary-button,
  .dspm-page .dspm-form > .primary-button,
  .dspm-page .final-cta > .primary-button {
    border-radius: 7px !important;
    min-height: 42px !important;
    padding: 0 22px !important;
    width: auto !important;
  }

  .demo-button {
    min-width: 190px;
    position: absolute;
    right: clamp(54px, 6.8vw, 128px);
    top: 66px;
  }

  .nav-toggle {
    background: transparent;
