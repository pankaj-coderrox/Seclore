---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL || (import.meta.env.DEV ? "http://127.0.0.1:5000" : "");

const trustLogos = ["Available", "General Dynamics", "Boeing", "FLEX", "AeroStar"];

const managementCards = [
  {
    title: "Identify and classify sensitive data",
    text: "Identify digital assets that contain intellectual property, sensitive business data, or confidential information and label them accordingly."
  },
  {
    title: "Apply the right level of protection",
    text: "Knowing which assets are sensitive and where they are helps organizations apply appropriate protection such as encryption, watermarking, EDRM, and tracking."
  },
  {
    title: "Visibility and control for your data",
    text: "Track activity information for anyone who accesses, shares, or modifies protected digital assets, and revoke access at any time."
  }
];

const mitigations = [
  ["Visual labels and dynamic watermarking", "Add a highly visible icon marker, header, footer, and dynamic watermark to classified assets to encourage proper handling of sensitive, private, or classified data."],
  ["Data encryption and EDRM", "Digital assets can be encrypted at rest, in transit, and in use with AES-256 encryption. Information owners can also edit access and usage rules to limit access to specific authorized users only."],
  ["Access and usage policies", "Limit access to specific users, groups, and locations, and prevent certain activities like printing, saving a copy, downloading, or copying text from a digital asset."],
  ["APIs and SDKs", "Seclore REST APIs and SDKs help enterprises achieve security at scale through integration with protection, policy enforcement, and permission management."],
  ["Audit trail and activity reporting", "Track and analyze internal or external user activity to identify risks, detect patterns, and generate audit-compliant reports."],
  ["Real-time revocation", "See user access for protected digital assets and revoke it at any time, after a false positive or when an internally revoked access is required."]
];

const relatedProducts = [
  {
    title: "Digital Asset Classification",
    text: "Classify digital assets based on their sensitivity, confidentiality, compliance, or regulatory requirements and automatically apply the right level of protection."
  },
  {
    title: "Enterprise Digital Rights Management",
    text: "Encrypt digital assets, limit access to groups or individuals, allow or deny specific actions, track usage, and revoke access at any time."
  }
];

const resources = [
  {
    type: "Blog Post",
    tag: "Security",
    title: "Securing Digital Assets with Dynamic Watermarking: The Seclore Advantage",
    image: "/images/integrations/file-storage/file-flow.png",
    alt: "Protected file movement with access controls"
  },
  {
    type: "Case Study",
    tag: "Energy",
    title: "Fugro Survey",
    image: "/images/integrations/intro-meeting.png",
    alt: "Enterprise security team discussing insider risk controls"
  }
];
---

<BaseLayout
  title="Internal Threats | seclore"
  description="Seclore data-centric security for internal threat protection, sensitive data classification, access controls, and insider risk reduction."
>
  <main id="top" class="internal-page">
    <Nav />

    <section class="internal-hero">
      <div class="hero-copy">
        <span>Internal Threats</span>
        <h1>Protect Sensitive Data from Internal Threats</h1>
        <p>
          Insider threats are one of the biggest sources of data leakage for most enterprises. Seclore enables you to address
          accidental or malicious sharing of data by applying persistent classification, encryption, watermarking, and access
          controls to digital assets.
        </p>
        <a class="primary-button alert" href="#demo">Book a Demo</a>
      </div>
      <div class="document-visual" aria-label="Protected document review visual">
        <img src="/images/integrations/file-storage/file-flow.png" alt="Protected document workflow with access controls" loading="eager" />
      </div>
    </section>

    <section class="trust-strip">
      <h2>Trusted by industry-leading enterprises</h2>
      <div class="trust-row">
        {trustLogos.map((logo) => <span>{logo}</span>)}
      </div>
    </section>

    <section class="split-section leak-section">
      <div class="office-visual" aria-label="Office insider threat prevention visual">
        <img src="/images/integrations/intro-meeting.png" alt="Enterprise team reviewing insider threat prevention controls" />
      </div>
      <div>
        <h2>Prevent data leaks</h2>
        <p>
          Stop data leaks such as unauthorized or accidental sharing, human error, and malicious exfiltration by applying
          persistent access and usage controls to digital assets.
        </p>
        <p>
          Seclore enables organizations to retain complete visibility and control over sensitive and proprietary information
          that employees, contractors, and third parties have access to.
        </p>
        <div class="section-actions">
          <a class="primary-button dark" href="#resources">View Insider Threats</a>
          <a class="primary-button dark" href="#demo">Contact For Inc.</a>
        </div>
      </div>
    </section>

    <section class="management-section">
      <div class="section-heading centered">
        <h2>Responsibly manage your enterprise data</h2>
        <p>
          With Seclore, organizations can identify and tag all of their digital assets, and then protect files that contain
          sensitive or private information to prevent data loss from being leaked or accidentally overshared.
        </p>
      </div>
      <div class="card-grid three">
        {managementCards.map((card) => (
          <article class="feature-card">
            <div class="hex-icon"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="story-section">
      <article class="story-card">
        <span>Top cement manufacturer</span>
        <blockquote>
          "Seven divisions within the group of companies use a single SAP instance and store all sensitive IP with access
          control managed in SAP. Seclore's integration with SAP enabled us to enforce SAP's security on downloaded assets
          and prevent insiders from sharing this critical information with competition."
        </blockquote>
        <strong>SAP Security</strong>
        <a class="primary-button dark" href="#resources">Customer Story</a>
      </article>
    </section>

    <section class="demo-band" id="demo">
      <div class="demo-copy">
        <h2>Meet with a data-centric security expert</h2>
        <p>
          See our data-centric security platform in action, and learn how to protect and control your digital assets wherever
          they go.
        </p>
        <strong>Learn more about</strong>
        <ul>
          <li>Digital asset security for every user, device, app, and cloud</li>
          <li>Granular access, usage, and privacy controls</li>
          <li>Never losing control or visibility of your digital assets</li>
        </ul>
        <div class="demo-logos">
          <span>ITAR</span>
          <span>General Dynamics</span>
          <span>AeroStar</span>
        </div>
      </div>
      <form class="internal-form" data-endpoint="/api/demo">
        <h3>Seclore Demo</h3>
        <label>Email<input name="email" type="email" required /></label>
        <label>First Name<input name="name" required minlength="2" /></label>
        <label>Last Name<input name="lastName" /></label>
        <label>Company Name<input name="company" required /></label>
        <label>Job Title<input name="role" /></label>
        <label>Phone Number<input name="phone" /></label>
        <label>Country<select name="country"><option>Please Select</option><option>United States</option><option>India</option></select></label>
        <button class="primary-button" type="submit">Submit</button>
        <p class="form-status" role="status" aria-live="polite"></p>
      </form>
    </section>

    <section class="mitigation-section">
      <div class="section-heading centered">
        <h2>Mitigate internal threats</h2>
      </div>
      <div class="mitigation-grid">
        {mitigations.map(([title, text]) => (
          <article class="offering-card">
            <div class="line-icon"></div>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="related-section">
      <div class="section-heading centered">
        <h2>Data-centric security related products</h2>
        <p>
          Add a layer of cybersecurity and regulatory compliance controls at the data level to ensure protection is applied
          where it is needed most.
        </p>
      </div>
      <div class="related-products">
        {relatedProducts.map((item) => (
          <article class="related-product">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <a href="#demo">Learn More</a>
          </article>
        ))}
      </div>
    </section>

    <section class="resources-section" id="resources">
      <div class="section-heading centered">
        <h2>Internal data security threat resources</h2>
        <p>
          Seclore is a leading provider of data-centric security. Our solutions help to secure highly effective risk
          mitigation, preventing data breaches, and ensuring regulatory compliance.
        </p>
      </div>
      <div class="resource-grid">
        {resources.map((resource) => (
          <article class="resource-card">
            <figure>
              <img src={resource.image} alt={resource.alt} />
            </figure>
            <div>
              <span>{resource.type}</span>
              <em>{resource.tag}</em>
              <h3>{resource.title}</h3>
            </div>
            <a href="#demo">View More</a>
          </article>
        ))}
      </div>
      <div class="slide-controls" aria-label="Resource carousel controls">
        <button type="button" aria-label="Previous resource">&lt;</button>
        <button type="button" aria-label="Next resource">&gt;</button>
      </div>
    </section>
  </main>

  <script is:inline define:vars={{ apiBase }}>
    document.querySelectorAll(".internal-form").forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const status = form.querySelector(".form-status");
        const button = form.querySelector("button[type='submit']");
        const payload = Object.fromEntries(new FormData(form).entries());

        status.textContent = "Sending...";
        status.className = "form-status";
        button.disabled = true;

        try {
          const response = await fetch(`${apiBase}${form.dataset.endpoint}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });
          const data = await response.json();
          if (!response.ok) throw new Error(data.message || "Request failed.");
          form.reset();
          status.textContent = data.message || "Submitted successfully.";
          status.classList.add("success");
        } catch (error) {
          status.textContent = error.message || "Something went wrong.";
          status.classList.add("error");
        } finally {
          button.disabled = false;
        }
      });
    });
  </script>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f2f3f5;
    --page-text: #232128;
    --page-muted: #636773;
    --purple: #5b2bd7;
    --wine: #2b1024;
    --alert: #eb3157;
    --orange: #ff9500;
    --plum: #8d204e;
    --card: #ffffff;
    --line: rgba(29, 29, 34, 0.13);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #5b2bd7;
    --demo-button-text: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  body { margin: 0; background: var(--page-bg); color: var(--page-text); }
  a { color: inherit; text-decoration: none; }
  button, input, textarea, select { font: inherit; }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    font-size: 1.35rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .nav-links, .nav-utilities { align-items: center; display: flex; }
  .nav-links { flex: 1 1 auto; gap: clamp(18px, 2.2vw, 34px); justify-content: center; min-width: 0; }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:hover .nav-trigger,
  .nav-item:focus-within .nav-trigger { color: var(--header-text); }

  .nav-item { position: static; }
  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret { transform: rotate(225deg) translateY(-1px); }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }

  .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns { display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .mega-column, .mega-sublinks { display: grid; }
  .mega-column { gap: 10px; }
  .mega-title { color: var(--dropdown-title); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .mega-link, .mega-link-group { border: 1px solid transparent; border-radius: 8px; }
  .mega-link { display: grid; gap: 5px; padding: 13px; }
  .mega-link strong { color: var(--dropdown-text); }
  .mega-link small, .mega-sublinks a { color: var(--dropdown-muted); }
  .mega-link:hover, .mega-link-group:hover { background: var(--dropdown-link-hover); border-color: var(--dropdown-link-border); }
  .mega-link-group { display: grid; gap: 4px; padding: 4px; }
  .mega-sublinks { gap: 2px; padding: 0 9px 8px 22px; }
  .mega-sublinks a { font-size: 0.84rem; padding: 5px 0; }
  .mega-feature { align-content: end; background: var(--dropdown-feature-bg); border: 1px solid var(--dropdown-feature-border); border-radius: 8px; display: grid; min-height: 268px; padding: 24px; }
  .mega-feature span, .mega-feature em { color: var(--dropdown-title); }
  .mega-feature strong { color: var(--dropdown-text); font-size: 1.35rem; line-height: 1.18; margin-top: auto; }
  .nav-utilities { flex: 0 0 auto; gap: clamp(12px, 1.5vw, 20px); margin-left: clamp(12px, 2vw, 28px); }
  .utility-link, .language-button, .utility-icon, .theme-toggle { display: none; }

  .demo-button,
  .primary-button {
    align-items: center;
    background: var(--demo-button-bg);
    border: 0;
    border-radius: 7px;
    color: var(--demo-button-text);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.88rem;
    font-weight: 850;
    justify-content: center;
    line-height: 1;
    min-height: 39px;
    padding: 0 18px;
    white-space: nowrap;
    width: fit-content;
  }

  .primary-button.alert { background: var(--alert); }
  .primary-button.dark { background: #211326; color: #ffffff; }
  .nav-toggle { background: transparent; border: 0; display: none; height: 42px; width: 42px; }
  .nav-toggle span { background: var(--header-text); display: block; height: 2px; margin: 6px 0; width: 24px; }

  h1, h2, h3, p { margin-top: 0; }
  h1 {
    font-size: clamp(3rem, 6vw, 5.8rem);
    font-weight: 500;
    line-height: 0.98;
    margin-bottom: 22px;
    overflow-wrap: break-word;
  }
  h2 { font-size: clamp(2rem, 4vw, 4rem); font-weight: 450; line-height: 1.05; }
  p, li { color: var(--page-muted); line-height: 1.6; }

  .internal-hero {
    align-items: center;
    background: var(--wine);
    color: #ffffff;
    display: grid;
    gap: 44px;
    grid-template-columns: minmax(0, 0.94fr) minmax(320px, 1.06fr);
    padding: clamp(56px, 7vw, 86px) clamp(18px, 4vw, 52px);
  }

  .internal-hero span {
    display: block;
    font-size: 0.88rem;
    font-weight: 850;
    letter-spacing: 0.05em;
    margin-bottom: 18px;
    text-transform: uppercase;
  }

  .internal-hero p { color: rgba(255, 255, 255, 0.82); max-width: 620px; }

  .document-visual {
    background: linear-gradient(135deg, #102237, #d6c0aa 48%, #f6f2ec);
    border-radius: 8px;
    min-height: 330px;
    overflow: hidden;
    position: relative;
  }

  .document-visual img,
  .office-visual img {
    display: block;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
    width: 100%;
  }

  .paper {
    background: #ffffff;
    border-radius: 5px;
    box-shadow: 0 18px 42px rgba(20, 27, 37, 0.22);
    height: 160px;
    left: 38%;
    position: absolute;
    top: 34%;
    transform: rotate(7deg);
    width: 250px;
  }

  .paper::before,
  .paper::after {
    background: rgba(67, 86, 112, 0.2);
    content: "";
    height: 6px;
    left: 28px;
    position: absolute;
    right: 28px;
  }

  .paper::before { top: 42px; }
  .paper::after { top: 72px; }

  .hand {
    background: linear-gradient(135deg, #b98369, #f0c7a6);
    border-radius: 48px;
    height: 72px;
    left: 16%;
    position: absolute;
    top: 48%;
    transform: rotate(15deg);
    width: 210px;
  }

  .pen {
    background: #1f2937;
    height: 8px;
    left: 40%;
    position: absolute;
    top: 58%;
    transform: rotate(26deg);
    width: 160px;
  }

  .keyboard {
    background:
      linear-gradient(rgba(66, 75, 91, 0.16) 1px, transparent 1px),
      linear-gradient(90deg, rgba(66, 75, 91, 0.16) 1px, transparent 1px),
      #f4f7fb;
    background-size: 22px 16px;
    bottom: 34px;
    height: 66px;
    left: 16%;
    position: absolute;
    transform: skewX(-10deg);
    width: 330px;
  }

  .trust-strip { background: var(--page-bg); padding: 48px clamp(18px, 4vw, 52px); text-align: center; }
  .trust-strip h2 { color: #a34462; font-size: 0.88rem; letter-spacing: 0.04em; margin-bottom: 32px; text-transform: uppercase; }
  .trust-row { align-items: center; display: grid; gap: 24px; grid-template-columns: repeat(5, minmax(0, 1fr)); }
  .trust-row span { color: rgba(36, 35, 41, 0.48); font-weight: 900; }

  .split-section,
  .demo-band {
    align-items: center;
    display: grid;
    gap: clamp(30px, 5vw, 72px);
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px);
  }

  .split-section, .mitigation-section, .story-section, .resources-section, .internal-footer { background: var(--card); }
  .leak-section { background: var(--page-bg); }

  .office-visual {
    background: linear-gradient(135deg, #dceef7, #ffffff 48%, #88a7b6);
    border-radius: 8px;
    min-height: 320px;
    overflow: hidden;
    position: relative;
  }

  .office-grid {
    background:
      linear-gradient(rgba(11, 93, 125, 0.12) 1px, transparent 1px),
      linear-gradient(90deg, rgba(11, 93, 125, 0.12) 1px, transparent 1px);
    background-size: 34px 34px;
    inset: 0;
    position: absolute;
  }

  .office-person {
    background: linear-gradient(150deg, #eef7ff, #32465c);
    border-radius: 48% 48% 6px 6px;
    bottom: 54px;
    height: 174px;
    left: 30%;
    position: absolute;
    width: 118px;
  }

  .office-person::before {
    background: #b77b5e;
    border-radius: 50%;
    content: "";
    height: 62px;
    left: 27px;
    position: absolute;
    top: -43px;
    width: 62px;
  }

  .office-desk {
    background: rgba(30, 41, 59, 0.12);
    bottom: 0;
    height: 78px;
    left: 0;
    position: absolute;
    right: 0;
  }

  .section-actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .management-section, .related-section { background: var(--page-bg); padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px); }
  .section-heading { margin: 0 auto 36px; max-width: 1040px; }
  .centered { text-align: center; }
  .card-grid { display: grid; gap: 22px; margin-inline: auto; max-width: 1120px; }
  .card-grid.three { grid-template-columns: repeat(3, minmax(0, 1fr)); }

  .feature-card,
  .offering-card,
  .internal-form,
  .story-card,
  .resource-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: clamp(24px, 4vw, 38px);
  }

  .hex-icon {
    background: linear-gradient(135deg, var(--orange), #f5a50d);
    clip-path: polygon(25% 4%, 75% 4%, 100% 50%, 75% 96%, 25% 96%, 0 50%);
    height: 44px;
    margin-bottom: 20px;
    width: 44px;
  }

  .feature-card:nth-child(2) .hex-icon { background: linear-gradient(135deg, var(--alert), #c4254d); }
  .feature-card:nth-child(3) .hex-icon { background: linear-gradient(135deg, var(--plum), #6f234a); }

  .story-section, .mitigation-section, .resources-section { padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px); }
  .story-card { margin-inline: auto; max-width: 1180px; }
  .story-card > span, .resource-card span, .resource-card em {
    color: var(--page-muted);
    display: block;
    font-size: 0.8rem;
    font-style: normal;
    font-weight: 900;
    letter-spacing: 0.04em;
    margin-bottom: 22px;
    text-transform: uppercase;
  }
