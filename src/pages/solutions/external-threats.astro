---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL || (import.meta.env.DEV ? "http://127.0.0.1:5000" : "");

const trustLogos = ["Orica", "FLEX", "American Auto Co.", "aramco"];

const controlCards = [
  {
    title: "Identity based access",
    text: "Link access to user identity, protected by attribute-based rules that revoke access before, during, and after external threat activity."
  },
  {
    title: "Complete external control",
    text: "Track users who access protected digital assets, download information, and which activities are blocked or allowed."
  },
  {
    title: "Visibility beyond the enterprise",
    text: "Dynamically allow or block users from accessing protected digital assets, manage permissions, and revoke access at any time."
  }
];

const mitigations = [
  ["Data encryption and EDRM", "Digital assets can be encrypted at rest, in transit, and in use with AES-256 encryption. Information owners can also edit access and usage rules at local access to specific, authorized users only."],
  ["Geo-fencing and access revocation", "The administrator can control access to protected data based on geo-physical location, to prevent unauthorized cross-border sharing, mitigate compliance risks, and prevent unauthorized access."],
  ["Audit trail and activity reporting", "Track and analyze internal or external user activity to identify risks, detect patterns, and generate audit-compliant reports."],
  ["Secure external collaboration", "Integrate your cloud repositories, DMS, Box, or M365 to automatically protect sensitive data shared with third parties."]
];

const relatedProducts = [
  {
    title: "Enterprise Digital Rights Management",
    text: "Encrypt digital assets, limit access to groups or individuals, allow or deny specific actions, track usage, and revoke access at any time."
  },
  {
    title: "Risk Insights and Reporting",
    text: "Get granular insights for risk management as well as for user-level activity to quickly address unauthorized access or non-compliance."
  }
];

const resources = [
  {
    type: "Whitepaper",
    tag: "General Business",
    title: "Cybersecurity's Reliance Crisis: Rethink Responsiveness Doesn't Cut It",
    image: "/images/integrations/dlp-casb/ai-readiness.png",
    alt: "Analyst reviewing external threat security posture"
  },
  {
    type: "Case Study",
    tag: "Manufacturing",
    title: "Maruti Suzuki",
    image: "/images/integrations/content-storage/enterprise-benefits.png",
    alt: "Manufacturing team reviewing protected intellectual property"
  },
  {
    type: "Whitepaper",
    tag: "Data Security",
    title: "A Comprehensive Guide to Data-Centric Email Security",
    image: "/images/integrations/file-storage/file-flow.png",
    alt: "Secure file exchange between external collaborators"
  }
];
---

<BaseLayout
  title="External Threats | seclore"
  description="Seclore data-centric security for external threat protection, third-party risk, supply chain security, and secure collaboration."
>
  <main id="top" class="external-page">
    <Nav />

    <section class="external-hero">
      <div class="hero-copy">
        <span>External Threats</span>
        <h1>Protect Sensitive Data from Third-Party Threats</h1>
        <p>
          Prevent unauthorized external users from accessing your enterprise's sensitive digital assets. Classify and protect
          digital assets, and apply context-aware usage policies to maintain control even after files leave your systems.
        </p>
        <a class="primary-button alert" href="#demo">Book a Demo</a>
      </div>
      <div class="threat-visual" aria-label="External threat monitoring visual">
        <img src="/images/integrations/spirion/spirion-lead.png" alt="Global external threat monitoring network" loading="eager" />
      </div>
    </section>

    <section class="trust-strip">
      <h2>Trusted by industry-leading enterprises</h2>
      <div class="trust-row">
        {trustLogos.map((logo) => <span>{logo}</span>)}
      </div>
    </section>

    <section class="split-section breach-section">
      <div class="breach-visual" aria-label="Data security analyst visual">
        <img src="/images/integrations/dlp-casb/ai-readiness.png" alt="Security analyst reviewing external threat activity" />
      </div>
      <div>
        <h2>Make data breaches harmless</h2>
        <p>
          Investments in data security are rising, but so are the frequency, severity, and cost of data breaches. It is time
          to take a data-centric approach.
        </p>
        <p>
          Digital assets protected with Seclore are encrypted and can only be accessed by authorized users and apps. Even
          when assets leave approved locations, controls follow the information.
        </p>
        <a class="primary-button dark" href="#resources">Read the Whitepaper</a>
      </div>
    </section>

    <section class="control-section">
      <div class="section-heading centered">
        <h2>Retain control of your digital assets, regardless of who has them</h2>
        <p>
          Organizations can protect digital assets that contain sensitive or regulated information so that only trusted,
          authorized users receive access and control continues if files are shared outside the organization.
        </p>
      </div>
      <div class="card-grid three">
        {controlCards.map((card) => (
          <article class="feature-card">
            <div class="hex-icon"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="split-section supply-section">
      <div class="supply-art" aria-label="Secure supply chain visual">
        <img src="/images/integrations/file-storage/file-flow.png" alt="Secure external file sharing workflow" />
      </div>
      <div>
        <h2>Supply chain security</h2>
        <p>
          Manufacturers often rely on third-party designers, suppliers, and contractors to bring their products to market.
          Each shared file can become a risk when access is governed only by network or repository boundaries.
        </p>
        <p>
          Seclore applies persistent protection directly to the file itself, so data owners can monitor, revoke, and update
          access after sharing.
        </p>
        <a class="primary-button dark" href="#demo">Contact For Inc.</a>
      </div>
    </section>

    <section class="demo-band" id="demo">
      <div class="demo-copy">
        <h2>Meet with a data-centric security expert</h2>
        <p>
          See our data-centric security platform in action, and learn how to protect and control your digital assets wherever
          they go.
        </p>
        <strong>Learn more about</strong>
        <ul>
          <li>Digital asset security for every user, device, app, and cloud</li>
          <li>Granular access, usage, and privacy controls</li>
          <li>Never losing control or visibility of your digital assets</li>
        </ul>
        <div class="demo-logos">
          <span>Orica</span>
          <span>FLEX</span>
        </div>
      </div>
      <form class="external-form" data-endpoint="/api/demo">
        <h3>Seclore Demo</h3>
        <label>Email<input name="email" type="email" required /></label>
        <label>First Name<input name="name" required minlength="2" /></label>
        <label>Last Name<input name="lastName" /></label>
        <label>Company Name<input name="company" required /></label>
        <label>Job Title<input name="role" /></label>
        <label>Phone Number<input name="phone" /></label>
        <label>Country<select name="country"><option>Please Select</option><option>United States</option><option>India</option></select></label>
        <button class="primary-button" type="submit">Submit</button>
        <p class="form-status" role="status" aria-live="polite"></p>
      </form>
    </section>

    <section class="mitigation-section">
      <div class="section-heading centered">
        <h2>Mitigate external threats</h2>
      </div>
      <div class="offering-list">
        {mitigations.map(([title, text]) => (
          <article class="offering-card">
            <div class="line-icon"></div>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="story-section">
      <article class="story-card">
        <span>Capital Equipment Manufacturer</span>
        <blockquote>
          "We not only replaced our existing encryption solution with Seclore EDRM, but also integrated it into our PLM
          application. This allowed us to protect over 2 million documents, many of which contained sensitive intellectual
          property."
        </blockquote>
        <strong>Capital Equipment Manufacturer</strong>
        <a class="primary-button dark" href="#resources">Customer Story</a>
      </article>
    </section>

    <section class="related-section">
      <div class="section-heading centered">
        <h2>Data-centric security related products</h2>
        <p>
          Add a layer of cybersecurity and regulatory compliance controls at the data level to ensure protection is applied
          where it is needed most.
        </p>
      </div>
      <div class="related-products">
        {relatedProducts.map((item) => (
          <article class="related-product">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <a href="#demo">Learn More</a>
          </article>
        ))}
      </div>
    </section>

    <section class="resources-section" id="resources">
      <div class="section-heading centered">
        <h2>External threat data security resources</h2>
        <p>
          Explore resources that can help reduce external threat exposure and strengthen data-centric security programs.
        </p>
      </div>
      <div class="resource-grid">
        {resources.map((resource) => (
          <article class="resource-card">
            <figure>
              <img src={resource.image} alt={resource.alt} />
            </figure>
            <div>
              <span>{resource.type}</span>
              <em>{resource.tag}</em>
              <h3>{resource.title}</h3>
            </div>
            <a href="#demo">View More</a>
          </article>
        ))}
      </div>
      <div class="slide-controls" aria-label="Resource carousel controls">
        <button type="button" aria-label="Previous resource">&lt;</button>
        <button type="button" aria-label="Next resource">&gt;</button>
      </div>
    </section>
  </main>

  <script is:inline define:vars={{ apiBase }}>
    document.querySelectorAll(".external-form").forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const status = form.querySelector(".form-status");
        const button = form.querySelector("button[type='submit']");
        const payload = Object.fromEntries(new FormData(form).entries());

        status.textContent = "Sending...";
        status.className = "form-status";
        button.disabled = true;

        try {
          const response = await fetch(`${apiBase}${form.dataset.endpoint}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });
          const data = await response.json();
          if (!response.ok) throw new Error(data.message || "Request failed.");
          form.reset();
          status.textContent = data.message || "Submitted successfully.";
          status.classList.add("success");
        } catch (error) {
          status.textContent = error.message || "Something went wrong.";
          status.classList.add("error");
        } finally {
          button.disabled = false;
        }
      });
    });
  </script>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f2f3f5;
    --page-text: #232128;
    --page-muted: #636773;
    --purple: #5b2bd7;
    --wine: #2b1024;
    --alert: #eb3157;
    --orange: #ff9500;
    --plum: #8d204e;
    --card: #ffffff;
    --line: rgba(29, 29, 34, 0.13);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #5b2bd7;
    --demo-button-text: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  body { margin: 0; background: var(--page-bg); color: var(--page-text); }
  a { color: inherit; text-decoration: none; }
  button, input, textarea, select { font: inherit; }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    font-size: 1.35rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .nav-links, .nav-utilities { align-items: center; display: flex; }
  .nav-links { flex: 1 1 auto; gap: clamp(18px, 2.2vw, 34px); justify-content: center; min-width: 0; }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:hover .nav-trigger,
  .nav-item:focus-within .nav-trigger { color: var(--header-text); }

  .nav-item { position: static; }
  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret { transform: rotate(225deg) translateY(-1px); }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }

  .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns { display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .mega-column, .mega-sublinks { display: grid; }
  .mega-column { gap: 10px; }
  .mega-title { color: var(--dropdown-title); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .mega-link, .mega-link-group { border: 1px solid transparent; border-radius: 8px; }
  .mega-link { display: grid; gap: 5px; padding: 13px; }
  .mega-link strong { color: var(--dropdown-text); }
  .mega-link small, .mega-sublinks a { color: var(--dropdown-muted); }
  .mega-link:hover, .mega-link-group:hover { background: var(--dropdown-link-hover); border-color: var(--dropdown-link-border); }
  .mega-link-group { display: grid; gap: 4px; padding: 4px; }
  .mega-sublinks { gap: 2px; padding: 0 9px 8px 22px; }
  .mega-sublinks a { font-size: 0.84rem; padding: 5px 0; }
  .mega-feature { align-content: end; background: var(--dropdown-feature-bg); border: 1px solid var(--dropdown-feature-border); border-radius: 8px; display: grid; min-height: 268px; padding: 24px; }
  .mega-feature span, .mega-feature em { color: var(--dropdown-title); }
  .mega-feature strong { color: var(--dropdown-text); font-size: 1.35rem; line-height: 1.18; margin-top: auto; }
  .nav-utilities { flex: 0 0 auto; gap: clamp(12px, 1.5vw, 20px); margin-left: clamp(12px, 2vw, 28px); }
  .utility-link, .language-button, .utility-icon, .theme-toggle { display: none; }

  .demo-button,
  .primary-button {
    align-items: center;
    background: var(--demo-button-bg);
    border: 0;
    border-radius: 7px;
    color: var(--demo-button-text);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.88rem;
    font-weight: 850;
    justify-content: center;
    line-height: 1;
    min-height: 39px;
    padding: 0 18px;
    white-space: nowrap;
    width: fit-content;
  }

  .primary-button.alert { background: var(--alert); }
  .primary-button.dark { background: #211326; color: #ffffff; }
  .nav-toggle { background: transparent; border: 0; display: none; height: 42px; width: 42px; }
  .nav-toggle span { background: var(--header-text); display: block; height: 2px; margin: 6px 0; width: 24px; }

  h1, h2, h3, p { margin-top: 0; }
  h1 {
    font-size: clamp(3rem, 6vw, 5.8rem);
    font-weight: 500;
    line-height: 0.98;
    margin-bottom: 22px;
    overflow-wrap: break-word;
  }
  h2 { font-size: clamp(2rem, 4vw, 4rem); font-weight: 450; line-height: 1.05; }
  p, li { color: var(--page-muted); line-height: 1.6; }

  .external-hero {
    align-items: center;
    background: var(--wine);
    color: #ffffff;
    display: grid;
    gap: 44px;
    grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.05fr);
    padding: clamp(56px, 7vw, 86px) clamp(18px, 4vw, 52px);
  }

  .external-hero span {
    display: block;
    font-size: 0.88rem;
    font-weight: 850;
    letter-spacing: 0.05em;
    margin-bottom: 18px;
    text-transform: uppercase;
  }

  .external-hero p { color: rgba(255, 255, 255, 0.82); max-width: 620px; }

  .threat-visual {
    background: linear-gradient(135deg, #06111c, #0b4262 45%, #59b8d5);
    border-radius: 8px;
    min-height: 330px;
    overflow: hidden;
    position: relative;
  }

  .threat-visual img,
  .breach-visual img,
  .supply-art img {
    display: block;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
    width: 100%;
  }

  .hood {
    background: linear-gradient(150deg, #05101a, #19273b);
    border-radius: 50% 50% 18px 18px;
    bottom: 44px;
    height: 230px;
    left: 34%;
    position: absolute;
    width: 170px;
    z-index: 2;
  }

  .hood::before {
    background: #07101b;
    border-radius: 50% 50% 40% 40%;
    content: "";
    height: 96px;
    left: 36px;
    position: absolute;
    top: 26px;
    width: 96px;
  }

  .monitor {
    background:
      linear-gradient(rgba(255, 255, 255, 0.22) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.22) 1px, transparent 1px),
      rgba(54, 198, 255, 0.2);
    background-size: 18px 18px;
    border: 1px solid rgba(134, 227, 255, 0.35);
    position: absolute;
  }

  .monitor-a { height: 118px; left: 8%; top: 24%; width: 170px; }
  .monitor-b { height: 92px; right: 8%; top: 18%; width: 190px; }
  .monitor-c { bottom: 18%; height: 76px; right: 12%; width: 156px; }

  .trust-strip { background: var(--page-bg); padding: 48px clamp(18px, 4vw, 52px); text-align: center; }
  .trust-strip h2 { color: #a34462; font-size: 0.88rem; letter-spacing: 0.04em; margin-bottom: 32px; text-transform: uppercase; }
  .trust-row { align-items: center; display: grid; gap: 24px; grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .trust-row span { color: rgba(36, 35, 41, 0.48); font-weight: 900; }

  .split-section,
  .demo-band {
    align-items: center;
    display: grid;
    gap: clamp(30px, 5vw, 72px);
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px);
  }

  .split-section, .mitigation-section, .story-section, .resources-section, .external-footer { background: var(--card); }
  .breach-section { background: var(--page-bg); }

  .breach-visual {
    background: linear-gradient(135deg, #103323, #6d884e 46%, #c4e7c8);
    border-radius: 8px;
    min-height: 320px;
    overflow: hidden;
    position: relative;
  }

  .grid-wall {
    background:
      linear-gradient(rgba(255, 255, 255, 0.22) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.18) 1px, transparent 1px);
    background-size: 28px 28px;
    inset: 0;
    position: absolute;
  }

  .analyst {
    background: #5a324c;
    border-radius: 46% 46% 8px 8px;
    bottom: 30px;
    height: 172px;
    left: 37%;
    position: absolute;
    width: 118px;
  }

  .analyst::before {
    background: #7a513c;
    border-radius: 50%;
    content: "";
    height: 62px;
    left: 28px;
    position: absolute;
    top: -44px;
    width: 62px;
  }

  .control-section, .related-section { background: var(--page-bg); padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px); }
  .section-heading { margin: 0 auto 36px; max-width: 1040px; }
  .centered { text-align: center; }
  .card-grid { display: grid; gap: 22px; margin-inline: auto; max-width: 1120px; }
  .card-grid.three { grid-template-columns: repeat(3, minmax(0, 1fr)); }

  .feature-card,
  .offering-card,
  .external-form,
  .story-card,
  .resource-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: clamp(24px, 4vw, 38px);
  }

  .hex-icon {
    background: linear-gradient(135deg, var(--orange), #f5a50d);
    clip-path: polygon(25% 4%, 75% 4%, 100% 50%, 75% 96%, 25% 96%, 0 50%);
    height: 44px;
    margin-bottom: 20px;
    width: 44px;
  }

  .feature-card:nth-child(2) .hex-icon { background: linear-gradient(135deg, var(--alert), #c4254d); }
  .feature-card:nth-child(3) .hex-icon { background: linear-gradient(135deg, var(--plum), #6f234a); }

  .supply-section { background: var(--card); }
  .supply-art {
    border-radius: 8px;
    min-height: 260px;
    overflow: hidden;
    position: relative;
  }
  .node {
    background: #ffffff;
    border: 2px solid #ff4267;
    border-radius: 50%;
    height: 62px;
    position: absolute;
    width: 62px;
    z-index: 2;
  }
  .node-a { left: 18%; top: 38%; }
  .node-b { left: 44%; top: 16%; }
  .node-c { right: 16%; top: 44%; }
  .node-line {
    background: linear-gradient(90deg, transparent, #ff4267, transparent);
    height: 3px;
    left: 20%;
    position: absolute;
    right: 18%;
    top: 45%;
    transform: rotate(-7deg);
  }

  .demo-band { background: linear-gradient(135deg, #dceaff, #f2eaff); }
