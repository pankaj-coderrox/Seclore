---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL || (import.meta.env.DEV ? "http://127.0.0.1:5000" : "");

const trustLogos = ["Itron", "Cummins", "FLEX", "Stanley Black & Decker"];

const controlCards = [
  {
    title: "Protect your strategic innovations",
    text: "Classify, protect, and watermark your IP so it is always protected at rest, in transit, and in use."
  },
  {
    title: "Control IP sprawl in supply chains",
    text: "Track supplier access to sensitive assets, grant time-limited permissions, and manage permissions with precise activity controls."
  },
  {
    title: "Enhance risk management overhead",
    text: "Monitor and track activity for protected digital assets and show that data is effectively governed across business ecosystems."
  }
];

const safeguards = [
  ["Data encryption and EDRM", "Digital assets can be encrypted at rest, in transit, and in use with AES-256 encryption. Information owners can also edit access and usage rules to limit access to specific authorized users only."],
  ["Access and usage policies", "Limit access to specific users, groups, domains, and locations, and prevent certain activities like editing, printing, or copying text from a protected digital asset."],
  ["Real-time revocation", "See user access for protected digital assets to expire on a certain day and time, after a false positive, or for an internally revoked access at any time."],
  ["Neutral CAD support", "Protect neutral CAD files with world-class encryption, rights management, dynamic watermarking, global tracking, and access control rules."],
  ["Audit trail and activity reporting", "Track and analyze internal or external user activity to identify risks, detect patterns, and generate audit-compliant reports."],
  ["Dynamic watermarking", "Dynamic watermarks help investigations and reinforce responsible handling by overlaying labels, usernames, dates, and times on protected files, which can also be applied to exported files."]
];

const relatedProducts = [
  {
    title: "Enterprise Digital Rights Management",
    text: "Encrypt digital assets, limit access to groups or individuals, allow or deny specific actions, track usage, and revoke access at any time."
  },
  {
    title: "Risk Insights and Reporting",
    text: "Get granular insights for risk management as well as for user-level activity to quickly address unauthorized access or non-compliance."
  }
];

const resources = [
  {
    type: "Whitepaper",
    tag: "Semiconductor",
    title: "Safeguarding Intellectual Property in the Semiconductor Equipment Industry",
    image: "/images/integrations/content-storage/enterprise-benefits.png",
    alt: "Engineers reviewing protected intellectual property designs"
  },
  {
    type: "Infographic",
    tag: "Trade Secrets",
    title: "Is your Organization Prone to Intellectual Property Theft?",
    image: "/images/integrations/file-storage/file-flow.png",
    alt: "Protected file movement for trade secret security"
  },
  {
    type: "Case Study",
    tag: "Manufacturing",
    title: "Global Video Game Company",
    image: "/images/integrations/intro-meeting.png",
    alt: "Business team discussing intellectual property protection"
  }
];
---

<BaseLayout
  title="IP Protection | seclore"
  description="Seclore data-centric security for intellectual property protection, trade secrets, CAD files, and secure collaboration."
>
  <main id="top" class="ip-page">
    <Nav />

    <section class="ip-hero">
      <div class="hero-copy">
        <span>IP Protection</span>
        <h1>Protect your IP</h1>
        <p>
          Gain complete control over your enterprise's intellectual property. IP, patent submission documents, and innovation
          content remain protected across creation, collaboration, and sharing throughout their entire lifecycle.
        </p>
        <a class="primary-button alert" href="#demo">Book a Demo</a>
      </div>
      <div class="justice-visual" aria-label="Intellectual property protection visual">
        <img
          src="/images/integrations/content-storage/enterprise-benefits.png"
          alt="Engineers reviewing protected intellectual property designs"
          loading="eager"
        />
      </div>
    </section>

    <section class="trust-strip">
      <h2>Trusted by industry-leading enterprises</h2>
      <div class="trust-row">
        {trustLogos.map((logo) => <span>{logo}</span>)}
      </div>
    </section>

    <section class="split-section advantage-section">
      <div class="meeting-visual" aria-label="Enterprise IP collaboration visual">
        <img
          src="/images/integrations/intro-meeting.png"
          alt="Enterprise team collaborating on intellectual property protection"
        />
      </div>
      <div>
        <h2>Extend your market advantage with data-centric security</h2>
        <p>
          Data breaches, corporate espionage, and human error can all threaten the integrity and value of your IP. Too many
          risks remain when teams rely only on repositories or perimeter controls.
        </p>
        <p>
          Seclore empowers organizations to classify, protect, and track IP assets across digital channels and collaborative
          workflows. Protection follows the asset wherever it goes.
        </p>
        <div class="section-actions">
          <a class="primary-button dark" href="#resources">IP Protection Use Cases</a>
          <a class="primary-button dark" href="#demo">Contact For Inc.</a>
        </div>
      </div>
    </section>

    <section class="control-section">
      <div class="section-heading centered">
        <h2>Remain in control of your IP throughout its lifecycle</h2>
        <p>
          Protect and control digital assets that contain sensitive or proprietary information like IP and trade secrets to
          keep your data safe from breaches, leaks, or accidental disclosures.
        </p>
      </div>
      <div class="card-grid three">
        {controlCards.map((card) => (
          <article class="feature-card">
            <div class="hex-icon"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="demo-band" id="demo">
      <div class="demo-copy">
        <h2>Meet with a data-centric security expert</h2>
        <p>
          See our data-centric security platform in action, and learn how to protect and control your digital assets wherever
          they go.
        </p>
        <strong>Learn more about</strong>
        <ul>
          <li>Digital asset security for every user, device, app, and cloud</li>
          <li>Granular access, usage, and privacy controls</li>
          <li>Never losing control or visibility of your digital assets</li>
        </ul>
        <div class="demo-logos">
          <span>Itron</span>
          <span>FLEX</span>
          <span>Cummins</span>
        </div>
      </div>
      <form class="ip-form" data-endpoint="/api/demo">
        <h3>Seclore Demo</h3>
        <label>Email<input name="email" type="email" required /></label>
        <label>First Name<input name="name" required minlength="2" /></label>
        <label>Last Name<input name="lastName" /></label>
        <label>Company Name<input name="company" required /></label>
        <label>Job Title<input name="role" /></label>
        <label>Phone Number<input name="phone" /></label>
        <label>Country<select name="country"><option>Please Select</option><option>United States</option><option>India</option></select></label>
        <button class="primary-button" type="submit">Submit</button>
        <p class="form-status" role="status" aria-live="polite"></p>
      </form>
    </section>

    <section class="safeguard-section">
      <div class="section-heading centered">
        <h2>Keep your IP and trade secrets secure</h2>
      </div>
      <div class="safeguard-grid">
        {safeguards.map(([title, text]) => (
          <article class="offering-card">
            <div class="line-icon"></div>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="story-section">
      <article class="story-card">
        <span>Capital Equipment Manufacturer</span>
        <blockquote>
          "We not only replaced our existing encryption solution with Seclore EDRM, but also integrated it into our PLM
          application. This allowed us to protect over 2 million documents, many of which contained sensitive intellectual
          property. Our customers have fully compliant rights-governed access to their data."
        </blockquote>
        <strong>Capital Equipment Manufacturer</strong>
        <a class="primary-button dark" href="#resources">Customer Story</a>
      </article>
    </section>

    <section class="related-section">
      <div class="section-heading centered">
        <h2>Data-centric security related products</h2>
        <p>
          Add a layer of cybersecurity and regulatory compliance controls at the data level to ensure protection is applied
          where it is needed most.
        </p>
      </div>
      <div class="related-products">
        {relatedProducts.map((item) => (
          <article class="related-product">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <a href="#demo">Learn More</a>
          </article>
        ))}
      </div>
    </section>

    <section class="resources-section" id="resources">
      <div class="section-heading centered">
        <h2>IP data security resources</h2>
        <p>
          Seclore is a leading provider of data-centric security. Our solutions help to secure and control highly effective IP,
          preventing data breaches, and ensuring regulatory compliance.
        </p>
      </div>
      <div class="resource-shell">
        <div class="resource-track" data-carousel>
          {resources.map((resource) => (
            <article class="resource-card">
              <figure>
                <img src={resource.image} alt={resource.alt} />
              </figure>
              <div>
                <span>{resource.type}</span>
                <em>{resource.tag}</em>
                <h3>{resource.title}</h3>
              </div>
              <a href="#demo">Read More</a>
            </article>
          ))}
        </div>
        <div class="slide-controls" aria-label="Resource carousel controls">
          <button type="button" data-carousel-prev aria-label="Previous resource">&lt;</button>
          <button type="button" data-carousel-next aria-label="Next resource">&gt;</button>
        </div>
      </div>
    </section>
  </main>

  <script is:inline define:vars={{ apiBase }}>
    document.querySelectorAll(".ip-form").forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const status = form.querySelector(".form-status");
        const button = form.querySelector("button[type='submit']");
        const payload = Object.fromEntries(new FormData(form).entries());

        status.textContent = "Sending...";
        status.className = "form-status";
        button.disabled = true;

        try {
          const response = await fetch(`${apiBase}${form.dataset.endpoint}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });
          const data = await response.json();
          if (!response.ok) throw new Error(data.message || "Request failed.");
          form.reset();
          status.textContent = data.message || "Submitted successfully.";
          status.classList.add("success");
        } catch (error) {
          status.textContent = error.message || "Something went wrong.";
          status.classList.add("error");
        } finally {
          button.disabled = false;
        }
      });
    });

    const carousel = document.querySelector("[data-carousel]");
    const previous = document.querySelector("[data-carousel-prev]");
    const next = document.querySelector("[data-carousel-next]");
    const scrollResources = (direction) => {
      if (!carousel) return;
      const card = carousel.querySelector(".resource-card");
      const distance = card ? card.getBoundingClientRect().width + 24 : 260;
      carousel.scrollBy({ left: direction * distance, behavior: "smooth" });
    };
    previous?.addEventListener("click", () => scrollResources(-1));
    next?.addEventListener("click", () => scrollResources(1));
  </script>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f2f3f5;
    --page-text: #232128;
    --page-muted: #636773;
    --purple: #5b2bd7;
    --wine: #2b1024;
    --alert: #eb3157;
    --orange: #ff9500;
    --plum: #8d204e;
    --card: #ffffff;
    --line: rgba(29, 29, 34, 0.13);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #5b2bd7;
    --demo-button-text: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  body { margin: 0; background: var(--page-bg); color: var(--page-text); }
  a { color: inherit; text-decoration: none; }
  button, input, textarea, select { font: inherit; }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    font-size: 1.35rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .nav-links, .nav-utilities { align-items: center; display: flex; }
  .nav-links { flex: 1 1 auto; gap: clamp(18px, 2.2vw, 34px); justify-content: center; min-width: 0; }
  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:hover .nav-trigger,
  .nav-item:focus-within .nav-trigger { color: var(--header-text); }
  .nav-item { position: static; }
  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret { transform: rotate(225deg) translateY(-1px); }
  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns { display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .mega-column, .mega-sublinks { display: grid; }
  .mega-column { gap: 10px; }
  .mega-title { color: var(--dropdown-title); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .mega-link, .mega-link-group { border: 1px solid transparent; border-radius: 8px; }
  .mega-link { display: grid; gap: 5px; padding: 13px; }
  .mega-link strong { color: var(--dropdown-text); }
  .mega-link small, .mega-sublinks a { color: var(--dropdown-muted); }
  .mega-link:hover, .mega-link-group:hover { background: var(--dropdown-link-hover); border-color: var(--dropdown-link-border); }
  .mega-link-group { display: grid; gap: 4px; padding: 4px; }
  .mega-sublinks { gap: 2px; padding: 0 9px 8px 22px; }
  .mega-sublinks a { font-size: 0.84rem; padding: 5px 0; }
  .mega-feature { align-content: end; background: var(--dropdown-feature-bg); border: 1px solid var(--dropdown-feature-border); border-radius: 8px; display: grid; min-height: 268px; padding: 24px; }
  .mega-feature span, .mega-feature em { color: var(--dropdown-title); }
  .mega-feature strong { color: var(--dropdown-text); font-size: 1.35rem; line-height: 1.18; margin-top: auto; }
  .nav-utilities { flex: 0 0 auto; gap: clamp(12px, 1.5vw, 20px); margin-left: clamp(12px, 2vw, 28px); }
  .utility-link, .language-button, .utility-icon, .theme-toggle { display: none; }

  .demo-button,
  .primary-button {
    align-items: center;
    background: var(--demo-button-bg);
    border: 0;
    border-radius: 7px;
    color: var(--demo-button-text);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.88rem;
    font-weight: 850;
    justify-content: center;
    line-height: 1;
    min-height: 39px;
    padding: 0 18px;
    white-space: nowrap;
    width: fit-content;
  }

  .primary-button.alert { background: var(--alert); }
  .primary-button.dark { background: #211326; color: #ffffff; }
  .nav-toggle { background: transparent; border: 0; display: none; height: 42px; width: 42px; }
  .nav-toggle span { background: var(--header-text); display: block; height: 2px; margin: 6px 0; width: 24px; }

  h1, h2, h3, p { margin-top: 0; }
  h1 {
    font-size: clamp(3rem, 6vw, 5.8rem);
    font-weight: 500;
    line-height: 0.98;
    margin-bottom: 22px;
    overflow-wrap: break-word;
  }
  h2 { font-size: clamp(2rem, 4vw, 4rem); font-weight: 450; line-height: 1.05; }
  p, li { color: var(--page-muted); line-height: 1.6; }

  .ip-hero {
    align-items: center;
    background: var(--wine);
    color: #ffffff;
    display: grid;
    gap: 44px;
    grid-template-columns: minmax(0, 0.92fr) minmax(320px, 1.08fr);
    padding: clamp(56px, 7vw, 86px) clamp(18px, 4vw, 52px);
  }

  .ip-hero span {
    display: block;
    font-size: 0.88rem;
    font-weight: 850;
    letter-spacing: 0.05em;
    margin-bottom: 18px;
    text-transform: uppercase;
  }
  .ip-hero p { color: rgba(255, 255, 255, 0.82); max-width: 620px; }

  .justice-visual {
    background: linear-gradient(135deg, #eef2f5, #d6d9de 48%, #91806d);
    border-radius: 8px;
    min-height: 330px;
    overflow: hidden;
    position: relative;
  }

  .justice-visual img,
  .meeting-visual img {
    display: block;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
    width: 100%;
  }

  .statue {
    background: linear-gradient(140deg, #98785b, #2d241f);
    bottom: 28px;
    height: 230px;
    left: 44%;
    position: absolute;
    width: 80px;
  }

  .statue::before {
    background: #7a5e45;
    border-radius: 50%;
    content: "";
    height: 44px;
    left: 16px;
    position: absolute;
    top: -36px;
    width: 44px;
  }

  .scale-beam {
    background: #5a4638;
    height: 6px;
    left: 26%;
    position: absolute;
    top: 34%;
    transform: rotate(-6deg);
    width: 300px;
  }

  .scale-chain {
    background: #5a4638;
    height: 100px;
    position: absolute;
    top: 35%;
    width: 3px;
  }

  .chain-left { left: 29%; }
  .chain-right { left: 69%; }
  .scale-pan {
    border: 3px solid #5a4638;
    border-top: 0;
    bottom: 96px;
    height: 24px;
    position: absolute;
    width: 94px;
  }
  .pan-left { left: 21%; }
  .pan-right { right: 22%; }

  .trust-strip { background: var(--page-bg); padding: 48px clamp(18px, 4vw, 52px); text-align: center; }
  .trust-strip h2 { color: #a34462; font-size: 0.88rem; letter-spacing: 0.04em; margin-bottom: 32px; text-transform: uppercase; }
  .trust-row { align-items: center; display: grid; gap: 24px; grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .trust-row span { color: rgba(36, 35, 41, 0.48); font-weight: 900; }

  .split-section,
  .demo-band {
    align-items: center;
    display: grid;
    gap: clamp(30px, 5vw, 72px);
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px);
  }

  .split-section, .safeguard-section, .story-section, .resources-section, .ip-footer { background: var(--card); }
  .advantage-section, .control-section, .related-section { background: var(--page-bg); }

  .meeting-visual {
    background: linear-gradient(135deg, #f2e5d6, #ffffff 46%, #6c4031);
    border-radius: 8px;
    min-height: 320px;
    overflow: hidden;
    position: relative;
  }

  .room-panel {
    background:
      linear-gradient(rgba(80, 44, 33, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(80, 44, 33, 0.08) 1px, transparent 1px);
    background-size: 44px 44px;
    inset: 0;
    position: absolute;
  }

  .person {
    border-radius: 48% 48% 6px 6px;
    bottom: 42px;
    position: absolute;
  }
  .person::before {
    border-radius: 50%;
    content: "";
    height: 50px;
    left: 20px;
    position: absolute;
    top: -35px;
    width: 50px;
  }
  .person-a { background: #2f4054; height: 160px; left: 18%; width: 92px; }
  .person-a::before { background: #c78364; }
  .person-b { background: #61402f; height: 150px; left: 42%; width: 88px; }
  .person-b::before { background: #e4b08e; }
  .person-c { background: #3c2f35; height: 142px; right: 18%; width: 82px; }
  .person-c::before { background: #b17558; }

  .section-actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .control-section, .related-section { padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px); }
  .section-heading { margin: 0 auto 36px; max-width: 1040px; }
  .centered { text-align: center; }
  .card-grid { display: grid; gap: 22px; margin-inline: auto; max-width: 1120px; }
  .card-grid.three { grid-template-columns: repeat(3, minmax(0, 1fr)); }

  .feature-card,
  .offering-card,
  .ip-form,
  .story-card,
  .resource-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: clamp(24px, 4vw, 38px);
  }

  .hex-icon {
    background: linear-gradient(135deg, var(--orange), #f5a50d);
    clip-path: polygon(25% 4%, 75% 4%, 100% 50%, 75% 96%, 25% 96%, 0 50%);
    height: 44px;
    margin-bottom: 20px;
    width: 44px;
  }
  .feature-card:nth-child(2) .hex-icon { background: linear-gradient(135deg, var(--alert), #c4254d); }
