---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:5000";

const trustLogos = ["100K", "GRAINGER", "aramco", "MAHINDRA", "EXIDE"];

const successCards = [
  {
    title: "IP protection",
    text: "Encrypt and watermark sensitive or proprietary digital assets like product specifications, CAD files, and formulas."
  },
  {
    title: "Operational resilience",
    text: "Prevent disruptions by ensuring critical digital assets, supplier files, and engineering data remain available and controlled."
  },
  {
    title: "Data control and visibility",
    text: "Track activity information for sensitive documents, designs, and data across partners and supply chains."
  }
];

const offerings = [
  ["Enterprise digital rights management", "Persistently protect digital assets from creation to consumption with granular controls for users, devices, and locations."],
  ["Neutral CAD support", "Protect CAD files with usage controls, encryption, rights management, dynamic watermarking, print tracking, and remote access control."],
  ["Granular controls", "Prevent leakage, revoke access, and enforce edit, print, share, and screen-capture controls."],
  ["Risk insights and dashboard", "Gain visibility into users, file activity, and supplier access with reports that help avoid risk and waste exceptions."],
  ["Dynamic watermarking", "Apply persistent watermarks dynamically for accountable sharing across partner ecosystems."],
  ["Secure external collaboration", "Integrate user-detail repositories with enterprise identity and collaboration workflows for secure sharing."]
];

const regulations = [
  "Cybersecurity Maturity Model Certification",
  "GDPR",
  "NIST SP 800-171",
  "RBI",
  "ISO 27001",
  "NIS2",
  "DFARS",
  "ITAR",
  "Agentic Cybersecurity Risk"
];

const relatedTopics = [
  {
    title: "Regulatory compliance",
    text: "Meet global data security regulations such as NIST, ITAR, CMMC, DPDP, and NIS2 while keeping teams productive."
  },
  {
    title: "Third party risk management",
    text: "Protect data shared with vendors, manufacturers, and suppliers across complex manufacturing supply chains."
  }
];

const resources = [
  ["Whitepaper", "Manufacturing", "Five Lessons from Major Attacks on Manufacturing Supply Chains"],
  ["Webinar", "Manufacturing", "Speeding Up on the Road to Manufacturing Supply Chain Fourth Party Risk"],
  ["Blueprint", "Manufacturing", "10 Essential Protocols for Keeping Third-Party Cybersecurity Risks in Manufacturing"]
];
---

<BaseLayout
  title="Manufacturing | seclore"
  description="Seclore data protection solutions for manufacturing, IP protection, CAD security, supplier collaboration, and regulatory compliance."
>
  <main id="top" class="manufacturing-page">
    <Nav />

    <section class="manufacturing-hero">
      <div class="hero-copy">
        <span>Manufacturing</span>
        <h1>Seclore for Manufacturing</h1>
        <p>
          Secure product designs, intellectual property, CAD files, blueprints, and other
          manufacturing IP with shared visibility and control across internal teams and partners.
        </p>
        <a class="primary-button alert" href="#demo">Book a Demo</a>
      </div>
      <div class="factory-visual" aria-label="Manufacturing floor visual">
        <span></span><span></span><span></span><span></span>
      </div>
    </section>

    <section class="trust-strip">
      <h2>Trusted by industry-leading enterprises</h2>
      <div class="trust-row">
        {trustLogos.map((logo) => <span>{logo}</span>)}
      </div>
    </section>

    <section class="split-section">
      <div class="photo-card lab" aria-label="Manufacturing cybersecurity visual">
        <span></span><span></span><span></span>
      </div>
      <div>
        <h2>Foster productivity and innovation through cybersecurity</h2>
        <p>
          In manufacturing today, protecting intellectual property, R&D, and sensitive data is
          central to keeping operations productive and supply chains resilient.
        </p>
        <p>
          Seclore data-centric security enables enterprises to safeguard product designs, CAD
          drawings, equipment files, and supplier data while maintaining collaboration.
        </p>
        <a class="primary-button dark" href="#resources">Get the Whitepaper</a>
      </div>
    </section>

    <section class="success-section">
      <div class="section-heading centered">
        <h2>Why Seclore is essential for success in manufacturing</h2>
        <p>
          Leverage manufacturing data protection to secure product IP, lower supplier risk, and
          maintain control after sensitive files leave enterprise systems.
        </p>
      </div>
      <div class="card-grid three">
        {successCards.map((card) => (
          <article class="feature-card">
            <div class="hex-icon"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="offerings-section">
      <div class="section-heading centered">
        <h2>Offerings for manufacturing organizations</h2>
      </div>
      <div class="offering-list">
        {offerings.map(([title, text]) => (
          <article class="offering-card">
            <div class="line-icon"></div>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="demo-band" id="demo">
      <div class="demo-copy">
        <h2>Meet with a data-centric security expert</h2>
        <p>
          See Seclore data-centric security platform in action, and learn how to protect and
          control your digital assets wherever they go.
        </p>
        <ul>
          <li>Digital asset security for every user, device, app, and cloud</li>
          <li>Granular access, usage, and privacy controls</li>
          <li>Never losing control or visibility of your digital assets</li>
        </ul>
      </div>
      <form class="manufacturing-form" data-endpoint="/api/demo">
        <h3>Seclore Demo</h3>
        <label>Email<input name="email" type="email" required /></label>
        <label>First Name<input name="name" required minlength="2" /></label>
        <label>Last Name<input name="lastName" /></label>
        <label>Company Name<input name="company" required /></label>
        <label>Job Title<input name="role" /></label>
        <label>Phone Number<input name="phone" /></label>
        <label>Country<select name="country"><option>Please Select</option><option>United States</option><option>India</option></select></label>
        <button class="primary-button" type="submit">Submit</button>
        <p class="form-status" role="status" aria-live="polite"></p>
      </form>
    </section>

    <section class="story-section">
      <article class="story-card">
        <span>American Auto Co.</span>
        <blockquote>
          "We use Seclore for our MIP/DLP where we need to share confidential designs to suppliers.
          Data owners can now manage shared information without slowing the business."
        </blockquote>
        <strong>Global Procurement Team</strong>
        <a class="primary-button dark" href="#resources">Customer Story</a>
      </article>
    </section>

    <section class="regulations-section">
      <div class="section-heading centered">
        <h2>Manufacturing industry regulations</h2>
        <p>Seclore helps manufacturers meet or exceed industry standards.</p>
        <a class="primary-button dark" href="#demo">Get in Touch</a>
      </div>
      <div class="regulation-grid">
        {regulations.map((item) => (
          <article>
            <h3>{item}</h3>
            <p>
              Protect sensitive manufacturing data, supplier information, technical files, and
              regulated intellectual property with persistent controls.
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="related-section">
      <div class="section-heading centered">
        <h2>Related topics</h2>
        <p>
          Add a layer of cybersecurity and regulatory compliance controls at the data level to
          ensure protection anywhere data is used or stored.
        </p>
      </div>
      <div class="related-grid">
        {relatedTopics.map((item) => (
          <article class="related-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <a href="#demo">Learn More</a>
          </article>
        ))}
      </div>
    </section>

    <section class="resources-section" id="resources">
      <div class="section-heading centered">
        <h2>Manufacturing industry resources</h2>
      </div>
      <div class="resource-grid">
        {resources.map(([type, tag, title]) => (
          <article class="resource-card">
            <span>{type}</span>
            <em>{tag}</em>
            <h3>{title}</h3>
            <a href="#demo">View More</a>
          </article>
        ))}
      </div>
      <div class="slide-controls" aria-label="Resource carousel controls">
        <button type="button" aria-label="Previous resource">&lt;</button>
        <button type="button" aria-label="Next resource">&gt;</button>
      </div>
    </section>
  </main>

  <script is:inline define:vars={{ apiBase }}>
    document.querySelectorAll(".manufacturing-form").forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const status = form.querySelector(".form-status");
        const button = form.querySelector("button[type='submit']");
        const payload = Object.fromEntries(new FormData(form).entries());

        status.textContent = "Sending...";
        status.className = "form-status";
        button.disabled = true;

        try {
          const response = await fetch(`${apiBase}${form.dataset.endpoint}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });
          const data = await response.json();
          if (!response.ok) throw new Error(data.message || "Request failed.");
          form.reset();
          status.textContent = data.message || "Submitted successfully.";
          status.classList.add("success");
        } catch (error) {
          status.textContent = error.message || "Something went wrong.";
          status.classList.add("error");
        } finally {
          button.disabled = false;
        }
      });
    });
  </script>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f2f3f5;
    --page-text: #232128;
    --page-muted: #636773;
    --purple: #5b2bd7;
    --wine: #2b1024;
    --alert: #eb3157;
    --orange: #ff9500;
    --plum: #8d204e;
    --card: #ffffff;
    --line: rgba(29, 29, 34, 0.13);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #5b2bd7;
    --demo-button-text: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  body { margin: 0; background: var(--page-bg); color: var(--page-text); }
  a { color: inherit; text-decoration: none; }
  button, input, textarea, select { font: inherit; }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    font-size: 1.35rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .nav-links, .nav-utilities { align-items: center; display: flex; }
  .nav-links { flex: 1 1 auto; gap: clamp(18px, 2.2vw, 34px); justify-content: center; min-width: 0; }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:hover .nav-trigger,
  .nav-item:focus-within .nav-trigger { color: var(--header-text); }

  .nav-item { position: static; }
  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret { transform: rotate(225deg) translateY(-1px); }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }

  .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns { display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .mega-column, .mega-sublinks { display: grid; }
  .mega-column { gap: 10px; }
  .mega-title { color: var(--dropdown-title); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .mega-link, .mega-link-group { border: 1px solid transparent; border-radius: 8px; }
  .mega-link { display: grid; gap: 5px; padding: 13px; }
  .mega-link strong { color: var(--dropdown-text); }
  .mega-link small, .mega-sublinks a { color: var(--dropdown-muted); }
  .mega-link:hover, .mega-link-group:hover { background: var(--dropdown-link-hover); border-color: var(--dropdown-link-border); }
  .mega-link-group { display: grid; gap: 4px; padding: 4px; }
  .mega-sublinks { gap: 2px; padding: 0 9px 8px 22px; }
  .mega-sublinks a { font-size: 0.84rem; padding: 5px 0; }
  .mega-feature { align-content: end; background: var(--dropdown-feature-bg); border: 1px solid var(--dropdown-feature-border); border-radius: 8px; display: grid; min-height: 268px; padding: 24px; }
  .mega-feature span, .mega-feature em { color: var(--dropdown-title); }
  .mega-feature strong { color: var(--dropdown-text); font-size: 1.35rem; line-height: 1.18; margin-top: auto; }

  .nav-utilities { flex: 0 0 auto; gap: clamp(12px, 1.5vw, 20px); margin-left: clamp(12px, 2vw, 28px); }
  .utility-link, .language-button, .utility-icon, .theme-toggle { display: none; }

  .demo-button,
  .primary-button,
  .secondary-button {
    align-items: center;
    border: 0;
    border-radius: 7px;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.88rem;
    font-weight: 850;
    justify-content: center;
    min-height: 39px;
    padding: 0 18px;
  }

  .demo-button, .primary-button { background: var(--demo-button-bg); color: var(--demo-button-text); }
  .primary-button.alert { background: var(--alert); }
  .primary-button.dark { background: #211326; color: #ffffff; }

  .nav-toggle { background: transparent; border: 0; display: none; height: 42px; width: 42px; }
  .nav-toggle span { background: var(--header-text); display: block; height: 2px; margin: 6px 0; width: 24px; }

  h1, h2, h3, p { margin-top: 0; }
  h1 {
    font-size: clamp(3rem, 6vw, 5.9rem);
    font-weight: 500;
    line-height: 0.98;
    margin-bottom: 22px;
    overflow-wrap: break-word;
  }
  h2 { font-size: clamp(2rem, 4vw, 4rem); font-weight: 450; line-height: 1.05; }
  p, li { color: var(--page-muted); line-height: 1.6; }

  .manufacturing-hero {
    align-items: center;
    background: var(--wine);
    color: #ffffff;
    display: grid;
    gap: 44px;
    grid-template-columns: minmax(0, 0.92fr) minmax(320px, 1.08fr);
    padding: clamp(56px, 7vw, 86px) clamp(18px, 4vw, 52px);
  }

  .manufacturing-hero span {
    display: block;
    font-size: 0.88rem;
    font-weight: 850;
    letter-spacing: 0.05em;
    margin-bottom: 18px;
    text-transform: uppercase;
  }

  .manufacturing-hero p { color: rgba(255, 255, 255, 0.82); max-width: 620px; }

  .factory-visual {
    background: linear-gradient(135deg, #ffb34f, #516b7e 38%, #132433);
    border-radius: 8px;
    min-height: 330px;
    overflow: hidden;
    position: relative;
  }

  .factory-visual span {
    background: rgba(255, 255, 255, 0.72);
    height: 3px;
    left: -10%;
    position: absolute;
    width: 130%;
  }

  .factory-visual span:nth-child(1) { top: 28%; transform: rotate(-18deg); }
  .factory-visual span:nth-child(2) { top: 44%; transform: rotate(-12deg); opacity: 0.7; }
  .factory-visual span:nth-child(3) { top: 62%; transform: rotate(-8deg); opacity: 0.55; }
  .factory-visual span:nth-child(4) { background: #f58b22; bottom: 0; height: 72px; left: 0; width: 100%; }

  .trust-strip { background: var(--page-bg); padding: 48px clamp(18px, 4vw, 52px); text-align: center; }
  .trust-strip h2 { color: #a34462; font-size: 0.88rem; letter-spacing: 0.04em; margin-bottom: 32px; text-transform: uppercase; }
  .trust-row { align-items: center; display: grid; gap: 24px; grid-template-columns: repeat(5, minmax(0, 1fr)); }
  .trust-row span { color: rgba(36, 35, 41, 0.48); font-weight: 900; }

  .split-section,
  .demo-band {
    align-items: center;
    display: grid;
    gap: clamp(30px, 5vw, 72px);
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px);
  }

  .split-section, .offerings-section, .story-section, .resources-section, .manufacturing-footer { background: var(--card); }

  .photo-card { border-radius: 8px; min-height: 320px; overflow: hidden; position: relative; }
  .photo-card span { position: absolute; }
  .lab { background: linear-gradient(135deg, #d7ecf6, #ffffff 48%, #315b76); }
  .lab span { background: linear-gradient(145deg, #84a9bc, #ffffff); border-radius: 50%; height: 74px; top: 34%; width: 74px; }
  .lab span:nth-child(1) { left: 18%; }
  .lab span:nth-child(2) { left: 43%; top: 26%; }
  .lab span:nth-child(3) { right: 18%; top: 42%; }

  .section-heading { margin: 0 auto 36px; max-width: 1040px; }
  .centered { text-align: center; }
  .success-section, .related-section, .regulations-section { background: var(--page-bg); padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px); }
  .card-grid { display: grid; gap: 22px; margin-inline: auto; max-width: 1120px; }
  .card-grid.three { grid-template-columns: repeat(3, minmax(0, 1fr)); }

  .feature-card,
  .offering-card,
  .manufacturing-form,
  .story-card,
  .resource-card,
  .regulation-grid article {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: clamp(24px, 4vw, 38px);
  }

  .hex-icon {
    background: linear-gradient(135deg, var(--orange), var(--alert));
    clip-path: polygon(25% 4%, 75% 4%, 100% 50%, 75% 96%, 25% 96%, 0 50%);
    height: 44px;
    margin-bottom: 20px;
    width: 44px;
  }

  .feature-card:nth-child(2) .hex-icon { background: linear-gradient(135deg, var(--alert), #ff7a8c); }
  .feature-card:nth-child(3) .hex-icon { background: linear-gradient(135deg, var(--plum), #c53772); }

  .offerings-section, .resources-section { padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px); }
  .offering-list { display: grid; gap: 18px; margin-inline: auto; max-width: 1120px; }
  .line-icon { border: 2px solid #ff4267; border-radius: 12px; height: 42px; margin-bottom: 20px; position: relative; width: 42px; }
  .line-icon::before, .line-icon::after { background: #ff4267; content: ""; height: 2px; left: 10px; position: absolute; right: 10px; }
  .line-icon::before { top: 14px; }
  .line-icon::after { bottom: 14px; }

  .demo-band { background: linear-gradient(135deg, #dceaff, #f2eaff); }
  .demo-copy ul { padding-left: 20px; }
  .manufacturing-form h3 { text-align: center; }
  .manufacturing-form label { color: var(--page-text); display: grid; font-size: 0.88rem; gap: 8px; margin-bottom: 14px; }
  .manufacturing-form input, .manufacturing-form select {
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(15, 23, 42, 0.16);
    border-radius: 4px;
    color: #111827;
    min-height: 40px;
    padding: 10px;
  }

  .form-status { min-height: 24px; }
  .form-status.success { color: #087f6f; }
  .form-status.error { color: #bd2b2b; }

  .story-section, .related-section, .resources-section { padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px); }
  .story-card { margin-inline: auto; max-width: 1180px; }
  .story-card > span, .resource-card span, .resource-card em {
    color: var(--page-muted);
    display: block;
    font-size: 0.8rem;
    font-style: normal;
    font-weight: 900;
    letter-spacing: 0.04em;
    margin-bottom: 22px;
    text-transform: uppercase;
  }

  .story-card blockquote { font-size: clamp(1.1rem, 2vw, 1.55rem); line-height: 1.45; margin: 0 0 24px; }
  .story-card strong { color: var(--purple); display: block; margin-bottom: 20px; text-transform: uppercase; }

  .regulation-grid { display: grid; gap: 18px; grid-template-columns: repeat(2, minmax(0, 1fr)); margin-inline: auto; max-width: 1120px; }
  .related-grid { display: grid; gap: 36px; grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .related-card a, .resource-card a { color: var(--page-text); font-weight: 900; }
  .resource-grid { display: grid; gap: 32px; grid-template-columns: repeat(3, minmax(0, 1fr)); margin-inline: auto; max-width: 980px; }
  .resource-card { min-height: 340px; }
  .slide-controls { display: flex; gap: 10px; margin-top: 28px; }
  .slide-controls button { background: var(--card); border: 1px solid var(--line); border-radius: 50%; height: 36px; width: 36px; }

  .manufacturing-footer { border-top: 1px solid var(--line); padding: 34px clamp(18px, 4vw, 52px); }
  .footer-lines { border-block: 1px solid var(--line); margin: 30px 0; }
