---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const trustLogos = ["I-works", "ClayLogix", "FLEX", "Maruti Suzuki"];

const services = [
  {
    title: "Consulting",
    text: "Seclore consulting services bring pragmatic industry expertise and best practices to align data security operations with business outcomes. We take a phased approach and leverage expertise in specific areas to create and sustain long-term value."
  },
  {
    title: "Integration",
    text: "Automate protection by working with our team or verified partners to deploy existing integrations or build custom integrations for your business applications."
  },
  {
    title: "Training",
    text: "Work with our technical product experts to learn system functionalities and set up Seclore in your environment. Useful for new employees and current employees who need a refresh."
  },
  {
    title: "Support",
    text: "Take your Seclore implementation to the next level with designated technical support managers who know your business and improve how systems work together."
  }
];

const partnerStats = [
  "Partnering with SaaS companies around the world to help clients achieve their digital journey.",
  "Transformational technology requires a new, elevated form of agility and flexibility.",
  "International cybersecurity company specializing in IT services and software development.",
  "21st Century software integration and training to accelerate adoption and velocity."
];

const capabilityBlocks = [
  {
    id: "integrations",
    title: "Custom integrations",
    text: "Seclore provides pre-built connectors for the most common security and business applications. We understand that enterprise needs and business workflows are unique, so we also offer custom integration services to extend security to all environments.",
    bullets: [
      "Well-documented Seclore SDKs and APIs",
      "Application and data-source integrations",
      "Business application integrations",
      "Hybrid and multi-cloud environments",
      "Security product integrations like CASB and SIEM"
    ]
  },
  {
    id: "training",
    title: "Training and onboarding",
    text: "Leveraging any solution's full potential requires well-trained users and administrators who can confidently configure and manage it. All while ensuring relevant processes are developed to work seamlessly with your existing operations.",
    bullets: [
      "Hands-on training workshops",
      "Installation and configuration",
      "End-user and administrator training",
      "Systems administration",
      "Policy development"
    ]
  },
  {
    id: "support",
    title: "Flexible support",
    text: "Seclore offers designated or dedicated support engineers to ensure our data-centric security solution meets the growing needs of your unique business and that we are a valued part of your security stack.",
    bullets: [
      "Priority ticket routing",
      "Quarterly business reviews",
      "Unique email and phone number",
      "Premium technical support",
      "Monthly case reviews"
    ]
  },
  {
    id: "consulting",
    title: "Consulting",
    text: "We understand your business is unique, and you may not know where to start in your data protection journey. What's important is that you know where to start, and you can count on us to be your trusted partner.",
    bullets: [
      "Data-security strategy and architecture",
      "Business process alignment",
      "Risk scoring",
      "Gap analysis",
      "Cloud migration"
    ]
  }
];
---

<BaseLayout
  title="Professional Services | seclore"
  description="Seclore professional services for consulting, integrations, training, support, onboarding, and data-centric security adoption."
>
  <main id="top" class="services-page">
    <Nav />

    <section class="services-hero">
      <div class="hero-copy">
        <span>Services</span>
        <h1>Professional Services</h1>
        <p>
          Seclore provides in-depth product and security expertise, onboarding, training, custom integrations, and managed
          services. Our experts are available to help you adopt data-centric security solutions that meet your business,
          security, and regulatory goals.
        </p>
        <a class="primary-button alert" href="#contact">Contact Us</a>
      </div>
      <img
        src="/assets/professional-services-hero.png"
        alt="Professional services support specialist"
        class="hero-photo"
      />
    </section>

    <section class="trust-strip">
      <h2>Trusted by industry-leading enterprises</h2>
      <div class="trust-row">
        {trustLogos.map((logo) => <span>{logo}</span>)}
      </div>
    </section>

    <section class="split-section intro-section">
      <img
        src="/assets/professional-services-implementation.png"
        alt="Team planning a Seclore implementation"
        class="feature-photo"
      />
      <div>
        <h2>Get the most out of your Seclore implementation</h2>
        <p>
          Modern enterprises are more interconnected and complex than ever, often using an organic mix of on-prem and cloud
          environments supporting a diverse set of siloed business and security applications.
        </p>
        <p>
          Seclore's professional services help your business get value faster, adapt your implementation to real workflows,
          and support long-term adoption across teams and markets.
        </p>
        <a class="primary-button dark" href="#contact">Contact Us</a>
      </div>
    </section>

    <section class="services-offer">
      <div class="section-heading centered">
        <h2>Services we offer</h2>
      </div>
      <div class="service-list">
        {services.map((service) => (
          <article class="service-card">
            <div class="line-icon"></div>
            <h3>{service.title}</h3>
            <p>{service.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="partner-section">
      <div class="section-heading centered">
        <h2>Verified partner network</h2>
        <a class="primary-button alert" href="/partners/register/">Become a Partner</a>
      </div>
      <div class="partner-grid">
        {partnerStats.map((stat) => <p>{stat}</p>)}
      </div>
      <blockquote>
        "It's a great privilege to solve the unique business challenges our enterprise customers face, but more than that,
        professional services is about creating the partner ecosystem and delivering the interoperability that platforms like
        Seclore provide, as a valued member of today's highly integrated security community."
        <strong>Vishal Galip, PhD</strong>
        <span>Chief CUSTOMER Officer, Seclore</span>
      </blockquote>
    </section>

    <section class="capability-section" id="contact">
      {capabilityBlocks.map((block, index) => (
        <article class:list={["capability-block", index % 2 === 1 && "reverse"]} id={block.id}>
          <div>
            <h2>{block.title}</h2>
            <p>{block.text}</p>
          </div>
          <ul>
            {block.bullets.map((bullet) => <li>{bullet}</li>)}
          </ul>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f2f3f5;
    --page-text: #232128;
    --page-muted: #636773;
    --purple: #5b2bd7;
    --wine: #2b1024;
    --alert: #eb3157;
    --card: #ffffff;
    --line: rgba(29, 29, 34, 0.13);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #5b2bd7;
    --demo-button-text: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  body { margin: 0; background: var(--page-bg); color: var(--page-text); }
  a { color: inherit; text-decoration: none; }
  button, input, textarea, select { font: inherit; }

  .site-header { align-items: center; background: var(--header-bg); border-bottom: 1px solid var(--header-border); box-shadow: var(--header-shadow); display: flex; gap: 18px; min-height: 68px; padding: 0 clamp(20px, 4vw, 42px) 0 22px; position: sticky; top: 0; z-index: 20; }
  .site-logo { color: var(--purple); font-size: 1.35rem; font-weight: 950; letter-spacing: 0.04em; margin-right: clamp(14px, 2vw, 28px); text-transform: uppercase; }
  .nav-links, .nav-utilities { align-items: center; display: flex; }
  .nav-links { flex: 1 1 auto; gap: clamp(18px, 2.2vw, 34px); justify-content: center; min-width: 0; }
  .nav-links > a, .nav-trigger { align-items: center; background: transparent; border: 0; color: var(--header-muted); cursor: pointer; display: inline-flex; font-size: 0.98rem; font-weight: 800; gap: 8px; min-height: 68px; padding: 0; }
  .nav-links > a:hover, .nav-trigger:hover, .nav-item:hover .nav-trigger, .nav-item:focus-within .nav-trigger { color: var(--header-text); }
  .nav-item { position: static; }
  .nav-caret { border-bottom: 2px solid currentColor; border-right: 2px solid currentColor; display: inline-block; height: 8px; transform: rotate(45deg) translateY(-2px); transition: transform 180ms ease; width: 8px; }
  .nav-item:hover .nav-caret, .nav-item:focus-within .nav-caret, .nav-item.is-open .nav-caret { transform: rotate(225deg) translateY(-1px); }
  .mega-menu { left: 22px; opacity: 0; pointer-events: none; position: absolute; right: clamp(20px, 4vw, 42px); top: calc(100% - 1px); transform: translateY(12px); transition: opacity 180ms ease, transform 180ms ease; }
  .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu, .nav-item.is-open .mega-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .mega-inner { background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px); border: 1px solid var(--dropdown-border); border-radius: 8px; box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2); display: grid; gap: 24px; grid-template-columns: minmax(0, 1fr) 320px; min-height: 320px; overflow: hidden; padding: 26px; }
  .mega-columns { display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .mega-column, .mega-sublinks { display: grid; }
  .mega-column { gap: 10px; }
  .mega-title { color: var(--dropdown-title); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .mega-link, .mega-link-group { border: 1px solid transparent; border-radius: 8px; }
  .mega-link { display: grid; gap: 5px; padding: 13px; }
  .mega-link strong { color: var(--dropdown-text); }
  .mega-link small, .mega-sublinks a { color: var(--dropdown-muted); }
  .mega-link:hover, .mega-link-group:hover { background: var(--dropdown-link-hover); border-color: var(--dropdown-link-border); }
  .mega-link-group { display: grid; gap: 4px; padding: 4px; }
  .mega-sublinks { gap: 2px; padding: 0 9px 8px 22px; }
  .mega-sublinks a { font-size: 0.84rem; padding: 5px 0; }
  .mega-feature { align-content: end; background: var(--dropdown-feature-bg); border: 1px solid var(--dropdown-feature-border); border-radius: 8px; display: grid; min-height: 268px; padding: 24px; }
  .mega-feature span, .mega-feature em { color: var(--dropdown-title); }
  .mega-feature strong { color: var(--dropdown-text); font-size: 1.35rem; line-height: 1.18; margin-top: auto; }
  .nav-utilities { flex: 0 0 auto; gap: clamp(12px, 1.5vw, 20px); margin-left: clamp(12px, 2vw, 28px); }
  .utility-link, .language-button, .utility-icon, .theme-toggle { display: none; }

  .demo-button, .primary-button { align-items: center; background: var(--demo-button-bg); border: 0; border-radius: 7px; color: var(--demo-button-text); cursor: pointer; display: inline-flex; font-size: 0.88rem; font-weight: 850; justify-content: center; min-height: 39px; padding: 0 18px; }
  .primary-button.alert { background: var(--alert); }
  .primary-button.dark { background: #211326; color: #ffffff; }
  .nav-toggle { background: transparent; border: 0; display: none; height: 42px; width: 42px; }
  .nav-toggle span { background: var(--header-text); display: block; height: 2px; margin: 6px 0; width: 24px; }

  h1, h2, h3, p { margin-top: 0; }
  h1 { font-size: clamp(3rem, 6vw, 5.7rem); font-weight: 500; line-height: 0.98; margin-bottom: 22px; overflow-wrap: break-word; }
  h2 { font-size: clamp(2rem, 4vw, 4rem); font-weight: 450; line-height: 1.05; }
  p, li { color: var(--page-muted); line-height: 1.6; }

  .services-hero { align-items: center; background: var(--wine); color: #ffffff; display: grid; gap: 44px; grid-template-columns: minmax(0, 0.92fr) minmax(320px, 1.08fr); padding: clamp(56px, 7vw, 86px) clamp(18px, 4vw, 52px); }
  .services-hero span { display: block; font-size: 0.88rem; font-weight: 850; letter-spacing: 0.05em; margin-bottom: 18px; text-transform: uppercase; }
  .services-hero p { color: rgba(255, 255, 255, 0.82); max-width: 620px; }
  .hero-photo, .feature-photo { border-radius: 8px; display: block; height: auto; object-fit: cover; width: 100%; }
  .hero-photo { box-shadow: 0 22px 48px rgba(0, 0, 0, 0.22); min-height: 300px; }

  .trust-strip { background: var(--page-bg); padding: 48px clamp(18px, 4vw, 52px); text-align: center; }
  .trust-strip h2 { color: #a34462; font-size: 0.88rem; letter-spacing: 0.04em; margin-bottom: 32px; text-transform: uppercase; }
  .trust-row { align-items: center; display: grid; gap: 24px; grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .trust-row span { color: rgba(36, 35, 41, 0.48); font-weight: 900; }

  .split-section { align-items: center; display: grid; gap: clamp(30px, 5vw, 72px); grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px); }
  .intro-section, .services-offer, .partner-section, .capability-section { background: var(--page-bg); }
  .section-heading { margin: 0 auto 36px; max-width: 1040px; }
  .centered { text-align: center; }
  .services-offer, .partner-section, .capability-section { padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px); }
  .service-list { display: grid; gap: 18px; margin-inline: auto; max-width: 1120px; }
  .service-card { background: var(--card); border: 1px solid var(--line); border-radius: 8px; padding: clamp(24px, 4vw, 38px); }
  .line-icon { border: 2px solid #ff4267; border-radius: 12px; height: 42px; margin-bottom: 20px; position: relative; width: 42px; }
  .line-icon::before, .line-icon::after { background: #ff4267; content: ""; height: 2px; left: 10px; position: absolute; right: 10px; }
  .line-icon::before { top: 14px; }
  .line-icon::after { bottom: 14px; }

  .partner-grid { display: grid; gap: 30px; grid-template-columns: repeat(4, minmax(0, 1fr)); margin: 64px auto 54px; max-width: 1120px; }
  .partner-grid p { color: #3f424a; font-size: 1rem; line-height: 1.55; }
  .partner-section blockquote { background: var(--card); border-radius: 8px; font-size: clamp(1.35rem, 2.6vw, 2.2rem); line-height: 1.15; margin: 0 auto; max-width: 1120px; padding: clamp(32px, 5vw, 58px); text-align: center; }
  .partner-section blockquote strong { color: var(--purple); display: block; font-size: 0.95rem; margin-top: 28px; text-transform: uppercase; }
  .partner-section blockquote span { color: var(--page-muted); display: block; font-size: 0.85rem; margin-top: 6px; }

  .capability-section { display: grid; gap: clamp(54px, 9vw, 120px); }
  .capability-block { align-items: start; display: grid; gap: clamp(28px, 6vw, 80px); grid-template-columns: minmax(0, 1fr) minmax(260px, 0.9fr); margin-inline: auto; max-width: 1120px; width: 100%; }
  .capability-block.reverse > div { order: 2; }
  .capability-block ul { margin: 0; padding-left: 20px; }
  .capability-block li { margin-bottom: 8px; }

  .services-footer { background: var(--card); border-top: 1px solid var(--line); padding: 34px clamp(18px, 4vw, 52px); }
  .footer-lines { border-block: 1px solid var(--line); margin: 30px 0; }
  .footer-lines details { border-bottom: 1px solid var(--line); padding: 18px 0; }
  .footer-lines details:last-child { border-bottom: 0; }
  .footer-lines summary { cursor: pointer; font-weight: 800; }
  .footer-logo { color: var(--purple); display: block; font-size: 1.45rem; font-weight: 950; letter-spacing: 0.04em; margin-bottom: 24px; text-transform: uppercase; }
  .store-row { display: grid; gap: 9px; margin: 26px 0; max-width: 160px; }
  .store-row span { background: #1a1421; border-radius: 5px; color: #ffffff; font-size: 0.85rem; font-weight: 800; padding: 10px 16px; }
  .legal { border-top: 1px solid var(--line); font-size: 0.86rem; padding-top: 26px; }

  @media (max-width: 1180px) {
    .nav-toggle { display: block; margin-left: auto; order: 1; }
    .site-header { flex-wrap: wrap; }
    .site-logo { order: 0; }
    .nav-links { background: var(--header-bg); border-top: 1px solid var(--header-border); display: none; flex: 1 0 100%; order: 2; padding: 10px 0 14px; }
    .nav-links.open { align-items: stretch; display: grid; }
    .nav-links > a, .nav-trigger { justify-content: space-between; min-height: 48px; width: 100%; }
    .nav-item { display: grid; }
    .mega-menu { display: none; opacity: 1; position: static; transform: none; }
    .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu { display: none; }
    .nav-item.is-open .mega-menu { display: block; }
    .mega-inner { box-shadow: none; grid-template-columns: 1fr; min-height: 0; padding: 16px; }
    .nav-utilities { align-items: stretch; display: flex; margin-left: auto; order: 0; }
  }

  @media (max-width: 900px) {
    .services-hero, .split-section, .capability-block { grid-template-columns: 1fr; }
    .trust-row { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .partner-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .capability-block.reverse > div { order: 0; }
  }

  @media (max-width: 520px) {
    h1 { font-size: 2.35rem; line-height: 1.05; }
    h2 { font-size: 2rem; }
    .partner-grid { grid-template-columns: 1fr; }
    .hero-photo { min-height: 220px; }
  }
</style>
