---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:5000";

const trustLogos = ["MICRON", "FLEX", "RENESAS", "SOFTSERVE", "CORNING"];

const trustCards = [
  {
    title: "Protect IP",
    text: "Protect chip designs, masks, manufacturing drawings, firmware, test data, and go-to-market plans wherever they travel."
  },
  {
    title: "Secure collaboration",
    text: "Enable suppliers, foundries, OSATs, and partners to work on protected files with usage controls and complete visibility."
  },
  {
    title: "Global compliance",
    text: "Meet obligations for export controls, privacy, and contractual protection with persistent access, audit, and revocation controls."
  }
];

const offerings = [
  ["Enterprise digital rights management", "Protect your IP and confidential files with granular controls, dynamic watermarking, and offline access across locations and devices."],
  ["Neutral CAD support", "Protect neutral CAD files with edit, view, print, rights management, dynamic watermarking, global tracking, and granular access control rules."],
  ["APIs and SDKs", "Extend data-centric security into enterprise applications by integrating your PLM, PDM, or collaboration system with protection and usage policies."],
  ["Agnostic file controls", "Reduce complexity by enabling browser-based access for customers, suppliers, and vendors, and keep IP protected without forcing a special network path."],
  ["Geo-fencing and access revocation", "Control data flows based on location, preventing unauthorized cross-border sharing and mitigating compliance risks."],
  ["Visibility into supply chain", "Get visibility into downstream supplier files so No-Tell, No-Use data leaks and insider risks can be investigated across suppliers and partners."]
];

const regulations = [
  {
    title: "DPDP Act",
    text: "Support responsible handling of personal and business information across design, collaboration, and supplier workflows."
  },
  {
    title: "International Traffic in Arms Regulations",
    text: "Control access to regulated technical files, design exports, and supplier collaboration across borders."
  },
  {
    title: "NIST SP 800-171",
    text: "Protect controlled unclassified information and technical data with persistent access, use, and audit controls."
  },
  {
    title: "GDPR",
    text: "Apply privacy-aware access controls, usage visibility, and revocation to sensitive personal and workforce data."
  }
];

const relatedProducts = [
  {
    title: "Enterprise Digital Rights Management",
    text: "Protect chips, boards, test reports, contracts, source files, and supply chain data with persistent controls across any file."
  },
  {
    title: "Risk Insights and Reporting",
    text: "Get granular insight into risk management and see how files are used, shared, and protected across your ecosystem."
  }
];

const resources = [
  ["Whitepaper", "Semiconductor", "AI Brings Speed, Quality, and Cybersecurity Risk to the Semiconductor Industry"],
  ["Whitepaper", "Semiconductor", "Safeguarding Intellectual Property in the Semiconductor Equipment Industry"],
  ["Whitepaper", "Semiconductor", "Critical Assets Protection and Control for the Semiconductor Industry"]
];
---

<BaseLayout
  title="Semiconductor | seclore"
  description="Seclore data-centric security for semiconductor IP, CAD protection, supply chain collaboration, and compliance."
>
  <main id="top" class="semiconductor-page">
    <Nav />

    <section class="semiconductor-hero">
      <div class="hero-copy">
        <span>Semiconductor</span>
        <h1>Seclore for Semiconductor</h1>
        <p>
          Expand your competitive advantage with persistent data protection, visibility, and control over the digital assets,
          designs, and collaboration workflows that power chip innovation.
        </p>
        <a class="primary-button alert" href="#demo">Book a Demo</a>
      </div>
      <div class="wafer-visual" aria-label="Semiconductor lab visual">
        <div class="lab-panel"></div>
        <div class="lab-figure"></div>
        <div class="wafer-disc"></div>
        <div class="chip-grid"></div>
      </div>
    </section>

    <section class="trust-strip">
      <h2>Trusted by industry-leading enterprises</h2>
      <div class="trust-row">
        {trustLogos.map((logo) => <span>{logo}</span>)}
      </div>
    </section>

    <section class="split-section">
      <div class="monitor-visual" aria-label="Protected semiconductor design visual">
        <div class="monitor-screen">
          <div class="cad-shape"></div>
          <div class="screen-lock"></div>
        </div>
        <div class="monitor-stand"></div>
      </div>
      <div>
        <h2>Persistent security for your semiconductor IP throughout its lifecycle</h2>
        <p>
          Semiconductor collaboration is critical to the semiconductor industry, but security is still too often limited to
          perimeter controls and document repositories.
        </p>
        <p>
          Seclore helps teams protect highly valuable chip designs, masks, firmware, contracts, and test files with controls
          that follow the data as it moves through fabs, suppliers, engineering teams, and customers.
        </p>
        <a class="primary-button dark" href="#resources">Get the Whitepaper</a>
      </div>
    </section>

    <section class="trust-reasons">
      <div class="section-heading centered">
        <h2>Why semiconductor pioneers trust Seclore</h2>
        <p>
          In the flow of growing global supply chains, an increasing need for external collaboration, and evolving cyber
          threats, traditional perimeter-based security is no longer good enough.
        </p>
      </div>
      <div class="card-grid three">
        {trustCards.map((card) => (
          <article class="feature-card">
            <div class="hex-icon"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="offerings-section">
      <div class="section-heading centered">
        <h2>Offerings for semiconductor organizations</h2>
      </div>
      <div class="offering-list">
        {offerings.map(([title, text]) => (
          <article class="offering-card">
            <div class="line-icon"></div>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="demo-band" id="demo">
      <div class="demo-copy">
        <h2>Meet with a data-centric security expert</h2>
        <p>
          See our data-centric security platform in action, and learn how to protect and control your digital assets wherever
          they go.
        </p>
        <ul>
          <li>Digital asset security for every user, device, app, and cloud</li>
          <li>Granular access, usage, and privacy controls</li>
          <li>Never losing control or visibility of your digital assets</li>
        </ul>
        <strong>MICRON</strong>
        <strong>FLEX</strong>
      </div>
      <form class="semiconductor-form" data-endpoint="/api/demo">
        <h3>Seclore Demo</h3>
        <label>Email<input name="email" type="email" required /></label>
        <label>First Name<input name="name" required minlength="2" /></label>
        <label>Last Name<input name="lastName" /></label>
        <label>Company Name<input name="company" required /></label>
        <label>Job Title<input name="role" /></label>
        <label>Phone Number<input name="phone" /></label>
        <label>Country<select name="country"><option>Please Select</option><option>United States</option><option>India</option></select></label>
        <button class="primary-button" type="submit">Submit</button>
        <p class="form-status" role="status" aria-live="polite"></p>
      </form>
    </section>

    <section class="story-section">
      <article class="story-card">
        <span>Semiconductor manufacturer</span>
        <blockquote>
          "With Seclore, we have data-centric security where the security follows the data. Seclore was, and generally still
          is, the only solution that provides holistic protection where we store, use, and communicate data at Micron."
        </blockquote>
        <strong>Global IT Security</strong>
        <a class="primary-button dark" href="#resources">Customer Story</a>
      </article>
    </section>

    <section class="regulations-section">
      <div class="section-heading centered">
        <h2>Semiconductor industry regulations</h2>
        <p>Seclore helps semiconductor companies meet or exceed industry standards.</p>
        <a class="primary-button dark" href="#demo">Get in Touch</a>
      </div>
      <div class="regulation-grid">
        {regulations.map((item) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="related-section">
      <div class="section-heading centered">
        <h2>Data-centric security related products</h2>
        <p>
          Add a layer of cybersecurity and regulatory compliance controls at the data level to ensure protection is applied
          where it is needed most.
        </p>
      </div>
      <div class="related-products">
        {relatedProducts.map((item) => (
          <article class="related-product">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <a href="#demo">Learn More</a>
          </article>
        ))}
      </div>
    </section>

    <section class="resources-section" id="resources">
      <div class="section-heading centered">
        <h2>Semiconductor industry resources</h2>
      </div>
      <div class="resource-grid">
        {resources.map(([type, tag, title]) => (
          <article class="resource-card">
            <span>{type}</span>
            <em>{tag}</em>
            <h3>{title}</h3>
            <a href="#demo">View More</a>
          </article>
        ))}
      </div>
      <div class="slide-controls" aria-label="Resource carousel controls">
        <button type="button" aria-label="Previous resource">&lt;</button>
        <button type="button" aria-label="Next resource">&gt;</button>
      </div>
    </section>
  </main>

  <script is:inline define:vars={{ apiBase }}>
    document.querySelectorAll(".semiconductor-form").forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const status = form.querySelector(".form-status");
        const button = form.querySelector("button[type='submit']");
        const payload = Object.fromEntries(new FormData(form).entries());

        status.textContent = "Sending...";
        status.className = "form-status";
        button.disabled = true;

        try {
          const response = await fetch(`${apiBase}${form.dataset.endpoint}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });
          const data = await response.json();
          if (!response.ok) throw new Error(data.message || "Request failed.");
          form.reset();
          status.textContent = data.message || "Submitted successfully.";
          status.classList.add("success");
        } catch (error) {
          status.textContent = error.message || "Something went wrong.";
          status.classList.add("error");
        } finally {
          button.disabled = false;
        }
      });
    });
  </script>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f2f3f5;
    --page-text: #232128;
    --page-muted: #636773;
    --purple: #5b2bd7;
    --wine: #2b1024;
    --alert: #eb3157;
    --orange: #ff9500;
    --plum: #8d204e;
    --card: #ffffff;
    --line: rgba(29, 29, 34, 0.13);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #5b2bd7;
    --demo-button-text: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  body { margin: 0; background: var(--page-bg); color: var(--page-text); }
  a { color: inherit; text-decoration: none; }
  button, input, textarea, select { font: inherit; }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    font-size: 1.35rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .nav-links, .nav-utilities { align-items: center; display: flex; }
  .nav-links { flex: 1 1 auto; gap: clamp(18px, 2.2vw, 34px); justify-content: center; min-width: 0; }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:hover .nav-trigger,
  .nav-item:focus-within .nav-trigger { color: var(--header-text); }

  .nav-item { position: static; }
  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret { transform: rotate(225deg) translateY(-1px); }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }

  .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns { display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .mega-column, .mega-sublinks { display: grid; }
  .mega-column { gap: 10px; }
  .mega-title { color: var(--dropdown-title); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .mega-link, .mega-link-group { border: 1px solid transparent; border-radius: 8px; }
  .mega-link { display: grid; gap: 5px; padding: 13px; }
  .mega-link strong { color: var(--dropdown-text); }
  .mega-link small, .mega-sublinks a { color: var(--dropdown-muted); }
  .mega-link:hover, .mega-link-group:hover { background: var(--dropdown-link-hover); border-color: var(--dropdown-link-border); }
  .mega-link-group { display: grid; gap: 4px; padding: 4px; }
  .mega-sublinks { gap: 2px; padding: 0 9px 8px 22px; }
  .mega-sublinks a { font-size: 0.84rem; padding: 5px 0; }
  .mega-feature { align-content: end; background: var(--dropdown-feature-bg); border: 1px solid var(--dropdown-feature-border); border-radius: 8px; display: grid; min-height: 268px; padding: 24px; }
  .mega-feature span, .mega-feature em { color: var(--dropdown-title); }
  .mega-feature strong { color: var(--dropdown-text); font-size: 1.35rem; line-height: 1.18; margin-top: auto; }

  .nav-utilities { flex: 0 0 auto; gap: clamp(12px, 1.5vw, 20px); margin-left: clamp(12px, 2vw, 28px); }
  .utility-link, .language-button, .utility-icon, .theme-toggle { display: none; }

  .demo-button,
  .primary-button {
    align-items: center;
    background: var(--demo-button-bg);
    border: 0;
    border-radius: 7px;
    color: var(--demo-button-text);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.88rem;
    font-weight: 850;
    justify-content: center;
    min-height: 39px;
    padding: 0 18px;
  }

  .primary-button.alert { background: var(--alert); }
  .primary-button.dark { background: #211326; color: #ffffff; }

  .nav-toggle { background: transparent; border: 0; display: none; height: 42px; width: 42px; }
  .nav-toggle span { background: var(--header-text); display: block; height: 2px; margin: 6px 0; width: 24px; }

  h1, h2, h3, p { margin-top: 0; }
  h1 {
    font-size: clamp(3rem, 6vw, 5.9rem);
    font-weight: 500;
    line-height: 0.98;
    margin-bottom: 22px;
    overflow-wrap: break-word;
  }
  h2 { font-size: clamp(2rem, 4vw, 4rem); font-weight: 450; line-height: 1.05; }
  p, li { color: var(--page-muted); line-height: 1.6; }

  .semiconductor-hero {
    align-items: center;
    background: var(--wine);
    color: #ffffff;
    display: grid;
    gap: 44px;
    grid-template-columns: minmax(0, 0.92fr) minmax(320px, 1.08fr);
    padding: clamp(56px, 7vw, 86px) clamp(18px, 4vw, 52px);
  }

  .semiconductor-hero span {
    display: block;
    font-size: 0.88rem;
    font-weight: 850;
    letter-spacing: 0.05em;
    margin-bottom: 18px;
    text-transform: uppercase;
  }

  .semiconductor-hero p { color: rgba(255, 255, 255, 0.82); max-width: 620px; }

  .wafer-visual {
    background: linear-gradient(135deg, #d9f0ff, #ffffff 43%, #68a8c9);
    border-radius: 8px;
    min-height: 330px;
    overflow: hidden;
    position: relative;
  }

  .lab-panel {
    background: linear-gradient(180deg, rgba(32, 117, 162, 0.2), rgba(32, 117, 162, 0));
    height: 100%;
    left: 0;
    position: absolute;
    top: 0;
    width: 62%;
  }

  .lab-figure {
    background: linear-gradient(150deg, #edf8ff, #8fd2f0);
    border-radius: 56% 44% 0 0;
    height: 220px;
    position: absolute;
    right: 16%;
    top: 34px;
    width: 170px;
  }

  .lab-figure::before {
    background: #e9f8ff;
    border-radius: 50%;
    content: "";
    height: 74px;
    left: 50px;
    position: absolute;
    top: -22px;
    width: 74px;
  }

  .wafer-disc {
    background:
      radial-gradient(circle at 32% 32%, rgba(255, 255, 255, 0.88), transparent 12%),
      conic-gradient(from 210deg, #d61857, #ff9148, #8ccbe9, #2870b4, #6336c5, #d61857);
    border-radius: 50%;
    bottom: 42px;
    box-shadow: 0 22px 38px rgba(30, 41, 59, 0.22);
    height: 150px;
    left: 9%;
    position: absolute;
    width: 150px;
  }

  .chip-grid {
    background:
      linear-gradient(rgba(255, 255, 255, 0.58) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.58) 1px, transparent 1px),
      rgba(31, 80, 115, 0.2);
    background-size: 22px 22px;
    border: 1px solid rgba(255, 255, 255, 0.56);
    bottom: 24px;
    height: 118px;
    position: absolute;
    right: 6%;
    transform: perspective(300px) rotateX(52deg) rotateZ(-8deg);
    width: 210px;
  }

  .trust-strip { background: var(--page-bg); padding: 48px clamp(18px, 4vw, 52px); text-align: center; }
  .trust-strip h2 { color: #a34462; font-size: 0.88rem; letter-spacing: 0.04em; margin-bottom: 32px; text-transform: uppercase; }
  .trust-row { align-items: center; display: grid; gap: 24px; grid-template-columns: repeat(5, minmax(0, 1fr)); }
  .trust-row span { color: rgba(36, 35, 41, 0.48); font-weight: 900; }

  .split-section,
  .demo-band {
    align-items: center;
    display: grid;
    gap: clamp(30px, 5vw, 72px);
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px);
  }

  .split-section, .offerings-section, .story-section, .resources-section, .semiconductor-footer { background: var(--card); }

  .monitor-visual {
    align-items: center;
    display: grid;
    justify-items: center;
    min-height: 360px;
  }

  .monitor-screen {
    background:
      linear-gradient(135deg, rgba(234, 250, 255, 0.84), rgba(255, 255, 255, 0.95)),
      linear-gradient(rgba(22, 99, 135, 0.12) 1px, transparent 1px),
      linear-gradient(90deg, rgba(22, 99, 135, 0.12) 1px, transparent 1px);
    background-size: auto, 26px 26px, 26px 26px;
    border: 10px solid #e8eef3;
    box-shadow: 0 16px 32px rgba(17, 24, 39, 0.16);
    height: 250px;
    position: relative;
    width: min(100%, 430px);
  }

  .monitor-screen::after {
    background: #d7dde5;
    bottom: -22px;
    content: "";
    height: 12px;
    left: 36%;
    position: absolute;
    width: 28%;
  }

  .cad-shape {
    background: linear-gradient(135deg, #172335, #a98a64);
    clip-path: polygon(14% 62%, 42% 14%, 88% 38%, 72% 78%, 28% 82%);
    height: 128px;
    left: 74px;
    position: absolute;
    top: 50px;
    transform: rotate(10deg);
    width: 220px;
  }

  .screen-lock {
    background: #ffffff;
    border: 2px solid #ef6b82;
    bottom: 42px;
    box-shadow: 0 10px 22px rgba(68, 32, 46, 0.16);
    height: 72px;
    position: absolute;
    right: 46px;
    width: 72px;
  }

  .screen-lock::before {
    border: 4px solid #ef6b82;
    border-bottom: 0;
    border-radius: 18px 18px 0 0;
    content: "";
    height: 22px;
    left: 17px;
    position: absolute;
    top: 12px;
    width: 30px;
  }

  .screen-lock::after {
    background: #ef6b82;
    content: "";
    height: 18px;
    left: 29px;
    position: absolute;
    top: 38px;
    width: 10px;
  }

  .monitor-stand {
    background: #d7dde5;
    height: 14px;
    margin-top: -38px;
    width: 180px;
  }

  .section-heading { margin: 0 auto 36px; max-width: 1040px; }
  .centered { text-align: center; }
  .trust-reasons, .related-section, .regulations-section { background: var(--page-bg); padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px); }
  .card-grid { display: grid; gap: 22px; margin-inline: auto; max-width: 1120px; }
  .card-grid.three { grid-template-columns: repeat(3, minmax(0, 1fr)); }

  .feature-card,
  .offering-card,
  .semiconductor-form,
  .story-card,
  .resource-card,
  .regulation-grid article {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: clamp(24px, 4vw, 38px);
  }

  .hex-icon {
    background: linear-gradient(135deg, var(--orange), var(--alert));
