---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:5000";

const trustLogos = ["Available", "General Dynamics", "Boeing", "FLEX", "AeroStar"];

const defenseCards = [
  {
    title: "Protect data",
    text: "Encrypt and watermark sensitive or proprietary digital assets in the cloud, on-premises, and in any approved environments so they remain protected at rest, in transit, and in use."
  },
  {
    title: "Monitor activity",
    text: "Track user access and activity related to protected digital assets including device name, IP address, and which activities are blocked or allowed."
  },
  {
    title: "Manage access and permissions",
    text: "Dynamically allow or block users from accessing protected digital assets, and update permissions, geo-fence data, or revoke access at any time."
  }
];

const offerings = [
  ["Data protection", "Discover, classify, protect, and track sensitive or regulated data to ensure compliance, prevent data theft/leakage, and manage access to digital assets."],
  ["Insider threat protection", "Prevent insider threats, improve investigations, and offboard inactive users with personalized watermarks, file-level activity information, and real-time revocation."],
  ["Regulatory compliance", "Meet and exceed stringent regulatory requirements, and generate reports demonstrating compliance for standards such as ITAR, EAR, CMMC, NIST, and more."],
  ["Securely share information", "Establish access rules including who and how sensitive, classified, and regulated data is shared by user attribute, organization, classification, or need-to-know policy."]
];

const relatedProducts = [
  {
    title: "Enterprise Digital Rights Management",
    text: "Encrypt digital assets, limit access to groups or individuals, allow or deny specific actions, track usage, and revoke access at any time."
  },
  {
    title: "Digital Asset Classification",
    text: "Classify digital assets based on their underlying data sensitivity, business value, compliance, or regulatory requirements."
  }
];
---

<BaseLayout
  title="Government | seclore"
  description="Seclore public sector data-centric security for sensitive government data, regulated information, compliance, and collaboration."
>
  <main id="top" class="government-page">
    <Nav />

    <section class="government-hero">
      <div class="hero-copy">
        <span>Public Sector</span>
        <h1>Seclore for Government and Public Sector Entities</h1>
        <p>
          Persistent protection, monitoring, and control for digital assets so agencies can be sure sensitive, private,
          and regulated data is not compromised, leaked, or non-compliant.
        </p>
        <a class="primary-button alert" href="#demo">Book a Demo</a>
      </div>
      <div class="public-sector-visual" aria-label="Public sector aviation visual">
        <div class="sun"></div>
        <div class="soldier"></div>
        <div class="helicopter helicopter-one"></div>
        <div class="helicopter helicopter-two"></div>
        <div class="field"></div>
      </div>
    </section>

    <section class="trust-strip">
      <h2>Trusted by industry-leading enterprises</h2>
      <div class="trust-row">
        {trustLogos.map((logo) => <span>{logo}</span>)}
      </div>
    </section>

    <section class="split-section protect-section">
      <div class="operations-visual" aria-label="Government operations security visual">
        <div class="screen-wall"></div>
        <div class="operator"></div>
        <div class="desk"></div>
      </div>
      <div>
        <h2>Protect sensitive and regulated data anywhere</h2>
        <p>
          Seclore's data-centric security platform orchestrates the discovery, classification, protection, and tracking of
          sensitive, private, and regulated data like controlled unclassified information.
        </p>
        <p>
          Keep access controlled remotely, manage user access policies and permissions, and stay in control of digital
          assets indefinitely.
        </p>
        <p><strong>Available Contract Vehicles</strong><br />SEWP V: NNG15SC73B<br />ITES-SW2: W52P1J-20-D-0033<br />OMNIA: 01-166</p>
        <a class="primary-button dark" href="#demo">Contact For Inc.</a>
      </div>
    </section>

    <section class="defense-section">
      <div class="section-heading centered">
        <h2>The last (and best) line of defense for your data</h2>
        <p>
          Cybersecurity incidents and attacks on government and public entities are increasing rapidly, and traditional
          perimeter protections can fail once sensitive or regulated information leaves approved spaces.
        </p>
      </div>
      <div class="card-grid three">
        {defenseCards.map((card) => (
          <article class="feature-card">
            <div class="hex-icon"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="demo-band" id="demo">
      <div class="demo-copy">
        <h2>Meet with a Public Sector data-centric security expert</h2>
        <p>
          See our data-centric security platform in action, and learn how to protect and control your digital assets wherever
          they go.
        </p>
        <strong>Learn more about</strong>
        <ul>
          <li>Digital asset security for every user, device, app, and cloud</li>
          <li>Granular access, usage, and privacy controls</li>
          <li>Never losing control or visibility of your digital assets</li>
        </ul>
        <div class="demo-logos">
          <span>ITAR</span>
          <span>FedRAMP</span>
          <span>NIST</span>
        </div>
      </div>
      <form class="government-form" data-endpoint="/api/demo">
        <h3>Seclore Demo</h3>
        <label>Email<input name="email" type="email" required /></label>
        <label>First Name<input name="name" required minlength="2" /></label>
        <label>Last Name<input name="lastName" /></label>
        <label>Company Name<input name="company" required /></label>
        <label>Job Title<input name="role" /></label>
        <label>Phone Number<input name="phone" /></label>
        <label>Country<select name="country"><option>Please Select</option><option>United States</option><option>India</option></select></label>
        <button class="primary-button" type="submit">Submit</button>
        <p class="form-status" role="status" aria-live="polite"></p>
      </form>
    </section>

    <section class="offerings-section">
      <div class="section-heading centered">
        <h2>Offerings for public sector entities</h2>
      </div>
      <div class="offering-list">
        {offerings.map(([title, text]) => (
          <article class="offering-card">
            <div class="line-icon"></div>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="related-section">
      <div class="section-heading centered">
        <h2>Data-centric security related products</h2>
        <p>
          Add a layer of cybersecurity and regulatory compliance controls at the data level to ensure protection is applied
          where it is needed most.
        </p>
      </div>
      <div class="related-products">
        {relatedProducts.map((item) => (
          <article class="related-product">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <a href="#demo">Learn More</a>
          </article>
        ))}
      </div>
    </section>
  </main>

  <script is:inline define:vars={{ apiBase }}>
    document.querySelectorAll(".government-form").forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const status = form.querySelector(".form-status");
        const button = form.querySelector("button[type='submit']");
        const payload = Object.fromEntries(new FormData(form).entries());

        status.textContent = "Sending...";
        status.className = "form-status";
        button.disabled = true;

        try {
          const response = await fetch(`${apiBase}${form.dataset.endpoint}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });
          const data = await response.json();
          if (!response.ok) throw new Error(data.message || "Request failed.");
          form.reset();
          status.textContent = data.message || "Submitted successfully.";
          status.classList.add("success");
        } catch (error) {
          status.textContent = error.message || "Something went wrong.";
          status.classList.add("error");
        } finally {
          button.disabled = false;
        }
      });
    });
  </script>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f2f3f5;
    --page-text: #232128;
    --page-muted: #636773;
    --purple: #5b2bd7;
    --wine: #2b1024;
    --alert: #eb3157;
    --orange: #ff9500;
    --plum: #8d204e;
    --card: #ffffff;
    --line: rgba(29, 29, 34, 0.13);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #5b2bd7;
    --demo-button-text: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  body { margin: 0; background: var(--page-bg); color: var(--page-text); }
  a { color: inherit; text-decoration: none; }
  button, input, textarea, select { font: inherit; }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    font-size: 1.35rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .nav-links, .nav-utilities { align-items: center; display: flex; }
  .nav-links { flex: 1 1 auto; gap: clamp(18px, 2.2vw, 34px); justify-content: center; min-width: 0; }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:hover .nav-trigger,
  .nav-item:focus-within .nav-trigger { color: var(--header-text); }

  .nav-item { position: static; }
  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret { transform: rotate(225deg) translateY(-1px); }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }

  .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns { display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .mega-column, .mega-sublinks { display: grid; }
  .mega-column { gap: 10px; }
  .mega-title { color: var(--dropdown-title); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .mega-link, .mega-link-group { border: 1px solid transparent; border-radius: 8px; }
  .mega-link { display: grid; gap: 5px; padding: 13px; }
  .mega-link strong { color: var(--dropdown-text); }
  .mega-link small, .mega-sublinks a { color: var(--dropdown-muted); }
  .mega-link:hover, .mega-link-group:hover { background: var(--dropdown-link-hover); border-color: var(--dropdown-link-border); }
  .mega-link-group { display: grid; gap: 4px; padding: 4px; }
  .mega-sublinks { gap: 2px; padding: 0 9px 8px 22px; }
  .mega-sublinks a { font-size: 0.84rem; padding: 5px 0; }
  .mega-feature { align-content: end; background: var(--dropdown-feature-bg); border: 1px solid var(--dropdown-feature-border); border-radius: 8px; display: grid; min-height: 268px; padding: 24px; }
  .mega-feature span, .mega-feature em { color: var(--dropdown-title); }
  .mega-feature strong { color: var(--dropdown-text); font-size: 1.35rem; line-height: 1.18; margin-top: auto; }
  .nav-utilities { flex: 0 0 auto; gap: clamp(12px, 1.5vw, 20px); margin-left: clamp(12px, 2vw, 28px); }
  .utility-link, .language-button, .utility-icon, .theme-toggle { display: none; }

  .demo-button,
  .primary-button {
    align-items: center;
    background: var(--demo-button-bg);
    border: 0;
    border-radius: 7px;
    color: var(--demo-button-text);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.88rem;
    font-weight: 850;
    justify-content: center;
    min-height: 39px;
    padding: 0 18px;
  }

  .primary-button.alert { background: var(--alert); }
  .primary-button.dark { background: #211326; color: #ffffff; }
  .nav-toggle { background: transparent; border: 0; display: none; height: 42px; width: 42px; }
  .nav-toggle span { background: var(--header-text); display: block; height: 2px; margin: 6px 0; width: 24px; }

  h1, h2, h3, p { margin-top: 0; }
  h1 {
    font-size: clamp(3rem, 6vw, 5.9rem);
    font-weight: 500;
    line-height: 0.98;
    margin-bottom: 22px;
    overflow-wrap: break-word;
  }
  h2 { font-size: clamp(2rem, 4vw, 4rem); font-weight: 450; line-height: 1.05; }
  p, li { color: var(--page-muted); line-height: 1.6; }

  .government-hero {
    align-items: center;
    background: var(--wine);
    color: #ffffff;
    display: grid;
    gap: 44px;
    grid-template-columns: minmax(0, 0.94fr) minmax(320px, 1.06fr);
    padding: clamp(56px, 7vw, 86px) clamp(18px, 4vw, 52px);
  }

  .government-hero span {
    display: block;
    font-size: 0.88rem;
    font-weight: 850;
    letter-spacing: 0.05em;
    margin-bottom: 18px;
    text-transform: uppercase;
  }

  .government-hero p { color: rgba(255, 255, 255, 0.82); max-width: 620px; }

  .public-sector-visual {
    background: linear-gradient(180deg, #89c6e8 0%, #f5cf88 54%, #3b371d 100%);
    border-radius: 8px;
    min-height: 330px;
    overflow: hidden;
    position: relative;
  }

  .sun {
    background: rgba(255, 214, 117, 0.82);
    border-radius: 50%;
    height: 104px;
    left: 18%;
    position: absolute;
    top: 36%;
    width: 104px;
  }

  .field {
    background: linear-gradient(180deg, rgba(87, 79, 34, 0.05), #36351b);
    bottom: 0;
    height: 96px;
    left: 0;
    position: absolute;
    right: 0;
  }

  .soldier {
    background: #1f2a20;
    bottom: 54px;
    height: 172px;
    left: 31%;
    position: absolute;
    width: 58px;
  }

  .soldier::before {
    background: #172116;
    border-radius: 50%;
    content: "";
    height: 42px;
    left: 8px;
    position: absolute;
    top: -35px;
    width: 42px;
  }

  .soldier::after {
    background: #172116;
    content: "";
    height: 150px;
    left: 58px;
    position: absolute;
    top: 28px;
    transform: rotate(70deg);
    transform-origin: top left;
    width: 12px;
  }

  .helicopter {
    background: #161b1d;
    height: 20px;
    position: absolute;
    width: 88px;
  }

  .helicopter::before {
    background: #161b1d;
    content: "";
    height: 4px;
    left: -38px;
    position: absolute;
    top: -12px;
    width: 160px;
  }

  .helicopter::after {
    background: #161b1d;
    content: "";
    height: 3px;
    position: absolute;
    right: -46px;
    top: 8px;
    transform: rotate(25deg);
    width: 54px;
  }

  .helicopter-one { right: 12%; top: 31%; transform: rotate(7deg); }
  .helicopter-two { right: 36%; top: 24%; transform: scale(0.58) rotate(-4deg); opacity: 0.74; }

  .trust-strip { background: var(--page-bg); padding: 48px clamp(18px, 4vw, 52px); text-align: center; }
  .trust-strip h2 { color: #a34462; font-size: 0.88rem; letter-spacing: 0.04em; margin-bottom: 32px; text-transform: uppercase; }
  .trust-row { align-items: center; display: grid; gap: 24px; grid-template-columns: repeat(5, minmax(0, 1fr)); }
  .trust-row span { color: rgba(36, 35, 41, 0.48); font-weight: 900; }

  .split-section,
  .demo-band {
    align-items: center;
    display: grid;
    gap: clamp(30px, 5vw, 72px);
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px);
  }

  .split-section, .offerings-section, .government-footer { background: var(--card); }

  .operations-visual {
    background: linear-gradient(135deg, #031826, #0d6d85 48%, #d9eef4);
    border-radius: 8px;
    min-height: 330px;
    overflow: hidden;
    position: relative;
  }

  .screen-wall {
    background:
      linear-gradient(rgba(255, 255, 255, 0.14) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.14) 1px, transparent 1px),
      rgba(0, 207, 255, 0.16);
    background-size: 34px 34px;
    height: 58%;
    left: 0;
    position: absolute;
    right: 0;
    top: 0;
  }

  .operator {
    background: linear-gradient(150deg, #f5f0e8, #283545);
    border-radius: 50% 50% 6px 6px;
    bottom: 46px;
    height: 150px;
    left: 38%;
    position: absolute;
    width: 106px;
  }

  .operator::before {
    background: #c58c72;
    border-radius: 50%;
    content: "";
    height: 54px;
    left: 26px;
    position: absolute;
    top: -36px;
    width: 54px;
  }

  .desk {
    background: rgba(2, 19, 29, 0.86);
    bottom: 0;
    height: 74px;
    left: 0;
    position: absolute;
    right: 0;
  }

  .protect-section strong { color: var(--page-text); }
  .section-heading { margin: 0 auto 36px; max-width: 1040px; }
  .centered { text-align: center; }
  .defense-section, .related-section { background: var(--page-bg); padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px); }
  .card-grid { display: grid; gap: 22px; margin-inline: auto; max-width: 1120px; }
  .card-grid.three { grid-template-columns: repeat(3, minmax(0, 1fr)); }

  .feature-card,
  .offering-card,
  .government-form {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: clamp(24px, 4vw, 38px);
  }

  .hex-icon {
    background: linear-gradient(135deg, var(--orange), #f5a50d);
    clip-path: polygon(25% 4%, 75% 4%, 100% 50%, 75% 96%, 25% 96%, 0 50%);
    height: 44px;
    margin-bottom: 20px;
    width: 44px;
  }

  .feature-card:nth-child(2) .hex-icon { background: linear-gradient(135deg, var(--alert), #c4254d); }
  .feature-card:nth-child(3) .hex-icon { background: linear-gradient(135deg, var(--plum), #6f234a); }

  .demo-band { background: linear-gradient(135deg, #dceaff, #f2eaff); }
  .demo-copy ul { padding-left: 20px; }
  .demo-copy strong { color: var(--page-text); display: block; margin-bottom: 8px; }
  .demo-logos { display: flex; flex-wrap: wrap; gap: 22px; margin-top: 26px; }
  .demo-logos span { color: rgba(36, 35, 41, 0.56); font-size: 0.82rem; font-weight: 900; letter-spacing: 0.06em; text-transform: uppercase; }
  .government-form h3 { text-align: center; }
  .government-form label { color: var(--page-text); display: grid; font-size: 0.88rem; gap: 8px; margin-bottom: 14px; }
  .government-form input, .government-form select {
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(15, 23, 42, 0.16);
    border-radius: 4px;
    color: #111827;
    min-height: 40px;
    padding: 10px;
  }

  .form-status { min-height: 24px; }
  .form-status.success { color: #087f6f; }
  .form-status.error { color: #bd2b2b; }

  .offerings-section { padding: clamp(58px, 8vw, 96px) clamp(18px, 4vw, 52px); }
  .offering-list { display: grid; gap: 18px; margin-inline: auto; max-width: 1120px; }
  .line-icon { border: 2px solid #ff4267; border-radius: 12px; height: 42px; margin-bottom: 20px; position: relative; width: 42px; }
  .line-icon::before, .line-icon::after { background: #ff4267; content: ""; height: 2px; left: 10px; position: absolute; right: 10px; }
  .line-icon::before { top: 14px; }
  .line-icon::after { bottom: 14px; }

  .related-products { display: grid; gap: 32px; margin-inline: auto; max-width: 980px; }
  .related-product {
    min-height: 280px;
    padding-top: clamp(36px, 7vw, 96px);
    text-align: center;
  }
  .related-product a { color: var(--page-text); font-weight: 900; }

  .government-footer { border-top: 1px solid var(--line); padding: 34px clamp(18px, 4vw, 52px); }
  .footer-lines { border-block: 1px solid var(--line); margin: 30px 0; }
  .footer-lines details { border-bottom: 1px solid var(--line); padding: 18px 0; }
  .footer-lines details:last-child { border-bottom: 0; }
  .footer-lines summary { cursor: pointer; font-weight: 800; }
  .footer-logo { color: var(--purple); display: block; font-size: 1.45rem; font-weight: 950; letter-spacing: 0.04em; margin-bottom: 24px; text-transform: uppercase; }
