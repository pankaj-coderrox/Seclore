---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const heroCards = [
  ["Understand Your Data", "Gain comprehensive visibility across all data touchpoints and interactions", "data"],
  ["Derive Context", "Make intelligent decisions based on who or what is using data, how it's used, and why", "context"],
  ["Enforce Automatically", "Controls that allow granular access to data wherever it moves - without slowing work", "enforce"],
  ["Prove It's Handled Correctly", "Maintain continuous visibility and proof across data usage, access, and activity to demonstrate compliance", "prove"]
];

const armorPillars = [
  ["Action, Not Just Visibility", "Protects against threats by adaptively using context-aware policies."],
  ["Built-In, Not Bolted-On", "AI data discovery embeds security intelligence directly into the data itself."],
  ["Ubiquitous, Not Bounded", "Protects data wherever it goes, both inside and outside the enterprise."],
  ["Adaptive, Not Static", "Understanding data's context and intent to manage rights at a granular level."],
  ["Anticipatory, Not Reactive", "Audit every action and maintain full traceability across both AI and people-driven workflows."]
];

const outcomes = [
  ["Empower Teams", "Let people collaborate freely while maintaining intelligent, invisible protection", "team"],
  ["Turn Risk into Readiness", "Transform data security from a barrier into a competitive advantage", "shield"],
  ["Enable AI Everywhere", "Deploy AI initiatives confidently across your organization without compromising security", "spark"],
  ["Maintain Continuous Control", "Keep oversight of sensitive data regardless of where it travels or who accesses it", "control"]
];

const useCases = [
  ["Secure third-party and partner collaboration", "Maintain control over shared data even when it moves beyond your organization", "shield"],
  ["Enable safe AI adoption across the business", "Adopt AI tools confidently while ensuring enterprise data remains protected", "spark"],
  ["Reduce insider risk without disrupting work", "Minimize internal data misuse while preserving everyday productivity across the organization", "team"],
  ["Support regulatory and audit readiness", "Demonstrate continuous compliance readiness with clear visibility and consistent policy enforcement", "folder"],
  ["Protect sensitive intellectual property", "Keep oversight of sensitive data regardless of where it travels or who accesses it", "lock"]
];

const industries = [
  ["Financial Services", "Protect sensitive financial data across banking, insurance, and capital markets with persistent, policy-based controls", "card"],
  ["Manufacturing", "Maintain control over critical information while enabling collaboration across the manufacturing ecosystem", "factory"],
  ["Semiconductor", "Secure high-value chip designs, R&D data, and supply-chain information throughout the product lifecycle", "chip"],
  ["Government", "Enable secure data sharing while maintaining strict governance, auditability, and national security compliance", "bank"],
  ["Other Regulated Industries", "Meet industry-specific regulatory and data protection requirements with persistent, content-aware security", "shield"]
];

const insights = [
  ["The Debate About AI in the Enterprise Is Over. Here Is the Only Question That Matters.", "AI, COMPANY, DATA SECURITY"],
  ["The Missing Link in Enterprise AI: Why Context and Behavior Are the New Security Perimeter", "AI RISK, DATA SECURITY"],
  ["ChatGPT Read 400 Internal Company Files in 42 Milliseconds. Security Stacks Saw Nothing.", "AI RISK, DATA SECURITY"]
];

const awards = [
  ["CYBER DEFENSE AWARDS", "Top Infosec Innovation Winner", "2024", "trophy"],
  ["THE CHANNEL CO.", "CRN Channel Chief Winner", "2025", "flame"],
  ["THE CHANNEL CO.", "CRN Women of the Channel", "2024", "medal"],
  ["BUSINESS INTELLIGENCE GROUP", "Fortress Cyber Security Award", "2024", "flag"]
];

const customerLogos = [
  ["AMERICAN EXPRESS", "amex", ""],
  ["adani", "adani", "/images/home/adani-40px.png"],
  ["stc", "stc", "/images/home/stc-40px.png"],
  ["SKYWORKS", "skyworks", "/images/home/skyworks-40px-gray.png"],
  ["QIB", "qib", "/images/home/qatar-40px.png"],
  ["flex.", "flex", ""],
  ["EXOSTAR", "exostar", ""],
  ["aramco", "aramco", ""]
];

---

<BaseLayout>
  <main id="top">
    <Nav />

    <section class="home-hero">
      <div class="home-hero-copy reveal">
        <span class="home-eyebrow">Data Security Intelligence</span>
        <h1>
          <span>Embrace AI</span>
          <span>Fearlessly</span>
        </h1>
        <p aria-label="Trust and control your data and achieve compliance wherever people and AI work">
          <span class="home-subtitle-desktop">
            Trust and control your data and achieve compliance wherever people and AI work
          </span>
          <span class="home-subtitle-mobile" aria-hidden="true">
            <span>Trust and control your</span>
            <span>data and achieve</span>
            <span>compliance wherever</span>
            <span>people and AI work</span>
          </span>
        </p>
        <div class="home-actions">
          <a class="home-button primary" href="/demo/">Book a Demo</a>
          <a class="home-button secondary" href="#platform">Explore Platform</a>
        </div>
        <section class="customer-scroll-section" aria-labelledby="customer-scroll-title">
          <h2 id="customer-scroll-title">Trusted by industry&#8209;leading enterprises</h2>
          <div class="customer-scroll-shell">
            <div class="customer-scroll-track" role="region" aria-label="Trusted customer logos" tabindex="0" data-logo-scroller>
              {[...customerLogos, ...customerLogos].map(([label, id, src], index) => (
                <span class={`customer-logo customer-logo--${id}`} aria-label={index >= customerLogos.length ? undefined : label} aria-hidden={index >= customerLogos.length ? "true" : undefined}>
                  {src ? <img src={src} alt="" loading="lazy" decoding="async" /> : label}
                </span>
              ))}
            </div>
          </div>
        </section>
      </div>
      <div class="hero-photo reveal">
        <img
          src="/images/home/homepage-hero-2026.png"
          alt="Seclore data security intelligence visualization"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    </section>

    <section class="enable-section" id="platform">
      <div class="enable-copy reveal">
        <h2>Safely Enable AI</h2>
        <p>
          Enable AI across the enterprise by understanding your data, applying contextual protection,
          and maintaining continuous control and proof.
        </p>
      </div>
      <div class="home-card-grid four">
        {heroCards.map(([title, text, icon]) => (
          <article class="home-info-card reveal">
            <span class={`mini-icon icon-${icon}`}></span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="armor-band">
      <div class="armor-panel reveal">
        <div class="armor-intro">
          <span class="armor-logo"><span class="armor-mark"></span><strong>ARMOR</strong><small>POWERED BY SECLORE</small></span>
          <h2>Data Security Intelligence, built for AI</h2>
          <p>
            Secure data with a unified, integrated control model. Intelligence is embedded directly
            into data, repositories, apps, users, partners, and AI agents.
          </p>
          <a class="home-button primary" href="/armor/dspm/">Explore ARMOR in Detail</a>
        </div>
        <div class="armor-pillars">
          {armorPillars.map(([title, text]) => (
            <article>
              <h3>{title}</h3>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="how-section">
      <h2>How Seclore ARMOR Works</h2>
      <div class="home-card-grid three">
        <article class="home-info-card reveal"><span class="mini-icon icon-data"></span><h3>Discover Your Data</h3><p>Discover what data exists and why it matters. Across people and AI</p></article>
        <article class="home-info-card reveal"><span class="mini-icon icon-control"></span><h3>Control Data Persistently</h3><p>Apply intelligent, context-aware protection that moves with your data</p></article>
        <article class="home-info-card reveal"><span class="mini-icon icon-prove"></span><h3>Prove Trust at Scale</h3><p>Demonstrate compliance and security posture with continuous evidence</p></article>
      </div>
    </section>

    <section class="achieve-section">
      <h2>What Organizations Achieve With Seclore</h2>
      <div class="home-card-grid four">
        {outcomes.map(([title, text, icon]) => (
          <article class="home-info-card reveal"><span class={`mini-icon icon-${icon}`}></span><h3>{title}</h3><p>{text}</p></article>
        ))}
      </div>
    </section>

    <section class="usecase-section" id="solutions">
      <h2>Real-World Use Cases</h2>
      <div class="home-card-grid five">
        {useCases.map(([title, text, icon], index) => (
          <article class="home-info-card reveal"><span class={`mini-icon icon-${icon}`}></span><h3>{title}</h3><p>{text}</p>{index === 0 && <a class="learn-link" href="/solutions/external-threats/">Learn More</a>}</article>
        ))}
      </div>
    </section>

    <section class="industries-section" id="partners">
      <div class="industries-heading">
        <h2>Trusted Across Regulated and IP-driven Industries</h2>
      </div>
      <div class="industry-grid">
        {industries.map(([title, text, icon]) => (
          <article class="industry-card reveal"><span class={`mini-icon icon-${icon}`}></span><h3>{title}</h3><p>{text}</p><a href="#demo">Explore +</a></article>
        ))}
      </div>
    </section>

    <section class="testimonial-home" id="about">
      <h2>Trusted by Security Leaders Around the World</h2>
      <article class="quote-panel reveal">
        <span>AMERICAN AUTO CO.</span>
        <p>
          "We use Seclore for our RFP/RFQs where we need to share confidential designs to suppliers
          (who also service our competitors). Once the contract is awarded, Seclore enables us to
          revoke access to the CAD files and other requirement documents from the other suppliers -
          drastically reducing the risk of competitive theft."
        </p>
        <strong>LEADER, PROCUREMENT TEAM</strong>
        <a class="story-button" href="/resources/customer-case-studies/">Customer Story</a>
      </article>
      <div class="testimonial-tabs" aria-label="Customer stories">
        <span class="is-active">AMERICAN AUTO CO.</span>
        <span>CHEMICAL MANUFACTURER</span>
        <span>CAPITAL EQUIPMENT MANUF</span>
      </div>
    </section>

    <section class="awards-section">
      <h2>Award-Winning Enterprise Security</h2>
      <div class="award-grid">
        {awards.map(([source, title, year, icon]) => (
          <article>
            <span class={`mini-icon icon-${icon}`}></span>
            <small>{source}</small>
            <strong>{title}</strong>
            <em>{year}</em>
          </article>
        ))}
      </div>
    </section>

    <section class="insights-home" id="resources">
      <div class="insights-heading">
        <h2>Insights on AI, data security, and trust</h2>
        <a href="#resources">View All Resources</a>
      </div>
      <div class="insight-grid">
        {insights.map(([title, tag]) => (
          <article class="insight-card reveal">
            <span class="post-type">BLOG POST</span>
            <span>{tag}</span>
            <h3>{title}</h3>
            <a href="#resources">View Blog Post +</a>
          </article>
        ))}
      </div>
      <div class="insight-controls" aria-hidden="true"><button type="button">←</button><button type="button">→</button></div>
    </section>
  </main>

  <script is:inline>
    const scrollStorageKey = "seclore-home-scroll-y";
    const navigationEntry = performance.getEntriesByType("navigation")[0];
    const shouldRestoreScroll = navigationEntry?.type === "reload";

    if ("scrollRestoration" in window.history) {
      window.history.scrollRestoration = "manual";
    }

    const savePageScroll = () => {
      sessionStorage.setItem(scrollStorageKey, String(window.scrollY));
    };

    if (shouldRestoreScroll) {
      const savedScrollY = Number(sessionStorage.getItem(scrollStorageKey) || "0");

      if (savedScrollY > 0) {
        requestAnimationFrame(() => {
          window.scrollTo({ top: savedScrollY, left: 0, behavior: "auto" });
        });
      }
    }

    window.addEventListener("scroll", savePageScroll, { passive: true });
    window.addEventListener("pagehide", savePageScroll);

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.18 }
    );

    document.querySelectorAll(".reveal").forEach((item) => observer.observe(item));

    const syncHeroEyebrowLength = () => {
      const eyebrow = document.querySelector(".home-hero .home-eyebrow");
      const titleLine = document.querySelector(".home-hero h1 span");

      if (!(eyebrow instanceof HTMLElement) || !(titleLine instanceof HTMLElement)) {
        return;
      }

      const measureInlineWidth = (element) => {
        const clone = element.cloneNode(true);

        if (!(clone instanceof HTMLElement)) {
          return 0;
        }

        const styles = window.getComputedStyle(element);
        clone.style.display = "inline-block";
        clone.style.fontFamily = styles.fontFamily;
        clone.style.fontSize = styles.fontSize;
        clone.style.fontStyle = styles.fontStyle;
        clone.style.fontWeight = styles.fontWeight;
        clone.style.letterSpacing = styles.letterSpacing;
        clone.style.lineHeight = styles.lineHeight;
        clone.style.left = "-9999px";
        clone.style.position = "absolute";
        clone.style.textAlign = "left";
        clone.style.textAlignLast = "auto";
        clone.style.transform = "none";
        clone.style.visibility = "hidden";
        clone.style.whiteSpace = "nowrap";
        clone.style.width = "auto";
        document.body.appendChild(clone);
        const width = clone.getBoundingClientRect().width;
        clone.remove();
        return width;
      };

      eyebrow.style.fontSize = "";

      if (!window.matchMedia("(max-width: 560px)").matches) {
        return;
      }

      const targetWidth = measureInlineWidth(titleLine);
      const currentWidth = measureInlineWidth(eyebrow);
      const currentSize = Number.parseFloat(window.getComputedStyle(eyebrow).fontSize);

      if (targetWidth > 0 && currentWidth > 0 && currentSize > 0) {
        eyebrow.style.fontSize = `${currentSize * (targetWidth / currentWidth)}px`;
      }
    };

    syncHeroEyebrowLength();
    window.addEventListener("load", syncHeroEyebrowLength);
    window.addEventListener("resize", syncHeroEyebrowLength);

    document.querySelectorAll("[data-logo-scroller]").forEach((scroller) => {
      let isDragging = false;
      let startX = 0;
      let startScrollLeft = 0;
      let pauseUntil = 0;
      let lastFrame = performance.now();
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const pauseAutoScroll = (duration = 1800) => {
        pauseUntil = performance.now() + duration;
      };

      const autoScroll = (time) => {
        const halfWidth = scroller.scrollWidth / 2;

        if (!prefersReducedMotion && !isDragging && time > pauseUntil && halfWidth > scroller.clientWidth) {
          const elapsed = Math.min(time - lastFrame, 40);
          scroller.scrollLeft += elapsed * 0.045;

          if (scroller.scrollLeft >= halfWidth) {
            scroller.scrollLeft -= halfWidth;
          }
        }

        lastFrame = time;
        requestAnimationFrame(autoScroll);
      };

      requestAnimationFrame(autoScroll);

      scroller.addEventListener("pointerdown", (event) => {
        if (!(event instanceof PointerEvent)) {
          return;
        }

        pauseAutoScroll(2400);
        isDragging = true;
        startX = event.clientX;
        startScrollLeft = scroller.scrollLeft;
        scroller.classList.add("is-dragging");
        scroller.setPointerCapture(event.pointerId);
      });

      scroller.addEventListener("pointermove", (event) => {
        if (!isDragging || !(event instanceof PointerEvent)) {
          return;
        }

        pauseAutoScroll(2400);
        scroller.scrollLeft = startScrollLeft - (event.clientX - startX);
      });

      ["pointerup", "pointercancel", "mouseleave"].forEach((eventName) => {
        scroller.addEventListener(eventName, (event) => {
          isDragging = false;
          scroller.classList.remove("is-dragging");
          if (event instanceof PointerEvent && scroller.hasPointerCapture(event.pointerId)) {
            scroller.releasePointerCapture(event.pointerId);
          }
        });
      });

      scroller.addEventListener("wheel", (event) => {
        if (Math.abs(event.deltaY) <= Math.abs(event.deltaX)) {
          return;
        }

        pauseAutoScroll(1800);
        event.preventDefault();
        scroller.scrollLeft += event.deltaY;
      }, { passive: false });

      scroller.addEventListener("keydown", (event) => {
        const step = scroller.clientWidth * 0.72;

        if (event.key === "ArrowRight") {
          pauseAutoScroll(2400);
          event.preventDefault();
          scroller.scrollBy({ left: step, behavior: "smooth" });
        } else if (event.key === "ArrowLeft") {
          pauseAutoScroll(2400);
          event.preventDefault();
          scroller.scrollBy({ left: -step, behavior: "smooth" });
        } else if (event.key === "Home") {
          pauseAutoScroll(2400);
          event.preventDefault();
          scroller.scrollTo({ left: 0, behavior: "smooth" });
        } else if (event.key === "End") {
          pauseAutoScroll(2400);
          event.preventDefault();
          scroller.scrollTo({ left: scroller.scrollWidth, behavior: "smooth" });
        }
      });

      scroller.addEventListener("focusin", () => pauseAutoScroll(600));
    });
  </script>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #05111f;
    --bg-soft: #0a1a2d;
    --panel: rgba(12, 30, 51, 0.82);
    --panel-strong: #10233a;
    --line: rgba(151, 190, 230, 0.18);
    --text: #edf7ff;
    --muted: #9eb5ca;
    --blue: #2dd4ff;
    --blue-strong: #4f8cff;
    --green: #7cf6c7;
    --warning: #ffd166;
    --shadow: 0 24px 80px rgba(0, 0, 0, 0.36);
    --body-gradient: linear-gradient(180deg, rgba(5, 17, 31, 0.92), var(--bg) 38%);
    --body-grid: repeating-linear-gradient(
      90deg,
      rgba(45, 212, 255, 0.04) 0,
      rgba(45, 212, 255, 0.04) 1px,
      transparent 1px,
      transparent 96px
    );
    --fixed-grid-line: rgba(45, 212, 255, 0.035);
    --header-bg: #07111f;
    --header-border: rgba(151, 190, 230, 0.18);
    --header-shadow: 0 14px 34px rgba(0, 0, 0, 0.28);
    --header-text: #edf7ff;
    --header-muted: #c5d6e8;
    --dropdown-bg: linear-gradient(135deg, rgba(9, 25, 44, 0.98), rgba(5, 17, 31, 0.98));
    --dropdown-grid-line: rgba(45, 212, 255, 0.045);
    --dropdown-border: rgba(151, 190, 230, 0.18);
    --dropdown-link-hover: rgba(255, 255, 255, 0.055);
    --dropdown-link-border: rgba(45, 212, 255, 0.22);
    --dropdown-title: var(--green);
    --dropdown-text: var(--text);
    --dropdown-muted: var(--muted);
    --dropdown-feature-bg: linear-gradient(
        160deg,
        rgba(45, 212, 255, 0.18),
        rgba(124, 246, 199, 0.08)
      ),
      rgba(255, 255, 255, 0.045);
    --dropdown-feature-border: rgba(45, 212, 255, 0.22);
    --form-bg: rgba(9, 25, 44, 0.72);
    --input-bg: rgba(255, 255, 255, 0.055);
    --testimonial-bg: #071523;
    --lead-bg: linear-gradient(180deg, var(--bg), #071626);
    --demo-button-bg: #ffffff;
    --demo-button-text: #07111f;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  html[data-theme="light"] {
    color-scheme: light;
    --bg: #f5f8fc;
    --bg-soft: #ffffff;
    --panel: rgba(255, 255, 255, 0.92);
    --panel-strong: #ffffff;
    --line: rgba(15, 23, 42, 0.12);
    --text: #0f172a;
    --muted: #53657a;
    --blue: #0b66d8;
    --blue-strong: #1457c8;
    --green: #087f6f;
    --warning: #a76500;
    --shadow: 0 22px 70px rgba(15, 23, 42, 0.12);
    --body-gradient: #ffffff;
    --body-grid: linear-gradient(transparent, transparent);
    --fixed-grid-line: transparent;
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #07111f;
    --header-muted: #2a2a2a;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(
        160deg,
        rgba(15, 92, 173, 0.12),
        rgba(11, 140, 115, 0.08)
      ),
      rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --form-bg: rgba(255, 255, 255, 0.88);
    --input-bg: rgba(15, 23, 42, 0.035);
    --testimonial-bg: #eef5fc;
    --lead-bg: linear-gradient(180deg, #f7fafc, #edf4fb);
    --demo-button-bg: #07111f;
    --demo-button-text: #ffffff;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--body-gradient), var(--body-grid);
    color: var(--text);
    transition:
      background 220ms ease,
      color 220ms ease;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(var(--fixed-grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--fixed-grid-line) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: linear-gradient(to bottom, black, transparent 70%);
  }

  html[data-theme="light"] body::before {
    display: none;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  select,
  textarea {
    font: inherit;
  }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    left: 0;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    right: 0;
    top: 0;
    z-index: 20;
  }

  .brand,
  .nav-links,
  .nav-actions,
  .hero-actions,
  .trust-row,
  .logo-strip,
  .site-footer nav,
  .nav-utilities {
    align-items: center;
    display: flex;
  }

  .site-logo {
    color: var(--header-text);
    flex: 0 0 auto;
    font-size: 1.35rem;
    font-weight: 900;
    letter-spacing: 0;
    line-height: 1;
    margin-right: clamp(14px, 2vw, 28px);
  }

  .brand {
    gap: 10px;
    font-size: 1.08rem;
    font-weight: 800;
    letter-spacing: 0;
  }

  .brand-mark {
    align-items: center;
    background: linear-gradient(135deg, var(--blue), var(--green));
    border-radius: 10px;
    display: inline-flex;
    height: 34px;
    justify-content: center;
    width: 34px;
  }

  .brand-mark span {
    border: 2px solid #061427;
    border-top: 0;
    height: 16px;
    transform: rotate(45deg);
    width: 10px;
  }

  .nav-links {
    flex: 1 1 auto;
    gap: clamp(18px, 2.2vw, 34px);
    justify-content: center;
    min-width: 0;
  }

  .nav-links > a,
  .nav-trigger,
  .site-footer a {
    color: var(--header-muted);
    font-size: 0.98rem;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:focus-within .nav-trigger,
  .nav-item:hover .nav-trigger,
  .site-footer a:hover {
    color: var(--header-text);
  }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    border-radius: 8px;
    display: inline-flex;
    gap: 8px;
    font-weight: 800;
    min-height: 68px;
    padding: 0;
  }

  .brand-trigger {
    color: var(--header-text);
    font-size: 0.98rem;
  }

  .nav-utilities {
    flex: 0 0 auto;
    gap: clamp(12px, 1.5vw, 20px);
    margin-left: clamp(12px, 2vw, 28px);
  }

  .utility-link,
  .language-button,
  .utility-icon {
    color: var(--header-muted);
    font-size: 0.88rem;
    font-weight: 750;
  }

  .utility-link {
    white-space: nowrap;
  }

  .utility-icon,
  .language-button,
  .theme-toggle {
    align-items: center;
    background: transparent;
    border: 0;
    cursor: pointer;
    display: inline-flex;
    gap: 8px;
    padding: 0;
  }

  .theme-toggle {
    color: var(--header-muted);
    font-size: 0.88rem;
    font-weight: 800;
  }

  .theme-toggle-track {
    align-items: center;
    background: rgba(127, 139, 155, 0.24);
    border: 1px solid var(--header-border);
    border-radius: 999px;
    display: inline-flex;
    height: 24px;
    padding: 2px;
    transition:
      background 180ms ease,
      border-color 180ms ease;
    width: 44px;
  }

  .theme-toggle-thumb {
    background: var(--header-text);
    border-radius: 50%;
    display: block;
    height: 18px;
    transform: translateX(18px);
    transition:
      background 180ms ease,
      transform 180ms ease;
    width: 18px;
  }

  html[data-theme="light"] .theme-toggle-thumb {
    transform: translateX(0);
  }

  .search-icon {
    border: 2px solid currentColor;
    border-radius: 50%;
    display: inline-block;
    height: 17px;
    position: relative;
    width: 17px;
  }

  .search-icon::after {
    background: currentColor;
    content: "";
    height: 2px;
    position: absolute;
    right: -6px;
    top: 12px;
    transform: rotate(45deg);
    width: 8px;
  }

  .demo-button {
    align-items: center;
    background: var(--demo-button-bg);
    border-radius: 999px;
    color: var(--demo-button-text);
    display: inline-flex;
    font-size: 0.9rem;
    font-weight: 850;
    min-height: 42px;
    padding: 0 18px;
    white-space: nowrap;
  }

  .nav-trigger {
    background: transparent;
    border: 0;
    cursor: pointer;
  }

  .nav-item {
    position: static;
  }

  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret {
    transform: rotate(225deg) translateY(-1px);
  }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mega-inner {
    background:
      var(--dropdown-bg),
      repeating-linear-gradient(
        135deg,
        var(--dropdown-grid-line) 0,
        var(--dropdown-grid-line) 1px,
        transparent 1px,
        transparent 20px
      );
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: var(--shadow);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .mega-column {
    display: grid;
    gap: 10px;
  }

  .mega-title {
    color: var(--dropdown-title);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    margin-bottom: 4px;
    text-transform: uppercase;
  }

  .mega-link {
    border: 1px solid transparent;
    border-radius: 8px;
    display: grid;
    gap: 5px;
    padding: 13px;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      transform 180ms ease;
  }

  .mega-link-group {
    border: 1px solid transparent;
    border-radius: 8px;
    display: grid;
    gap: 4px;
    padding: 4px;
  }

  .mega-link-group:hover {
    background: var(--dropdown-link-hover);
    border-color: var(--dropdown-link-border);
  }

  .mega-link-group .mega-link {
    padding: 9px 9px 5px;
  }

  .mega-link-group .mega-link:hover {
    background: transparent;
    border-color: transparent;
    transform: none;
  }

  .mega-parent-link strong {
    align-items: center;
    display: flex;
    gap: 8px;
  }

  .mega-parent-link strong::after {
    border-bottom: 1.5px solid currentColor;
    border-right: 1.5px solid currentColor;
    content: "";
    height: 6px;
    transform: rotate(-45deg);
    width: 6px;
  }

  .mega-sublinks {
    display: grid;
    gap: 2px;
    padding: 0 9px 8px 22px;
  }

  .mega-sublinks a {
    color: var(--dropdown-muted);
    font-size: 0.84rem;
    line-height: 1.35;
    padding: 5px 0;
  }

  .mega-sublinks a:hover {
    color: var(--dropdown-text);
  }

  .mega-link:hover {
    background: var(--dropdown-link-hover);
    border-color: var(--dropdown-link-border);
    transform: translateX(3px);
  }

  .mega-link strong {
    color: var(--dropdown-text);
    font-size: 0.98rem;
  }

  .mega-link small {
    color: var(--dropdown-muted);
    line-height: 1.45;
  }

  .mega-feature {
    align-content: end;
    background: var(--dropdown-feature-bg);
    border: 1px solid var(--dropdown-feature-border);
    border-radius: 8px;
    display: grid;
    min-height: 268px;
    padding: 24px;
  }

  .mega-feature span {
    color: var(--dropdown-title);
    font-size: 0.8rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mega-feature strong {
    align-self: end;
    color: var(--dropdown-text);
    font-size: 1.4rem;
    line-height: 1.18;
    margin-top: auto;
  }

  .mega-feature em {
    color: var(--dropdown-title);
    font-style: normal;
    font-weight: 850;
    margin-top: 18px;
  }

  .nav-actions,
  .hero-actions {
    gap: 12px;
  }

  .btn {
    align-items: center;
    border: 1px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    display: inline-flex;
    font-weight: 750;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
    white-space: nowrap;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--blue), var(--blue-strong));
    box-shadow: 0 12px 30px rgba(45, 212, 255, 0.18);
    color: #03101d;
  }

  .btn-ghost {
    background: rgba(255, 255, 255, 0.04);
    border-color: var(--line);
    color: var(--text);
  }

  .nav-toggle {
    background: transparent;
    border: 0;
    display: none;
    height: 42px;
    margin-left: auto;
    width: 42px;
  }

  .nav-toggle span {
    background: var(--header-text);
    display: block;
    height: 2px;
    margin: 6px 0;
    width: 24px;
  }

  .hero {
    align-items: center;
    display: grid;
    gap: clamp(32px, 7vw, 92px);
    grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.98fr);
    min-height: calc(100vh - 82px);
    padding: clamp(56px, 8vw, 108px) clamp(20px, 5vw, 72px) 56px;
  }

  .hero-copy {
    max-width: 760px;
  }

  .eyebrow {
    color: var(--green);
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin-bottom: 14px;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    font-size: clamp(3rem, 7vw, 6.5rem);
    letter-spacing: 0;
    line-height: 0.94;
    margin-bottom: 26px;
  }

  h2 {
    font-size: clamp(2rem, 4.4vw, 4.2rem);
    letter-spacing: 0;
    line-height: 1;
    margin-bottom: 18px;
  }

  h3 {
    font-size: 1.24rem;
    line-height: 1.25;
  }

  p {
    color: var(--muted);
    font-size: 1.04rem;
    line-height: 1.7;
  }

  .hero-copy p {
    font-size: clamp(1.08rem, 1.6vw, 1.28rem);
    max-width: 640px;
  }

  .trust-row {
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 30px;
  }

  .trust-row span,
  .logo-strip span {
    border: 1px solid var(--line);
    border-radius: 999px;
    color: #cfe3f7;
    font-size: 0.86rem;
    padding: 9px 13px;
  }

  .hero-visual {
    aspect-ratio: 1 / 1.02;
    background:
      linear-gradient(145deg, rgba(18, 42, 71, 0.96), rgba(4, 15, 28, 0.98)),
      linear-gradient(90deg, transparent, rgba(45, 212, 255, 0.12), transparent);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow);
    min-height: 520px;
    overflow: hidden;
    padding: clamp(18px, 3vw, 32px);
    position: relative;
  }

  .hero-visual::before {
    content: "";
    inset: 70px 0 auto 0;
    height: 1px;
    position: absolute;
    background: linear-gradient(90deg, transparent, rgba(45, 212, 255, 0.75), transparent);
  }

  .visual-topbar {
    align-items: center;
    display: flex;
    gap: 8px;
  }

  .visual-topbar span {
    background: rgba(255, 255, 255, 0.22);
    border-radius: 50%;
    height: 10px;
    width: 10px;
  }

  .visual-topbar strong {
    color: #cfe3f7;
    font-size: 0.9rem;
    margin-left: 10px;
  }

  .risk-ring {
    align-items: center;
    background:
      radial-gradient(circle at center, #0b1b2e 0 52%, transparent 53%),
      conic-gradient(var(--green) 0 76%, rgba(255, 255, 255, 0.08) 76% 100%);
    border-radius: 50%;
    display: flex;
    height: min(46vw, 230px);
    justify-content: center;
    left: 50%;
    position: absolute;
    top: 104px;
    transform: translateX(-50%);
    width: min(46vw, 230px);
  }

  .risk-ring span {
    display: block;
    font-size: 3.2rem;
    font-weight: 850;
    text-align: center;
  }

  .risk-ring small,
  .policy-card small,
  .signal-list small {
    color: var(--muted);
    display: block;
  }

  .signal-list {
    display: grid;
    gap: 12px;
    position: absolute;
    right: 28px;
    top: 112px;
    width: min(230px, 42%);
  }

  .signal-list div,
  .policy-card,
  .module-card,
  .resource-panel,
  .lead-form,
  .about-card,
  .quote,
  .solution-card {
    background: var(--form-bg);
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .signal-list div {
    padding: 14px;
  }

  .signal-dot {
    border-radius: 50%;
    display: inline-block;
    height: 9px;
    margin-right: 8px;
    width: 9px;
  }

  .secure {
    background: var(--green);
  }

  .watch {
    background: var(--warning);
  }

  .policy-card {
    bottom: 30px;
    left: 30px;
    padding: 20px;
    position: absolute;
    right: 30px;
  }

  .policy-card strong {
    display: block;
    font-size: clamp(1rem, 2vw, 1.4rem);
    margin: 8px 0 18px;
  }

  .policy-bars {
    display: grid;
    gap: 10px;
  }

  .policy-bars span {
    background: linear-gradient(90deg, var(--blue), var(--green));
    border-radius: 999px;
    display: block;
    height: 8px;
    width: var(--w);
  }

  .logo-strip {
    border-block: 1px solid var(--line);
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
    padding: 24px clamp(20px, 5vw, 72px);
  }

  .section,
  .platform-band,
  .stats-row,
  .testimonial-band,
  .lead-section,
  .site-footer {
    padding: clamp(64px, 9vw, 116px) clamp(20px, 5vw, 72px);
  }

  .section-heading {
    max-width: 820px;
  }

  .card-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 36px;
  }

  .solution-card {
    min-height: 300px;
    padding: 28px;
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .solution-card:hover {
    border-color: rgba(45, 212, 255, 0.45);
    transform: translateY(-4px);
  }

  .card-index {
    color: var(--green);
    display: block;
    font-weight: 850;
    margin-bottom: 62px;
  }

  .solution-card a {
    color: var(--blue);
    font-weight: 800;
  }

  .platform-band {
    align-items: center;
    background:
      linear-gradient(90deg, rgba(10, 26, 45, 0.94), rgba(8, 20, 35, 0.82)),
      repeating-linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.04) 0,
        rgba(255, 255, 255, 0.04) 1px,
        transparent 1px,
        transparent 18px
      );
    border-block: 1px solid var(--line);
    display: grid;
    gap: 36px;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
  }

  .platform-copy {
    max-width: 640px;
  }

  .module-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .module-card {
    align-items: center;
    display: flex;
    gap: 14px;
    min-height: 88px;
    padding: 18px;
  }

  .module-card span {
    background: linear-gradient(135deg, var(--blue), var(--green));
    border-radius: 7px;
    flex: 0 0 34px;
    height: 34px;
  }

  .module-card p {
    color: var(--text);
    line-height: 1.35;
    margin: 0;
  }

  .stats-row {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .stat {
    border-left: 1px solid var(--line);
    padding: 8px 0 8px 22px;
  }

  .stat strong {
    display: block;
    font-size: clamp(2rem, 4vw, 3.5rem);
  }

  .stat span {
    color: var(--muted);
  }

  .split,
  .testimonial-band {
    align-items: start;
    display: grid;
    gap: 36px;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
  }

  .resource-panel {
    box-shadow: var(--shadow);
    padding: 18px;
  }

  .panel-row {
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 8px;
    padding: 22px 10px;
  }

  .panel-row:last-child {
    border-bottom: 0;
  }

  .panel-row span {
    color: var(--green);
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .panel-row strong {
    font-size: clamp(1.2rem, 2.5vw, 2rem);
  }

  .testimonial-band {
    background: var(--testimonial-bg);
    border-block: 1px solid var(--line);
  }

  .quote,
  .about-card,
  .lead-form {
    padding: clamp(24px, 4vw, 38px);
  }

  .quote p {
    color: var(--text);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    line-height: 1.18;
  }

  .quote span {
    color: var(--muted);
  }

  .lead-section {
    background: var(--lead-bg);
  }

  .form-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 36px;
  }

  .form-title {
    align-items: center;
    display: flex;
    gap: 14px;
    margin-bottom: 20px;
  }

  .form-title span {
    align-items: center;
    background: rgba(45, 212, 255, 0.12);
    border: 1px solid rgba(45, 212, 255, 0.28);
    border-radius: 8px;
    color: var(--green);
    display: inline-flex;
    font-weight: 850;
    height: 42px;
    justify-content: center;
    width: 42px;
  }

  .form-title h3 {
    margin: 0;
  }

  label {
    color: #cfe3f7;
    display: grid;
    font-size: 0.92rem;
    font-weight: 750;
    gap: 8px;
    margin-bottom: 16px;
  }

  input,
  select,
  textarea {
    background: var(--input-bg);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--text);
    min-height: 46px;
    outline: none;
    padding: 12px 14px;
    width: 100%;
  }

  textarea {
    resize: vertical;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--blue);
  }

  .lead-form button {
    width: 100%;
  }

  .lead-form button:disabled {
    cursor: progress;
    opacity: 0.6;
    transform: none;
  }

  .form-status {
    font-size: 0.92rem;
    min-height: 24px;
    margin: 14px 0 0;
  }

  .form-status.success {
    color: var(--green);
  }

  .form-status.error {
    color: #ff9e9e;
  }

  .site-footer {
    align-items: center;
    border-top: 1px solid var(--line);
    display: flex;
    gap: 28px;
    justify-content: space-between;
  }

  .site-footer p {
    margin-bottom: 0;
  }

  .site-footer nav {
    flex-wrap: wrap;
    gap: 18px;
  }

  .site-footer a {
    color: var(--muted);
  }

  .site-footer a:hover {
    color: var(--text);
  }

  .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 650ms ease,
      transform 650ms ease;
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1100px) {
    .site-header {
      flex-wrap: wrap;
      padding-block: 0;
    }

    .nav-toggle {
      display: block;
      margin-left: auto;
      order: 1;
    }

    .site-logo {
      order: 0;
    }

    .nav-links {
      background: var(--header-bg);
      border-top: 1px solid var(--header-border);
      display: none;
      flex: 1 0 100%;
      gap: 8px;
      justify-content: start;
      order: 2;
      padding: 10px 0 14px;
    }

    .nav-links.open {
      align-items: stretch;
      display: grid;
    }

    .nav-links > a,
    .nav-trigger {
      justify-content: space-between;
      min-height: 48px;
      padding-inline: 0;
      width: 100%;
    }

    .nav-item {
      display: grid;
    }

    .mega-menu {
      display: none;
      left: auto;
      opacity: 1;
      pointer-events: auto;
      position: static;
      right: auto;
      top: auto;
      transform: none;
      transition: none;
    }

    .nav-item:hover .mega-menu,
    .nav-item:focus-within .mega-menu {
      display: none;
    }

    .nav-item.is-open .mega-menu {
      display: block;
    }

    .mega-inner {
      box-shadow: none;
      grid-template-columns: 1fr;
      min-height: 0;
      padding: 16px;
    }

    .mega-columns {
      grid-template-columns: 1fr;
    }

    .mega-feature {
      min-height: 180px;
    }

    .nav-actions {
      display: none;
    }

    .nav-utilities {
      align-items: stretch;
      border-top: 1px solid var(--header-border);
      display: none;
      flex: 1 0 100%;
      gap: 12px;
      margin-left: 0;
      order: 3;
      padding: 0 0 16px;
    }

    .nav-links.open + .nav-utilities {
      display: grid;
    }

    .utility-link,
    .language-button,
    .utility-icon,
    .theme-toggle,
    .demo-button {
      justify-content: space-between;
      min-height: 44px;
      width: 100%;
    }

    .utility-icon {
      justify-content: flex-start;
    }

    .hero,
    .platform-band,
    .split,
    .testimonial-band {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
    }
  }

  @media (max-width: 820px) {
    .card-grid,
    .stats-row,
    .form-grid,
    .module-grid {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      min-height: 430px;
    }

    .signal-list {
      left: 24px;
      right: 24px;
      top: 110px;
      width: auto;
    }

    .risk-ring {
      display: none;
    }

    .site-footer {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 560px) {
    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .btn {
      width: 100%;
    }

    .site-header {
      padding-inline: 16px;
    }

    .hero,
    .section,
    .platform-band,
    .stats-row,
    .testimonial-band,
    .lead-section,
    .site-footer {
      padding-inline: 16px;
    }
  }

  .home-hero,
  .enable-section,
