---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const heroCards = [
  ["Understand Your Data", "Gain comprehensive visibility across all data repositories and interactions."],
  ["Derive Context", "Make intelligent decisions based on who uses data, where it moves, and why."],
  ["Enforce Automatically", "Classify data and enforce controls across people and AI workflows."],
  ["Prove It Is Handled Correctly", "Maintain continuous evidence that controls are active and policy is measurable."]
];

const armorPillars = [
  ["Action, Not Just Visibility", "Protects against threats by applying controls across data systems."],
  ["Built-In, Not Bolted-On", "Unified discovery and protection workflows work with the data itself."],
  ["Ubiquitous, Not Bounded", "Protects data wherever it goes, both internal and external."],
  ["Adaptive, Not Static", "Understands data context and adapts as usage changes."],
  ["Anticipatory, Not Reactive", "Acts early and reduces risk before data exposure becomes damage."]
];

const outcomes = [
  ["Empower Teams", "Let people collaborate freely while maintaining intelligent, invisible protection."],
  ["Turn Risk into Readiness", "Transform data security from a barrier into a competitive advantage."],
  ["Enable AI Everywhere", "Deploy AI initiatives confidently across your organization without compromising security."],
  ["Maintain Continuous Control", "Keep oversight of sensitive data regardless of where it travels or who accesses it."]
];

const useCases = [
  ["Secure third-party and partner collaboration", "Maintain control over shared data even when it moves beyond your organization."],
  ["Enable safe AI adoption across the business", "Adopt AI tools confidently while ensuring enterprise data remains protected."],
  ["Reduce insider risk without disrupting work", "Monitor misuse without preventing everyday productivity across the organization."],
  ["Support regulatory and audit readiness", "Demonstrate continuous control, clear visibility, and compliant policy enforcement."],
  ["Protect sensitive intellectual property", "Keep oversight of sensitive engineering and business trade data as it moves."]
];

const industries = [
  ["Financial Services", "Protect sensitive financial data across banking, insurance, and capital markets workflows."],
  ["Manufacturing", "Maintain control over critical information while enabling collaboration across the manufacturing ecosystem."],
  ["Semiconductor", "Secure high-value chip designs, IP, and supply-chain collaboration."],
  ["Government", "Enable secure data sharing while maintaining strict governance, sovereignty, and compliance."],
  ["Other Regulated Industries", "Meet industry-specific security and compliance requirements."]
];

const insights = [
  ["The Debate Over AI in the Enterprise Is Over. Here Is the Only Question That Still Matters.", "AI, Company, Data Security"],
  ["The Missing Link in Enterprise AI: Why Context and Behavior Are the New Security Perimeter", "AI Risk, Data Security"],
  ["ChatGPT Read 400 Internal Company Files in 42 Milliseconds. Security Stacks Saw Nothing.", "AI Risk, Data Security"]
];

---

<BaseLayout>
  <main id="top">
    <Nav />

    <section class="home-hero">
      <div class="home-hero-copy reveal">
        <span class="home-eyebrow">Data Security Intelligence</span>
        <h1>Embrace AI Fearlessly</h1>
        <p>
          Trust and control your data and achieve compliance wherever people and AI work.
        </p>
        <div class="home-actions">
          <a class="home-button primary" href="#demo">Book a Demo</a>
          <a class="home-button secondary" href="#platform">Explore Platform</a>
        </div>
        <div class="home-trust">
          <span>Trusted by industry-leading enterprises</span>
          <strong>SKYW0RKS</strong>
          <strong>MARUTI SUZUKI</strong>
        </div>
      </div>
      <div class="hero-photo reveal" aria-label="AI data security product visualization">
        <div class="glass-stage">
          <div class="data-column one"></div>
          <div class="data-column two"></div>
          <div class="data-column three"></div>
          <div class="data-line"></div>
        </div>
      </div>
    </section>

    <section class="enable-section" id="platform">
      <div class="enable-copy reveal">
        <h2>Safely Enable AI</h2>
        <p>
          Enable AI across the enterprise by understanding your data, applying contextual protection,
          and maintaining continuous control and proof.
        </p>
      </div>
      <div class="home-card-grid four">
        {heroCards.map(([title, text]) => (
          <article class="home-info-card reveal">
            <span class="mini-icon"></span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="armor-band">
      <div class="armor-panel reveal">
        <div>
          <span class="armor-logo">ARMOR</span>
          <h2>Data Security Intelligence, built for AI</h2>
          <p>
            Secure data with a unified, integrated control model. Intelligence is embedded directly
            into data, repositories, apps, users, partners, and AI agents.
          </p>
          <a class="home-button primary" href="/armor/dspm/">Explore ARMOR in Detail</a>
        </div>
        <div class="armor-pillars">
          {armorPillars.map(([title, text]) => (
            <article>
              <h3>{title}</h3>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="how-section">
      <h2>How Seclore ARMOR Works</h2>
      <div class="home-card-grid three">
        <article class="home-info-card reveal"><span class="mini-icon"></span><h3>Discover Your Data</h3><p>Discover what data exists and why it matters. Access people and AI.</p></article>
        <article class="home-info-card reveal"><span class="mini-icon"></span><h3>Control Data Persistently</h3><p>Apply intelligent, context-aware protection that moves with your data.</p></article>
        <article class="home-info-card reveal"><span class="mini-icon"></span><h3>Prove Trust at Scale</h3><p>Demonstrate compliance and security posture with continuous evidence.</p></article>
      </div>
    </section>

    <section class="achieve-section">
      <h2>What Organizations Achieve With Seclore</h2>
      <div class="home-card-grid four">
        {outcomes.map(([title, text]) => (
          <article class="home-info-card reveal"><span class="mini-icon"></span><h3>{title}</h3><p>{text}</p></article>
        ))}
      </div>
    </section>

    <section class="usecase-section" id="solutions">
      <h2>Real-World Use Cases</h2>
      <div class="home-card-grid five">
        {useCases.map(([title, text]) => (
          <article class="home-info-card reveal"><span class="mini-icon"></span><h3>{title}</h3><p>{text}</p></article>
        ))}
      </div>
    </section>

    <section class="industries-section" id="partners">
      <div class="industries-heading">
        <h2>Trusted Across Regulated and IP-driven Industries</h2>
      </div>
      <div class="industry-grid">
        {industries.map(([title, text]) => (
          <article class="industry-card reveal"><span class="mini-icon"></span><h3>{title}</h3><p>{text}</p><a href="#demo">Explore +</a></article>
        ))}
      </div>
    </section>

    <section class="testimonial-home" id="about">
      <h2>Trusted by Security Leaders Around the World</h2>
      <article class="quote-panel reveal">
        <span>AMERICAN AUTO CO.</span>
        <p>
          "We use Seclore for our ERP-PG where we need to share confidential designs to suppliers
          today, plus archive our specifications. From the moment a supplier receives access,
          controls and requirements move with the data."
        </p>
        <strong>Customer Story</strong>
      </article>
    </section>

    <section class="awards-section">
      <h2>Award-Winning Enterprise Security</h2>
      <div class="award-grid">
        <article>CRN Top 100 Cloud Security Winner</article>
        <article>CRN Channel Chief Winner</article>
        <article>CRN Women of the Channel</article>
        <article>Fortress Cybersecurity Award</article>
      </div>
    </section>

    <section class="insights-home" id="resources">
      <div class="insights-heading">
        <h2>Insights on AI, data security, and trust</h2>
        <a href="#resources">View All Resources</a>
      </div>
      <div class="insight-grid">
        {insights.map(([title, tag]) => (
          <article class="insight-card reveal">
            <div class="insight-image"></div>
            <span>{tag}</span>
            <h3>{title}</h3>
            <a href="#resources">View Blog Post +</a>
          </article>
        ))}
      </div>
    </section>
  </main>

  <script is:inline>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.18 }
    );

    document.querySelectorAll(".reveal").forEach((item) => observer.observe(item));
  </script>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #05111f;
    --bg-soft: #0a1a2d;
    --panel: rgba(12, 30, 51, 0.82);
    --panel-strong: #10233a;
    --line: rgba(151, 190, 230, 0.18);
    --text: #edf7ff;
    --muted: #9eb5ca;
    --blue: #2dd4ff;
    --blue-strong: #4f8cff;
    --green: #7cf6c7;
    --warning: #ffd166;
    --shadow: 0 24px 80px rgba(0, 0, 0, 0.36);
    --body-gradient: linear-gradient(180deg, rgba(5, 17, 31, 0.92), var(--bg) 38%);
    --body-grid: repeating-linear-gradient(
      90deg,
      rgba(45, 212, 255, 0.04) 0,
      rgba(45, 212, 255, 0.04) 1px,
      transparent 1px,
      transparent 96px
    );
    --fixed-grid-line: rgba(45, 212, 255, 0.035);
    --header-bg: #07111f;
    --header-border: rgba(151, 190, 230, 0.18);
    --header-shadow: 0 14px 34px rgba(0, 0, 0, 0.28);
    --header-text: #edf7ff;
    --header-muted: #c5d6e8;
    --dropdown-bg: linear-gradient(135deg, rgba(9, 25, 44, 0.98), rgba(5, 17, 31, 0.98));
    --dropdown-grid-line: rgba(45, 212, 255, 0.045);
    --dropdown-border: rgba(151, 190, 230, 0.18);
    --dropdown-link-hover: rgba(255, 255, 255, 0.055);
    --dropdown-link-border: rgba(45, 212, 255, 0.22);
    --dropdown-title: var(--green);
    --dropdown-text: var(--text);
    --dropdown-muted: var(--muted);
    --dropdown-feature-bg: linear-gradient(
        160deg,
        rgba(45, 212, 255, 0.18),
        rgba(124, 246, 199, 0.08)
      ),
      rgba(255, 255, 255, 0.045);
    --dropdown-feature-border: rgba(45, 212, 255, 0.22);
    --form-bg: rgba(9, 25, 44, 0.72);
    --input-bg: rgba(255, 255, 255, 0.055);
    --testimonial-bg: #071523;
    --lead-bg: linear-gradient(180deg, var(--bg), #071626);
    --demo-button-bg: #ffffff;
    --demo-button-text: #07111f;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  html[data-theme="light"] {
    color-scheme: light;
    --bg: #f5f8fc;
    --bg-soft: #ffffff;
    --panel: rgba(255, 255, 255, 0.92);
    --panel-strong: #ffffff;
    --line: rgba(15, 23, 42, 0.12);
    --text: #0f172a;
    --muted: #53657a;
    --blue: #0b66d8;
    --blue-strong: #1457c8;
    --green: #087f6f;
    --warning: #a76500;
    --shadow: 0 22px 70px rgba(15, 23, 42, 0.12);
    --body-gradient: linear-gradient(180deg, #f8fbff, #eef5fc 42%, #f7fafc);
    --body-grid: repeating-linear-gradient(
      90deg,
      rgba(11, 102, 216, 0.045) 0,
      rgba(11, 102, 216, 0.045) 1px,
      transparent 1px,
      transparent 96px
    );
    --fixed-grid-line: rgba(11, 102, 216, 0.035);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #07111f;
    --header-muted: #2a2a2a;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(
        160deg,
        rgba(15, 92, 173, 0.12),
        rgba(11, 140, 115, 0.08)
      ),
      rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --form-bg: rgba(255, 255, 255, 0.88);
    --input-bg: rgba(15, 23, 42, 0.035);
    --testimonial-bg: #eef5fc;
    --lead-bg: linear-gradient(180deg, #f7fafc, #edf4fb);
    --demo-button-bg: #07111f;
    --demo-button-text: #ffffff;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--body-gradient), var(--body-grid);
    color: var(--text);
    transition:
      background 220ms ease,
      color 220ms ease;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(var(--fixed-grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--fixed-grid-line) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: linear-gradient(to bottom, black, transparent 70%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  select,
  textarea {
    font: inherit;
  }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    left: 0;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    right: 0;
    top: 0;
    z-index: 20;
  }

  .brand,
  .nav-links,
  .nav-actions,
  .hero-actions,
  .trust-row,
  .logo-strip,
  .site-footer nav,
  .nav-utilities {
    align-items: center;
    display: flex;
  }

  .site-logo {
    color: var(--header-text);
    flex: 0 0 auto;
    font-size: 1.35rem;
    font-weight: 900;
    letter-spacing: 0;
    line-height: 1;
    margin-right: clamp(14px, 2vw, 28px);
  }

  .brand {
    gap: 10px;
    font-size: 1.08rem;
    font-weight: 800;
    letter-spacing: 0;
  }

  .brand-mark {
    align-items: center;
    background: linear-gradient(135deg, var(--blue), var(--green));
    border-radius: 10px;
    display: inline-flex;
    height: 34px;
    justify-content: center;
    width: 34px;
  }

  .brand-mark span {
    border: 2px solid #061427;
    border-top: 0;
    height: 16px;
    transform: rotate(45deg);
    width: 10px;
  }

  .nav-links {
    flex: 1 1 auto;
    gap: clamp(18px, 2.2vw, 34px);
    justify-content: center;
    min-width: 0;
  }

  .nav-links > a,
  .nav-trigger,
  .site-footer a {
    color: var(--header-muted);
    font-size: 0.98rem;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:focus-within .nav-trigger,
  .nav-item:hover .nav-trigger,
  .site-footer a:hover {
    color: var(--header-text);
  }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    border-radius: 8px;
    display: inline-flex;
    gap: 8px;
    font-weight: 800;
    min-height: 68px;
    padding: 0;
  }

  .brand-trigger {
    color: var(--header-text);
    font-size: 0.98rem;
  }

  .nav-utilities {
    flex: 0 0 auto;
    gap: clamp(12px, 1.5vw, 20px);
    margin-left: clamp(12px, 2vw, 28px);
  }

  .utility-link,
  .language-button,
  .utility-icon {
    color: var(--header-muted);
    font-size: 0.88rem;
    font-weight: 750;
  }

  .utility-link {
    white-space: nowrap;
  }

  .utility-icon,
  .language-button,
  .theme-toggle {
    align-items: center;
    background: transparent;
    border: 0;
    cursor: pointer;
    display: inline-flex;
    gap: 8px;
    padding: 0;
  }

  .theme-toggle {
    color: var(--header-muted);
    font-size: 0.88rem;
    font-weight: 800;
  }

  .theme-toggle-track {
    align-items: center;
    background: rgba(127, 139, 155, 0.24);
    border: 1px solid var(--header-border);
    border-radius: 999px;
    display: inline-flex;
    height: 24px;
    padding: 2px;
    transition:
      background 180ms ease,
      border-color 180ms ease;
    width: 44px;
  }

  .theme-toggle-thumb {
    background: var(--header-text);
    border-radius: 50%;
    display: block;
    height: 18px;
    transform: translateX(18px);
    transition:
      background 180ms ease,
      transform 180ms ease;
    width: 18px;
  }

  html[data-theme="light"] .theme-toggle-thumb {
    transform: translateX(0);
  }

  .search-icon {
    border: 2px solid currentColor;
    border-radius: 50%;
    display: inline-block;
    height: 17px;
    position: relative;
    width: 17px;
  }

  .search-icon::after {
    background: currentColor;
    content: "";
    height: 2px;
    position: absolute;
    right: -6px;
    top: 12px;
    transform: rotate(45deg);
    width: 8px;
  }

  .demo-button {
    align-items: center;
    background: var(--demo-button-bg);
    border-radius: 999px;
    color: var(--demo-button-text);
    display: inline-flex;
    font-size: 0.9rem;
    font-weight: 850;
    min-height: 42px;
    padding: 0 18px;
    white-space: nowrap;
  }

  .nav-trigger {
    background: transparent;
    border: 0;
    cursor: pointer;
  }

  .nav-item {
    position: static;
  }

  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret {
    transform: rotate(225deg) translateY(-1px);
  }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mega-inner {
    background:
      var(--dropdown-bg),
      repeating-linear-gradient(
        135deg,
        var(--dropdown-grid-line) 0,
        var(--dropdown-grid-line) 1px,
        transparent 1px,
        transparent 20px
      );
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: var(--shadow);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .mega-column {
    display: grid;
    gap: 10px;
  }

  .mega-title {
    color: var(--dropdown-title);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    margin-bottom: 4px;
    text-transform: uppercase;
  }

  .mega-link {
    border: 1px solid transparent;
    border-radius: 8px;
    display: grid;
    gap: 5px;
    padding: 13px;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      transform 180ms ease;
  }

  .mega-link-group {
    border: 1px solid transparent;
    border-radius: 8px;
    display: grid;
    gap: 4px;
    padding: 4px;
  }

  .mega-link-group:hover {
    background: var(--dropdown-link-hover);
    border-color: var(--dropdown-link-border);
  }

  .mega-link-group .mega-link {
    padding: 9px 9px 5px;
  }

  .mega-link-group .mega-link:hover {
    background: transparent;
    border-color: transparent;
    transform: none;
  }

  .mega-parent-link strong {
    align-items: center;
    display: flex;
    gap: 8px;
  }

  .mega-parent-link strong::after {
    border-bottom: 1.5px solid currentColor;
    border-right: 1.5px solid currentColor;
    content: "";
    height: 6px;
    transform: rotate(-45deg);
    width: 6px;
  }

  .mega-sublinks {
    display: grid;
    gap: 2px;
    padding: 0 9px 8px 22px;
  }

  .mega-sublinks a {
    color: var(--dropdown-muted);
    font-size: 0.84rem;
    line-height: 1.35;
    padding: 5px 0;
  }

  .mega-sublinks a:hover {
    color: var(--dropdown-text);
  }

  .mega-link:hover {
    background: var(--dropdown-link-hover);
    border-color: var(--dropdown-link-border);
    transform: translateX(3px);
  }

  .mega-link strong {
    color: var(--dropdown-text);
    font-size: 0.98rem;
  }

  .mega-link small {
    color: var(--dropdown-muted);
    line-height: 1.45;
  }

  .mega-feature {
    align-content: end;
    background: var(--dropdown-feature-bg);
    border: 1px solid var(--dropdown-feature-border);
    border-radius: 8px;
    display: grid;
    min-height: 268px;
    padding: 24px;
  }

  .mega-feature span {
    color: var(--dropdown-title);
    font-size: 0.8rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mega-feature strong {
    align-self: end;
    color: var(--dropdown-text);
    font-size: 1.4rem;
    line-height: 1.18;
    margin-top: auto;
  }

  .mega-feature em {
    color: var(--dropdown-title);
    font-style: normal;
    font-weight: 850;
    margin-top: 18px;
  }

  .nav-actions,
  .hero-actions {
    gap: 12px;
  }

  .btn {
    align-items: center;
    border: 1px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    display: inline-flex;
    font-weight: 750;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
    white-space: nowrap;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--blue), var(--blue-strong));
    box-shadow: 0 12px 30px rgba(45, 212, 255, 0.18);
    color: #03101d;
  }

  .btn-ghost {
    background: rgba(255, 255, 255, 0.04);
    border-color: var(--line);
    color: var(--text);
  }

  .nav-toggle {
    background: transparent;
    border: 0;
    display: none;
    height: 42px;
    margin-left: auto;
    width: 42px;
  }

  .nav-toggle span {
    background: var(--header-text);
    display: block;
    height: 2px;
    margin: 6px 0;
    width: 24px;
  }

  .hero {
    align-items: center;
    display: grid;
    gap: clamp(32px, 7vw, 92px);
    grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.98fr);
    min-height: calc(100vh - 82px);
    padding: clamp(56px, 8vw, 108px) clamp(20px, 5vw, 72px) 56px;
  }

  .hero-copy {
    max-width: 760px;
  }

  .eyebrow {
    color: var(--green);
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin-bottom: 14px;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    font-size: clamp(3rem, 7vw, 6.5rem);
    letter-spacing: 0;
    line-height: 0.94;
    margin-bottom: 26px;
  }

  h2 {
    font-size: clamp(2rem, 4.4vw, 4.2rem);
    letter-spacing: 0;
    line-height: 1;
    margin-bottom: 18px;
  }

  h3 {
    font-size: 1.24rem;
    line-height: 1.25;
  }

  p {
    color: var(--muted);
    font-size: 1.04rem;
    line-height: 1.7;
  }

  .hero-copy p {
    font-size: clamp(1.08rem, 1.6vw, 1.28rem);
    max-width: 640px;
  }

  .trust-row {
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 30px;
  }

  .trust-row span,
  .logo-strip span {
    border: 1px solid var(--line);
    border-radius: 999px;
    color: #cfe3f7;
    font-size: 0.86rem;
    padding: 9px 13px;
  }

  .hero-visual {
    aspect-ratio: 1 / 1.02;
    background:
      linear-gradient(145deg, rgba(18, 42, 71, 0.96), rgba(4, 15, 28, 0.98)),
      linear-gradient(90deg, transparent, rgba(45, 212, 255, 0.12), transparent);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow);
    min-height: 520px;
    overflow: hidden;
    padding: clamp(18px, 3vw, 32px);
    position: relative;
  }

  .hero-visual::before {
    content: "";
    inset: 70px 0 auto 0;
    height: 1px;
    position: absolute;
    background: linear-gradient(90deg, transparent, rgba(45, 212, 255, 0.75), transparent);
  }

  .visual-topbar {
    align-items: center;
    display: flex;
    gap: 8px;
  }

  .visual-topbar span {
    background: rgba(255, 255, 255, 0.22);
    border-radius: 50%;
    height: 10px;
    width: 10px;
  }

  .visual-topbar strong {
    color: #cfe3f7;
    font-size: 0.9rem;
    margin-left: 10px;
  }

  .risk-ring {
    align-items: center;
    background:
      radial-gradient(circle at center, #0b1b2e 0 52%, transparent 53%),
      conic-gradient(var(--green) 0 76%, rgba(255, 255, 255, 0.08) 76% 100%);
    border-radius: 50%;
    display: flex;
    height: min(46vw, 230px);
    justify-content: center;
    left: 50%;
    position: absolute;
    top: 104px;
    transform: translateX(-50%);
    width: min(46vw, 230px);
  }

  .risk-ring span {
    display: block;
    font-size: 3.2rem;
    font-weight: 850;
    text-align: center;
  }

  .risk-ring small,
  .policy-card small,
  .signal-list small {
    color: var(--muted);
    display: block;
  }

  .signal-list {
    display: grid;
    gap: 12px;
    position: absolute;
    right: 28px;
    top: 112px;
    width: min(230px, 42%);
  }

  .signal-list div,
  .policy-card,
  .module-card,
  .resource-panel,
  .lead-form,
  .about-card,
  .quote,
  .solution-card {
    background: var(--form-bg);
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .signal-list div {
    padding: 14px;
  }

  .signal-dot {
    border-radius: 50%;
    display: inline-block;
    height: 9px;
    margin-right: 8px;
    width: 9px;
  }

  .secure {
    background: var(--green);
  }

  .watch {
    background: var(--warning);
  }

  .policy-card {
    bottom: 30px;
    left: 30px;
    padding: 20px;
    position: absolute;
    right: 30px;
  }

  .policy-card strong {
    display: block;
    font-size: clamp(1rem, 2vw, 1.4rem);
    margin: 8px 0 18px;
  }

  .policy-bars {
    display: grid;
    gap: 10px;
  }

  .policy-bars span {
    background: linear-gradient(90deg, var(--blue), var(--green));
    border-radius: 999px;
    display: block;
    height: 8px;
    width: var(--w);
  }

  .logo-strip {
    border-block: 1px solid var(--line);
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
    padding: 24px clamp(20px, 5vw, 72px);
  }

  .section,
  .platform-band,
  .stats-row,
  .testimonial-band,
  .lead-section,
  .site-footer {
    padding: clamp(64px, 9vw, 116px) clamp(20px, 5vw, 72px);
  }

  .section-heading {
    max-width: 820px;
  }

  .card-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 36px;
  }

  .solution-card {
    min-height: 300px;
    padding: 28px;
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .solution-card:hover {
    border-color: rgba(45, 212, 255, 0.45);
    transform: translateY(-4px);
  }

  .card-index {
    color: var(--green);
    display: block;
    font-weight: 850;
    margin-bottom: 62px;
  }

  .solution-card a {
    color: var(--blue);
    font-weight: 800;
  }

  .platform-band {
    align-items: center;
    background:
      linear-gradient(90deg, rgba(10, 26, 45, 0.94), rgba(8, 20, 35, 0.82)),
      repeating-linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.04) 0,
        rgba(255, 255, 255, 0.04) 1px,
        transparent 1px,
        transparent 18px
      );
    border-block: 1px solid var(--line);
    display: grid;
    gap: 36px;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
  }

  .platform-copy {
    max-width: 640px;
  }

  .module-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .module-card {
    align-items: center;
    display: flex;
    gap: 14px;
    min-height: 88px;
    padding: 18px;
  }

  .module-card span {
    background: linear-gradient(135deg, var(--blue), var(--green));
    border-radius: 7px;
    flex: 0 0 34px;
    height: 34px;
  }

  .module-card p {
    color: var(--text);
    line-height: 1.35;
    margin: 0;
  }

  .stats-row {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .stat {
    border-left: 1px solid var(--line);
    padding: 8px 0 8px 22px;
  }

  .stat strong {
    display: block;
    font-size: clamp(2rem, 4vw, 3.5rem);
  }

  .stat span {
    color: var(--muted);
  }

  .split,
  .testimonial-band {
    align-items: start;
    display: grid;
    gap: 36px;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
  }

  .resource-panel {
    box-shadow: var(--shadow);
    padding: 18px;
  }

  .panel-row {
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 8px;
    padding: 22px 10px;
  }

  .panel-row:last-child {
    border-bottom: 0;
  }

  .panel-row span {
    color: var(--green);
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .panel-row strong {
    font-size: clamp(1.2rem, 2.5vw, 2rem);
  }

  .testimonial-band {
    background: var(--testimonial-bg);
    border-block: 1px solid var(--line);
  }

  .quote,
  .about-card,
  .lead-form {
    padding: clamp(24px, 4vw, 38px);
  }

  .quote p {
    color: var(--text);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    line-height: 1.18;
  }

  .quote span {
    color: var(--muted);
  }

  .lead-section {
    background: var(--lead-bg);
  }

  .form-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 36px;
  }

  .form-title {
    align-items: center;
    display: flex;
    gap: 14px;
    margin-bottom: 20px;
  }

  .form-title span {
    align-items: center;
    background: rgba(45, 212, 255, 0.12);
    border: 1px solid rgba(45, 212, 255, 0.28);
    border-radius: 8px;
    color: var(--green);
    display: inline-flex;
    font-weight: 850;
    height: 42px;
    justify-content: center;
    width: 42px;
  }

  .form-title h3 {
    margin: 0;
  }

  label {
    color: #cfe3f7;
    display: grid;
    font-size: 0.92rem;
    font-weight: 750;
    gap: 8px;
    margin-bottom: 16px;
  }

  input,
  select,
  textarea {
    background: var(--input-bg);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--text);
    min-height: 46px;
    outline: none;
    padding: 12px 14px;
    width: 100%;
  }

  textarea {
    resize: vertical;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--blue);
  }

  .lead-form button {
    width: 100%;
  }

  .lead-form button:disabled {
    cursor: progress;
    opacity: 0.6;
    transform: none;
  }

  .form-status {
    font-size: 0.92rem;
    min-height: 24px;
    margin: 14px 0 0;
  }

  .form-status.success {
    color: var(--green);
  }

  .form-status.error {
    color: #ff9e9e;
  }

  .site-footer {
    align-items: center;
    border-top: 1px solid var(--line);
    display: flex;
    gap: 28px;
    justify-content: space-between;
  }

  .site-footer p {
    margin-bottom: 0;
  }

  .site-footer nav {
    flex-wrap: wrap;
    gap: 18px;
  }

  .site-footer a {
    color: var(--muted);
  }

  .site-footer a:hover {
    color: var(--text);
  }

  .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 650ms ease,
      transform 650ms ease;
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1100px) {
    .site-header {
      flex-wrap: wrap;
      padding-block: 0;
    }

    .nav-toggle {
      display: block;
      margin-left: auto;
      order: 1;
    }

    .site-logo {
      order: 0;
    }

    .nav-links {
      background: var(--header-bg);
      border-top: 1px solid var(--header-border);
      display: none;
      flex: 1 0 100%;
      gap: 8px;
      justify-content: start;
      order: 2;
      padding: 10px 0 14px;
    }

    .nav-links.open {
      align-items: stretch;
      display: grid;
    }

    .nav-links > a,
    .nav-trigger {
      justify-content: space-between;
      min-height: 48px;
      padding-inline: 0;
      width: 100%;
    }

    .nav-item {
      display: grid;
    }

    .mega-menu {
      display: none;
      left: auto;
      opacity: 1;
      pointer-events: auto;
      position: static;
      right: auto;
      top: auto;
      transform: none;
      transition: none;
    }

    .nav-item:hover .mega-menu,
    .nav-item:focus-within .mega-menu {
      display: none;
    }

    .nav-item.is-open .mega-menu {
      display: block;
    }

    .mega-inner {
      box-shadow: none;
      grid-template-columns: 1fr;
      min-height: 0;
      padding: 16px;
    }

    .mega-columns {
      grid-template-columns: 1fr;
    }

    .mega-feature {
      min-height: 180px;
    }

    .nav-actions {
      display: none;
    }

    .nav-utilities {
      align-items: stretch;
      border-top: 1px solid var(--header-border);
      display: none;
      flex: 1 0 100%;
      gap: 12px;
      margin-left: 0;
      order: 3;
      padding: 0 0 16px;
    }

    .nav-links.open + .nav-utilities {
      display: grid;
    }

    .utility-link,
    .language-button,
    .utility-icon,
    .theme-toggle,
    .demo-button {
      justify-content: space-between;
      min-height: 44px;
      width: 100%;
    }

    .utility-icon {
      justify-content: flex-start;
    }

    .hero,
    .platform-band,
    .split,
    .testimonial-band {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
    }
  }

  @media (max-width: 820px) {
    .card-grid,
    .stats-row,
    .form-grid,
    .module-grid {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      min-height: 430px;
    }

    .signal-list {
      left: 24px;
      right: 24px;
      top: 110px;
      width: auto;
    }

    .risk-ring {
      display: none;
    }

    .site-footer {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 560px) {
    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .btn {
      width: 100%;
    }

    .site-header {
      padding-inline: 16px;
    }

    .hero,
    .section,
    .platform-band,
    .stats-row,
    .testimonial-band,
    .lead-section,
    .site-footer {
      padding-inline: 16px;
    }
  }

  .home-hero,
  .enable-section,
  .armor-band,
  .how-section,
  .achieve-section,
  .usecase-section,
  .industries-section,
  .testimonial-home,
  .awards-section,
  .insights-home,
  .site-footer {
    background: #ffffff;
    color: #251f2f;
    padding: clamp(48px, 7vw, 92px) clamp(18px, 5vw, 72px);
  }

  html[data-theme="dark"] .home-hero,
  html[data-theme="dark"] .enable-section,
  html[data-theme="dark"] .how-section,
  html[data-theme="dark"] .achieve-section,
  html[data-theme="dark"] .usecase-section,
  html[data-theme="dark"] .industries-section,
  html[data-theme="dark"] .testimonial-home,
  html[data-theme="dark"] .insights-home,
  html[data-theme="dark"] .site-footer {
    background: #07111f;
    color: var(--text);
  }

  .home-hero {
    align-items: center;
    display: grid;
    gap: clamp(34px, 7vw, 96px);
    grid-template-columns: minmax(0, 0.92fr) minmax(320px, 1.08fr);
    min-height: calc(100vh - 68px);
    padding-top: clamp(34px, 6vw, 76px);
  }

  .home-eyebrow {
    color: #5b2bd7;
    display: block;
    font-size: 0.86rem;
    font-weight: 800;
    margin-bottom: 18px;
  }

  .home-hero h1 {
    color: inherit;
    font-size: clamp(3.4rem, 7vw, 7rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 0.92;
    margin-bottom: 24px;
  }

  .home-hero p,
  .enable-copy p,
  .home-info-card p,
  .armor-panel p,
  .industry-card p,
  .quote-panel p,
  .site-footer p {
    color: #635d6f;
  }

  html[data-theme="dark"] .home-hero p,
  html[data-theme="dark"] .enable-copy p,
  html[data-theme="dark"] .home-info-card p,
  html[data-theme="dark"] .armor-panel p,
  html[data-theme="dark"] .industry-card p,
  html[data-theme="dark"] .quote-panel p,
  html[data-theme="dark"] .site-footer p {
    color: var(--muted);
  }

  .home-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 28px 0 58px;
  }

  .home-button {
    align-items: center;
    border-radius: 7px;
    display: inline-flex;
    font-weight: 850;
    justify-content: center;
    min-height: 42px;
    padding: 0 18px;
  }

  .home-button.primary {
    background: #5b2bd7;
    color: #ffffff;
  }

  .home-button.secondary {
    border: 1px solid rgba(91, 43, 215, 0.32);
    color: #5b2bd7;
  }

  .home-trust {
    display: grid;
    gap: 18px;
  }

  .home-trust span {
    color: #7a7484;
    font-size: 0.92rem;
  }

  .home-trust strong {
    color: #2d2836;
    display: inline-block;
    font-size: 1rem;
    margin-right: 24px;
  }

  .hero-photo {
    align-items: center;
    background:
      linear-gradient(135deg, rgba(91, 43, 215, 0.1), rgba(91, 43, 215, 0)),
      linear-gradient(180deg, #f5efff, #fff);
    border-radius: 14px;
    display: flex;
    min-height: min(62vw, 560px);
    overflow: hidden;
    padding: clamp(28px, 5vw, 58px);
    position: relative;
  }

  .hero-photo::before {
    background: radial-gradient(circle, rgba(91, 43, 215, 0.18), transparent 58%);
    content: "";
    inset: -20%;
    position: absolute;
  }

  .glass-stage {
    aspect-ratio: 0.78 / 1;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.56), rgba(255, 255, 255, 0.22));
    border: 1px solid rgba(91, 43, 215, 0.18);
    box-shadow: 0 28px 80px rgba(91, 43, 215, 0.18);
    margin: auto;
    position: relative;
    width: min(360px, 86%);
  }

  .glass-stage::after {
    background: linear-gradient(90deg, transparent, #5b2bd7, transparent);
    content: "";
    height: 8px;
    left: 8%;
    position: absolute;
    right: 8%;
    top: 50%;
  }

  .data-column {
    background: rgba(255, 255, 255, 0.54);
    border: 1px solid rgba(91, 43, 215, 0.26);
    bottom: 18%;
    position: absolute;
    width: 18%;
  }

  .data-column.one { height: 52%; left: 18%; }
  .data-column.two { height: 72%; left: 42%; }
  .data-column.three { height: 44%; right: 16%; }

  .enable-section {
    align-items: start;
    display: grid;
    gap: 30px;
    grid-template-columns: 0.75fr 1.25fr;
  }

  .enable-copy h2,
  .how-section h2,
  .achieve-section h2,
  .usecase-section h2,
  .testimonial-home h2,
  .awards-section h2,
  .insights-heading h2 {
    color: inherit;
    font-size: clamp(2rem, 4vw, 4rem);
    font-weight: 450;
    letter-spacing: 0;
    line-height: 1;
  }

  .home-card-grid {
    display: grid;
    gap: 18px;
  }

  .home-card-grid.four {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .home-card-grid.three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .home-card-grid.five,
  .industry-grid,
  .insight-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .home-info-card,
  .industry-card,
  .insight-card {
    background: #f8f7fb;
    border: 1px solid rgba(91, 43, 215, 0.08);
    border-radius: 12px;
    min-height: 220px;
    padding: 24px;
  }

  html[data-theme="dark"] .home-info-card,
  html[data-theme="dark"] .industry-card,
  html[data-theme="dark"] .insight-card {
    background: var(--panel);
    border-color: var(--line);
  }

  .mini-icon {
    background: linear-gradient(135deg, rgba(91, 43, 215, 0.08), rgba(91, 43, 215, 0.22));
    border: 1px solid rgba(91, 43, 215, 0.18);
    border-radius: 8px;
    display: block;
    height: 34px;
    margin-bottom: 22px;
    width: 34px;
  }

  .home-info-card h3,
  .industry-card h3,
  .insight-card h3 {
    color: inherit;
    font-size: 1.1rem;
    margin-bottom: 12px;
  }

  .armor-band,
  .awards-section {
    background:
      linear-gradient(135deg, rgba(91, 43, 215, 0.12), rgba(91, 43, 215, 0.02)),
      #eaf0ff;
  }

  html[data-theme="dark"] .armor-band,
  html[data-theme="dark"] .awards-section {
    background: linear-gradient(135deg, #101d36, #21173a);
  }

  .armor-panel {
    align-items: center;
    display: grid;
    gap: 36px;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    margin: 0 auto;
    max-width: 1180px;
  }

  .armor-logo {
    color: #5b2bd7;
    display: block;
    font-size: clamp(2rem, 4vw, 4.5rem);
    font-weight: 900;
    margin-bottom: 20px;
  }

  .armor-pillars {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .armor-pillars article {
    background: rgba(255, 255, 255, 0.72);
    border-radius: 12px;
    padding: 24px;
