---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

export function getStaticPaths() {
  return [
    {
      params: { device: "laptop-desktop" },
      props: {
        title: "Laptop or Desktop",
        intro: "Use these steps when you are opening a Seclore-protected file on Windows or macOS.",
        steps: [
          "Open the protected file from your email, browser download, or shared location.",
          "If prompted, install or launch the Seclore agent for your laptop or desktop.",
          "Sign in with the email address that received access to the file.",
          "After authorization completes, the file opens in the supported application."
        ]
      }
    },
    {
      params: { device: "mobile-tablet" },
      props: {
        title: "Mobile Phone or Tablet",
        intro: "Use these steps when you are opening a Seclore-protected file on a phone or tablet.",
        steps: [
          "Open the protected file link or attachment on your mobile device.",
          "Install the Seclore app from the app store if your device asks for it.",
          "Sign in with the email address that was granted access.",
          "The Seclore app validates your permissions and opens the protected file."
        ]
      }
    }
  ];
}

const { title, intro, steps } = Astro.props;
---

<BaseLayout
  title={`${title} | How to Open a Seclore-protected File`}
  description={intro}
>
  <main class="device-page">
    <Nav />
    <header class="simple-header">
      <a class="site-logo" href="/">seclore</a>
      <a class="demo-button" href="/about/contact-us/">Book a Demo</a>
      <a class="menu-mark" href="/how-to-open-a-seclore-protected-file/" aria-label="Back to device choices">
        <span></span><span></span><span></span>
      </a>
    </header>

    <section class="device-hero">
      <span class="eyebrow">How to open a Seclore-protected file</span>
      <h1>{title}</h1>
      <p>{intro}</p>
      <a class="primary-button" href="/how-to-open-a-seclore-protected-file/">Choose a different device</a>
    </section>

    <section class="instruction-section">
      <div class="step-badge" aria-hidden="true">2</div>
      <div>
        <h2>Follow these steps</h2>
        <ol>
          {steps.map((step) => <li>{step}</li>)}
        </ol>
      </div>
    </section>

    <section class="cta-section">
      <h2>Ready to get started?</h2>
      <p>Contact our sales team to find out how Seclore can help with data security and compliance.</p>
      <a class="primary-button" href="/about/contact-us/">Book a Demo</a>
    </section>
  </main>
</BaseLayout>

<style>
  :global(body) {
    margin: 0;
    background: #fff;
    color: #17111d;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a { color: inherit; text-decoration: none; }
  h1, h2, p { margin: 0; }

  .simple-header {
    align-items: center;
    background: #fff;
    box-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    display: flex;
    min-height: 88px;
    padding: 0 clamp(20px, 4vw, 42px) 0 30px;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .site-logo {
    color: #5a31d6;
    font-size: 1.55rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: auto;
    text-transform: uppercase;
  }

  .demo-button,
  .primary-button {
    align-items: center;
    background: linear-gradient(135deg, #5a31d6, #4620bf);
    border-radius: 8px;
    color: #fff;
    display: inline-flex;
    font-weight: 850;
    justify-content: center;
    min-height: 50px;
    padding: 0 34px;
  }

  .menu-mark {
    display: grid;
    gap: 7px;
    margin-left: 28px;
    padding: 8px;
  }

  .menu-mark span {
    background: #25242a;
    display: block;
    height: 2px;
    width: 30px;
  }

  .device-hero {
    background: #271126;
    color: #fff;
    padding: clamp(52px, 8vw, 92px) clamp(30px, 6vw, 86px);
  }

  .eyebrow {
    color: #cfc3ff;
    display: block;
    font-weight: 850;
    margin-bottom: 1.4rem;
  }

  .device-hero h1 {
    font-size: clamp(4rem, 8vw, 6.4rem);
    font-weight: 400;
    line-height: 0.98;
  }

  .device-hero p {
    color: rgba(255, 255, 255, 0.78);
    font-size: clamp(1.25rem, 2vw, 1.55rem);
    line-height: 1.5;
    margin-top: 2rem;
    max-width: 760px;
  }

  .device-hero .primary-button { margin-top: 2.4rem; }

  .instruction-section {
    display: grid;
    gap: 72px;
    grid-template-columns: 56px minmax(0, 1fr);
    padding: 68px clamp(30px, 5vw, 72px) 82px;
  }

  .step-badge {
    align-items: center;
    background: #2e2f33;
    border-radius: 50%;
    color: #fff;
    display: inline-flex;
    font-size: 1.4rem;
    font-weight: 800;
    height: 54px;
    justify-content: center;
    margin-top: 12px;
    width: 54px;
  }

  .instruction-section h2 {
    font-size: clamp(3rem, 5vw, 5rem);
    font-weight: 400;
  }

  ol {
    counter-reset: steps;
    display: grid;
    gap: 20px;
    list-style: none;
    margin: 42px 0 0;
    max-width: 900px;
    padding: 0;
  }

  li {
    background: #f7f7f9;
    border: 1px solid #dedee5;
    border-radius: 10px;
    font-size: 1.22rem;
    line-height: 1.5;
    padding: 22px 24px;
  }

  .cta-section { padding: 30px 30px 66px; }
  .cta-section h2,
  .cta-section p,
  .cta-section a { margin-left: auto; margin-right: auto; max-width: 1120px; }
  .cta-section h2 { font-size: clamp(2rem, 3.2vw, 2.85rem); font-weight: 500; }
  .cta-section p { color: #92939b; font-size: 1.32rem; line-height: 1.55; margin-top: 0.8rem; }
  .cta-section .primary-button { margin-top: 2rem; }

  @media (max-width: 640px) {
    .simple-header { min-height: 74px; padding-left: 20px; }
    .site-logo { font-size: 1.25rem; }
    .demo-button { min-height: 44px; padding-inline: 22px; }
    .instruction-section { gap: 18px; grid-template-columns: 42px minmax(0, 1fr); padding-inline: 24px; }
    .step-badge { height: 42px; width: 42px; }
  }
</style>
