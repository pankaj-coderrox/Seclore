---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
---

<BaseLayout
  title="How to Open a Seclore-protected File | Seclore"
  description="Choose your device type and learn how to open a file protected with Seclore."
>
  <main id="top" class="protected-file-page">
    <Nav />

    <section class="file-hero">
      <div class="hero-copy">
        <h1>How to Open a Seclore-Protected File</h1>
        <p>
          Welcome to Seclore. If you have received a file protected with Seclore and are unsure how
          to open it, you have come to the right place! The file has been protected by Seclore to
          ensure only authorized users can access it.
        </p>
      </div>
      <img
        src="/images/protected-file/share-data-fearlessly.png"
        alt="Share Data Fearlessly across desktop, tablet, and phone"
        loading="eager"
      />
    </section>

    <section class="starter-section" aria-labelledby="starter-title">
      <div class="step-badge" aria-hidden="true">1</div>
      <div class="starter-content">
        <h2 id="starter-title">Lets get started</h2>
        <p>Choose One</p>
        <div class="choice-list">
          <a href="/how-to-open-a-seclore-protected-file/laptop-desktop/">
            I&rsquo;m Using a Laptop or Desktop
          </a>
          <a href="/how-to-open-a-seclore-protected-file/mobile-tablet/">
            I&rsquo;m Using a Mobile Phone or Tablet
          </a>
        </div>
      </div>
    </section>

    <section class="cta-section" id="demo">
      <h2>Ready to get started?</h2>
      <p>Contact our sales team to find out how Seclore can help with data security and compliance.</p>
      <a class="primary-button" href="/about/contact-us/">Book a Demo</a>
    </section>
  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #ffffff;
    --page-text: #17111d;
    --page-muted: #6b6e78;
    --purple: #5a31d6;
    --purple-dark: #4620bf;
    --ink: #271126;
    --line: #cfcfd4;
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: #ffffff;
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a { color: inherit; text-decoration: none; }
  button { font: inherit; }

  .protected-file-page h1,
  .protected-file-page h2,
  .protected-file-page p { margin: 0; }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 88px;
    padding: 0 clamp(20px, 4vw, 42px) 0 30px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo { color: var(--purple); font-size: 1.55rem; font-weight: 950; letter-spacing: 0.04em; margin-right: clamp(14px, 2vw, 28px); text-transform: uppercase; }
  .nav-links, .nav-utilities { align-items: center; display: flex; }
  .nav-links { flex: 1 1 auto; gap: clamp(18px, 2.2vw, 34px); justify-content: center; min-width: 0; }
  .nav-links > a, .nav-trigger { align-items: center; background: transparent; border: 0; color: var(--header-muted); cursor: pointer; display: inline-flex; font-size: 0.98rem; font-weight: 800; gap: 8px; min-height: 68px; padding: 0; }
  .nav-links > a:hover, .nav-trigger:hover, .nav-item:hover .nav-trigger, .nav-item:focus-within .nav-trigger { color: var(--header-text); }
  .nav-item { position: static; }
  .nav-caret { border-bottom: 2px solid currentColor; border-right: 2px solid currentColor; display: inline-block; height: 8px; transform: rotate(45deg) translateY(-2px); transition: transform 180ms ease; width: 8px; }
  .nav-item:hover .nav-caret, .nav-item:focus-within .nav-caret, .nav-item.is-open .nav-caret { transform: rotate(225deg) translateY(-1px); }
  .mega-menu { left: 22px; opacity: 0; pointer-events: none; position: absolute; right: clamp(20px, 4vw, 42px); top: calc(100% - 1px); transform: translateY(12px); transition: opacity 180ms ease, transform 180ms ease; }
  .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu, .nav-item.is-open .mega-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .mega-inner { background: var(--dropdown-bg); border: 1px solid var(--dropdown-border); border-radius: 8px; box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2); display: grid; gap: 24px; grid-template-columns: minmax(0, 1fr) 320px; min-height: 320px; overflow: hidden; padding: 26px; }
  .mega-columns { display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .mega-column, .mega-sublinks { display: grid; }
  .mega-column { gap: 10px; }
  .mega-title { color: var(--dropdown-title); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .mega-link, .mega-link-group { border: 1px solid transparent; border-radius: 8px; }
  .mega-link { display: grid; gap: 5px; padding: 13px; }
  .mega-link strong { color: var(--dropdown-text); }
  .mega-link small, .mega-sublinks a { color: var(--dropdown-muted); }
  .mega-link:hover, .mega-link-group:hover { background: var(--dropdown-link-hover); border-color: var(--dropdown-link-border); }
  .mega-link-group { display: grid; gap: 4px; padding: 4px; }
  .mega-sublinks { gap: 2px; padding: 0 9px 8px 22px; }
  .mega-sublinks a { font-size: 0.84rem; padding: 5px 0; }
  .mega-feature { align-content: end; background: var(--dropdown-feature-bg); border: 1px solid var(--dropdown-feature-border); border-radius: 8px; display: grid; min-height: 268px; padding: 24px; }
  .mega-feature span, .mega-feature em { color: var(--dropdown-title); }
  .mega-feature strong { color: var(--dropdown-text); font-size: 1.35rem; line-height: 1.18; margin-top: auto; }
  .nav-utilities { flex: 0 0 auto; gap: clamp(12px, 1.5vw, 20px); margin-left: clamp(12px, 2vw, 28px); }
  .utility-link, .utility-label, .language-button, .utility-icon, .theme-toggle { color: var(--header-muted); display: none; font-size: 0.88rem; font-weight: 750; }
  .demo-button,
  .primary-button { align-items: center; background: linear-gradient(135deg, var(--purple), var(--purple-dark)); border: 0; border-radius: 8px; color: #fff; cursor: pointer; display: inline-flex; font-size: 1rem; font-weight: 850; justify-content: center; min-height: 50px; padding: 0 34px; }
  .nav-toggle { background: transparent; border: 0; display: none; height: 42px; width: 42px; }
  .nav-toggle span { background: var(--header-text); display: block; height: 2px; margin: 7px 0; width: 30px; }

  .file-hero {
    align-items: center;
    background: var(--ink);
    color: #fff;
    display: grid;
    gap: clamp(2rem, 5vw, 5rem);
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.85fr);
    min-height: 610px;
    padding: clamp(48px, 7vw, 74px) clamp(30px, 4vw, 66px);
  }

  .file-hero h1 {
    font-size: clamp(4.4rem, 7vw, 6.15rem);
    font-weight: 400;
    line-height: 0.98;
    max-width: 690px;
  }

  .file-hero p {
    color: rgba(255, 255, 255, 0.78);
    font-size: clamp(1.25rem, 2vw, 1.6rem);
    line-height: 1.45;
    margin-top: 2.6rem;
    max-width: 640px;
  }

  .file-hero img {
    display: block;
    justify-self: center;
    max-width: 540px;
    width: 100%;
  }

  .starter-section {
    display: grid;
    gap: 72px;
    grid-template-columns: 56px minmax(0, 1fr);
    padding: 62px clamp(30px, 4vw, 72px) 96px;
  }

  .step-badge {
    align-items: center;
    background: #2e2f33;
    border-radius: 50%;
    color: #fff;
    display: inline-flex;
    font-size: 1.4rem;
    font-weight: 800;
    height: 54px;
    justify-content: center;
    margin-top: 12px;
    width: 54px;
  }

  .starter-content h2 {
    color: #090909;
    font-size: clamp(4rem, 6vw, 5.7rem);
    font-weight: 400;
    line-height: 1.04;
  }

  .starter-content > p {
    color: #090909;
    font-size: clamp(2.8rem, 5vw, 4.1rem);
    line-height: 1;
    margin-top: 42px;
  }

  .choice-list {
    display: grid;
    gap: 40px;
    margin-top: 48px;
  }

  .choice-list a {
    align-items: center;
    background: linear-gradient(135deg, var(--purple), var(--purple-dark));
    border-radius: 8px;
    color: #fff;
    display: flex;
    font-size: 1.18rem;
    font-weight: 850;
    justify-content: center;
    min-height: 50px;
    padding: 0 18px;
    text-align: center;
  }

  .cta-section { background: #fff; padding: 20px 30px 48px; }
  .cta-section h2,
  .cta-section p,
  .cta-section a { margin-left: auto; margin-right: auto; max-width: 1120px; }
  .cta-section h2 { font-size: clamp(2rem, 3.2vw, 2.85rem); font-weight: 500; }
  .cta-section p { color: #92939b; font-size: 1.32rem; line-height: 1.55; margin-top: 0.8rem; }
  .cta-section .primary-button { margin-top: 2rem; }

  .site-footer { background: #fff; color: #5f626b; padding: 0 30px 55px; }
  .site-footer > * { margin-left: auto; margin-right: auto; max-width: 1120px; }
  .footer-lines { border-top: 1px solid var(--line); }
  .footer-lines details { border-bottom: 1px solid var(--line); color: #22222b; padding: 1.35rem 0; }
  .footer-lines summary { cursor: pointer; font-size: 1.28rem; font-weight: 800; }
  .footer-lines p { color: #656873; line-height: 1.6; margin-top: 0.75rem; }
  .footer-logo { color: var(--purple); display: block; font-size: 2rem; font-weight: 900; letter-spacing: 1px; margin-top: 2.4rem; text-transform: uppercase; }
  .site-footer p { font-size: 1.22rem; line-height: 1.65; margin-top: 1.4rem; }
  .store-row { display: flex; flex-direction: column; gap: 10px; margin-top: 2.4rem; }
  .store-row span { align-items: center; background: #17101b; border-radius: 6px; color: #fff; display: inline-flex; font-size: 0.9rem; font-weight: 800; height: 40px; justify-content: center; width: 168px; }
  .social-row { border-top: 1px solid #d1d1d6; padding-top: 1.7rem; }
  .legal a { text-decoration: underline; }

  @media (max-width: 1280px) {
    .nav-toggle { display: block; margin-left: 12px; order: 1; }
    .site-header { flex-wrap: wrap; }
    .site-logo { order: 0; }
    .nav-links { background: var(--header-bg); border-top: 1px solid var(--header-border); display: none; flex: 1 0 100%; order: 2; padding: 10px 0 14px; }
    .nav-links.open { align-items: stretch; display: grid; }
    .nav-links > a, .nav-trigger { justify-content: space-between; min-height: 48px; width: 100%; }
    .nav-item { display: grid; }
    .mega-menu { display: none; opacity: 1; position: static; transform: none; }
    .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu { display: none; }
    .nav-item.is-open .mega-menu { display: block; }
    .mega-inner { box-shadow: none; grid-template-columns: 1fr; min-height: 0; padding: 16px; }
    .nav-utilities { align-items: stretch; display: flex; margin-left: auto; order: 0; }
  }

  @media (max-width: 820px) {
    .file-hero {
      grid-template-columns: 1fr;
      min-height: 0;
      padding-top: 46px;
    }

    .file-hero h1 { font-size: clamp(3.4rem, 12vw, 5.2rem); }
    .starter-section { gap: 36px; grid-template-columns: 48px minmax(0, 1fr); }
    .starter-content h2 { font-size: clamp(3rem, 11vw, 4.8rem); }
    .starter-content > p { font-size: clamp(2.2rem, 9vw, 3.4rem); }
  }

  @media (max-width: 560px) {
    .site-header { min-height: 74px; padding-left: 20px; }
    .site-logo { font-size: 1.25rem; }
    .demo-button { min-height: 44px; padding-inline: 22px; }
    .file-hero { padding-inline: 24px; }
    .file-hero p { font-size: 1.1rem; }
    .starter-section { gap: 18px; grid-template-columns: 42px minmax(0, 1fr); padding-inline: 24px; }
    .step-badge { height: 42px; width: 42px; }
    .choice-list a { min-height: 56px; }
  }
</style>
