---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL || (import.meta.env.DEV ? "http://127.0.0.1:5000" : "");

const complianceCards = [
  {
    title: "Reduce compliance overhead",
    text: "Automated classification makes it easier to comply with changing regulatory frameworks while reducing user and admin effort."
  },
  {
    title: "Protect appropriately",
    text: "Use classification context to apply encryption, watermarking, EDRM, blocking, and external sharing controls where they matter."
  },
  {
    title: "Prove compliance",
    text: "Audit trails, activity logs, and reporting dashboards help teams demonstrate compliance and close control gaps."
  }
];

const capabilityCards = [
  {
    title: "Visual labels and dynamic watermarking",
    icon: "watermark",
    text: "Add visible markers, headers, footers, and dynamic watermarks to classified assets so people handle sensitive data correctly."
  },
  {
    title: "Classification of legacy and bulk data",
    icon: "bulk",
    text: "Bulk-classify digital assets through DLP, discovery, and built-in classification capabilities that support retention policies."
  },
  {
    title: "DLP-driven classification",
    icon: "dlp",
    text: "Use trusted discovery tools to scan sensitive information and programmatically classify assets through connectors and APIs."
  },
  {
    title: "Readable metadata classification tags",
    icon: "metadata",
    text: "Add multi-level tags to document and email metadata so downstream DLP, CASB, DSPM, and EDRM tools can act."
  },
  {
    title: "Email and file classification",
    icon: "emailFile",
    text: "Classify emails and files with suggested sensitivity labels based on each asset's content and data."
  },
  {
    title: "Enterprise-wide visibility",
    icon: "visibility",
    text: "Explore classification trends by label, user, policy, or file to find anomalies and improve governance."
  }
];

const capabilityIcons = {
  watermark:
    '<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M11 9h26v30H11z"/><path d="M16 16h16M16 22h10"/><path d="M19 31c3-6 7-6 10 0 1.6 3.1 4.1 3.1 6 0"/></svg>',
  bulk:
    '<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M13 13h22v24H13z"/><path d="M17 8h22v24"/><path d="M9 18h22v24"/><path d="M16 25h10M16 31h8"/></svg>',
  dlp:
    '<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M21 34a13 13 0 1 1 9-3.7L39 39"/><path d="M17 20h11M17 25h7"/><path d="M31 12l5 5-5 5"/></svg>',
  metadata:
    '<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M10 12h19l9 9v15H10z"/><path d="M29 12v9h9"/><path d="M16 25h16M16 31h11"/><path d="M17 18h7"/></svg>',
  emailFile:
    '<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M8 16h21v18H8z"/><path d="m9 17 9.5 8L28 17"/><path d="M31 10h9v25H25v-7"/><path d="M31 16h4M31 22h4"/></svg>',
  visibility:
    '<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M6 24s7-10 18-10 18 10 18 10-7 10-18 10S6 24 6 24Z"/><circle cx="24" cy="24" r="5"/><path d="M37 34l4 4"/></svg>'
};

const screenshotSlides = [
  "User-driven document classification",
  "Suggested classification",
  "User-driven email classification",
  "Dynamic watermarks and visual labels",
  "Mandatory classification"
];

const relatedTopics = [
  {
    title: "Regulatory compliance",
    text: "Simplified adherence to standards like GDPR, GLBA, SOX, DORA, PCI DSS, RBI Guidelines, SAMA, and more."
  },
  {
    title: "Discovery and classification integrations",
    text: "Leverage existing investments in discovery and classification systems to drive automatic persistent protection."
  }
];

const relatedProducts = [
  {
    title: "Enterprise Digital Rights Management",
    text: "Encrypt digital assets, limit access, allow or deny actions, track usage, and revoke access at any time."
  },
  {
    title: "Risk Insights and Reporting",
    text: "Use file and user activity insights to quickly address unauthorized access or non-compliance."
  }
];

const customerLogos = ["deccan", "Eugenus", "IDFC FIRST Bank", "Shilpa Medicare", "STC", "American Express", "Adani"];
---

<BaseLayout
  title="Digital Asset Classification | seclore"
  description="Classify sensitive digital assets based on sensitivity, business value, privacy, and regulatory requirements."
>
  <main id="top" class="classification-page">
    <Nav />

    <section class="classification-hero">
      <div class="hero-copy">
        <span class="eyebrow">Data-Centric Security Platform</span>
        <h1>Digital Asset Classification</h1>
        <p>
          Classify digital assets based on their sensitivity, business value, privacy, or regulatory
          requirements.
        </p>
        <a class="primary-button" href="#demo">Get a Demo</a>
      </div>
      <figure class="laptop-visual" aria-label="Classification interface preview">
        <img
          src="/images/platform/classification-hero-laptop.png"
          alt="Laptop showing digital asset classification intelligence"
          loading="eager"
          decoding="async"
        />
      </figure>
    </section>

    <section class="split-section">
      <div>
        <h2>Classify sensitive digital assets throughout your enterprise</h2>
        <p>
          Replace bulky legacy classification tools with agile, scalable classification that can be
          rolled out across geographies, business units, and compliance requirements.
        </p>
        <p>
          Integrate with discovery tools to automate, standardize, and scale classification across
          documents, emails, and repositories.
        </p>
      </div>
      <div class="motion-image" aria-label="Enterprise data movement visualization">
        <span></span><span></span><span></span><span></span><span></span>
      </div>
    </section>

    <section class="comply-section">
      <div class="section-heading centered">
        <h2>Classify to protect and comply</h2>
        <p>
          Classification is the first step in data-centric security because it helps enterprises
          prioritize protection for their most sensitive assets and prove compliance.
        </p>
      </div>
      <div class="compliance-grid">
        {complianceCards.map((card) => (
          <article class="compliance-card">
            <div class="hex-icon"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="capabilities-section">
      <div class="section-heading centered">
        <h2>Leverage asset classification to its fullest</h2>
        <p>
          Apply classification labels and sub-labels, explore trends, and integrate with discovery
          engines to identify sensitive data and apply the right label.
        </p>
        <a class="secondary-button" href="#screenshots">Watch Classification Video</a>
      </div>
      <div class="capability-grid">
        {capabilityCards.map((card) => (
          <article class="capability-card">
            <div class={`line-icon capability-icon ${card.icon}`} set:html={capabilityIcons[card.icon]}></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="screenshots-section" id="screenshots">
      <div class="section-heading centered">
        <h2>Product screenshots</h2>
      </div>
      <div class="screenshot-shell">
        <figure class="classification-screenshot-frame">
          <img
            src="/images/platform/classification-product-screenshot.png"
            alt="Spreadsheet classification interface with protected enterprise data"
            loading="lazy"
            decoding="async"
          />
        </figure>
        <div class="slide-controls" aria-label="Screenshot carousel controls">
          <button type="button" aria-label="Previous screenshot">‹</button>
          <button type="button" aria-label="Next screenshot">›</button>
        </div>
        <p>
          Suggested classification prompts users with classification suggestions based on content,
          while allowing another label and justification when needed.
        </p>
        <div class="slide-list">
          {screenshotSlides.map((slide) => <span>{slide}</span>)}
        </div>
      </div>
    </section>

    <section class="story-section">
      <blockquote>
        "Shilpa shares over 1,000 documents back and forth each month, and 30+ authorized users
        protect and share hundreds of confidential files with external agencies."
      </blockquote>
      <span>Shilpa Medicare</span>
      <a class="secondary-button" href="#demo">Customer Story</a>
      <div class="customer-row">
        <div class="customer-track">
          <div class="customer-group">
            {customerLogos.map((logo) => <strong>{logo}</strong>)}
          </div>
          <div class="customer-group" aria-hidden="true">
            {customerLogos.map((logo) => <strong>{logo}</strong>)}
          </div>
        </div>
      </div>
    </section>

    <section class="related-section">
      <div class="section-heading centered">
        <h2>Related topics</h2>
        <p>
          Add cybersecurity and regulatory compliance controls at the data level, where protection
          is needed most.
        </p>
      </div>
      <div class="related-grid">
        {relatedTopics.map((item) => (
          <article class="related-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <a href="#demo">Learn More</a>
          </article>
        ))}
      </div>
    </section>

    <section class="products-section">
      <div class="section-heading centered">
        <h2>Related products</h2>
      </div>
      <div class="related-grid">
        {relatedProducts.map((item) => (
          <article class="related-card product">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <a href="#demo">Learn More</a>
          </article>
        ))}
      </div>
    </section>

    <section class="demo-band" id="demo">
      <div class="demo-copy">
        <h2>Ready to get started?</h2>
        <p>Contact our sales team to find out how Seclore can help with data security and compliance.</p>
      </div>
      <form class="classification-form" data-endpoint="/api/demo">
        <h3>Book a Demo</h3>
        <label>Email<input name="email" type="email" required /></label>
        <label>First Name<input name="name" required minlength="2" /></label>
        <label>Company Name<input name="company" required /></label>
        <label>Job Title<input name="role" /></label>
        <label>Phone Number<input name="phone" /></label>
        <label>Comments<textarea name="message" rows="4"></textarea></label>
        <button class="primary-button" type="submit">Schedule a Demo</button>
        <p class="form-status" role="status" aria-live="polite"></p>
      </form>
    </section>
  </main>

  <script is:inline define:vars={{ apiBase }}>
    document.querySelectorAll(".classification-form").forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const status = form.querySelector(".form-status");
        const button = form.querySelector("button[type='submit']");
        const payload = Object.fromEntries(new FormData(form).entries());

        status.textContent = "Sending...";
        status.className = "form-status";
        button.disabled = true;

        try {
          const response = await fetch(`${apiBase}${form.dataset.endpoint}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });
          const data = await response.json();
          if (!response.ok) throw new Error(data.message || "Request failed.");
          form.reset();
          status.textContent = data.message || "Submitted successfully.";
          status.classList.add("success");
        } catch (error) {
          status.textContent = error.message || "Something went wrong.";
          status.classList.add("error");
        } finally {
          button.disabled = false;
        }
      });
    });
  </script>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #ffffff;
    --page-text: #202020;
    --page-muted: #5f6670;
    --purple: #5630d6;
    --purple-dark: #4321b4;
    --rose: #ef3f5f;
    --orange: #ff9900;
    --plum: #8e1f4b;
    --card: #ffffff;
    --line: rgba(17, 19, 28, 0.08);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #07111f;
    --header-muted: #2a2a2a;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #4f2bd6;
    --demo-button-text: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  html[data-theme="dark"] {
    color-scheme: dark;
    --page-bg: #07111f;
    --page-text: #f4f0ff;
    --page-muted: #c9bedb;
    --card: #11192a;
    --line: rgba(177, 145, 255, 0.22);
    --header-bg: #07111f;
    --header-border: rgba(151, 190, 230, 0.18);
    --header-shadow: 0 14px 34px rgba(0, 0, 0, 0.28);
    --header-text: #edf7ff;
    --header-muted: #c5d6e8;
    --dropdown-bg: linear-gradient(135deg, rgba(9, 25, 44, 0.98), rgba(5, 17, 31, 0.98));
    --dropdown-grid-line: rgba(45, 212, 255, 0.045);
    --dropdown-border: rgba(151, 190, 230, 0.18);
    --dropdown-link-hover: rgba(255, 255, 255, 0.055);
    --dropdown-link-border: rgba(45, 212, 255, 0.22);
    --dropdown-title: #7cf6c7;
    --dropdown-text: #edf7ff;
    --dropdown-muted: #9eb5ca;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(45, 212, 255, 0.18), rgba(124, 246, 199, 0.08)), rgba(255, 255, 255, 0.045);
    --dropdown-feature-border: rgba(45, 212, 255, 0.22);
    --demo-button-bg: #ffffff;
    --demo-button-text: #07111f;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: #ffffff;
    color: #202020;
  }

  .classification-page {
    --page-bg: #ffffff;
    --page-text: #202020;
    --page-muted: #5f6670;
    --purple: #5630d6;
    --purple-dark: #4321b4;
    --card: #ffffff;
    --line: rgba(15, 23, 42, 0.1);
    background: #ffffff;
    color: #202020;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  .site-header {
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: grid;
    gap: 0 clamp(28px, 3.5vw, 70px);
    grid-template-columns: minmax(230px, 280px) minmax(0, 1fr) auto;
    grid-template-rows: 42px 122px;
    min-height: 164px;
    padding: 0 clamp(28px, 6vw, 126px);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    align-self: center;
    color: var(--purple);
    font-size: clamp(1.55rem, 1.7vw, 1.95rem);
    font-weight: 900;
    grid-column: 1;
    grid-row: 2;
    letter-spacing: 0.05em;
    margin-right: 0;
    text-transform: uppercase;
  }

  .nav-links,
  .nav-utilities {
    align-items: center;
    display: flex;
  }

  .nav-links {
    align-self: center;
    flex: 1 1 auto;
    gap: clamp(26px, 3.2vw, 56px);
    grid-column: 2;
    grid-row: 2;
    justify-content: start;
    min-width: 0;
  }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: clamp(1rem, 1.05vw, 1.2rem);
    font-weight: 800;
    gap: 8px;
    min-height: 80px;
    padding: 0;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:hover .nav-trigger,
  .nav-item:focus-within .nav-trigger {
    color: var(--header-text);
  }

  .nav-item {
    position: static;
  }

  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret {
    transform: rotate(225deg) translateY(-1px);
  }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .mega-column,
  .mega-sublinks {
    display: grid;
  }

  .mega-column {
    gap: 10px;
  }

  .mega-title {
    color: var(--dropdown-title);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mega-link,
  .mega-link-group {
    border: 1px solid transparent;
    border-radius: 8px;
  }

  .mega-link {
    display: grid;
    gap: 5px;
    padding: 13px;
  }

  .mega-link strong {
    color: var(--dropdown-text);
  }

  .mega-link small,
  .mega-sublinks a {
    color: var(--dropdown-muted);
  }

  .mega-link:hover,
  .mega-link-group:hover {
    background: var(--dropdown-link-hover);
    border-color: var(--dropdown-link-border);
  }

  .mega-link-group {
    display: grid;
    gap: 4px;
    padding: 4px;
  }

  .mega-sublinks {
    gap: 2px;
    padding: 0 9px 8px 22px;
  }

  .mega-sublinks a {
    font-size: 0.84rem;
    padding: 5px 0;
  }

  .mega-feature {
    align-content: end;
    background: var(--dropdown-feature-bg);
    border: 1px solid var(--dropdown-feature-border);
    border-radius: 8px;
    display: grid;
    min-height: 268px;
    padding: 24px;
  }

  .mega-feature span,
  .mega-feature em {
    color: var(--dropdown-title);
  }

  .mega-feature strong {
    color: var(--dropdown-text);
    font-size: 1.35rem;
    line-height: 1.18;
    margin-top: auto;
  }

  .nav-utilities {
    align-self: center;
    flex: 0 0 auto;
    gap: clamp(14px, 1.3vw, 24px);
    grid-column: 2 / 4;
    grid-row: 1;
    justify-self: end;
    margin-left: 0;
  }

  .utility-link,
  .utility-label,
  .language-button,
  .utility-icon,
  .theme-toggle {
    color: var(--header-muted);
    font-size: clamp(0.85rem, 0.86vw, 1rem);
    font-weight: 500;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .utility-link {
    white-space: nowrap;
  }

  .utility-icon,
  .language-button,
  .theme-toggle {
    align-items: center;
    background: transparent;
    border: 0;
    cursor: pointer;
    display: inline-flex;
    gap: 8px;
    padding: 0;
  }

  .theme-toggle {
    display: none;
  }

  .search-icon {
    border: 2px solid currentColor;
    border-radius: 50%;
    display: inline-block;
    height: 17px;
    position: relative;
    width: 17px;
  }

  .search-icon::after {
    background: currentColor;
    content: "";
    height: 2px;
    position: absolute;
    right: -6px;
    top: 12px;
    transform: rotate(45deg);
    width: 8px;
  }

  .globe-icon {
    border: 2px solid currentColor;
    border-radius: 50%;
    display: inline-block;
    height: 23px;
    position: relative;
    width: 23px;
  }

  .globe-icon::before,
  .globe-icon::after {
    content: "";
    left: 50%;
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  .globe-icon::before {
    border-left: 2px solid currentColor;
    border-right: 2px solid currentColor;
    border-radius: 50%;
    height: 19px;
    width: 9px;
  }

  .globe-icon::after {
    border-top: 2px solid currentColor;
    width: 19px;
  }

  .theme-toggle-track {
    align-items: center;
    background: rgba(127, 139, 155, 0.24);
    border: 1px solid var(--header-border);
    border-radius: 999px;
    display: inline-flex;
    height: 24px;
    padding: 2px;
    width: 44px;
  }

  .theme-toggle-thumb {
    background: var(--header-text);
    border-radius: 50%;
    display: block;
    height: 18px;
    transform: translateX(18px);
    transition: transform 180ms ease;
    width: 18px;
  }

  html[data-theme="light"] .theme-toggle-thumb {
    transform: translateX(0);
  }

  .demo-button,
  .primary-button,
  .secondary-button {
    align-items: center;
    border: 0;
    border-radius: 7px;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.94rem;
    font-weight: 700;
    justify-content: center;
    line-height: 1.15;
    min-height: 42px;
    padding: 0 22px;
    text-decoration: none;
    white-space: nowrap;
  }

  .classification-page .hero-copy > .primary-button,
  .classification-page .story-section > .secondary-button,
  .classification-page .classification-form > .primary-button {
    border-radius: 7px !important;
    min-height: 42px !important;
    padding: 0 22px !important;
    width: auto !important;
  }

  .demo-button,
  .primary-button {
    background: var(--demo-button-bg);
    color: var(--demo-button-text);
  }

  .nav-utilities .demo-button {
    border-radius: 8px;
    font-size: clamp(0.95rem, 1vw, 1.12rem);
    min-height: 50px;
    min-width: 190px;
    padding: 0 28px;
    position: absolute;
    right: clamp(28px, 6vw, 126px);
    top: 66px;
  }

  .secondary-button {
    background: #17131f;
    color: #ffffff;
