---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const controls = [
  "Encrypt files wherever they travel",
  "Limit view, edit, print, copy, and share actions",
  "Revoke access after distribution",
  "Track usage across internal and external users"
];
---

<BaseLayout
  title="Enterprise Digital Rights Management | seclore"
  description="Protect sensitive documents and emails with persistent Enterprise Digital Rights Management controls."
>
  <main id="top" class="simple-route-page">
    <Nav />

    <section class="simple-route-hero">
      <div class="hero-copy">
        <span>Data-Centric Security Platform</span>
        <h1>Enterprise Digital Rights Management</h1>
        <p>
          Apply persistent controls to sensitive files so access, usage, and revocation remain under
          your control after data leaves repositories, applications, or your organization.
        </p>
        <a class="simple-route-button" href="/demo/">Book a Demo</a>
      </div>
      <figure
        class="edrm-visual"
        aria-label="Enterprise Digital Rights Management intelligence preview"
        style="background:none;border:0;box-shadow:none;display:block;min-height:0;padding:0;"
      >
        <img
          src="/images/platform/edrm-hero-laptop.png"
          alt="Laptop showing enterprise data classification and protection intelligence"
          loading="eager"
          decoding="async"
        />
      </figure>
    </section>

    <section class="simple-route-grid" aria-label="EDRM capabilities">
      {controls.map((control) => (
        <article>
          <h2>{control}</h2>
          <p>Keep protection attached to the data itself across people, partners, devices, and AI workflows.</p>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .simple-route-page {
    background: #ffffff;
    color: #101828;
    min-height: 100vh;
  }

  .simple-route-hero {
    align-items: center;
    display: grid;
    gap: clamp(52px, 5vw, 76px);
    grid-template-columns: minmax(0, 0.92fr) minmax(320px, 1.08fr);
    margin: 0 auto;
    max-width: 1190px;
    padding: 68px 24px 104px;
  }

  .simple-route-hero span {
    color: #5630d6;
    display: block;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .simple-route-hero h1 {
    font-size: clamp(3.4rem, 5.8vw, 5.8rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1;
    margin: 0 0 28px;
    max-width: 920px;
  }

  .simple-route-hero p {
    color: #3b3b44;
    font-size: 1.22rem;
    line-height: 1.55;
    max-width: 600px;
  }

  .simple-route-button {
    align-items: center;
    background: #5630d6;
    border-radius: 7px;
    color: #ffffff;
    display: inline-flex;
    font-weight: 800;
    justify-content: center;
    margin-top: 24px;
    min-height: 48px;
    padding: 0 22px;
    text-decoration: none;
  }

  .edrm-visual {
    background: none;
    border: 0;
    box-shadow: none;
    display: block;
    justify-self: end;
    margin: 0;
    max-width: 760px;
    min-height: 0;
    padding: 0;
    width: 100%;
  }

  .edrm-visual img {
    display: block;
    height: auto;
    object-fit: contain;
    transform: translateX(18px);
    width: 100%;
  }

  .simple-route-grid {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin: 0 auto;
    max-width: 1190px;
    padding: 0 24px 96px;
  }

  .simple-route-grid article {
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    min-height: 190px;
    padding: 28px;
  }

  .simple-route-grid h2 {
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.2;
    margin: 0 0 16px;
  }

  .simple-route-grid p {
    color: #5b6472;
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 900px) {
    .simple-route-hero {
      grid-template-columns: 1fr;
      padding: 56px 20px 76px;
    }

    .simple-route-hero h1 {
      font-size: 40px;
      font-weight: 400;
      line-height: 1.1;
      max-width: 340px;
      width: calc(100vw - 32px);
    }

    .simple-route-hero p {
      font-size: 18px;
      line-height: 1.5;
      max-width: 312px;
    }

    .simple-route-button {
      min-height: 42px;
    }

    .edrm-visual {
      justify-self: stretch;
      max-width: none;
      overflow: visible;
    }

    .simple-route-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      padding: 0 20px 76px;
    }
  }

  @media (max-width: 560px) {
    .simple-route-hero {
      gap: 76px;
      padding-top: 56px;
    }

    .simple-route-hero span {
      font-size: 0.88rem;
      line-height: 1.35;
      margin-bottom: 28px;
      max-width: 320px;
    }

    .edrm-visual {
      margin-left: -20px;
      margin-top: -36px;
      width: calc(100% + 40px);
    }

    .edrm-visual img {
      transform: none;
    }

    .simple-route-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<style is:inline>
  .simple-route-page .edrm-visual {
    background: none !important;
    border: 0 !important;
    box-shadow: none !important;
    display: block !important;
    min-height: 0 !important;
    padding: 0 !important;
  }

  .simple-route-page .edrm-visual img {
    display: block !important;
    height: auto !important;
    object-fit: contain !important;
    width: 100% !important;
  }

  @media (min-width: 901px) {
    .simple-route-page .edrm-visual {
      max-width: min(760px, 53vw) !important;
    }

    .simple-route-page .edrm-visual img {
      transform: translateX(18px);
    }
  }

  @media (max-width: 560px) {
    .simple-route-page .simple-route-hero {
      gap: 48px !important;
    }

    .simple-route-page .edrm-visual {
      margin-left: calc(50% - 50vw + 8px) !important;
      margin-top: -26px !important;
      width: calc(100vw - 16px) !important;
    }

    .simple-route-page .edrm-visual img {
      transform: none !important;
    }
  }
</style>
