---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const protectionCards = [
  {
    title: "Automated Protection",
    text: "Provide true protection for labeled and classified assets by automatically applying dynamic watermarks and attaching persistent granular security controls to documents and emails on endpoints.",
    icon: "shield"
  },
  {
    title: "Secure collaboration",
    text: "Give users the freedom to confidently share and collaborate on classified digital assets with co-workers and third-parties anywhere in the world.",
    icon: "collab"
  },
  {
    title: "Mitigate risk in real-time",
    text: "Revoke access or change security permissions on classified emails or documents instantly, so you are always in control of your data.",
    icon: "lock"
  },
  {
    title: "Protect against data breaches",
    text: "Track suspicious and unauthorized activities on classified digital assets. Take immediate action and protect your organization from reputation or financial loss.",
    icon: "server"
  },
  {
    title: "Leverage existing investments",
    text: "Protect the investment you've already made in Microsoft Sensitivity Labels by seamlessly adding data-centric security to the documents and emails you've already classified.",
    icon: "chart"
  },
  {
    title: "Meet compliance",
    text: "Achieve compliance with evidence, audit information related to the sensitivity of data, access permissions, and activities performed.",
    icon: "check"
  }
];

const resources = [
  {
    type: "Blog Post",
    tag: "AI, Company, Data Security",
    title: "The Debate About AI in the Enterprise Is Over. Here Is the Only Question That Matters.",
    cta: "View Blog Post"
  },
  {
    type: "Blog Post",
    tag: "AI Risk, Data Security",
    title: "The Missing Link in Enterprise AI: Why Context and Behavior Are the New Security Perimeter",
    cta: "View Blog Post"
  },
  {
    type: "Blog Post",
    tag: "AI Risk, Data Security",
    title: "ChatGPT Read 400 Internal Company Files In 42 Milliseconds. Security Stacks Saw Nothing",
    cta: "View Blog Post"
  }
];
---

<BaseLayout
  title="Microsoft Purview Sensitivity Labels | seclore"
  description="Leverage Microsoft Sensitivity Labels with Seclore persistent protection, access controls, tracking, and revocation."
>
  <main id="top" class="labels-page">
    <Nav />

    <section class="product-hero">
      <span>Integrations</span>
      <h1>Microsoft Purview Sensitivity Labels</h1>
      <p>
        Leverage Microsoft Sensitivity Labels to automatically add persistent protection and access
        controls to digital assets that contain private, sensitive, or regulated data.
      </p>
      <a class="primary-button" href="#demo">Book a Demo</a>
    </section>

    <section class="intro-section">
      <div class="intro-copy">
        <h2>Combine Microsoft classification with Seclore protection</h2>
        <p>
          Microsoft's Sensitivity Labels classify and categorize sensitive data, but classification
          alone doesn't prevent data loss or breaches. With Seclore's integration, labeled data can
          be protected automatically with encryption, granular access controls, tracking, and
          real-time revocation, even beyond your enterprise.
        </p>
        <p>
          Protection is dynamically applied based on the sensitivity label, ensuring the right
          balance of security and accessibility.
        </p>
        <p>
          Together, Microsoft and Seclore deliver end-to-end data security, ensuring compliance and
          safeguarding sensitive digital assets wherever they travel.
        </p>
        <a class="primary-button small" href="#demo">Read the Solution Brief</a>
      </div>
    </section>

    <section class="protection-section">
      <div class="section-heading centered">
        <h2>Advanced data labeling integrated with Seclore's unmatched data protection and control</h2>
      </div>
      <div class="card-list">
        {protectionCards.map((card) => (
          <article class="protection-card">
            <div class={`line-icon ${card.icon}`} aria-hidden="true"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="demo-section">
      <h2>Seclore for Microsoft Sensitivity Labels demo</h2>
    </section>

    <section class="resources-section" id="resources">
      <div class="section-heading centered">
        <h2>Additional Resources</h2>
      </div>
      <div class="resource-grid">
        {resources.map((resource) => (
          <article class="resource-card">
            <div class="resource-body">
              <span>{resource.type}</span>
              <strong>{resource.tag}</strong>
              <h3>{resource.title}</h3>
              <a href="#resources">{resource.cta} <span aria-hidden="true">&rarr;</span></a>
            </div>
          </article>
        ))}
      </div>
      <div class="resource-controls" aria-label="Resource carousel controls">
        <button type="button" aria-label="Previous resources">&larr;</button>
        <button type="button" aria-label="Next resources">&rarr;</button>
      </div>
    </section>

    <section class="cta-section" id="demo">
      <h2>Ready to get started?</h2>
      <p>Contact our sales team to find out how Seclore can help with data security and compliance.</p>
      <a class="primary-button" href="#top">Book a Demo</a>
    </section>
  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f6f6f7;
    --page-text: #29282d;
    --purple: #5b2bd7;
    --purple-dark: #4515c7;
    --line: #dedee5;
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: #ffffff;
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a { color: inherit; text-decoration: none; }
  button { font: inherit; }
  .labels-page h1,
  .labels-page h2,
  .labels-page h3,
  .labels-page p { margin: 0; }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo { color: var(--purple); font-size: 1.35rem; font-weight: 950; letter-spacing: 0.04em; margin-right: clamp(14px, 2vw, 28px); text-transform: uppercase; }
  .nav-links, .nav-utilities { align-items: center; display: flex; }
  .nav-links { flex: 1 1 auto; gap: clamp(18px, 2.2vw, 34px); justify-content: center; min-width: 0; }
  .nav-links > a, .nav-trigger { align-items: center; background: transparent; border: 0; color: var(--header-muted); cursor: pointer; display: inline-flex; font-size: 0.98rem; font-weight: 800; gap: 8px; min-height: 68px; padding: 0; }
  .nav-item { position: static; }
  .nav-caret { border-bottom: 2px solid currentColor; border-right: 2px solid currentColor; display: inline-block; height: 8px; transform: rotate(45deg) translateY(-2px); width: 8px; }
  .mega-menu { left: 22px; opacity: 0; pointer-events: none; position: absolute; right: clamp(20px, 4vw, 42px); top: calc(100% - 1px); transform: translateY(12px); transition: opacity 180ms ease, transform 180ms ease; }
  .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu, .nav-item.is-open .mega-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .mega-inner { background: var(--dropdown-bg); border: 1px solid var(--dropdown-border); border-radius: 8px; box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2); display: grid; gap: 24px; grid-template-columns: minmax(0, 1fr) 320px; min-height: 320px; overflow: hidden; padding: 26px; }
  .mega-columns { display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .mega-column, .mega-sublinks { display: grid; }
  .mega-column { gap: 10px; }
  .mega-title { color: var(--dropdown-title); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .mega-link, .mega-link-group { border: 1px solid transparent; border-radius: 8px; }
  .mega-link { display: grid; gap: 5px; padding: 13px; }
  .mega-link strong { color: var(--dropdown-text); }
  .mega-link small, .mega-sublinks a { color: var(--dropdown-muted); }
  .mega-link:hover, .mega-link-group:hover { background: var(--dropdown-link-hover); border-color: var(--dropdown-link-border); }
  .mega-link-group { display: grid; gap: 4px; padding: 4px; }
  .mega-sublinks { gap: 2px; padding: 0 9px 8px 22px; }
  .mega-sublinks a { font-size: 0.84rem; padding: 5px 0; }
  .mega-feature { align-content: end; background: var(--dropdown-feature-bg); border: 1px solid var(--dropdown-feature-border); border-radius: 8px; display: grid; min-height: 268px; padding: 24px; }
  .mega-feature span, .mega-feature em { color: var(--dropdown-title); }
  .mega-feature strong { color: var(--dropdown-text); font-size: 1.35rem; line-height: 1.18; margin-top: auto; }
  .nav-utilities { flex: 0 0 auto; gap: clamp(12px, 1.5vw, 20px); margin-left: clamp(12px, 2vw, 28px); }
  .utility-link, .language-button, .utility-icon, .theme-toggle { color: var(--header-muted); display: none; font-size: 0.88rem; font-weight: 750; }
  .demo-button, .primary-button { align-items: center; background: linear-gradient(135deg, var(--purple), var(--purple-dark)); border: 0; border-radius: 7px; color: #fff; cursor: pointer; display: inline-flex; font-size: 0.9rem; font-weight: 850; justify-content: center; min-height: 40px; padding: 0 18px; }
  .primary-button.small { font-size: 0.82rem; min-height: 38px; padding: 0 18px; }
  .nav-toggle { background: transparent; border: 0; display: none; height: 42px; width: 42px; }
  .nav-toggle span { background: var(--header-text); display: block; height: 2px; margin: 6px 0; width: 24px; }

  .product-hero {
    align-items: center;
    background: radial-gradient(circle at 15% 86%, rgba(229, 175, 245, 0.86), transparent 36%), linear-gradient(125deg, #8736df 0%, #7d2dea 45%, #4a04dc 100%);
    color: #fff;
    display: flex;
    flex-direction: column;
    min-height: 720px;
    padding: 145px 24px 118px;
    text-align: center;
  }

  .product-hero span { font-size: 0.92rem; font-weight: 850; margin-bottom: 2.2rem; }
  .product-hero h1 { font-size: clamp(3.1rem, 6.3vw, 5.8rem); font-weight: 500; line-height: 1.05; max-width: 980px; }
  .product-hero p { font-size: clamp(0.95rem, 1.45vw, 1.12rem); line-height: 1.55; margin: 2.4rem auto 2rem; max-width: 1100px; }

  .intro-section {
    background: #fff;
    display: grid;
    grid-template-columns: minmax(280px, 1fr) minmax(360px, 0.9fr);
    min-height: 690px;
    padding: 130px clamp(30px, 5vw, 92px);
  }

  .intro-copy { display: grid; gap: 1.7rem; grid-column: 2; max-width: 520px; }
  .intro-copy h2 { color: #333136; font-size: clamp(2.5rem, 4.3vw, 4.15rem); font-weight: 500; line-height: 1.05; }
  .intro-copy p { color: #1d1c24; font-size: 1.03rem; line-height: 1.68; }

  .protection-section { background: #f4f4f5; padding: 78px 30px 90px; }
  .section-heading.centered { margin: 0 auto; max-width: 1000px; text-align: center; }
  .section-heading h2 { color: #333136; font-size: clamp(2.2rem, 4vw, 3.6rem); font-weight: 500; line-height: 1.1; }
  .card-list { display: grid; gap: 28px; margin: 62px auto 0; max-width: 1120px; }
  .protection-card { background: #fff; border: 1px solid var(--line); border-radius: 18px; display: grid; gap: 20px; min-height: 150px; padding: 32px 38px 34px; }
  .protection-card h3 { color: #15141d; font-size: 1.25rem; font-weight: 650; }
  .protection-card p { color: #4a4951; font-size: 0.95rem; line-height: 1.62; }

  .line-icon { color: var(--purple); height: 38px; position: relative; width: 38px; }
  .line-icon::before, .line-icon::after { border: 3px solid currentColor; border-radius: 5px; content: ""; position: absolute; }
  .line-icon::before { height: 25px; left: 6px; top: 6px; width: 25px; }
  .line-icon.shield::before { border-radius: 12px 12px 16px 16px; }
  .line-icon.collab::after { border-color: #f2a86c; height: 16px; left: 13px; top: 12px; width: 16px; }
  .line-icon.lock::before { height: 17px; top: 14px; width: 26px; }
  .line-icon.lock::after { border-bottom: 0; border-radius: 14px 14px 0 0; height: 14px; left: 12px; top: 1px; width: 14px; }
  .line-icon.chart::before { border-left: 0; border-top: 0; height: 27px; transform: rotate(45deg); width: 15px; }
  .line-icon.check::after { border-left: 0; border-top: 0; height: 18px; left: 14px; top: 7px; transform: rotate(45deg); width: 10px; }

  .demo-section {
    align-items: start;
    background: #fff;
    display: flex;
    justify-content: center;
    min-height: 720px;
    padding: 76px 24px;
    text-align: center;
  }

  .demo-section h2 { color: #333136; font-size: clamp(2rem, 3.4vw, 3.1rem); font-weight: 500; line-height: 1.1; }

  .resources-section { background: #f4f4f5; padding: 95px 30px 105px; }
  .resource-grid { display: grid; gap: 40px min(13vw, 250px); grid-template-columns: repeat(2, minmax(260px, 365px)); margin: 65px auto 0; max-width: 970px; }
  .resource-card { background: #fff; border: 1px solid var(--line); border-radius: 18px; min-height: 420px; overflow: hidden; }
  .resource-body { display: grid; gap: 1.35rem; padding: 165px 38px 40px; }
  .resource-body span, .resource-body strong { background: #f1f1f3; border-radius: 999px; color: #191826; display: inline-flex; font-size: 0.82rem; font-weight: 900; justify-content: center; line-height: 1.35; padding: 0.55rem 1rem; text-transform: uppercase; width: max-content; }
  .resource-body strong { max-width: 270px; text-align: center; }
  .resource-body h3 { color: #151321; font-size: 1.45rem; font-weight: 500; line-height: 1.12; }
  .resource-card a { color: #111118; display: inline-flex; font-weight: 800; gap: 0.5rem; }
  .resource-controls { display: flex; gap: 20px; margin: 48px auto 0; max-width: 970px; }
  .resource-controls button { background: #fff; border: 1px solid #a9a9b2; border-radius: 999px; color: #7d7d87; height: 44px; width: 44px; }

  .cta-section { background: #fff; padding: 55px 30px 65px; }
  .cta-section h2, .cta-section p, .cta-section a { margin-left: auto; margin-right: auto; max-width: 1120px; }
  .cta-section h2 { font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 500; }
  .cta-section p { color: #92939b; font-size: 1.16rem; line-height: 1.55; margin-top: 0.8rem; }
  .cta-section .primary-button { margin-top: 2rem; }

  .site-footer { background: #fff; color: #5f626b; padding: 0 30px 55px; }
  .site-footer > * { margin-left: auto; margin-right: auto; max-width: 1120px; }
  .footer-lines { border-top: 1px solid #cfcfd4; }
  .footer-lines details { border-bottom: 1px solid #cfcfd4; color: #22222b; padding: 1.35rem 0; }
  .footer-lines summary { cursor: pointer; font-size: 1.18rem; font-weight: 800; }
  .footer-lines p { color: #656873; line-height: 1.6; margin-top: 0.75rem; }
  .footer-logo { color: #5b2bd7; display: block; font-size: 2rem; font-weight: 900; letter-spacing: 1px; margin-top: 2.4rem; text-transform: uppercase; }
  .site-footer p { font-size: 1.05rem; line-height: 1.65; margin-top: 1.4rem; }
  .store-row { display: flex; flex-direction: column; gap: 10px; margin-top: 2.4rem; }
  .store-row span { align-items: center; background: #17101b; border-radius: 6px; color: #fff; display: inline-flex; font-size: 0.9rem; font-weight: 800; height: 40px; justify-content: center; width: 168px; }
  .social-row { border-top: 1px solid #d1d1d6; padding-top: 1.7rem; }
  .legal a { text-decoration: underline; }

  @media (max-width: 1280px) {
    .nav-toggle { display: block; margin-left: 12px; order: 1; }
    .site-header { flex-wrap: wrap; }
    .site-logo { order: 0; }
    .nav-links { background: var(--header-bg); border-top: 1px solid var(--header-border); display: none; flex: 1 0 100%; order: 2; padding: 10px 0 14px; }
    .nav-links.open { align-items: stretch; display: grid; }
    .nav-links > a, .nav-trigger { justify-content: space-between; min-height: 48px; width: 100%; }
    .nav-item { display: grid; }
    .mega-menu { display: none; opacity: 1; position: static; transform: none; }
    .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu { display: none; }
    .nav-item.is-open .mega-menu { display: block; }
    .mega-inner { box-shadow: none; grid-template-columns: 1fr; min-height: 0; padding: 16px; }
    .nav-utilities { align-items: stretch; display: flex; margin-left: auto; order: 0; }
  }

  @media (max-width: 900px) {
    .product-hero { min-height: 540px; padding: 100px 20px 88px; }
    .intro-section { grid-template-columns: 1fr; min-height: 0; padding: 85px 20px; }
    .intro-copy { grid-column: auto; }
    .protection-section, .resources-section { padding: 72px 20px; }
    .resource-grid { grid-template-columns: 1fr; }
    .demo-section { min-height: 430px; }
  }

  @media (max-width: 560px) {
    .product-hero h1 { font-size: 2.65rem; }
    .intro-copy h2, .section-heading h2, .demo-section h2 { font-size: 2.1rem; }
    .protection-card { padding: 30px 26px; }
    .resource-body { padding: 145px 30px 34px; }
  }
</style>
