---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const complianceCards = [
  {
    title: "SIEM integration framework",
    text: "Enrich your SIEM with deep, file-level intelligence -- exposing risk, elevating investigations, and strengthening your detection strategy. Integrate seamlessly with cloud, hybrid, and on-prem SIEMs using universal formats. Stream intelligence where your analysts already work.",
    icon: "framework"
  },
  {
    title: "BI dashboard report templates",
    text: "Leverage pre-built Power BI dashboard templates, and customize them to capture dimensions specific to your organization. Track how various teams influence enterprise security and get visibility into document access patterns such as who accessed what, when, and how. Demonstrate measurable security ROI by showing reduced policy violations, unauthorized access attempts, and fewer compliance violations.",
    icon: "chart"
  },
  {
    title: "Cloud & on-premise support",
    text: "Enterprises can integrate seclore with SIEM, SOAR, and BI tools on any infrastructure whether it's on-premises, on-cloud, or a hybrid environment.",
    icon: "globe"
  },
  {
    title: "Professional services",
    text: "Leverage our professional services expertise for best practices, and how to build specific dashboards in your SIEM, SOAR, or BI platform.",
    icon: "support"
  }
];
---

<BaseLayout
  title="SIEM and BI Tools | Seclore"
  description="Give SOC, security, compliance, and business teams file-level alerts and BI reports from Seclore activity intelligence."
>
  <main id="top" class="siem-page">
    <Nav />

    <section class="product-hero">
      <span>Integrations</span>
      <h1>SIEM and BI Tools</h1>
      <p>
        Give your SOC team alerts driven by real file-level activity so they can identify and
        contain threats before they escalate. Provide security, compliance, and business leaders
        with periodic data-driven reports that surface clear, actionable insights.
      </p>
      <a class="primary-button" href="#demo">Book a Demo</a>
    </section>

    <section class="intro-section">
      <div class="intro-spacer" aria-hidden="true"></div>
      <div class="intro-copy">
        <h2>Stay ahead of threats with seamless SIEM and BI tool integrations</h2>
        <p>
          Increase the efficiency of SOC teams by augmenting existing data with Seclore's activity
          logs. Understand your data flows, and triangulate suspicious behavior based on user
          activity to quickly take corrective action and ensure that your sensitive data remains
          secure and compliant.
        </p>
        <p>
          Keep business leaders better informed with high impact cybersecurity reports that combine
          insights from user and file-level repositories. Leverage your preferred security
          information and event management (SIEM) or business intelligence (BI) tool to analyze
          patterns, optimize security policies, and strengthen data governance.
        </p>
      </div>
    </section>

    <section class="compliance-section">
      <div class="section-heading centered">
        <h2>Improve data security and compliance</h2>
        <p>
          Maintain complete visibility over sensitive, private, and regulated data shared inside and
          outside your organization, and see how employees and partners interact with it. Seclore
          also provides a data pipeline that surfaces industry-specific and compliance-centric
          insights to help organizations identify and address data security gaps.
        </p>
      </div>
      <div class="card-list">
        {complianceCards.map((card) => (
          <article class="compliance-card">
            <div class={`line-icon ${card.icon}`} aria-hidden="true"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="cta-section" id="demo">
      <h2>Ready to get started?</h2>
      <p>Contact our sales team to find out how Seclore can help with data security and compliance.</p>
      <a class="primary-button" href="#top">Book a Demo</a>
    </section>
  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f6f6f7;
    --page-text: #29282d;
    --purple: #5b2bd7;
    --purple-dark: #4515c7;
    --line: #dedee5;
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: #ffffff;
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a { color: inherit; text-decoration: none; }
  button { font: inherit; }
  .siem-page h1,
  .siem-page h2,
  .siem-page h3,
  .siem-page p { margin: 0; }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo { color: var(--purple); font-size: 1.35rem; font-weight: 950; letter-spacing: 0.04em; margin-right: clamp(14px, 2vw, 28px); text-transform: uppercase; }
  .nav-links, .nav-utilities { align-items: center; display: flex; }
  .nav-links { flex: 1 1 auto; gap: clamp(18px, 2.2vw, 34px); justify-content: center; min-width: 0; }
  .nav-links > a, .nav-trigger { align-items: center; background: transparent; border: 0; color: var(--header-muted); cursor: pointer; display: inline-flex; font-size: 0.98rem; font-weight: 800; gap: 8px; min-height: 68px; padding: 0; }
  .nav-links > a:hover, .nav-trigger:hover, .nav-item:hover .nav-trigger, .nav-item:focus-within .nav-trigger { color: var(--header-text); }
  .nav-item { position: static; }
  .nav-caret { border-bottom: 2px solid currentColor; border-right: 2px solid currentColor; display: inline-block; height: 8px; transform: rotate(45deg) translateY(-2px); transition: transform 180ms ease; width: 8px; }
  .nav-item:hover .nav-caret, .nav-item:focus-within .nav-caret, .nav-item.is-open .nav-caret { transform: rotate(225deg) translateY(-1px); }
  .mega-menu { left: 22px; opacity: 0; pointer-events: none; position: absolute; right: clamp(20px, 4vw, 42px); top: calc(100% - 1px); transform: translateY(12px); transition: opacity 180ms ease, transform 180ms ease; }
  .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu, .nav-item.is-open .mega-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .mega-inner { background: var(--dropdown-bg); border: 1px solid var(--dropdown-border); border-radius: 8px; box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2); display: grid; gap: 24px; grid-template-columns: minmax(0, 1fr) 320px; min-height: 320px; overflow: hidden; padding: 26px; }
  .mega-columns { display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .mega-column, .mega-sublinks { display: grid; }
  .mega-column { gap: 10px; }
  .mega-title { color: var(--dropdown-title); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .mega-link, .mega-link-group { border: 1px solid transparent; border-radius: 8px; }
  .mega-link { display: grid; gap: 5px; padding: 13px; }
  .mega-link strong { color: var(--dropdown-text); }
  .mega-link small, .mega-sublinks a { color: var(--dropdown-muted); }
  .mega-link:hover, .mega-link-group:hover { background: var(--dropdown-link-hover); border-color: var(--dropdown-link-border); }
  .mega-link-group { display: grid; gap: 4px; padding: 4px; }
  .mega-sublinks { gap: 2px; padding: 0 9px 8px 22px; }
  .mega-sublinks a { font-size: 0.84rem; padding: 5px 0; }
  .mega-feature { align-content: end; background: var(--dropdown-feature-bg); border: 1px solid var(--dropdown-feature-border); border-radius: 8px; display: grid; min-height: 268px; padding: 24px; }
  .mega-feature span, .mega-feature em { color: var(--dropdown-title); }
  .mega-feature strong { color: var(--dropdown-text); font-size: 1.35rem; line-height: 1.18; margin-top: auto; }
  .nav-utilities { flex: 0 0 auto; gap: clamp(12px, 1.5vw, 20px); margin-left: clamp(12px, 2vw, 28px); }
  .utility-link, .language-button, .utility-icon, .theme-toggle { color: var(--header-muted); display: none; font-size: 0.88rem; font-weight: 750; }
  .demo-button, .primary-button { align-items: center; background: linear-gradient(135deg, var(--purple), var(--purple-dark)); border: 0; border-radius: 7px; color: #fff; cursor: pointer; display: inline-flex; font-size: 0.9rem; font-weight: 850; justify-content: center; min-height: 40px; padding: 0 18px; }
  .nav-toggle { background: transparent; border: 0; display: none; height: 42px; width: 42px; }
  .nav-toggle span { background: var(--header-text); display: block; height: 2px; margin: 6px 0; width: 24px; }

  .product-hero {
    align-items: center;
    background: radial-gradient(circle at 16% 82%, rgba(229, 175, 245, 0.86), transparent 36%), linear-gradient(125deg, #8736df 0%, #7d2dea 45%, #4a04dc 100%);
    color: #fff;
    display: flex;
    flex-direction: column;
    min-height: 665px;
    padding: 145px 20px 112px;
    text-align: center;
  }

  .product-hero span { font-size: 0.86rem; font-weight: 850; margin-bottom: 2rem; }
  .product-hero h1 { font-size: clamp(3.4rem, 7vw, 5.9rem); font-weight: 500; letter-spacing: 0; line-height: 1.04; }
  .product-hero p { font-size: clamp(0.98rem, 1.5vw, 1.15rem); line-height: 1.55; margin: 2.35rem auto 2.1rem; max-width: 1180px; }

  .intro-section {
    align-items: center;
    background: #fff;
    display: grid;
    gap: clamp(3rem, 8vw, 8.5rem);
    grid-template-columns: minmax(260px, 0.95fr) minmax(310px, 0.85fr);
    margin: 0 auto;
    max-width: 1120px;
    min-height: 720px;
    padding: 132px 30px 140px;
  }

  .intro-spacer { min-height: 360px; }
  .intro-copy h2,
  .section-heading h2 { color: #333136; font-size: clamp(2.25rem, 4.1vw, 4rem); font-weight: 500; letter-spacing: 0; line-height: 1.06; }
  .intro-copy p { color: #1d1c24; font-size: 1.05rem; line-height: 1.66; margin-top: 2.1rem; }

  .compliance-section { background: #f4f4f5; padding: 86px 30px 108px; }
  .section-heading.centered { margin: 0 auto; max-width: 1040px; text-align: center; }
  .section-heading p { color: #292931; font-size: 1.02rem; line-height: 1.55; margin: 1.8rem auto 0; max-width: 1030px; }
  .card-list { display: grid; gap: 30px; margin: 62px auto 0; max-width: 1120px; }
  .compliance-card { background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 38px 38px 40px; }
  .compliance-card h3 { color: #15141d; font-size: 1.45rem; font-weight: 500; margin-top: 1.7rem; }
  .compliance-card p { color: #30313a; font-size: 1rem; line-height: 1.62; margin-top: 1.4rem; }

  .line-icon { height: 46px; position: relative; width: 46px; }
  .line-icon::before,
  .line-icon::after { content: ""; position: absolute; }
  .line-icon.framework::before { border: 4px solid var(--purple); border-radius: 4px; height: 16px; left: 2px; top: 1px; width: 16px; box-shadow: 24px 0 0 -4px #fff, 24px 0 0 0 #ef8d29, 0 24px 0 -4px #fff, 0 24px 0 0 #ef8d29, 24px 24px 0 -4px #fff, 24px 24px 0 0 var(--purple); }
  .line-icon.chart::before { border-bottom: 4px solid var(--purple); border-left: 4px solid var(--purple); height: 32px; left: 5px; top: 5px; width: 32px; }
  .line-icon.chart::after { background: linear-gradient(90deg, #ef8d29 0 6px, transparent 6px 11px, var(--purple) 11px 17px, transparent 17px 22px, #7bb4ff 22px 28px); bottom: 9px; height: 28px; left: 13px; width: 28px; }
  .line-icon.globe::before { border: 4px solid var(--purple); border-radius: 50%; height: 34px; left: 5px; top: 5px; width: 34px; }
  .line-icon.globe::after { border-left: 3px solid #ef8d29; border-right: 3px solid #ef8d29; height: 34px; left: 17px; top: 5px; width: 10px; }
  .line-icon.support::before { border: 4px solid var(--purple); border-bottom: 0; border-radius: 20px 20px 0 0; height: 25px; left: 6px; top: 4px; width: 31px; }
  .line-icon.support::after { border: 4px solid #ef8d29; border-radius: 4px; box-shadow: 30px 0 0 -4px #fff, 30px 0 0 0 #ef8d29; height: 18px; left: 2px; top: 22px; width: 10px; }

  .cta-section { background: #fff; padding: 55px 30px 65px; }
  .cta-section h2,
  .cta-section p,
  .cta-section a { margin-left: auto; margin-right: auto; max-width: 1120px; }
  .cta-section h2 { font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 500; }
  .cta-section p { color: #92939b; font-size: 1.16rem; line-height: 1.55; margin-top: 0.8rem; }
  .cta-section .primary-button { margin-top: 2rem; }

  .site-footer { background: #fff; color: #5f626b; padding: 0 30px 55px; }
  .site-footer > * { margin-left: auto; margin-right: auto; max-width: 1120px; }
  .footer-lines { border-top: 1px solid #cfcfd4; }
  .footer-lines details { border-bottom: 1px solid #cfcfd4; color: #22222b; padding: 1.35rem 0; }
  .footer-lines summary { cursor: pointer; font-size: 1.18rem; font-weight: 800; }
  .footer-lines p { color: #656873; line-height: 1.6; margin-top: 0.75rem; }
  .footer-logo { color: #5b2bd7; display: block; font-size: 2rem; font-weight: 900; letter-spacing: 1px; margin-top: 2.4rem; text-transform: uppercase; }
  .site-footer p { font-size: 1.05rem; line-height: 1.65; margin-top: 1.4rem; }
  .store-row { display: flex; flex-direction: column; gap: 10px; margin-top: 2.4rem; }
  .store-row span { align-items: center; background: #17101b; border-radius: 6px; color: #fff; display: inline-flex; font-size: 0.9rem; font-weight: 800; height: 40px; justify-content: center; width: 168px; }
  .social-row { border-top: 1px solid #d1d1d6; padding-top: 1.7rem; }
  .legal a { text-decoration: underline; }

  @media (max-width: 1280px) {
    .nav-toggle { display: block; margin-left: 12px; order: 1; }
    .site-header { flex-wrap: wrap; }
    .site-logo { order: 0; }
    .nav-links { background: var(--header-bg); border-top: 1px solid var(--header-border); display: none; flex: 1 0 100%; order: 2; padding: 10px 0 14px; }
    .nav-links.open { align-items: stretch; display: grid; }
    .nav-links > a, .nav-trigger { justify-content: space-between; min-height: 48px; width: 100%; }
    .nav-item { display: grid; }
    .mega-menu { display: none; opacity: 1; position: static; transform: none; }
    .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu { display: none; }
    .nav-item.is-open .mega-menu { display: block; }
    .mega-inner { box-shadow: none; grid-template-columns: 1fr; min-height: 0; padding: 16px; }
    .nav-utilities { align-items: stretch; display: flex; margin-left: auto; order: 0; }
  }

  @media (max-width: 900px) {
    .product-hero { min-height: 560px; padding: 105px 20px 90px; }
    .intro-section { gap: 2rem; grid-template-columns: 1fr; min-height: 0; padding: 85px 20px; }
    .intro-spacer { display: none; }
    .compliance-section { padding: 72px 20px; }
    .compliance-card { padding: 32px 28px; }
  }

  @media (max-width: 560px) {
    .product-hero h1 { font-size: 2.72rem; }
    .intro-copy h2,
    .section-heading h2 { font-size: 2.15rem; }
  }
</style>
