---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const optionCards = [
  {
    title: "Use your existing IdP",
    text: "Enable existing users to authenticate and get single-click access to Seclore-protected digital assets.",
    icon: "fingerprint"
  },
  {
    title: "Increase operational efficiency",
    text: "Eliminate the need for separate user management and identity libraries, and utilize your existing organization structure and schemas to access protected assets.",
    icon: "workflow"
  },
  {
    title: "Seamless user lifecycle management",
    text: "Seamlessly integrate Seclore with pre-built connectors for leading IAM systems, and manage user on/offboarding with automatic synchronization, ensuring that updates in your IdP are instantly reflected in Seclore.",
    icon: "sync"
  }
];

const providerCards = [
  {
    title: "Pre-built IdP/IAM connectors",
    text: "Simplify authentication and get immediate value with out-of-the-box support for the most widely used identity providers like Microsoft Entra ID, Okta, AFDS, and Google Authentication.",
    icon: "plug"
  },
  {
    title: "SAML & OAUTH SSO integrations",
    text: "Connect with any classic or Modern SSO system through SAML 2.0 or Oauth protocols, using Seclore identity federation framework. Support for OpenID and XML is also included.",
    icon: "user-check"
  },
  {
    title: "External user management",
    text: "Save time and effort by using Seclore's built-in external user identity management systems. Onboard external users to enterprise identity systems or Seclore's user management system automatically during collaboration, with no admin overhead.",
    icon: "users"
  },
  {
    title: "Professional services",
    text: "Leverage Seclore professional services for best practices around integration with IdP and SSO platforms, and to build any custom integration with your home-grown identity or SSO systems.",
    icon: "support"
  }
];

const resources = [
  {
    type: "Blog Post",
    tag: "AI, Company, Data Security",
    title: "The Debate About AI in the Enterprise Is Over. Here Is the Only Question That Matters.",
    cta: "View Blog Post"
  },
  {
    type: "Blog Post",
    tag: "AI Risk, Data Security",
    title: "The Missing Link in Enterprise AI: Why Context and Behavior Are the New Security Perimeter",
    cta: "View Blog Post"
  },
  {
    type: "On-Demand Webinar",
    tag: "Compliance",
    title: "From AI Risk to AI Readiness: Where Trust Becomes Operational, Not Aspirational",
    cta: "View On-Demand Webinar"
  }
];
---

<BaseLayout
  title="Identity Providers | Seclore"
  description="Connect enterprise identity providers and single sign-on systems to Seclore for seamless protected asset access."
>
  <main id="top" class="idp-page">
    <Nav />

    <section class="product-hero">
      <span>Integrations</span>
      <h1>Identity Providers and Single Sign-on Solutions</h1>
      <p>
        Continue using your preferred identity provider (IdP) to authenticate users when they access
        Seclore protected assets. Connect your enterprise' SSO solutions to Seclore to give your
        employees, partners, and external users a seamless experience. Leverage multi factor
        authentication (MFA) supported by IdPs to enhance protection.
      </p>
      <a class="primary-button" href="#demo">Book a Demo</a>
    </section>

    <section class="intro-section">
      <div class="photo-card">
        <img src="/images/platform/idp-sso/authentication-lead.png" alt="User authenticating on laptop and phone" loading="lazy" />
      </div>
      <div class="intro-copy">
        <h2>Simplified user authentication</h2>
        <p>
          Seclore integrates seamlessly with your existing identity management &amp; single sign-on
          (SSO) provider, ensuring effortless user authentication and one-click access. Identities
          can be sourced from any identity and access management (IAM) system, or a combination of
          different IAM systems and SSO providers. Separate authentication mechanisms for internal
          and external users are also supported, reinforcing security while maintaining a seamless
          user experience.
        </p>
      </div>
    </section>

    <section class="options-section">
      <div class="section-heading centered">
        <h2>Use enterprise-preferred authentication options</h2>
        <p>
          IAM &amp; SSO integrations make Seclore a natural extension of your security architecture,
          ensuring data-centric security without disrupting workflows and user experiences.
        </p>
        <div class="logo-row" aria-label="Supported identity providers">
          <span class="provider-logo microsoft" aria-label="Microsoft"></span>
          <span class="provider-logo entra" aria-label="Microsoft Entra ID"></span>
          <span class="provider-logo google" aria-label="Google Authentication"></span>
          <span class="provider-logo okta" aria-label="Okta"></span>
          <span class="provider-logo ping">Ping <small>Identity</small></span>
        </div>
      </div>
      <div class="option-grid">
        {optionCards.map((card) => (
          <article class="option-card">
            <div class={`hex-icon ${card.icon}`} aria-hidden="true"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="provider-section">
      <div class="section-heading centered">
        <h2>Use your existing enterprise identity provider</h2>
        <p>
          Access protected digital assets using your enterprise SSO credentials so users have a
          better experience.
        </p>
      </div>
      <div class="provider-list">
        {providerCards.map((card) => (
          <article class="provider-card">
            <div class={`line-icon ${card.icon}`} aria-hidden="true"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="resources-section" id="resources">
      <div class="section-heading centered">
        <h2>Additional Resources</h2>
      </div>
      <div class="resource-grid">
        {resources.map((resource) => (
          <article class="resource-card">
            <div class="resource-body">
              <span>{resource.type}</span>
              <strong>{resource.tag}</strong>
              <h3>{resource.title}</h3>
              <a href="#resources">{resource.cta} <span aria-hidden="true">&rarr;</span></a>
            </div>
          </article>
        ))}
      </div>
      <div class="resource-controls" aria-label="Resource carousel controls">
        <button type="button" aria-label="Previous resources">&larr;</button>
        <button type="button" aria-label="Next resources">&rarr;</button>
      </div>
    </section>

    <section class="cta-section" id="demo">
      <h2>Ready to get started?</h2>
      <p>Contact our sales team to find out how Seclore can help with data security and compliance.</p>
      <a class="primary-button" href="#top">Book a Demo</a>
    </section>
  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f6f6f7;
    --page-text: #29282d;
    --purple: #5b2bd7;
    --purple-dark: #4515c7;
    --line: #dedee5;
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: #ffffff;
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a { color: inherit; text-decoration: none; }
  button { font: inherit; }
  .idp-page h1,
  .idp-page h2,
  .idp-page h3,
  .idp-page p { margin: 0; }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo { color: var(--purple); font-size: 1.35rem; font-weight: 950; letter-spacing: 0.04em; margin-right: clamp(14px, 2vw, 28px); text-transform: uppercase; }
  .nav-links, .nav-utilities { align-items: center; display: flex; }
  .nav-links { flex: 1 1 auto; gap: clamp(18px, 2.2vw, 34px); justify-content: center; min-width: 0; }
  .nav-links > a, .nav-trigger { align-items: center; background: transparent; border: 0; color: var(--header-muted); cursor: pointer; display: inline-flex; font-size: 0.98rem; font-weight: 800; gap: 8px; min-height: 68px; padding: 0; }
  .nav-links > a:hover, .nav-trigger:hover, .nav-item:hover .nav-trigger, .nav-item:focus-within .nav-trigger { color: var(--header-text); }
  .nav-item { position: static; }
  .nav-caret { border-bottom: 2px solid currentColor; border-right: 2px solid currentColor; display: inline-block; height: 8px; transform: rotate(45deg) translateY(-2px); transition: transform 180ms ease; width: 8px; }
  .nav-item:hover .nav-caret, .nav-item:focus-within .nav-caret, .nav-item.is-open .nav-caret { transform: rotate(225deg) translateY(-1px); }
  .mega-menu { left: 22px; opacity: 0; pointer-events: none; position: absolute; right: clamp(20px, 4vw, 42px); top: calc(100% - 1px); transform: translateY(12px); transition: opacity 180ms ease, transform 180ms ease; }
  .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu, .nav-item.is-open .mega-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .mega-inner { background: var(--dropdown-bg); border: 1px solid var(--dropdown-border); border-radius: 8px; box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2); display: grid; gap: 24px; grid-template-columns: minmax(0, 1fr) 320px; min-height: 320px; overflow: hidden; padding: 26px; }
  .mega-columns { display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .mega-column, .mega-sublinks { display: grid; }
  .mega-column { gap: 10px; }
  .mega-title { color: var(--dropdown-title); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .mega-link, .mega-link-group { border: 1px solid transparent; border-radius: 8px; }
  .mega-link { display: grid; gap: 5px; padding: 13px; }
  .mega-link strong { color: var(--dropdown-text); }
  .mega-link small, .mega-sublinks a { color: var(--dropdown-muted); }
  .mega-link:hover, .mega-link-group:hover { background: var(--dropdown-link-hover); border-color: var(--dropdown-link-border); }
  .mega-link-group { display: grid; gap: 4px; padding: 4px; }
  .mega-sublinks { gap: 2px; padding: 0 9px 8px 22px; }
  .mega-sublinks a { font-size: 0.84rem; padding: 5px 0; }
  .mega-feature { align-content: end; background: var(--dropdown-feature-bg); border: 1px solid var(--dropdown-feature-border); border-radius: 8px; display: grid; min-height: 268px; padding: 24px; }
  .mega-feature span, .mega-feature em { color: var(--dropdown-title); }
  .mega-feature strong { color: var(--dropdown-text); font-size: 1.35rem; line-height: 1.18; margin-top: auto; }
  .nav-utilities { flex: 0 0 auto; gap: clamp(12px, 1.5vw, 20px); margin-left: clamp(12px, 2vw, 28px); }
  .utility-link, .language-button, .utility-icon, .theme-toggle { color: var(--header-muted); display: none; font-size: 0.88rem; font-weight: 750; }
  .demo-button, .primary-button { align-items: center; background: linear-gradient(135deg, var(--purple), var(--purple-dark)); border: 0; border-radius: 7px; color: #fff; cursor: pointer; display: inline-flex; font-size: 0.9rem; font-weight: 850; justify-content: center; min-height: 40px; padding: 0 18px; }
  .nav-toggle { background: transparent; border: 0; display: none; height: 42px; width: 42px; }
  .nav-toggle span { background: var(--header-text); display: block; height: 2px; margin: 6px 0; width: 24px; }

  .product-hero {
    align-items: center;
    background: radial-gradient(circle at 16% 82%, rgba(229, 175, 245, 0.86), transparent 36%), linear-gradient(125deg, #8736df 0%, #7d2dea 45%, #4a04dc 100%);
    color: #fff;
    display: flex;
    flex-direction: column;
    min-height: 665px;
    padding: 145px 20px 112px;
    text-align: center;
  }

  .product-hero span { font-size: 0.86rem; font-weight: 850; margin-bottom: 2rem; }
  .product-hero h1 { font-size: clamp(3rem, 6.9vw, 5.85rem); font-weight: 500; letter-spacing: 0; line-height: 1; max-width: 1130px; }
  .product-hero p { font-size: clamp(0.98rem, 1.55vw, 1.18rem); line-height: 1.55; margin: 2.35rem auto 2.1rem; max-width: 1120px; }

  .intro-section {
    align-items: center;
    background: #fff;
    display: grid;
    gap: clamp(3rem, 8vw, 8.5rem);
    grid-template-columns: minmax(260px, 0.95fr) minmax(310px, 0.95fr);
    margin: 0 auto;
    max-width: 1120px;
    padding: 142px 30px 150px;
  }

  .photo-card { align-self: center; aspect-ratio: 1.37; border-radius: 18px; overflow: hidden; }
  .photo-card img { display: block; height: 100%; object-fit: cover; width: 100%; }
  .intro-copy h2,
  .section-heading h2 { color: #333136; font-size: clamp(2.25rem, 4.1vw, 4rem); font-weight: 500; letter-spacing: 0; line-height: 1.06; }
  .intro-copy p { color: #1d1c24; font-size: 1.05rem; line-height: 1.66; margin-top: 2.1rem; }

  .options-section,
  .resources-section { background: #f4f4f5; padding: 86px 30px 108px; }
  .provider-section { background: #fff; padding: 115px 30px 118px; }
  .section-heading.centered { margin: 0 auto; max-width: 1040px; text-align: center; }
  .section-heading p { color: #292931; font-size: 1.02rem; line-height: 1.55; margin: 1.8rem auto 0; max-width: 1030px; }

  .logo-row { align-items: center; display: flex; flex-wrap: wrap; gap: 26px; justify-content: center; margin: 42px auto 60px; }
  .provider-logo { display: inline-block; height: 74px; width: 74px; }
  .provider-logo.microsoft { background: conic-gradient(#4caf50 0 25%, #ffcb05 0 50%, #2196f3 0 75%, #f44336 0); clip-path: inset(6px round 2px); }
  .provider-logo.entra { background: linear-gradient(135deg, #58d4f5 0 39%, #0f65c9 40% 70%, #064b9e 71%); clip-path: polygon(50% 3%, 98% 87%, 54% 67%, 23% 96%, 2% 58%); }
  .provider-logo.google { position: relative; width: 92px; }
  .provider-logo.google::before,
  .provider-logo.google::after { border-radius: 999px; content: ""; left: 6px; position: absolute; right: 6px; top: 31px; height: 12px; }
  .provider-logo.google::before { background: linear-gradient(90deg, #34a853 0 22%, #4285f4 22% 50%, #fbbc05 50% 75%, #ea4335 75%); transform: rotate(58deg); }
  .provider-logo.google::after { background: linear-gradient(90deg, #fbbc05 0 28%, #4285f4 28% 55%, #34a853 55% 76%, #ea4335 76%); transform: rotate(-58deg); }
  .provider-logo.okta { border-radius: 50%; background: repeating-conic-gradient(#111 0 8deg, transparent 8deg 14deg); position: relative; }
  .provider-logo.okta::after { background: #f4f4f5; border-radius: 50%; content: ""; height: 34px; left: 20px; position: absolute; top: 20px; width: 34px; }
  .provider-logo.ping { align-items: center; background: #bd1d2d; border-radius: 4px 14px 4px 4px; color: #fff; display: inline-flex; flex-direction: column; font-size: 1.58rem; font-weight: 850; justify-content: center; line-height: 0.92; padding-top: 4px; width: 82px; }
  .provider-logo.ping small { font-size: 0.72rem; font-weight: 500; }

  .option-grid {
    display: grid;
    gap: 34px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: 0 auto;
    max-width: 1120px;
  }

  .option-card,
  .provider-card,
  .resource-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 14px;
  }

  .option-card { min-height: 390px; padding: 46px 38px 42px; }
  .option-card h3 { color: #0d0d14; font-size: clamp(1.85rem, 3vw, 2.65rem); font-weight: 600; line-height: 1.02; margin-top: 1.7rem; }
  .option-card p { color: #30313a; font-size: 1rem; line-height: 1.62; margin-top: 1.8rem; }

  .hex-icon { align-items: center; border-radius: 20px; color: #fff; display: flex; height: 72px; justify-content: center; position: relative; width: 72px; }
  .hex-icon::before { background: #f9d997; clip-path: polygon(25% 4%, 75% 4%, 100% 50%, 75% 96%, 25% 96%, 0 50%); content: ""; inset: 0; position: absolute; }
  .hex-icon.workflow::before { background: var(--purple); }
  .hex-icon.sync::before { background: #ffcfa5; }
  .hex-icon::after { content: ""; position: absolute; }
  .hex-icon.fingerprint::after { border: 4px double #fff; border-radius: 50%; height: 25px; width: 25px; }
  .hex-icon.workflow::after { border: 3px solid #fff; border-left: 0; border-right: 0; height: 26px; width: 30px; }
  .hex-icon.sync::after { border: 4px solid #fff; border-left-color: transparent; border-radius: 50%; height: 28px; transform: rotate(25deg); width: 28px; }

  .provider-list { display: grid; gap: 30px; margin: 62px auto 0; max-width: 1120px; }
  .provider-card { padding: 38px 38px 40px; }
  .provider-card h3 { color: #15141d; font-size: 1.45rem; font-weight: 500; margin-top: 1.7rem; }
  .provider-card p { color: #30313a; font-size: 1rem; line-height: 1.62; margin-top: 1.4rem; }

  .line-icon { height: 46px; position: relative; width: 46px; }
  .line-icon::before,
  .line-icon::after { content: ""; position: absolute; }
  .line-icon.plug::before { border: 4px solid var(--purple); border-radius: 8px; height: 18px; left: 0; top: 11px; transform: rotate(-45deg); width: 20px; }
  .line-icon.plug::after { border: 4px solid #ef8d29; border-radius: 8px; height: 18px; right: 1px; top: 11px; transform: rotate(-45deg); width: 20px; }
  .line-icon.user-check::before { border: 4px solid var(--purple); border-radius: 50%; height: 15px; left: 10px; top: 1px; width: 15px; }
  .line-icon.user-check::after { border-bottom: 4px solid #ef8d29; border-right: 4px solid var(--purple); height: 20px; right: 5px; top: 17px; transform: rotate(35deg); width: 12px; }
  .line-icon.users::before { border: 4px solid var(--purple); border-radius: 50%; box-shadow: 16px 0 0 -4px #fff, 16px 0 0 0 #ef8d29, 32px 0 0 -4px #fff, 32px 0 0 0 var(--purple); height: 14px; left: 0; top: 4px; width: 14px; }
  .line-icon.users::after { border: 4px solid #ef8d29; border-radius: 18px 18px 6px 6px; height: 18px; left: 11px; top: 21px; width: 24px; }
  .line-icon.support::before { border: 4px solid var(--purple); border-bottom: 0; border-radius: 20px 20px 0 0; height: 25px; left: 6px; top: 4px; width: 31px; }
  .line-icon.support::after { border: 4px solid #ef8d29; border-radius: 4px; height: 18px; left: 2px; top: 22px; width: 10px; box-shadow: 30px 0 0 -4px #fff, 30px 0 0 0 #ef8d29; }

  .resource-grid { display: grid; gap: 40px min(13vw, 250px); grid-template-columns: repeat(2, minmax(260px, 365px)); margin: 65px auto 0; max-width: 970px; }
  .resource-card { min-height: 430px; overflow: hidden; }
  .resource-body { background: #fff; display: grid; gap: 1.4rem; padding: 185px 38px 40px; }
  .resource-body span,
  .resource-body strong { background: #f1f1f3; border-radius: 999px; color: #191826; display: inline-flex; font-size: 0.86rem; font-weight: 900; justify-content: center; line-height: 1.35; padding: 0.55rem 1rem; text-transform: uppercase; width: max-content; }
  .resource-body strong { max-width: 270px; text-align: center; }
  .resource-body h3 { color: #151321; font-size: 1.8rem; font-weight: 500; line-height: 1.12; }
  .resource-card a { color: #111118; display: inline-flex; font-weight: 800; gap: 0.5rem; }
  .resource-controls { display: flex; gap: 20px; margin: 48px auto 0; max-width: 970px; }
  .resource-controls button { background: #fff; border: 1px solid #a9a9b2; border-radius: 999px; color: #7d7d87; height: 44px; width: 44px; }

  .cta-section { background: #fff; padding: 55px 30px 65px; }
  .cta-section h2,
  .cta-section p,
  .cta-section a { margin-left: auto; margin-right: auto; max-width: 1120px; }
  .cta-section h2 { font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 500; }
  .cta-section p { color: #92939b; font-size: 1.16rem; line-height: 1.55; margin-top: 0.8rem; }
  .cta-section .primary-button { margin-top: 2rem; }

  .site-footer { background: #fff; color: #5f626b; padding: 0 30px 55px; }
  .site-footer > * { margin-left: auto; margin-right: auto; max-width: 1120px; }
  .footer-lines { border-top: 1px solid #cfcfd4; }
  .footer-lines details { border-bottom: 1px solid #cfcfd4; color: #22222b; padding: 1.35rem 0; }
  .footer-lines summary { cursor: pointer; font-size: 1.18rem; font-weight: 800; }
  .footer-lines p { color: #656873; line-height: 1.6; margin-top: 0.75rem; }
  .footer-logo { color: #5b2bd7; display: block; font-size: 2rem; font-weight: 900; letter-spacing: 1px; margin-top: 2.4rem; text-transform: uppercase; }
  .site-footer p { font-size: 1.05rem; line-height: 1.65; margin-top: 1.4rem; }
  .store-row { display: flex; flex-direction: column; gap: 10px; margin-top: 2.4rem; }
  .store-row span { align-items: center; background: #17101b; border-radius: 6px; color: #fff; display: inline-flex; font-size: 0.9rem; font-weight: 800; height: 40px; justify-content: center; width: 168px; }
  .social-row { border-top: 1px solid #d1d1d6; padding-top: 1.7rem; }
  .legal a { text-decoration: underline; }

  @media (max-width: 1280px) {
    .nav-toggle { display: block; margin-left: 12px; order: 1; }
    .site-header { flex-wrap: wrap; }
    .site-logo { order: 0; }
    .nav-links { background: var(--header-bg); border-top: 1px solid var(--header-border); display: none; flex: 1 0 100%; order: 2; padding: 10px 0 14px; }
    .nav-links.open { align-items: stretch; display: grid; }
    .nav-links > a, .nav-trigger { justify-content: space-between; min-height: 48px; width: 100%; }
    .nav-item { display: grid; }
    .mega-menu { display: none; opacity: 1; position: static; transform: none; }
    .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu { display: none; }
    .nav-item.is-open .mega-menu { display: block; }
    .mega-inner { box-shadow: none; grid-template-columns: 1fr; min-height: 0; padding: 16px; }
    .nav-utilities { align-items: stretch; display: flex; margin-left: auto; order: 0; }
  }

  @media (max-width: 900px) {
    .product-hero { min-height: 560px; padding: 105px 20px 90px; }
    .intro-section { gap: 3rem; grid-template-columns: 1fr; padding: 85px 20px; }
