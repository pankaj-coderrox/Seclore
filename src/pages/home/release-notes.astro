---

<BaseLayout
  title="Release Notes | Seclore Documentation Portal"
  description="Release notes for Seclore platform versions and released components."
>
  <main class="docs-page">
    <Nav />
    <header class="docs-topbar">
      <button type="button" aria-label="Search documentation">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="10.5" cy="10.5" r="6.5" />
          <path d="m16 16 5 5" />
        </svg>
      </button>
    </header>

    <section class="docs-hero">
      <div class="hero-copy">
        <p>Documentation Portal <span>|</span> <strong>SECLORE</strong></p>
        <nav aria-label="Documentation quick links">
          <a href="#">Release Announcement</a>
          <span>|</span>
          <a href="#">Expected Behavior</a>
          <span>|</span>
          <a href="#">Supported Formats</a>
        </nav>
      </div>
      <a class="docs-logo" href="/" aria-label="Seclore home">S</a>
    </section>

    <article class="release-notes">
      <h1>Release Notes</h1>

      {releases.map((release) => (
        <section class="release-entry">
          <h2>{release.date} (Seclore {release.version})</h2>
          <div class="release-table">
            <h3>Release summary</h3>
            <h3>Components released</h3>
            <div>
              <ul>
                {release.summary.map((item) => <li>{item}</li>)}
              </ul>
            </div>
            <div>
              <ul>
                {release.components.map((item) => (
                  <li><a href="#">{item}</a></li>
                ))}
              </ul>
            </div>
          </div>
        </section>
      ))}
    </article>

    <aside class="cookie-banner" id="cookie-banner" aria-label="Cookie notice">
      <div>
        <h2>About cookies on this site</h2>
        <p>
          We use cookies to collect and analyze information on site performance and usage. By
          continuing to use our site, you accept our use of cookies.
          <a href="#">Learn more</a>
        </p>
      </div>
      <div class="cookie-actions">
        <button class="allow-button" type="button" data-cookie-dismiss>ALLOW ALL COOKIES</button>
        <button class="preference-button" type="button" data-cookie-dismiss>Set cookie preference</button>
      </div>
    </aside>

    <script is:inline>
      const banner = document.querySelector("#cookie-banner");
      const dismissed = localStorage.getItem("docs-release-cookies");
      if (dismissed === "accepted") {
        banner?.remove();
      }
      document.querySelectorAll("[data-cookie-dismiss]").forEach((button) => {
        button.addEventListener("click", () => {
          localStorage.setItem("docs-release-cookies", "accepted");
          banner?.remove();
        });
      });
    </script>
  </main>
</BaseLayout>

<style>
  :global(body) {
    background: #ffffff;
    color: #202020;
    font-family: Arial, Helvetica, sans-serif;
  }

  :global(body::before) {
    display: none;
  }

  .docs-page {
    background: #ffffff;
    min-height: 100vh;
  }

  .docs-topbar {
    align-items: center;
    background: #ffffff;
    display: flex;
    height: 38px;
    justify-content: flex-end;
    padding: 0 12px;
  }

  .docs-topbar button {
    align-items: center;
    background: transparent;
    border: 0;
    color: #4b4b4b;
    cursor: pointer;
    display: inline-flex;
    height: 28px;
    justify-content: center;
    padding: 0;
    width: 28px;
  }

  .docs-topbar svg {
    fill: none;
    height: 18px;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
    width: 18px;
  }

  .docs-hero {
    background: #6f35bd;
    color: #ffffff;
    height: 190px;
    position: relative;
  }

  .hero-copy {
    left: 50%;
    position: absolute;
    text-align: center;
    top: 64px;
    transform: translateX(-50%);
    white-space: nowrap;
  }

