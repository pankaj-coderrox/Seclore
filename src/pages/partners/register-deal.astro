---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
---

<BaseLayout
  title="Register a Deal | seclore"
  description="Register a deal through the Seclore Partner Network portal."
>
  <main class="redirect-page">
    <Nav />
    <p>Opening Seclore Partner Network...</p>
    <a href="/partners/login/">Continue to Partner Portal</a>
  </main>

  <script is:inline>
    window.location.replace("/partners/login/");
  </script>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #251123;
    --pink: #ee2355;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  body {
    margin: 0;
  }

  .redirect-page {
    align-items: center;
    background: var(--ink);
    color: #ffffff;
    display: grid;
    gap: 18px;
    justify-items: center;
    min-height: 100vh;
    padding: 24px;
    text-align: center;
  }

  .redirect-page p {
    font-size: 1.2rem;
    margin: 0;
  }

  .redirect-page a {
    background: var(--pink);
    border-radius: 999px;
    color: #ffffff;
    font-weight: 850;
    padding: 14px 24px;
    text-decoration: none;
  }
</style>
