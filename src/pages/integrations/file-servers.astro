---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const volumeCards = [
  {
    title: "Use your existing file server infrastructure",
    text: "Continue to use your existing file repositories on Windows, Linux, NetApp, and EMC Dell, with protocols like NAS and SMB, with no configuration changes.",
    icon: "server",
    tone: "gold"
  },
  {
    title: "Enterprise or department-wide enforcement",
    text: "Admin-defined policies ensure that security is consistent and predictable throughout the enterprise or team. Minimize end-user dependency for decision making on security policy.",
    icon: "team",
    tone: "purple"
  },
  {
    title: "Overcome file server access management limitations",
    text: "No need to rely on the file server's limited access control. Seclore provides granular access control capabilities to define and enforce user access and mitigate insider threats.",
    icon: "controls",
    tone: "peach"
  }
];

const repositoryCards = [
  {
    title: "Data encryption & EDRM (in bulk and on-demand)",
    text: "Digital assets already in the File servers can be encrypted in bulk. New files added will be automatically encrypted in near real-time. Enterprise administrators can add access and usage rules to limit access to specific, authorized users only.",
    icon: "encrypt"
  },
  {
    title: "Access and usage policies",
    text: "Limit access to specific users, groups, and locations and prevent certain activities, such as printing, saving a copy, downloading, or copying text from a digital asset. Dynamic watermark helps guide end users on properly handling sensitive documents.",
    icon: "key"
  },
  {
    title: "Automated protection",
    text: "Automate digital asset protection to reduce security dependencies on end users. Enforce consistent protection in line with enterprise or department security and compliance needs.",
    icon: "auto"
  },
  {
    title: "Any file format",
    text: "With Seclore, automatically encrypt files of any format and extension. Ensure only authenticated users have access to the files on a need-to-know basis.",
    icon: "check"
  },
  {
    title: "Audit trail & activity reporting",
    text: "Track and analyze internal or external user activity to identify risks, detect patterns, and generate audit-compliant reports.",
    icon: "audit"
  },
  {
    title: "Revoke access",
    text: "Administrators can set an expiration date and time for protected digital assets or instantly and remotely revoke access when it is no longer needed.",
    icon: "revoke"
  }
];
---

<BaseLayout
  title="File Server Integration | seclore"
  description="Automated bulk protection for file servers with persistent encryption, usage controls, tracking, and revocation."
>
  <main id="top" class="file-servers-page">
    <Nav />

    <section class="server-hero">
      <div class="hero-copy">
        <span>Integrations</span>
        <h1>Seclore for File Servers</h1>
        <p>
          Automate bulk protection of data on file servers with Seclore. Protect existing and new
          files, as they are added or moved into network folders or document repositories.
        </p>
        <a class="primary-button" href="#demo">Book a Demo</a>
      </div>
      <div class="hero-visual">
        <img src="/images/integrations/file-servers/file-servers-hero.png" alt="Seclore file server protection dashboard on a laptop" />
      </div>
    </section>

    <section class="intro-section">
      <div class="photo-card intro-photo">
        <img src="/images/integrations/file-servers/file-servers-lead.png" alt="Business team collaborating on file server protection" loading="lazy" />
      </div>
      <div class="intro-copy">
        <h2>Secure &amp; control sensitive data in your file servers</h2>
        <p>
          Files servers continue to be the most commonly used systems for storage and archival of
          volumes of data. Many enterprises prefer to maintain the more sensitive assets on-premise
          in a storage system they own and control.
        </p>
        <p>
          Employees and partners collaborate on documents stored in file servers through shared
          drives and folders. However, over years of usage, the basic NTFS permissions in file
          servers go out of sync and are difficult to manage, making it a security risk.
        </p>
        <p>
          With Seclore, map folders or entire drives to automatically protect all existing and new
          files that are added. Authorized users can work with the files locally and collaborate
          seamlessly with other internal or external users.
        </p>
        <a class="primary-button small" href="#advanced">Read the Solution Brief</a>
      </div>
    </section>

    <section class="ransomware-band">
      <h2>Protect against ransomware with persistent encryption</h2>
      <p>
        Seclore ensures that even if attackers gain control of sensitive files, they won't be able
        to access them due to persistent data protection. The protection travels with the files,
        whether exfiltrated or not, allowing only authorized users to access them. Additionally,
        organizations can monitor and quickly revoke access to any files, rendering them useless to
        threat actors. This approach effectively minimizes the impact of ransomware attacks and
        keeps data secure.
      </p>
    </section>

    <section class="volume-section">
      <div class="section-heading centered">
        <h2>Security for large volumes of data</h2>
        <p>
          Protect and control large volumes of sensitive data on file servers, including legacy and
          archived data, preventing insider threat and exfiltration.
        </p>
      </div>
      <div class="volume-grid">
        {volumeCards.map((card) => (
          <article class="volume-card">
            <div class={`hex-icon ${card.tone} ${card.icon}`} aria-hidden="true"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="advanced-section" id="advanced">
      <div class="section-heading centered">
        <h2>Advanced protection for document repositories</h2>
        <p>
          As soon as a document is placed in a Seclore-protected "hot folder" on the file server, it
          automatically gets protected with security and access permissions defined in line with
          enterprise security policies. The protected document can be accessed on any device,
          application, or operating system, and usage controls stay with the document when
          downloaded, shared, or moved to different locations.
        </p>
      </div>
      <div class="repository-list">
        {repositoryCards.map((card) => (
          <article class="repository-card">
            <div class={`line-icon ${card.icon}`} aria-hidden="true"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="cta-section" id="demo">
      <h2>Ready to get started?</h2>
      <p>Contact our sales team to find out how Seclore can help with data security and compliance.</p>
      <a class="primary-button" href="#top">Book a Demo</a>
    </section>
  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f6f6f7;
    --page-text: #29282d;
    --purple: #5b2bd7;
    --purple-dark: #4515c7;
    --line: #dedee5;
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: #ffffff;
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a { color: inherit; text-decoration: none; }
  button { font: inherit; }
  .file-servers-page h1,
  .file-servers-page h2,
  .file-servers-page h3,
  .file-servers-page p { margin: 0; }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo { color: var(--purple); font-size: 1.35rem; font-weight: 950; letter-spacing: 0.04em; margin-right: clamp(14px, 2vw, 28px); text-transform: uppercase; }
  .nav-links, .nav-utilities { align-items: center; display: flex; }
  .nav-links { flex: 1 1 auto; gap: clamp(18px, 2.2vw, 34px); justify-content: center; min-width: 0; }
  .nav-links > a, .nav-trigger { align-items: center; background: transparent; border: 0; color: var(--header-muted); cursor: pointer; display: inline-flex; font-size: 0.98rem; font-weight: 800; gap: 8px; min-height: 68px; padding: 0; }
  .nav-item { position: static; }
  .nav-caret { border-bottom: 2px solid currentColor; border-right: 2px solid currentColor; display: inline-block; height: 8px; transform: rotate(45deg) translateY(-2px); width: 8px; }
  .mega-menu { left: 22px; opacity: 0; pointer-events: none; position: absolute; right: clamp(20px, 4vw, 42px); top: calc(100% - 1px); transform: translateY(12px); transition: opacity 180ms ease, transform 180ms ease; }
  .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu, .nav-item.is-open .mega-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .mega-inner { background: var(--dropdown-bg); border: 1px solid var(--dropdown-border); border-radius: 8px; box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2); display: grid; gap: 24px; grid-template-columns: minmax(0, 1fr) 320px; min-height: 320px; overflow: hidden; padding: 26px; }
  .mega-columns { display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .mega-column, .mega-sublinks { display: grid; }
  .mega-column { gap: 10px; }
  .mega-title { color: var(--dropdown-title); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .mega-link, .mega-link-group { border: 1px solid transparent; border-radius: 8px; }
  .mega-link { display: grid; gap: 5px; padding: 13px; }
  .mega-link strong { color: var(--dropdown-text); }
  .mega-link small, .mega-sublinks a { color: var(--dropdown-muted); }
  .mega-link:hover, .mega-link-group:hover { background: var(--dropdown-link-hover); border-color: var(--dropdown-link-border); }
  .mega-link-group { display: grid; gap: 4px; padding: 4px; }
  .mega-sublinks { gap: 2px; padding: 0 9px 8px 22px; }
  .mega-sublinks a { font-size: 0.84rem; padding: 5px 0; }
  .mega-feature { align-content: end; background: var(--dropdown-feature-bg); border: 1px solid var(--dropdown-feature-border); border-radius: 8px; display: grid; min-height: 268px; padding: 24px; }
  .mega-feature span, .mega-feature em { color: var(--dropdown-title); }
  .mega-feature strong { color: var(--dropdown-text); font-size: 1.35rem; line-height: 1.18; margin-top: auto; }
  .nav-utilities { flex: 0 0 auto; gap: clamp(12px, 1.5vw, 20px); margin-left: clamp(12px, 2vw, 28px); }
  .utility-link, .language-button, .utility-icon, .theme-toggle { color: var(--header-muted); display: none; font-size: 0.88rem; font-weight: 750; }
  .demo-button,
  .primary-button {
    align-items: center;
    background: linear-gradient(135deg, var(--purple), var(--purple-dark));
    border: 0;
    border-radius: 7px;
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.9rem;
    font-weight: 850;
    justify-content: center;
    line-height: 1;
    min-height: 40px;
    padding: 0 18px;
    white-space: nowrap;
    width: fit-content;
  }

  .primary-button.small {
    font-size: 0.9rem;
    min-height: 40px;
    padding: 0 18px;
    white-space: nowrap;
    width: fit-content;
  }
  .nav-toggle { background: transparent; border: 0; display: none; height: 42px; width: 42px; }
  .nav-toggle span { background: var(--header-text); display: block; height: 2px; margin: 6px 0; width: 24px; }

  .server-hero {
    align-items: center;
    background: radial-gradient(circle at 12% 86%, rgba(229, 175, 245, 0.86), transparent 34%), linear-gradient(125deg, #8736df 0%, #7d2dea 45%, #4a04dc 100%);
    color: #fff;
    display: grid;
    gap: clamp(32px, 6vw, 90px);
    grid-template-columns: minmax(280px, 0.7fr) minmax(360px, 1fr);
    min-height: 790px;
    padding: 120px clamp(24px, 4vw, 86px);
  }

  .hero-copy { display: grid; gap: 1.9rem; max-width: 480px; }
  .hero-copy span { font-size: 0.92rem; font-weight: 850; }
  .server-hero h1 { font-size: clamp(4.2rem, 7vw, 6.7rem); font-weight: 500; line-height: 1.02; }
  .server-hero p { font-size: clamp(1.05rem, 1.7vw, 1.35rem); line-height: 1.52; }
  .hero-visual img { display: block; height: auto; width: 100%; }

  .intro-section {
    align-items: center;
    background: #fff;
    display: grid;
    gap: clamp(3rem, 9vw, 9rem);
    grid-template-columns: minmax(280px, 1fr) minmax(320px, 0.92fr);
    padding: 150px clamp(30px, 5vw, 92px);
  }

  .photo-card { align-self: center; border-radius: 18px; overflow: hidden; }
  .photo-card img { display: block; height: 100%; object-fit: cover; width: 100%; }
  .intro-photo { aspect-ratio: 1.39; }
  .intro-copy { display: grid; gap: 2rem; max-width: 575px; }
  .intro-copy h2 { color: #333136; font-size: clamp(2.7rem, 4.6vw, 4.55rem); font-weight: 500; line-height: 1.04; }
  .intro-copy p { color: #1d1c24; font-size: 1.05rem; line-height: 1.68; }

  .ransomware-band {
    background: #4d27cf;
    color: #fff;
    padding: 70px clamp(24px, 5vw, 80px);
    text-align: center;
  }

  .ransomware-band h2 { font-size: clamp(2.4rem, 4.4vw, 4.4rem); font-weight: 500; line-height: 1.1; margin: 0 auto; max-width: 1050px; }
  .ransomware-band p { font-size: 1.13rem; line-height: 1.65; margin: 2.1rem auto 0; max-width: 1120px; }

  .volume-section { background: #fff; padding: 82px 30px 118px; }
  .section-heading.centered { margin: 0 auto; max-width: 1120px; text-align: center; }
  .section-heading h2 { color: #333136; font-size: clamp(2.8rem, 4.6vw, 4.6rem); font-weight: 500; line-height: 1.08; }
  .section-heading p { color: #23222b; font-size: 1.15rem; line-height: 1.55; margin: 2rem auto 0; max-width: 1110px; }
  .volume-grid { display: grid; gap: 44px; grid-template-columns: repeat(3, minmax(0, 1fr)); margin: 74px auto 0; max-width: 1120px; }
  .volume-card { border: 1px solid var(--line); border-radius: 18px; min-height: 610px; padding: 48px 42px; }
  .volume-card h3 { color: #07070a; font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 650; line-height: 1.02; margin-top: 3.5rem; }
  .volume-card p { color: #272630; font-size: 1.14rem; line-height: 1.58; margin-top: 3rem; }
  .hex-icon { background: #ffdca6; height: 90px; position: relative; width: 78px; clip-path: polygon(50% 0, 95% 25%, 95% 75%, 50% 100%, 5% 75%, 5% 25%); }
  .hex-icon.purple { background: #5630d1; }
  .hex-icon.peach { background: #ffd4aa; }
  .hex-icon::before { color: #fff; content: "S"; font-size: 2.4rem; font-weight: 900; left: 50%; position: absolute; top: 50%; transform: translate(-50%, -50%); }
  .hex-icon.team::before { content: "P"; }
  .hex-icon.controls::before { content: "="; }

  .advanced-section { background: #f4f4f5; padding: 86px 30px 95px; }
  .repository-list { display: grid; gap: 30px; margin: 72px auto 0; max-width: 1120px; }
  .repository-card { background: #fff; border: 1px solid var(--line); border-radius: 18px; display: grid; gap: 26px; min-height: 250px; padding: 42px 42px 40px; }
  .repository-card h3 { color: #15141d; font-size: 1.8rem; font-weight: 550; }
  .repository-card p { color: #3f3f48; font-size: 1.05rem; line-height: 1.68; }
  .line-icon { color: var(--purple); height: 48px; position: relative; width: 48px; }
  .line-icon::before, .line-icon::after { border: 4px solid currentColor; border-radius: 5px; content: ""; position: absolute; }
  .line-icon::before { height: 32px; left: 7px; top: 7px; width: 32px; }
  .line-icon.encrypt::after { border-left: 0; border-top: 0; height: 16px; left: 21px; top: 22px; width: 16px; }
  .line-icon.key::before { border-radius: 50%; height: 20px; left: 7px; top: 12px; width: 20px; }
  .line-icon.key::after { border-bottom: 0; border-left: 0; height: 14px; left: 26px; top: 14px; transform: rotate(-45deg); width: 18px; }
  .line-icon.audit::before { border-bottom-width: 6px; border-radius: 4px 4px 13px 13px; }
  .line-icon.revoke::after { border-bottom: 0; border-left: 0; height: 18px; left: 14px; top: 14px; transform: rotate(135deg); width: 18px; }

  .cta-section { background: #fff; padding: 55px 30px 65px; }
  .cta-section h2, .cta-section p, .cta-section a { margin-left: auto; margin-right: auto; max-width: 1120px; }
  .cta-section h2 { font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 500; }
  .cta-section p { color: #92939b; font-size: 1.16rem; line-height: 1.55; margin-top: 0.8rem; }
  .cta-section .primary-button { margin-top: 2rem; }

  .site-footer { background: #fff; color: #5f626b; padding: 0 30px 55px; }
  .site-footer > * { margin-left: auto; margin-right: auto; max-width: 1120px; }
  .footer-lines { border-top: 1px solid #cfcfd4; }
  .footer-lines details { border-bottom: 1px solid #cfcfd4; color: #22222b; padding: 1.35rem 0; }
  .footer-lines summary { cursor: pointer; font-size: 1.18rem; font-weight: 800; }
  .footer-lines p { color: #656873; line-height: 1.6; margin-top: 0.75rem; }
  .footer-logo { color: #5b2bd7; display: block; font-size: 2rem; font-weight: 900; letter-spacing: 1px; margin-top: 2.4rem; text-transform: uppercase; }
  .site-footer p { font-size: 1.05rem; line-height: 1.65; margin-top: 1.4rem; }
  .store-row { display: flex; flex-direction: column; gap: 10px; margin-top: 2.4rem; }
  .store-row span { align-items: center; background: #17101b; border-radius: 6px; color: #fff; display: inline-flex; font-size: 0.9rem; font-weight: 800; height: 40px; justify-content: center; width: 168px; }
  .social-row { border-top: 1px solid #d1d1d6; padding-top: 1.7rem; }
  .legal a { text-decoration: underline; }

  @media (max-width: 1280px) {
    .nav-toggle { display: block; margin-left: 12px; order: 1; }
    .site-header { flex-wrap: wrap; }
    .site-logo { order: 0; }
    .nav-links { background: var(--header-bg); border-top: 1px solid var(--header-border); display: none; flex: 1 0 100%; order: 2; padding: 10px 0 14px; }
    .nav-links.open { align-items: stretch; display: grid; }
    .nav-links > a, .nav-trigger { justify-content: space-between; min-height: 48px; width: 100%; }
    .nav-item { display: grid; }
    .mega-menu { display: none; opacity: 1; position: static; transform: none; }
    .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu { display: none; }
    .nav-item.is-open .mega-menu { display: block; }
    .mega-inner { box-shadow: none; grid-template-columns: 1fr; min-height: 0; padding: 16px; }
    .nav-utilities { align-items: stretch; display: flex; margin-left: auto; order: 0; }
  }

  @media (max-width: 900px) {
    .server-hero, .intro-section, .volume-grid { grid-template-columns: 1fr; }
    .server-hero { min-height: 640px; padding: 90px 20px; }
    .intro-section { gap: 3rem; padding: 85px 20px; }
    .volume-section, .advanced-section { padding: 72px 20px; }
    .volume-card { min-height: 0; }
    .repository-card { padding: 34px 28px; }
    .file-servers-page .hero-copy > .primary-button,
    .file-servers-page .intro-copy .primary-button.small,
    .file-servers-page .cta-section > .primary-button {
      max-width: 100%;
      width: fit-content !important;
    }
  }

  @media (max-width: 560px) {
    .server-hero h1 { font-size: 3.25rem; }
    .intro-copy h2, .section-heading h2 { font-size: 2.2rem; }
    .ransomware-band h2 { font-size: 2rem; }
    .file-servers-page .hero-copy > .primary-button,
    .file-servers-page .intro-copy .primary-button.small,
    .file-servers-page .cta-section > .primary-button {
      font-size: 0.9rem !important;
      min-height: 40px;
      padding-inline: 18px;
      white-space: normal;
    }
  }
</style>
