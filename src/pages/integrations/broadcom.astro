---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const solutionCards = [
  {
    title: "Automated email protection",
    text: "When Symantec detects emails that contain sensitive information, those emails can be protected with Seclore by automatically applying granular usage and access controls for enhanced protection.",
    icon: "mail"
  },
  {
    title: "Automated classification and protection for data on endpoints",
    text: "When sensitive data is discovered on endpoints or external USB drives by Symantec, Seclore can automatically classify it and apply persistent protection policies to ensure compliance and security.",
    icon: "endpoint"
  },
  {
    title: "Automated protection for data in cloud repositories",
    text: "Seclore and Symantec CloudSOC CASB work together to detect sensitive digital assets in cloud repositories and automatically protect them by applying granular access and usage controls.",
    icon: "cloud"
  },
  {
    title: "Automated protection for data on network shares",
    text: "Leverage Seclore to apply granular access and usage controls to sensitive digital assets discovered by Symantec on network file servers which may be used for internal/external collaboration and communication.",
    icon: "database"
  },
  {
    title: "Comprehensive monitoring and access control",
    text: "Track activity related to protected digital assets, including who, what, when, and how. Unauthorized activity is also logged, analyzed, and blocked to mitigate risks in real time.",
    icon: "pin"
  },
  {
    title: "Enhanced reporting and analytics",
    text: "Seamlessly integrate Seclore with your existing SIEM solution, or enhance your business intelligence (BI) tool with actionable insights for risk assessments and compliance reporting.",
    icon: "bars"
  }
];

const resources = [
  {
    image: "/images/integrations/dlp-casb/debate-ai.png",
    type: "Blog Post",
    tag: "AI, Company, Data Security",
    title: "The Debate About AI in the Enterprise Is Over. Here Is the Only Question That Matters.",
    cta: "View Blog Post"
  },
  {
    image: "/images/integrations/dlp-casb/ai-perimeter.png",
    type: "Blog Post",
    tag: "AI Risk, Data Security",
    title: "The Missing Link in Enterprise AI: Why Context and Behavior Are the New Security Perimeter",
    cta: "View Blog Post"
  },
  {
    image: "/images/integrations/dlp-casb/ai-readiness.png",
    type: "On-Demand Webinar",
    tag: "Compliance",
    title: "From AI Risk to AI Readiness: Where Trust Becomes Operational, Not Aspirational",
    cta: "View On-Demand Webinar"
  }
];
---

<BaseLayout
  title="Broadcom Symantec DLP and CloudSOC CASB Integration | seclore"
  description="Seclore integrates with Broadcom Symantec DLP and CloudSOC CASB to orchestrate discovery, classification, and protection of sensitive enterprise data."
>
  <main id="top" class="broadcom-page">
    <Nav />

    <section class="product-hero">
      <span>Integrations</span>
      <h1>Broadcom (Symantec) DLP &amp; CloudSOC CASB</h1>
      <p>
        Seclore integrates seamlessly with Broadcom (Symantec) DLP and CloudSOC CASB to orchestrate
        the discovery, classification and protection of sensitive enterprise data throughout its
        entire lifecycle.
      </p>
      <div class="hero-actions">
        <a class="primary-button" href="#demo">Get a Demo</a>
        <a class="secondary-button" href="#resources">Read the Solution Brief</a>
      </div>
    </section>

    <section class="intro-section">
      <div class="photo-card">
        <img src="/images/integrations/broadcom/broadcom-lead.png" alt="Business leader reviewing data security alerts on a tablet" loading="lazy" />
      </div>
      <div class="intro-copy">
        <h2>Strengthening data security with Seclore and Broadcom</h2>
        <p>
          Seclore and Broadcom have joined forces to deliver a powerful integration that enhances
          data protection and security. With a combined offering, organizations can now seamlessly
          and automatically classify, protect, and track sensitive information across its lifecycle.
          This integration ensures that data remains secure, even when shared outside the
          organization, providing businesses with greater control, visibility, and compliance in
          today's dynamic digital landscape. Together, Seclore and Broadcom empower enterprises to
          safeguard their critical assets and reduce user dependency while enabling secure
          collaboration.
        </p>
      </div>
    </section>

    <section class="solutions-section">
      <div class="section-heading centered">
        <h2>Get more out of your Broadcom (Symantec) solutions</h2>
        <div class="partner-lockup" aria-label="Seclore and Symantec by Broadcom">
          <strong>seclore</strong>
          <span></span>
          <b>Symantec <small>by Broadcom</small></b>
        </div>
      </div>
      <div class="solution-grid">
        {solutionCards.map((card) => (
          <article class="solution-card">
            <div class={`line-icon ${card.icon}`} aria-hidden="true"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="resources-section" id="resources">
      <div class="section-heading centered">
        <h2>Additional Resources</h2>
      </div>
      <div class="resource-grid">
        {resources.map((resource) => (
          <article class="resource-card">
            <img src={resource.image} alt="" loading="lazy" />
            <div class="resource-body">
              <span>{resource.type}</span>
              <strong>{resource.tag}</strong>
              <h3>{resource.title}</h3>
              <a href="#resources">{resource.cta} <span aria-hidden="true">&rarr;</span></a>
            </div>
          </article>
        ))}
      </div>
      <div class="resource-controls" aria-label="Resource carousel controls">
        <button type="button" aria-label="Previous resources">&larr;</button>
        <button type="button" aria-label="Next resources">&rarr;</button>
      </div>
    </section>

    <section class="cta-section" id="demo">
      <h2>Ready to get started?</h2>
      <p>Contact our sales team to find out how Seclore can help with data security and compliance.</p>
      <a class="primary-button" href="#top">Book a Demo</a>
    </section>
  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f6f6f7;
    --page-text: #29282d;
    --page-muted: #686b73;
    --purple: #5b2bd7;
    --purple-dark: #4515c7;
    --line: #dedee5;
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #5b2bd7;
    --demo-button-text: #ffffff;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    font: inherit;
  }

  .broadcom-page h1,
  .broadcom-page h2,
  .broadcom-page h3,
  .broadcom-page p {
    margin: 0;
  }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    font-size: 1.35rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .nav-links,
  .nav-utilities {
    align-items: center;
    display: flex;
  }

  .nav-links {
    flex: 1 1 auto;
    gap: clamp(18px, 2.2vw, 34px);
    justify-content: center;
    min-width: 0;
  }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:hover .nav-trigger,
  .nav-item:focus-within .nav-trigger {
    color: var(--header-text);
  }

  .nav-item {
    position: static;
  }

  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret {
    transform: rotate(225deg) translateY(-1px);
  }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .mega-column,
  .mega-sublinks {
    display: grid;
  }

  .mega-column {
    gap: 10px;
  }

  .mega-title {
    color: var(--dropdown-title);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mega-link,
  .mega-link-group {
    border: 1px solid transparent;
    border-radius: 8px;
  }

  .mega-link {
    display: grid;
    gap: 5px;
    padding: 13px;
  }

  .mega-link strong {
    color: var(--dropdown-text);
  }

  .mega-link small,
  .mega-sublinks a {
    color: var(--dropdown-muted);
  }

  .mega-link:hover,
  .mega-link-group:hover {
    background: var(--dropdown-link-hover);
    border-color: var(--dropdown-link-border);
  }

  .mega-link-group {
    display: grid;
    gap: 4px;
    padding: 4px;
  }

  .mega-sublinks {
    gap: 2px;
    padding: 0 9px 8px 22px;
  }

  .mega-sublinks a {
    font-size: 0.84rem;
    padding: 5px 0;
  }

  .mega-feature {
    align-content: end;
    background: var(--dropdown-feature-bg);
    border: 1px solid var(--dropdown-feature-border);
    border-radius: 8px;
    display: grid;
    min-height: 268px;
    padding: 24px;
  }

  .mega-feature span,
  .mega-feature em {
    color: var(--dropdown-title);
  }

  .mega-feature strong {
    color: var(--dropdown-text);
    font-size: 1.35rem;
    line-height: 1.18;
    margin-top: auto;
  }

  .nav-utilities {
    flex: 0 0 auto;
    gap: clamp(12px, 1.5vw, 20px);
    margin-left: clamp(12px, 2vw, 28px);
  }

  .utility-link,
  .language-button,
  .utility-icon,
  .theme-toggle {
    color: var(--header-muted);
    display: none;
    font-size: 0.88rem;
    font-weight: 750;
  }

  .demo-button,
  .primary-button,
  .secondary-button {
    align-items: center;
    border: 0;
    border-radius: 7px;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.9rem;
    font-weight: 850;
    justify-content: center;
    min-height: 40px;
    padding: 0 18px;
  }

  .demo-button,
  .primary-button {
    background: linear-gradient(135deg, var(--purple), var(--purple-dark));
    color: #fff;
  }

  .secondary-button {
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.42);
    color: #fff;
  }

  .nav-toggle {
    background: transparent;
    border: 0;
    display: none;
    height: 42px;
    width: 42px;
  }

  .nav-toggle span {
    background: var(--header-text);
    display: block;
    height: 2px;
    margin: 6px 0;
    width: 24px;
  }

  .product-hero {
    align-items: center;
    background:
      radial-gradient(circle at 14% 84%, rgba(229, 175, 245, 0.86), transparent 36%),
      linear-gradient(125deg, #8736df 0%, #7d2dea 45%, #4a04dc 100%);
    color: #fff;
    display: flex;
    flex-direction: column;
    min-height: 760px;
    padding: 150px 28px 135px;
    text-align: center;
  }

  .product-hero span {
    font-size: 0.86rem;
    font-weight: 850;
    margin-bottom: 2.2rem;
  }

  .product-hero h1 {
    font-size: clamp(3rem, 7vw, 5.25rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.04;
    max-width: 1040px;
  }

  .product-hero p {
    font-size: clamp(1rem, 2vw, 1.3rem);
    line-height: 1.55;
    margin: 2.5rem auto 2.3rem;
    max-width: 1110px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: center;
  }

  .intro-section {
    display: grid;
    gap: clamp(4rem, 10vw, 12rem);
    grid-template-columns: minmax(260px, 0.78fr) minmax(360px, 1.22fr);
    margin: 0 auto;
    max-width: 1120px;
    padding: 145px 30px;
  }

  .photo-card {
    aspect-ratio: 1.43;
    border-radius: 18px;
    margin-top: 2rem;
    overflow: hidden;
  }

  .photo-card img {
    display: block;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    width: 100%;
  }

  .intro-copy h2,
  .section-heading h2 {
    color: #333136;
    font-size: clamp(2.25rem, 4.1vw, 4rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.06;
  }

  .intro-copy p {
    color: #1d1c24;
    font-size: 1.05rem;
    line-height: 1.66;
    margin-top: 2.1rem;
  }

  .solutions-section {
    background: #f1f1f3;
    padding: 86px 30px 112px;
  }

  .section-heading.centered {
    margin: 0 auto;
    max-width: 820px;
    text-align: center;
  }

  .partner-lockup {
    align-items: center;
    display: flex;
    gap: 34px;
    justify-content: center;
    margin: 80px auto 72px;
  }

  .partner-lockup strong {
    color: #ef2953;
    font-size: clamp(2rem, 4vw, 4.15rem);
    font-weight: 950;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .partner-lockup span {
    background: #7e7f87;
    height: 72px;
    width: 2px;
  }

  .partner-lockup b {
    color: #17171d;
    font-size: clamp(1.7rem, 3vw, 3rem);
    font-weight: 900;
  }

  .partner-lockup b::before {
    border: 9px solid #f6cf23;
    border-radius: 50%;
    content: "";
    display: inline-block;
    height: 32px;
    margin-right: 6px;
    vertical-align: -7px;
    width: 32px;
  }

  .partner-lockup small {
    display: block;
    font-size: 1rem;
    font-weight: 600;
  }

  .solution-grid {
    display: grid;
    gap: 34px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin: 0 auto;
    max-width: 1120px;
  }

  .solution-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 18px;
    min-height: 320px;
    padding: 42px 36px;
  }

  .solution-card h3 {
    color: #171720;
    font-size: 1.42rem;
    font-weight: 500;
    line-height: 1.28;
    margin-top: 2rem;
  }

  .solution-card p {
    color: #30313a;
    font-size: 0.98rem;
    line-height: 1.62;
    margin-top: 1.5rem;
  }

  .line-icon {
    height: 48px;
    position: relative;
    width: 48px;
  }

  .line-icon::before,
  .line-icon::after {
    content: "";
    position: absolute;
  }

  .line-icon.mail::before {
    border: 4px solid #5b2bd7;
    height: 27px;
    left: 4px;
    top: 8px;
    width: 35px;
  }

  .line-icon.mail::after {
    border-bottom: 4px solid #ef8d29;
    border-right: 4px solid #ef8d29;
    height: 16px;
    left: 14px;
    top: 10px;
    transform: rotate(45deg);
    width: 16px;
  }

  .line-icon.endpoint::before,
  .line-icon.pin::before {
    border: 4px solid #5b2bd7;
    border-radius: 4px;
    bottom: 4px;
    height: 22px;
    left: 5px;
    width: 35px;
  }

  .line-icon.endpoint::after {
    border: 4px solid #ef8d29;
    border-radius: 4px;
    height: 15px;
    right: 2px;
    top: 1px;
    width: 15px;
  }

  .line-icon.cloud::before {
    border: 4px solid #5b2bd7;
    border-radius: 22px;
    height: 24px;
    left: 3px;
    top: 13px;
    width: 39px;
  }

  .line-icon.cloud::after,
  .line-icon.database::after {
    border: 4px solid #ef8d29;
    border-radius: 5px;
    bottom: 1px;
    height: 15px;
    left: 18px;
    width: 15px;
  }

  .line-icon.database::before {
    border: 4px solid #5b2bd7;
    border-radius: 50%;
    height: 14px;
    left: 7px;
    top: 5px;
    width: 31px;
    box-shadow: 0 12px 0 -4px #fff, 0 12px 0 0 #5b2bd7, 0 24px 0 -4px #fff, 0 24px 0 0 #5b2bd7;
  }

  .line-icon.pin::after {
    border: 4px solid #ef8d29;
    border-radius: 50% 50% 50% 0;
    height: 17px;
    right: 3px;
    top: 1px;
    transform: rotate(-45deg);
    width: 17px;
  }

  .line-icon.bars::before {
    border-bottom: 5px solid #5b2bd7;
    border-left: 5px solid #5b2bd7;
    bottom: 6px;
    height: 24px;
    left: 5px;
    width: 27px;
  }

  .line-icon.bars::after {
    background: linear-gradient(90deg, #35a7ff 0 6px, transparent 6px 10px, #f28c28 10px 16px, transparent 16px 20px, #8b54e9 20px 26px);
    bottom: 10px;
    height: 30px;
    left: 11px;
    width: 26px;
  }

  .resources-section {
    background: #fff;
    padding: 95px 30px 105px;
  }

  .resource-grid {
    display: grid;
    gap: 40px min(9vw, 230px);
    grid-template-columns: repeat(2, minmax(260px, 365px));
    margin: 65px auto 0;
    max-width: 970px;
  }

  .resource-card {
    border: 1px solid var(--line);
    border-radius: 18px;
    overflow: hidden;
  }

  .resource-card img {
    aspect-ratio: 1.5;
    display: block;
    object-fit: cover;
    object-position: top center;
    width: 100%;
  }

  .resource-body {
    background: #fff;
    padding: 40px 38px;
  }

  .resource-body span,
  .resource-body strong {
    background: #f1f1f3;
    border-radius: 999px;
    color: #191826;
    display: inline-flex;
    font-size: 0.86rem;
    font-weight: 900;
    justify-content: center;
    line-height: 1.35;
    padding: 0.55rem 1rem;
    text-transform: uppercase;
  }

  .resource-body strong {
    display: flex;
    margin-top: 1.2rem;
    max-width: 270px;
    text-align: center;
  }

  .resource-body h3 {
    color: #11111b;
    font-size: 1.8rem;
    font-weight: 500;
    line-height: 1.12;
    margin-top: 2.1rem;
  }

  .resource-card a {
    color: #111118;
    display: inline-flex;
    font-weight: 800;
    gap: 0.5rem;
    margin-top: 1.6rem;
  }

  .resource-controls {
    display: flex;
    gap: 20px;
    margin: 48px auto 0;
    max-width: 970px;
  }

  .resource-controls button {
    background: #fff;
    border: 1px solid #a9a9b2;
    border-radius: 999px;
    color: #7d7d87;
    height: 64px;
    width: 64px;
  }

  .cta-section {
    background: #fff;
    padding: 55px 30px 65px;
  }

  .cta-section h2,
  .cta-section p,
  .cta-section a {
    margin-left: auto;
    margin-right: auto;
    max-width: 1120px;
  }

  .cta-section h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 500;
  }

  .cta-section p {
    color: #92939b;
    font-size: 1.16rem;
    line-height: 1.55;
    margin-top: 0.8rem;
  }

  .cta-section .primary-button {
    margin-top: 2rem;
  }

  .site-footer {
    background: #fff;
    color: #5f626b;
    padding: 0 30px 55px;
  }

  .site-footer > * {
    margin-left: auto;
    margin-right: auto;
    max-width: 1120px;
  }

  .footer-lines {
    border-top: 1px solid #cfcfd4;
  }

  .footer-lines details {
    border-bottom: 1px solid #cfcfd4;
    color: #22222b;
    padding: 1.35rem 0;
  }

  .footer-lines summary {
    cursor: pointer;
    font-size: 1.18rem;
    font-weight: 800;
  }

