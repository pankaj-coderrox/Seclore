---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const protectionSteps = [
  {
    title: "Protect what's valuable",
    text: "Automatically apply fine-grained security policies based on the sensitivity of digital assets.",
    icon: "document"
  },
  {
    title: "Close security gaps",
    text: "Add persistent protection to classified data, to keep that data secure across devices, networks, and cloud environments.",
    icon: "close"
  },
  {
    title: "Eliminate threats",
    text: "Prevent human error, malicious insiders, and hackers from compromising sensitive or classified data.",
    icon: "database"
  },
  {
    title: "Data-centric governance",
    text: "Meet compliance regulations with data-centric audits and visibility into authorized and unauthorized access and activities.",
    icon: "lock"
  }
];

const resources = [
  {
    image: "/images/integrations/discovery-classification/keyboard.png",
    type: "Blog Post",
    tag: "Access Control, AI Risk, Data Loss Prevention, Data Protection",
    title: "Ctrl+C and Ctrl+V are the Latest Major Data Exposure Risk",
    cta: "View Blog Post"
  },
  {
    type: "Blog Post",
    tag: "Third Party Risk",
    title: "Why You Need a Data Security Intelligence Framework",
    cta: "View Blog Post"
  },
  {
    type: "Blog Post",
    tag: "Third Party Risk",
    title: "5 Warning Signs of Poor Third-Party Cybersecurity Practices",
    cta: "View Blog Post"
  }
];
---

<BaseLayout
  title="Discovery and Classification Integrations | seclore"
  description="Integrate discovery and classification tools with persistent protection for sensitive digital assets."
>
  <main id="top" class="discovery-page">
    <Nav />

    <section class="product-hero">
      <span>Integrations</span>
      <h1>Integrate with Discovery and Classification Solutions to Secure Your Sensitive Data</h1>
      <p>
        Persistently protect sensitive data with dynamic watermarking and advanced encryption,
        activity tracking for users, and the ability to revoke access on demand to secure your most
        sensitive digital assets.
      </p>
      <a class="primary-button" href="/demo/">Book a Demo</a>
    </section>

    <section class="intro-section">
      <div class="photo-card intro-photo">
        <img src="/images/integrations/discovery-classification/datacenter.png" alt="Secure digital data repository" loading="lazy" />
      </div>
      <div class="intro-copy">
        <h2>Apply adaptive security controls based on the sensitivity of your data</h2>
        <p>
          Ensuring the security of valuable digital assets goes beyond mere identification and
          classification - it requires a holistic strategy. Discovery and classification tools play
          a critical role in identifying and labeling sensitive data, offering visibility and aiding
          compliance efforts.
        </p>
        <p>
          However, the risk of data leakage or theft is not completely eliminated. Businesses must
          combine intelligent discovery and classification with strong security measures, including
          encryption, access controls, and activity tracking. This integrated approach ensures data
          remains protected both within and outside the organization.
        </p>
      </div>
    </section>

    <section class="steps-section">
      <div class="section-heading centered">
        <h2>Take the next step to protect your sensitive data</h2>
      </div>
      <div class="step-list">
        {protectionSteps.map((step) => (
          <article class="step-card">
            <div class={`line-icon ${step.icon}`} aria-hidden="true"></div>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="resources-section" id="resources">
      <div class="section-heading centered">
        <h2>Additional Resources</h2>
      </div>
      <div class="resource-grid">
        {resources.map((resource) => (
          <article class="resource-card">
            {resource.image && <img src={resource.image} alt="" loading="lazy" />}
            <div class="resource-body">
              <span>{resource.type}</span>
              <strong>{resource.tag}</strong>
              <h3>{resource.title}</h3>
              <a href="#resources">{resource.cta} <span aria-hidden="true">&rarr;</span></a>
            </div>
          </article>
        ))}
      </div>
      <div class="resource-controls" aria-label="Resource carousel controls">
        <button type="button" aria-label="Previous resources">&larr;</button>
        <button type="button" aria-label="Next resources">&rarr;</button>
      </div>
    </section>
  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f6f6f7;
    --page-text: #29282d;
    --purple: #5b2bd7;
    --purple-dark: #4515c7;
    --line: #dedee5;
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: #ffffff;
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a { color: inherit; text-decoration: none; }
  button { font: inherit; }
  .discovery-page h1,
  .discovery-page h2,
  .discovery-page h3,
  .discovery-page p { margin: 0; }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo { color: var(--purple); font-size: 1.35rem; font-weight: 950; letter-spacing: 0.04em; margin-right: clamp(14px, 2vw, 28px); text-transform: uppercase; }
  .nav-links, .nav-utilities { align-items: center; display: flex; }
  .nav-links { flex: 1 1 auto; gap: clamp(18px, 2.2vw, 34px); justify-content: center; min-width: 0; }
  .nav-links > a, .nav-trigger { align-items: center; background: transparent; border: 0; color: var(--header-muted); cursor: pointer; display: inline-flex; font-size: 0.98rem; font-weight: 800; gap: 8px; min-height: 68px; padding: 0; }
  .nav-item { position: static; }
  .nav-caret { border-bottom: 2px solid currentColor; border-right: 2px solid currentColor; display: inline-block; height: 8px; transform: rotate(45deg) translateY(-2px); width: 8px; }
  .mega-menu { left: 22px; opacity: 0; pointer-events: none; position: absolute; right: clamp(20px, 4vw, 42px); top: calc(100% - 1px); transform: translateY(12px); transition: opacity 180ms ease, transform 180ms ease; }
  .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu, .nav-item.is-open .mega-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .mega-inner { background: var(--dropdown-bg); border: 1px solid var(--dropdown-border); border-radius: 8px; box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2); display: grid; gap: 24px; grid-template-columns: minmax(0, 1fr) 320px; min-height: 320px; overflow: hidden; padding: 26px; }
  .mega-columns { display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .mega-column, .mega-sublinks { display: grid; }
  .mega-column { gap: 10px; }
  .mega-title { color: var(--dropdown-title); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .mega-link, .mega-link-group { border: 1px solid transparent; border-radius: 8px; }
  .mega-link { display: grid; gap: 5px; padding: 13px; }
  .mega-link strong { color: var(--dropdown-text); }
  .mega-link small, .mega-sublinks a { color: var(--dropdown-muted); }
  .mega-link:hover, .mega-link-group:hover { background: var(--dropdown-link-hover); border-color: var(--dropdown-link-border); }
  .mega-link-group { display: grid; gap: 4px; padding: 4px; }
  .mega-sublinks { gap: 2px; padding: 0 9px 8px 22px; }
  .mega-sublinks a { font-size: 0.84rem; padding: 5px 0; }
  .mega-feature { align-content: end; background: var(--dropdown-feature-bg); border: 1px solid var(--dropdown-feature-border); border-radius: 8px; display: grid; min-height: 268px; padding: 24px; }
  .mega-feature span, .mega-feature em { color: var(--dropdown-title); }
  .mega-feature strong { color: var(--dropdown-text); font-size: 1.35rem; line-height: 1.18; margin-top: auto; }
  .nav-utilities { flex: 0 0 auto; gap: clamp(12px, 1.5vw, 20px); margin-left: clamp(12px, 2vw, 28px); }
  .utility-link, .language-button, .utility-icon, .theme-toggle { color: var(--header-muted); display: none; font-size: 0.88rem; font-weight: 750; }
  .demo-button,
  .primary-button {
    align-items: center;
    background: linear-gradient(135deg, var(--purple), var(--purple-dark));
    border: 0;
    border-radius: 7px;
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.9rem;
    font-weight: 850;
    justify-content: center;
    line-height: 1;
    min-height: 40px;
    padding: 0 18px;
    white-space: nowrap;
    width: fit-content;
  }
  .nav-toggle { background: transparent; border: 0; display: none; height: 42px; width: 42px; }
  .nav-toggle span { background: var(--header-text); display: block; height: 2px; margin: 6px 0; width: 24px; }

  .product-hero {
    align-items: center;
    background: radial-gradient(circle at 14% 86%, rgba(229, 175, 245, 0.86), transparent 36%), linear-gradient(125deg, #8736df 0%, #7d2dea 45%, #4a04dc 100%);
    color: #fff;
    display: flex;
    flex-direction: column;
    min-height: 850px;
    padding: 170px 24px 125px;
    text-align: center;
  }

  .product-hero span { font-size: 1rem; font-weight: 850; margin-bottom: 2.2rem; }
  .product-hero h1 { font-size: clamp(3rem, 7vw, 6.6rem); font-weight: 500; letter-spacing: 0; line-height: 1.04; max-width: 1120px; }
  .product-hero p { font-size: clamp(1rem, 1.6vw, 1.22rem); line-height: 1.55; margin: 3rem auto 2.2rem; max-width: 1190px; }

  .intro-section {
    align-items: center;
    background: #fff;
    display: grid;
    gap: clamp(3rem, 9vw, 9rem);
    grid-template-columns: minmax(280px, 0.75fr) minmax(360px, 1fr);
    padding: 150px clamp(30px, 5vw, 92px);
  }

  .photo-card { align-self: center; border-radius: 18px; overflow: hidden; }
  .photo-card img { display: block; height: 100%; object-fit: cover; width: 100%; }
  .intro-photo { aspect-ratio: 1.36; }
  .intro-copy { display: grid; gap: 2.3rem; max-width: 620px; }
  .intro-copy h2 { color: #333136; font-size: clamp(2.8rem, 4.9vw, 4.8rem); font-weight: 500; line-height: 1.04; }
  .intro-copy p { color: #1d1c24; font-size: 1.18rem; line-height: 1.66; }

  .steps-section { background: #f4f4f5; padding: 88px 30px 95px; }
  .section-heading.centered { margin: 0 auto; max-width: 1020px; text-align: center; }
  .section-heading h2 { color: #333136; font-size: clamp(2.6rem, 4.8vw, 4.8rem); font-weight: 500; line-height: 1.1; }
  .step-list { display: grid; gap: 30px; margin: 72px auto 0; max-width: 1120px; }
  .step-card { background: #fff; border: 1px solid var(--line); border-radius: 18px; display: grid; gap: 26px; min-height: 220px; padding: 42px 42px 40px; }
  .step-card h3 { color: #111018; font-size: 1.8rem; font-weight: 550; }
  .step-card p { color: #3f3f48; font-size: 1.05rem; line-height: 1.68; }

  .line-icon { color: var(--purple); height: 48px; position: relative; width: 48px; }
  .line-icon::before,
  .line-icon::after { border: 4px solid currentColor; border-radius: 6px; content: ""; position: absolute; }
  .line-icon::before { height: 30px; left: 8px; top: 8px; width: 30px; }
  .line-icon.document::after { border-color: #f2a86c; height: 20px; left: 15px; top: 14px; width: 16px; }
  .line-icon.close::before { border-radius: 50%; }
  .line-icon.close::after { border-bottom: 0; border-left: 0; height: 34px; left: 21px; top: 6px; transform: rotate(45deg); width: 0; }
  .line-icon.database::before { border-radius: 50% / 18%; height: 32px; }
  .line-icon.database::after { border-color: #f2a86c; border-radius: 50%; height: 22px; left: 22px; top: 20px; width: 22px; }
  .line-icon.lock::before { border-radius: 6px; height: 22px; left: 7px; top: 18px; width: 34px; }
  .line-icon.lock::after { border-bottom: 0; border-radius: 16px 16px 0 0; height: 18px; left: 15px; top: 2px; width: 18px; }

  .resources-section { background: #fff; padding: 95px 30px 105px; }
  .resource-grid { display: grid; gap: 40px min(13vw, 250px); grid-template-columns: repeat(2, minmax(260px, 365px)); margin: 65px auto 0; max-width: 970px; }
  .resource-card { border: 1px solid var(--line); border-radius: 18px; min-height: 430px; overflow: hidden; }
  .resource-card img { aspect-ratio: 1.45; display: block; object-fit: cover; object-position: top center; width: 100%; }
  .resource-body { background: #fff; display: grid; gap: 1.4rem; padding: 40px 38px; }
  .resource-card:not(:has(img)) .resource-body { padding-top: 185px; }
  .resource-body span, .resource-body strong { background: #f1f1f3; border-radius: 999px; color: #191826; display: inline-flex; font-size: 0.86rem; font-weight: 900; justify-content: center; line-height: 1.35; padding: 0.55rem 1rem; text-transform: uppercase; width: max-content; }
  .resource-body strong { max-width: 270px; text-align: center; }
  .resource-body h3 { color: #151321; font-size: 1.8rem; font-weight: 500; line-height: 1.12; }
  .resource-card a { color: #111118; display: inline-flex; font-weight: 800; gap: 0.5rem; }
  .resource-controls { display: flex; gap: 20px; margin: 48px auto 0; max-width: 970px; }
  .resource-controls button { background: #fff; border: 1px solid #a9a9b2; border-radius: 999px; color: #7d7d87; height: 64px; width: 64px; }

  .site-footer { background: #fff; color: #5f626b; padding: 0 30px 55px; }
  .site-footer > * { margin-left: auto; margin-right: auto; max-width: 1120px; }
  .footer-lines { border-top: 1px solid #cfcfd4; }
  .footer-lines details { border-bottom: 1px solid #cfcfd4; color: #22222b; padding: 1.35rem 0; }
  .footer-lines summary { cursor: pointer; font-size: 1.18rem; font-weight: 800; }
  .footer-lines p { color: #656873; line-height: 1.6; margin-top: 0.75rem; }
  .footer-logo { color: #5b2bd7; display: block; font-size: 2rem; font-weight: 900; letter-spacing: 1px; margin-top: 2.4rem; text-transform: uppercase; }
  .site-footer p { font-size: 1.05rem; line-height: 1.65; margin-top: 1.4rem; }
  .store-row { display: flex; flex-direction: column; gap: 10px; margin-top: 2.4rem; }
  .store-row span { align-items: center; background: #17101b; border-radius: 6px; color: #fff; display: inline-flex; font-size: 0.9rem; font-weight: 800; height: 40px; justify-content: center; width: 168px; }
  .social-row { border-top: 1px solid #d1d1d6; padding-top: 1.7rem; }
  .legal a { text-decoration: underline; }

  @media (max-width: 1280px) {
    .nav-toggle { display: block; margin-left: 12px; order: 1; }
    .site-header { flex-wrap: wrap; }
    .site-logo { order: 0; }
    .nav-links { background: var(--header-bg); border-top: 1px solid var(--header-border); display: none; flex: 1 0 100%; order: 2; padding: 10px 0 14px; }
    .nav-links.open { align-items: stretch; display: grid; }
    .nav-links > a, .nav-trigger { justify-content: space-between; min-height: 48px; width: 100%; }
    .nav-item { display: grid; }
    .mega-menu { display: none; opacity: 1; position: static; transform: none; }
    .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu { display: none; }
    .nav-item.is-open .mega-menu { display: block; }
    .mega-inner { box-shadow: none; grid-template-columns: 1fr; min-height: 0; padding: 16px; }
    .nav-utilities { align-items: stretch; display: flex; margin-left: auto; order: 0; }
  }

  @media (max-width: 900px) {
    .product-hero { min-height: 620px; padding: 105px 20px 90px; }
    .intro-section { gap: 3rem; grid-template-columns: 1fr; padding: 85px 20px; }
    .steps-section, .resources-section { padding: 72px 20px; }
    .resource-grid { grid-template-columns: 1fr; }
    .step-card { padding: 34px 28px; }
    .discovery-page .product-hero > .primary-button {
      max-width: 100%;
      width: fit-content !important;
    }
  }

  @media (max-width: 560px) {
    .product-hero h1 { font-size: 2.65rem; }
    .intro-copy h2, .section-heading h2 { font-size: 2.2rem; }
    .resource-body { padding: 34px 30px; }
    .resource-card:not(:has(img)) .resource-body { padding-top: 150px; }
    .discovery-page .product-hero > .primary-button {
      font-size: 0.9rem !important;
      min-height: 40px;
      padding-inline: 18px;
      white-space: normal;
    }
  }
</style>
