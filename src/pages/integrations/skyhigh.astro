---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const solutionCards = [
  {
    title: "Automatically protect sensitive data in the cloud",
    text: "Sensitive files identified or classified with Skyhigh CASB in cloud environments like M365 and Box are automatically protected with Seclore's persistent file-level encryption and access controls.",
    icon: "cloud"
  },
  {
    title: "Protect email automatically",
    text: "Sensitive content in emails that is identified by Skyhigh Security CASB can be automatically protected with Seclore's email auto-protector, ensuring email security in the cloud.",
    icon: "mail"
  },
  {
    title: "Protect data beyond the cloud",
    text: "Skyhigh CASB monitors and controls data flows across cloud applications, while Seclore extends protection beyond cloud environments, safeguarding data wherever it travels.",
    icon: "shield"
  },
  {
    title: "Data-centric usage tracking and auditing",
    text: "Apply protection policies to digital assets and enjoy end-to-end tracking and audit reporting, even for files that are downloaded from cloud repositories.",
    icon: "pin"
  },
  {
    title: "Real-time access controls",
    text: "Policy updates or changes to user access and privilege rules take effect immediately in near real-time for documents inside and outside cloud applications.",
    icon: "access"
  },
  {
    title: "Real-time revocation",
    text: "Revoke access at any time, even after documents have been downloaded from a cloud application, shared externally, or exfiltrated as part of a breach.",
    icon: "revoke"
  }
];

const resources = [
  {
    image: "/images/integrations/dlp-casb/debate-ai.png",
    type: "Blog Post",
    tag: "AI, Company, Data Security",
    title: "The Debate About AI in the Enterprise Is Over. Here Is the Only Question That Matters.",
    cta: "View Blog Post"
  },
  {
    image: "/images/integrations/dlp-casb/ai-perimeter.png",
    type: "Blog Post",
    tag: "AI Risk, Data Security",
    title: "The Missing Link in Enterprise AI: Why Context and Behavior Are the New Security Perimeter",
    cta: "View Blog Post"
  },
  {
    image: "/images/integrations/dlp-casb/ai-readiness.png",
    type: "On-Demand Webinar",
    tag: "Compliance",
    title: "From AI Risk to AI Readiness: Where Trust Becomes Operational, Not Aspirational",
    cta: "View On-Demand Webinar"
  }
];
---

<BaseLayout
  title="Skyhigh CASB Integration | seclore"
  description="Seclore and Skyhigh Security join forces to deliver persistent data security for cloud data through protection, access, and control policies."
>
  <main id="top" class="skyhigh-page">
    <Nav />

    <section class="product-hero">
      <span>Integrations</span>
      <h1>Skyhigh CASB</h1>
      <p>
        Seclore and Skyhigh Security join forces to deliver unprecedented security for your data in
        the cloud by applying protection, access, and control policies to sensitive digital assets.
      </p>
      <a class="primary-button" href="#demo">Book a Demo</a>
    </section>

    <section class="intro-section">
      <div class="photo-card">
        <img src="/images/integrations/skyhigh/skyhigh-lead.png" alt="Professional working on a laptop in a secure cloud workspace" loading="lazy" />
      </div>
      <div class="intro-copy">
        <h2>Persistent data security in the cloud and beyond</h2>
        <p>
          Seclore and Skyhigh Security work together to seamlessly protect sensitive data across
          cloud platforms such as Microsoft 365, Box, Slack, Google Workspace, and Salesforce.
          Skyhigh's CASB solutions identify and classify sensitive data, while Seclore's persistent
          protection keeps it encrypted and under organizational control even when it's shared
          internally, externally, or downloaded. This effortless integration automates security,
          provides visibility, and enforces dynamic access controls, enabling organizations to
          safeguard data anywhere.
        </p>
        <a class="primary-button small" href="#resources">Read the Solution Brief</a>
      </div>
    </section>

    <section class="solutions-section">
      <div class="section-heading centered">
        <h2>Enjoy secure collaboration with persistent protection for data in the cloud</h2>
        <div class="partner-lockup" aria-label="Seclore and Skyhigh Security">
          <strong>seclore</strong>
          <span></span>
          <b>Skyhigh <small>Security</small></b>
        </div>
      </div>
      <div class="solution-grid">
        {solutionCards.map((card) => (
          <article class="solution-card">
            <div class={`line-icon ${card.icon}`} aria-hidden="true"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="resources-section" id="resources">
      <div class="section-heading centered">
        <h2>Additional Resources</h2>
      </div>
      <div class="resource-grid">
        {resources.map((resource) => (
          <article class="resource-card">
            <img src={resource.image} alt="" loading="lazy" />
            <div class="resource-body">
              <span>{resource.type}</span>
              <strong>{resource.tag}</strong>
              <h3>{resource.title}</h3>
              <a href="#resources">{resource.cta} <span aria-hidden="true">&rarr;</span></a>
            </div>
          </article>
        ))}
      </div>
      <div class="resource-controls" aria-label="Resource carousel controls">
        <button type="button" aria-label="Previous resources">&larr;</button>
        <button type="button" aria-label="Next resources">&rarr;</button>
      </div>
    </section>

    <section class="cta-section" id="demo">
      <h2>Ready to get started?</h2>
      <p>Contact our sales team to find out how Seclore can help with data security and compliance.</p>
      <a class="primary-button" href="#top">Book a Demo</a>
    </section>
  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f6f6f7;
    --page-text: #29282d;
    --purple: #5b2bd7;
    --purple-dark: #4515c7;
    --line: #dedee5;
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    font: inherit;
  }

  .skyhigh-page h1,
  .skyhigh-page h2,
  .skyhigh-page h3,
  .skyhigh-page p {
    margin: 0;
  }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    font-size: 1.35rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .nav-links,
  .nav-utilities {
    align-items: center;
    display: flex;
  }

  .nav-links {
    flex: 1 1 auto;
    gap: clamp(18px, 2.2vw, 34px);
    justify-content: center;
    min-width: 0;
  }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:hover .nav-trigger,
  .nav-item:focus-within .nav-trigger {
    color: var(--header-text);
  }

  .nav-item {
    position: static;
  }

  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret {
    transform: rotate(225deg) translateY(-1px);
  }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .mega-column,
  .mega-sublinks {
    display: grid;
  }

  .mega-column {
    gap: 10px;
  }

  .mega-title {
    color: var(--dropdown-title);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mega-link,
  .mega-link-group {
    border: 1px solid transparent;
    border-radius: 8px;
  }

  .mega-link {
    display: grid;
    gap: 5px;
    padding: 13px;
  }

  .mega-link strong {
    color: var(--dropdown-text);
  }

  .mega-link small,
  .mega-sublinks a {
    color: var(--dropdown-muted);
  }

  .mega-link:hover,
  .mega-link-group:hover {
    background: var(--dropdown-link-hover);
    border-color: var(--dropdown-link-border);
  }

  .mega-link-group {
    display: grid;
    gap: 4px;
    padding: 4px;
  }

  .mega-sublinks {
    gap: 2px;
    padding: 0 9px 8px 22px;
  }

  .mega-sublinks a {
    font-size: 0.84rem;
    padding: 5px 0;
  }

  .mega-feature {
    align-content: end;
    background: var(--dropdown-feature-bg);
    border: 1px solid var(--dropdown-feature-border);
    border-radius: 8px;
    display: grid;
    min-height: 268px;
    padding: 24px;
  }

  .mega-feature span,
  .mega-feature em {
    color: var(--dropdown-title);
  }

  .mega-feature strong {
    color: var(--dropdown-text);
    font-size: 1.35rem;
    line-height: 1.18;
    margin-top: auto;
  }

  .nav-utilities {
    flex: 0 0 auto;
    gap: clamp(12px, 1.5vw, 20px);
    margin-left: clamp(12px, 2vw, 28px);
  }

  .utility-link,
  .language-button,
  .utility-icon,
  .theme-toggle {
    color: var(--header-muted);
    display: none;
    font-size: 0.88rem;
    font-weight: 750;
  }

  .demo-button,
  .primary-button {
    align-items: center;
    background: linear-gradient(135deg, var(--purple), var(--purple-dark));
    border: 0;
    border-radius: 7px;
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.9rem;
    font-weight: 850;
    justify-content: center;
    min-height: 40px;
    padding: 0 18px;
  }

  .primary-button.small {
    font-size: 0.82rem;
    min-height: 34px;
    padding-inline: 14px;
  }

  .nav-toggle {
    background: transparent;
    border: 0;
    display: none;
    height: 42px;
    width: 42px;
  }

  .nav-toggle span {
    background: var(--header-text);
    display: block;
    height: 2px;
    margin: 6px 0;
    width: 24px;
  }

  .product-hero {
    align-items: center;
    background:
      radial-gradient(circle at 14% 84%, rgba(229, 175, 245, 0.86), transparent 36%),
      linear-gradient(125deg, #8736df 0%, #7d2dea 45%, #4a04dc 100%);
    color: #fff;
    display: flex;
    flex-direction: column;
    min-height: 665px;
    padding: 145px 28px 115px;
    text-align: center;
  }

  .product-hero span {
    font-size: 0.86rem;
    font-weight: 850;
    margin-bottom: 2rem;
  }

  .product-hero h1 {
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.04;
  }

  .product-hero p {
    font-size: clamp(0.98rem, 1.6vw, 1.18rem);
    line-height: 1.55;
    margin: 2.2rem auto 2.1rem;
    max-width: 1040px;
  }

  .intro-section {
    display: grid;
    gap: clamp(3rem, 8vw, 8rem);
    grid-template-columns: minmax(260px, 0.95fr) minmax(310px, 1fr);
    margin: 0 auto;
    max-width: 1120px;
    padding: 142px 30px 150px;
  }

  .photo-card {
    align-self: center;
    aspect-ratio: 1.43;
    border-radius: 18px;
    overflow: hidden;
  }

  .photo-card img {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .intro-copy h2,
  .section-heading h2 {
    color: #333136;
    font-size: clamp(2.25rem, 4.1vw, 4rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.06;
  }

  .intro-copy p {
    color: #1d1c24;
    font-size: 1.05rem;
    line-height: 1.66;
    margin-top: 2.1rem;
  }

  .intro-copy .primary-button {
    margin-top: 2.2rem;
  }

  .solutions-section {
    background: #f1f1f3;
    padding: 80px 30px 112px;
  }

  .section-heading.centered {
    margin: 0 auto;
    max-width: 850px;
    text-align: center;
  }

  .partner-lockup {
    align-items: center;
    display: flex;
    gap: 34px;
    justify-content: center;
    margin: 55px auto 70px;
  }

  .partner-lockup strong {
    color: #ef2953;
    font-size: clamp(2rem, 4vw, 3.55rem);
    font-weight: 950;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .partner-lockup span {
    background: #7e7f87;
    height: 62px;
    width: 2px;
  }

  .partner-lockup b {
    color: #1b1757;
    font-size: clamp(1.55rem, 3vw, 2.7rem);
    font-weight: 850;
    letter-spacing: -1px;
  }

  .partner-lockup b::before {
    border: 6px solid #3d67f1;
    border-radius: 8px;
    content: "";
    display: inline-block;
    height: 24px;
    margin-right: 8px;
    transform: rotate(45deg);
    vertical-align: -3px;
    width: 24px;
  }

  .partner-lockup small {
    display: block;
    font-size: 0.86rem;
    font-weight: 600;
    text-align: right;
  }

  .solution-grid {
    display: grid;
    gap: 34px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin: 0 auto;
    max-width: 1120px;
  }

  .solution-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 14px;
    min-height: 245px;
    padding: 36px 34px 40px;
  }

  .solution-card h3 {
    color: #171720;
    font-size: 1.32rem;
    font-weight: 500;
    line-height: 1.28;
    margin-top: 1.6rem;
  }

  .solution-card p {
    color: #30313a;
    font-size: 0.98rem;
    line-height: 1.62;
    margin-top: 1.5rem;
  }

  .line-icon {
    height: 46px;
    position: relative;
    width: 46px;
  }

  .line-icon::before,
  .line-icon::after {
    content: "";
    position: absolute;
  }

  .line-icon.cloud::before {
    border: 4px solid var(--purple);
    border-radius: 22px;
    height: 24px;
    left: 3px;
    top: 13px;
    width: 39px;
  }

  .line-icon.cloud::after,
  .line-icon.mail::after,
  .line-icon.pin::after,
  .line-icon.access::after,
  .line-icon.revoke::after {
    border: 4px solid #ef8d29;
    border-radius: 5px;
    bottom: 1px;
    height: 15px;
    left: 18px;
    width: 15px;
  }

  .line-icon.mail::before {
    border: 4px solid var(--purple);
    height: 27px;
    left: 4px;
    top: 8px;
    width: 35px;
  }

  .line-icon.mail::after {
    border-bottom: 4px solid #ef8d29;
    border-left: 0;
    border-radius: 0;
    border-top: 0;
    bottom: auto;
    height: 16px;
    left: 14px;
    top: 10px;
    transform: rotate(45deg);
    width: 16px;
  }

  .line-icon.shield::before {
    border: 4px solid var(--purple);
    border-radius: 20px 20px 14px 14px;
    height: 34px;
    left: 8px;
    top: 5px;
    width: 28px;
  }

  .line-icon.shield::after {
    border-bottom: 4px solid #ef8d29;
    border-right: 4px solid #ef8d29;
    height: 14px;
    left: 18px;
    top: 14px;
    transform: rotate(45deg);
    width: 9px;
  }

  .line-icon.pin::before {
    border: 4px solid var(--purple);
    border-radius: 4px;
    bottom: 5px;
    height: 23px;
    left: 7px;
    width: 31px;
  }

  .line-icon.pin::after {
    border-radius: 50% 50% 50% 0;
    bottom: auto;
    left: 24px;
    top: 1px;
    transform: rotate(-45deg);
  }

  .line-icon.access::before,
  .line-icon.revoke::before {
    border: 4px solid var(--purple);
    border-radius: 50%;
    height: 34px;
    left: 5px;
    top: 5px;
    width: 34px;
  }

  .line-icon.access::after {
    border-radius: 50%;
    bottom: 3px;
    left: 20px;
  }

  .line-icon.revoke::after {
    border-radius: 0;
    border-top: 0;
    height: 0;
    left: 12px;
    top: 21px;
    transform: rotate(-30deg);
    width: 24px;
  }

  .resources-section {
    background: #fff;
    padding: 95px 30px 105px;
  }

  .resource-grid {
    display: grid;
    gap: 40px min(9vw, 230px);
    grid-template-columns: repeat(2, minmax(260px, 365px));
    margin: 65px auto 0;
    max-width: 970px;
  }

  .resource-card {
    border: 1px solid var(--line);
    border-radius: 18px;
    overflow: hidden;
  }

  .resource-card img {
    aspect-ratio: 1.5;
    display: block;
    object-fit: cover;
    object-position: top center;
    width: 100%;
  }

  .resource-body {
    background: #fff;
    padding: 40px 38px;
  }

  .resource-body span,
  .resource-body strong {
    background: #f1f1f3;
    border-radius: 999px;
    color: #191826;
    display: inline-flex;
    font-size: 0.86rem;
    font-weight: 900;
    justify-content: center;
    line-height: 1.35;
    padding: 0.55rem 1rem;
    text-transform: uppercase;
  }

  .resource-body strong {
    display: flex;
    margin-top: 1.2rem;
    max-width: 270px;
    text-align: center;
  }

  .resource-body h3 {
    color: #11111b;
    font-size: 1.8rem;
    font-weight: 500;
    line-height: 1.12;
    margin-top: 2.1rem;
  }

  .resource-card a {
    color: #111118;
    display: inline-flex;
    font-weight: 800;
    gap: 0.5rem;
    margin-top: 1.6rem;
  }

  .resource-controls {
    display: flex;
    gap: 20px;
    margin: 48px auto 0;
    max-width: 970px;
  }

  .resource-controls button {
    background: #fff;
    border: 1px solid #a9a9b2;
    border-radius: 999px;
    color: #7d7d87;
    height: 64px;
    width: 64px;
  }

  .cta-section {
    background: #fff;
    padding: 55px 30px 65px;
  }

  .cta-section h2,
  .cta-section p,
  .cta-section a {
    margin-left: auto;
    margin-right: auto;
    max-width: 1120px;
  }

  .cta-section h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 500;
  }

  .cta-section p {
    color: #92939b;
    font-size: 1.16rem;
    line-height: 1.55;
    margin-top: 0.8rem;
  }

  .cta-section .primary-button {
    margin-top: 2rem;
  }

  .site-footer {
    background: #fff;
    color: #5f626b;
    padding: 0 30px 55px;
  }

  .site-footer > * {
    margin-left: auto;
    margin-right: auto;
    max-width: 1120px;
  }

  .footer-lines {
    border-top: 1px solid #cfcfd4;
  }

  .footer-lines details {
    border-bottom: 1px solid #cfcfd4;
    color: #22222b;
    padding: 1.35rem 0;
  }

  .footer-lines summary {
    cursor: pointer;
    font-size: 1.18rem;
    font-weight: 800;
  }

  .footer-lines p {
    color: #656873;
    line-height: 1.6;
    margin-top: 0.75rem;
  }

  .footer-logo {
    color: #5b2bd7;
    display: block;
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: 1px;
    margin-top: 2.4rem;
    text-transform: uppercase;
  }

  .site-footer p {
    font-size: 1.05rem;
    line-height: 1.65;
    margin-top: 1.4rem;
