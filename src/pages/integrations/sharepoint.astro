---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const capabilities = [
  {
    title: "Automated protection",
    text: "Automatically protect data across office and non-office formats with persistent, granular usage controls as they are downloaded from Microsoft SharePoint.",
    icon: "key"
  },
  {
    title: "Permission federation and enforcement",
    text: "User permissions set at the document library/folder are automatically extended to downloaded copies. Any access permission changes within SharePoint are also automatically reflected in real-time on downloaded copies.",
    icon: "shield"
  },
  {
    title: "Secure access",
    text: "Open encrypted office and non-office files seamlessly in native applications post download or access securely with a dynamic watermark within the browser.",
    icon: "access"
  },
  {
    title: "Reduce the risk of data leakage",
    text: "Sensitive files are automatically encrypted on download. Revoke access on demand in case of unauthorized access or sharing to remain in control of your data.",
    icon: "revoke"
  },
  {
    title: "Visibility and tracking",
    text: "Go beyond SharePoint's native logging and auditing features with granular user activities, even for downloaded copies.",
    icon: "file"
  },
  {
    title: "Regulatory compliance",
    text: "Achieve compliance with evidence, audit information related to the sensitivity of data, access permissions, and activities performed.",
    icon: "compliance"
  }
];

const resources = [
  {
    type: "Blog Post",
    tag: "AI, Company, Data Security",
    title: "The Debate About AI in the Enterprise Is Over. Here Is the Only Question That Matters.",
    cta: "View Blog Post"
  },
  {
    type: "Blog Post",
    tag: "AI Risk, Data Security",
    title: "The Missing Link in Enterprise AI: Why Context and Behavior Are the New Security Perimeter",
    cta: "View Blog Post"
  },
  {
    type: "Blog Post",
    tag: "AI Risk, Data Security",
    title: "ChatGPT Read 400 Internal Company Files In 42 Milliseconds. Security Stacks Saw Nothing",
    cta: "View Blog Post"
  }
];
---

<BaseLayout
  title="Microsoft SharePoint Server Integration | seclore"
  description="Data-centric security for Microsoft SharePoint Server with persistent protection, access controls, tracking, and compliance."
>
  <main id="top" class="sharepoint-page">
    <Nav />

    <section class="product-hero">
      <span>Integrations</span>
      <h1>Seclore for Microsoft SharePoint Server</h1>
      <p>
        Implement data-centric security to improve Microsoft SharePoint Server security and keep
        sensitive data protected even after they are downloaded and shared.
      </p>
      <a class="primary-button" href="/demo/">Book a Demo</a>
    </section>

    <section class="intro-section">
      <div class="photo-card intro-photo">
        <img src="/images/integrations/sharepoint/sharepoint-lead.png" alt="Professionals collaborating near a city office building" loading="lazy" />
      </div>
      <div class="intro-copy">
        <h2>Address SharePoint security gaps with data-centric protection</h2>
        <p>
          Microsoft SharePoint provides essential collaboration features, but its built-in security
          features are limited, including complex access controls, limited tracking, and lack of
          protection once data leaves the platform.
        </p>
        <p>
          Once data leaves SharePoint, whether through downloads or via sharing links, it becomes
          impossible to track and control. Without persistent security, sensitive information
          remains vulnerable to unauthorized access, data leaks, and compliance risks.
        </p>
        <p>
          Data-centric security enhances SharePoint by applying encryption, access control, and
          tracking at the file level, ensuring continuous protection wherever data travels beyond
          SharePoint.
        </p>
        <a class="primary-button small" href="#resources">Read the Solution Brief</a>
      </div>
    </section>

    <section class="capability-section">
      <div class="section-heading centered">
        <h2>Overcome unauthorized access and data leakage for sensitive data within the SharePoint Server</h2>
      </div>
      <div class="capability-list">
        {capabilities.map((capability) => (
          <article class="capability-card">
            <div class={`line-icon ${capability.icon}`} aria-hidden="true"></div>
            <h3>{capability.title}</h3>
            <p>{capability.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="resources-section" id="resources">
      <div class="section-heading centered">
        <h2>Additional resources</h2>
      </div>
      <div class="resource-grid">
        {resources.map((resource) => (
          <article class="resource-card">
            <div class="resource-body">
              <span>{resource.type}</span>
              <strong>{resource.tag}</strong>
              <h3>{resource.title}</h3>
              <a href="#resources">{resource.cta} <span aria-hidden="true">&rarr;</span></a>
            </div>
          </article>
        ))}
      </div>
      <div class="resource-controls" aria-label="Resource carousel controls">
        <button type="button" aria-label="Previous resources">&larr;</button>
        <button type="button" aria-label="Next resources">&rarr;</button>
      </div>
    </section>
  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f6f6f7;
    --page-text: #29282d;
    --purple: #5b2bd7;
    --purple-dark: #4515c7;
    --line: #dedee5;
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: #ffffff;
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a { color: inherit; text-decoration: none; }
  button { font: inherit; }
  .sharepoint-page h1,
  .sharepoint-page h2,
  .sharepoint-page h3,
  .sharepoint-page p { margin: 0; }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    font-size: 1.35rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .nav-links,
  .nav-utilities { align-items: center; display: flex; }
  .nav-links { flex: 1 1 auto; gap: clamp(18px, 2.2vw, 34px); justify-content: center; min-width: 0; }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .nav-item { position: static; }
  .nav-caret { border-bottom: 2px solid currentColor; border-right: 2px solid currentColor; display: inline-block; height: 8px; transform: rotate(45deg) translateY(-2px); width: 8px; }
  .mega-menu { left: 22px; opacity: 0; pointer-events: none; position: absolute; right: clamp(20px, 4vw, 42px); top: calc(100% - 1px); transform: translateY(12px); transition: opacity 180ms ease, transform 180ms ease; }
  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .mega-inner { background: var(--dropdown-bg); border: 1px solid var(--dropdown-border); border-radius: 8px; box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2); display: grid; gap: 24px; grid-template-columns: minmax(0, 1fr) 320px; min-height: 320px; overflow: hidden; padding: 26px; }
  .mega-columns { display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .mega-column, .mega-sublinks { display: grid; }
  .mega-column { gap: 10px; }
  .mega-title { color: var(--dropdown-title); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .mega-link, .mega-link-group { border: 1px solid transparent; border-radius: 8px; }
  .mega-link { display: grid; gap: 5px; padding: 13px; }
  .mega-link strong { color: var(--dropdown-text); }
  .mega-link small, .mega-sublinks a { color: var(--dropdown-muted); }
  .mega-link:hover, .mega-link-group:hover { background: var(--dropdown-link-hover); border-color: var(--dropdown-link-border); }
  .mega-link-group { display: grid; gap: 4px; padding: 4px; }
  .mega-sublinks { gap: 2px; padding: 0 9px 8px 22px; }
  .mega-sublinks a { font-size: 0.84rem; padding: 5px 0; }
  .mega-feature { align-content: end; background: var(--dropdown-feature-bg); border: 1px solid var(--dropdown-feature-border); border-radius: 8px; display: grid; min-height: 268px; padding: 24px; }
  .mega-feature span, .mega-feature em { color: var(--dropdown-title); }
  .mega-feature strong { color: var(--dropdown-text); font-size: 1.35rem; line-height: 1.18; margin-top: auto; }
  .nav-utilities { flex: 0 0 auto; gap: clamp(12px, 1.5vw, 20px); margin-left: clamp(12px, 2vw, 28px); }
  .utility-link, .language-button, .utility-icon, .theme-toggle { color: var(--header-muted); display: none; font-size: 0.88rem; font-weight: 750; }

  .demo-button,
  .primary-button {
    align-items: center;
    background: linear-gradient(135deg, var(--purple), var(--purple-dark));
    border: 0;
    border-radius: 7px;
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.9rem;
    font-weight: 850;
    justify-content: center;
    line-height: 1;
    min-height: 40px;
    padding: 0 18px;
    white-space: nowrap;
    width: fit-content;
  }

  .primary-button.small {
    font-size: 0.9rem;
    min-height: 40px;
    padding: 0 18px;
    white-space: nowrap;
    width: fit-content;
  }

  .nav-toggle { background: transparent; border: 0; display: none; height: 42px; width: 42px; }
  .nav-toggle span { background: var(--header-text); display: block; height: 2px; margin: 6px 0; width: 24px; }

  .product-hero {
    align-items: center;
    background: radial-gradient(circle at 15% 86%, rgba(229, 175, 245, 0.86), transparent 36%), linear-gradient(125deg, #8736df 0%, #7d2dea 45%, #4a04dc 100%);
    color: #fff;
    display: flex;
    flex-direction: column;
    min-height: 670px;
    padding: 145px 24px 118px;
    text-align: center;
  }

  .product-hero span { font-size: 0.86rem; font-weight: 850; margin-bottom: 2rem; }
  .product-hero h1 { font-size: clamp(3rem, 7vw, 5.3rem); font-weight: 500; letter-spacing: 0; line-height: 1.04; max-width: 980px; }
  .product-hero p { font-size: clamp(0.98rem, 1.6vw, 1.18rem); line-height: 1.55; margin: 2.2rem auto 2.1rem; max-width: 1140px; }

  .intro-section {
    align-items: center;
    background: #fff;
    display: grid;
    gap: clamp(3rem, 9vw, 9rem);
    grid-template-columns: minmax(280px, 1fr) minmax(320px, 0.92fr);
    margin: 0 auto;
    padding: 150px clamp(30px, 5vw, 92px);
  }

  .photo-card { align-self: center; border-radius: 18px; overflow: hidden; }
  .photo-card img { display: block; height: 100%; object-fit: cover; width: 100%; }
  .intro-photo { aspect-ratio: 1.39; }
  .intro-copy { display: grid; gap: 2rem; max-width: 570px; }
  .intro-copy h2 { color: #333136; font-size: clamp(2.7rem, 4.5vw, 4.5rem); font-weight: 500; line-height: 1.04; }
  .intro-copy p { color: #1d1c24; font-size: 1.05rem; line-height: 1.68; }

  .capability-section {
    background: #f4f4f5;
    padding: 85px 30px 95px;
  }

  .section-heading.centered { margin: 0 auto; max-width: 1060px; text-align: center; }
  .section-heading h2 { color: #333136; font-size: clamp(2.3rem, 4.3vw, 4.15rem); font-weight: 500; line-height: 1.1; }
  .capability-list { display: grid; gap: 30px; margin: 72px auto 0; max-width: 1120px; }
  .capability-card { background: #fff; border: 1px solid var(--line); border-radius: 18px; display: grid; gap: 24px; min-height: 230px; padding: 42px 42px 40px; }
  .capability-card h3 { color: #101018; font-size: 1.65rem; font-weight: 550; }
  .capability-card p { color: #3f3f48; font-size: 1.02rem; line-height: 1.65; }

  .line-icon { color: var(--purple); height: 46px; position: relative; width: 46px; }
  .line-icon::before,
  .line-icon::after { border: 4px solid currentColor; content: ""; position: absolute; }
  .line-icon.key::before { border-radius: 50%; height: 21px; left: 3px; top: 12px; width: 21px; }
  .line-icon.key::after { border-bottom: 0; border-left: 0; height: 14px; left: 25px; top: 14px; transform: rotate(-45deg); width: 20px; }
  .line-icon.shield::before { border-radius: 18px 18px 22px 22px; height: 32px; left: 7px; top: 5px; width: 28px; }
  .line-icon.access::before { border-radius: 50%; height: 28px; left: 3px; top: 7px; width: 28px; }
  .line-icon.access::after { border-left: 0; border-top: 0; height: 15px; right: 3px; top: 18px; width: 10px; }
  .line-icon.revoke::before { border-radius: 50%; height: 30px; left: 4px; top: 8px; width: 30px; }
  .line-icon.revoke::after { border-bottom: 0; border-left: 0; height: 15px; right: 3px; top: 3px; width: 15px; }
  .line-icon.file::before { border-radius: 4px; height: 32px; left: 8px; top: 6px; width: 28px; }
  .line-icon.file::after { border-bottom: 0; border-left: 0; height: 11px; left: 2px; top: 24px; width: 18px; }
  .line-icon.compliance::before { border-radius: 50%; height: 28px; left: 7px; top: 7px; width: 28px; }
  .line-icon.compliance::after { border-bottom: 0; border-left: 0; height: 36px; left: 20px; top: 4px; transform: rotate(45deg); width: 0; }

  .resources-section { background: #fff; padding: 95px 30px 105px; }
  .resource-grid { display: grid; gap: 40px min(13vw, 280px); grid-template-columns: repeat(2, minmax(260px, 365px)); margin: 65px auto 0; max-width: 970px; }
  .resource-card { border: 1px solid var(--line); border-radius: 18px; min-height: 440px; overflow: hidden; }
  .resource-body { background: #fff; display: grid; gap: 1.4rem; padding: 185px 38px 40px; }
  .resource-body span, .resource-body strong { background: #f1f1f3; border-radius: 999px; color: #191826; display: inline-flex; font-size: 0.86rem; font-weight: 900; justify-content: center; line-height: 1.35; padding: 0.55rem 1rem; text-transform: uppercase; width: max-content; }
  .resource-body strong { max-width: 270px; text-align: center; }
  .resource-body h3 { color: #151321; font-size: 1.8rem; font-weight: 500; line-height: 1.12; }
  .resource-card a { color: #111118; display: inline-flex; font-weight: 800; gap: 0.5rem; }
  .resource-controls { display: flex; gap: 20px; margin: 48px auto 0; max-width: 970px; }
  .resource-controls button { background: #fff; border: 1px solid #a9a9b2; border-radius: 999px; color: #7d7d87; height: 64px; width: 64px; }

  .site-footer { background: #fff; color: #5f626b; padding: 0 30px 55px; }
  .site-footer > * { margin-left: auto; margin-right: auto; max-width: 1120px; }
  .footer-lines { border-top: 1px solid #cfcfd4; }
  .footer-lines details { border-bottom: 1px solid #cfcfd4; color: #22222b; padding: 1.35rem 0; }
  .footer-lines summary { cursor: pointer; font-size: 1.18rem; font-weight: 800; }
  .footer-lines p { color: #656873; line-height: 1.6; margin-top: 0.75rem; }
  .footer-logo { color: #5b2bd7; display: block; font-size: 2rem; font-weight: 900; letter-spacing: 1px; margin-top: 2.4rem; text-transform: uppercase; }
  .site-footer p { font-size: 1.05rem; line-height: 1.65; margin-top: 1.4rem; }
  .store-row { display: flex; flex-direction: column; gap: 10px; margin-top: 2.4rem; }
  .store-row span { align-items: center; background: #17101b; border-radius: 6px; color: #fff; display: inline-flex; font-size: 0.9rem; font-weight: 800; height: 40px; justify-content: center; width: 168px; }
  .social-row { border-top: 1px solid #d1d1d6; padding-top: 1.7rem; }
  .legal a { text-decoration: underline; }

  @media (max-width: 1280px) {
    .nav-toggle { display: block; margin-left: 12px; order: 1; }
    .site-header { flex-wrap: wrap; }
    .site-logo { order: 0; }
    .nav-links { background: var(--header-bg); border-top: 1px solid var(--header-border); display: none; flex: 1 0 100%; order: 2; padding: 10px 0 14px; }
    .nav-links.open { align-items: stretch; display: grid; }
    .nav-links > a, .nav-trigger { justify-content: space-between; min-height: 48px; width: 100%; }
    .nav-item { display: grid; }
    .mega-menu { display: none; opacity: 1; position: static; transform: none; }
    .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu { display: none; }
    .nav-item.is-open .mega-menu { display: block; }
    .mega-inner { box-shadow: none; grid-template-columns: 1fr; min-height: 0; padding: 16px; }
    .nav-utilities { align-items: stretch; display: flex; margin-left: auto; order: 0; }
  }

  @media (max-width: 900px) {
    .product-hero { min-height: 560px; padding: 105px 20px 90px; }
    .intro-section { gap: 3rem; grid-template-columns: 1fr; padding: 85px 20px; }
    .capability-section, .resources-section { padding: 72px 20px; }
    .resource-grid { grid-template-columns: 1fr; }
    .capability-card { padding: 34px 28px; }
    .sharepoint-page .product-hero > .primary-button,
    .sharepoint-page .intro-copy .primary-button.small {
      max-width: 100%;
      width: fit-content !important;
    }
  }

  @media (max-width: 560px) {
    .product-hero h1 { font-size: 2.7rem; }
    .intro-copy h2, .section-heading h2 { font-size: 2.2rem; }
    .resource-body { padding: 155px 30px 34px; }
    .sharepoint-page .product-hero > .primary-button,
    .sharepoint-page .intro-copy .primary-button.small {
      font-size: 0.9rem !important;
      min-height: 40px;
      padding-inline: 18px;
      white-space: normal;
    }
  }
</style>
