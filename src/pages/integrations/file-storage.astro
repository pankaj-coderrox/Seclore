---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const storageCards = [
  {
    id: "fileserver",
    title: "Fileserver",
    text: "Address risk of insider threat or third party risk by protecting data at the source where it is stored and managed.",
    icon: "folder",
    href: "/integrations/file-servers/"
  },
  {
    id: "sharepoint",
    title: "Microsoft SharePoint Server",
    text: "Apply advanced encryption, access control, and tracking at the file level as they are downloaded and shared beyond SharePoint.",
    href: "/integrations/sharepoint/"
  },
  {
    id: "microsoft-365",
    title: "Microsoft 365",
    text: "Protect your files, emails, and attachments via productivity and collaboration apps like Outlook, SharePoint, OneDrive, and Teams.",
    href: "/integrations/microsoft/"
  }
];

const resources = [
  {
    image: "/images/integrations/dlp-casb/debate-ai.png",
    type: "Blog Post",
    tag: "AI, Company, Data Security",
    title: "The Debate About AI in the Enterprise Is Over. Here Is the Only Question That Matters.",
    cta: "View Blog Post"
  },
  {
    image: "/images/integrations/dlp-casb/ai-perimeter.png",
    type: "Blog Post",
    tag: "AI Risk, Data Security",
    title: "The Missing Link in Enterprise AI: Why Context and Behavior Are the New Security Perimeter",
    cta: "View Blog Post"
  },
  {
    image: "/images/integrations/dlp-casb/ai-readiness.png",
    type: "On-Demand Webinar",
    tag: "Compliance",
    title: "From AI Risk to AI Readiness: Where Trust Becomes Operational, Not Aspirational",
    cta: "View On-Demand Webinar"
  }
];
---

<BaseLayout
  title="File Sharing and Storage Integrations | seclore"
  description="Data-centric security for file sharing and storage systems with persistent protection, access controls, and tracking."
>
  <main id="top" class="file-storage-page">
    <Nav />

    <section class="product-hero">
      <span>Integrations</span>
      <h1>Data-Centric Security for File Sharing and Storage Systems</h1>
      <p>
        Safeguard sensitive data managed and maintained within file storage and sharing systems by
        embedding data security and compliance policies within the data itself.
      </p>
      <a class="primary-button" href="/demo/">Book a Demo</a>
    </section>

    <section class="intro-section">
      <div class="photo-card intro-photo">
        <img src="/images/integrations/dlp-casb.png" alt="Analyst managing sensitive data across storage systems" loading="lazy" />
      </div>
      <div class="intro-copy">
        <h2>Persistent protection for your sensitive data stored and managed centrally</h2>
        <p>
          Enterprises rely on on-premises or cloud-based file storage and sharing systems to
          securely store, manage, and distribute data across teams, departments, customers, and
          third parties. Both cloud-based and on-premises solutions cater to different business
          needs, offering scalability and integration with other enterprise applications.
        </p>
        <p>
          However, if security is not prioritized, centrally storing sensitive data for daily use or
          archival purposes increases the risk of data leakage, insider threats, and cyberattacks.
          To mitigate these risks, businesses must enforce strong security policies, implement
          encryption, and maintain continuous monitoring to protect their data and ensure regulatory
          compliance.
        </p>
      </div>
    </section>

    <section class="band-section">
      <h2>Secure your data within storage and sharing applications to prevent cyberattacks, exfiltration, and accidental exposure.</h2>
    </section>

    <section class="detail-section">
      <div class="detail-copy">
        <p>
          Seclore's integration with your file sharing and storage systems ensure automatic
          document protection, and apply security controls when files are placed in network folders
          or downloaded or exported from the collaboration system. Protected files remain secure and
          trackable, no matter where they go.
        </p>
        <p>
          By automatically attaching security controls to downloaded files, Seclore ensures that
          security policies are consistently enforced across and beyond your organization,
          effortlessly maintaining data governance.
        </p>
        <p>
          Gain full visibility into your file's activity with Seclore's comprehensive tracking and
          auditing features. Monitor who accesses documents and what actions were performed, and
          easily identify both authorized and unauthorized attempts to ensure complete security and
          compliance for your sensitive data.
        </p>
      </div>
      <div class="photo-card detail-photo">
        <img src="/images/integrations/file-storage/file-flow.png" alt="Secure document transfer between file storage systems" loading="lazy" />
      </div>
    </section>

    <section class="storage-section">
      <div class="storage-grid">
        {storageCards.map((card) => (
          <article class="storage-card" id={card.id}>
            {card.icon === "folder" && <div class="folder-icon" aria-hidden="true"></div>}
            <h3>{card.title}</h3>
            <p>{card.text}</p>
            <a href={card.href || "/demo/"}>Learn More <span aria-hidden="true">&rarr;</span></a>
          </article>
        ))}
      </div>
    </section>

    <section class="resources-section" id="resources">
      <div class="section-heading centered">
        <h2>Additional Resources</h2>
      </div>
      <div class="resource-grid">
        {resources.map((resource) => (
          <article class="resource-card">
            <img src={resource.image} alt="" loading="lazy" />
            <div class="resource-body">
              <span>{resource.type}</span>
              <strong>{resource.tag}</strong>
              <h3>{resource.title}</h3>
              <a href="#resources">{resource.cta} <span aria-hidden="true">&rarr;</span></a>
            </div>
          </article>
        ))}
      </div>
      <div class="resource-controls" aria-label="Resource carousel controls">
        <button type="button" aria-label="Previous resources">&larr;</button>
        <button type="button" aria-label="Next resources">&rarr;</button>
      </div>
    </section>
  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f6f6f7;
    --page-text: #29282d;
    --purple: #5b2bd7;
    --purple-dark: #4515c7;
    --line: #dedee5;
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: #ffffff;
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a { color: inherit; text-decoration: none; }
  button { font: inherit; }
  .file-storage-page h1,
  .file-storage-page h2,
  .file-storage-page h3,
  .file-storage-page p { margin: 0; }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    font-size: 1.35rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .nav-links,
  .nav-utilities { align-items: center; display: flex; }
  .nav-links { flex: 1 1 auto; gap: clamp(18px, 2.2vw, 34px); justify-content: center; min-width: 0; }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .nav-item { position: static; }
  .nav-caret { border-bottom: 2px solid currentColor; border-right: 2px solid currentColor; display: inline-block; height: 8px; transform: rotate(45deg) translateY(-2px); width: 8px; }
  .mega-menu { left: 22px; opacity: 0; pointer-events: none; position: absolute; right: clamp(20px, 4vw, 42px); top: calc(100% - 1px); transform: translateY(12px); transition: opacity 180ms ease, transform 180ms ease; }
  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .mega-inner { background: var(--dropdown-bg); border: 1px solid var(--dropdown-border); border-radius: 8px; box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2); display: grid; gap: 24px; grid-template-columns: minmax(0, 1fr) 320px; min-height: 320px; overflow: hidden; padding: 26px; }
  .mega-columns { display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  .mega-column, .mega-sublinks { display: grid; }
  .mega-column { gap: 10px; }
  .mega-title { color: var(--dropdown-title); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .mega-link, .mega-link-group { border: 1px solid transparent; border-radius: 8px; }
  .mega-link { display: grid; gap: 5px; padding: 13px; }
  .mega-link strong { color: var(--dropdown-text); }
  .mega-link small, .mega-sublinks a { color: var(--dropdown-muted); }
  .mega-link:hover, .mega-link-group:hover { background: var(--dropdown-link-hover); border-color: var(--dropdown-link-border); }
  .mega-link-group { display: grid; gap: 4px; padding: 4px; }
  .mega-sublinks { gap: 2px; padding: 0 9px 8px 22px; }
  .mega-sublinks a { font-size: 0.84rem; padding: 5px 0; }
  .mega-feature { align-content: end; background: var(--dropdown-feature-bg); border: 1px solid var(--dropdown-feature-border); border-radius: 8px; display: grid; min-height: 268px; padding: 24px; }
  .mega-feature span, .mega-feature em { color: var(--dropdown-title); }
  .mega-feature strong { color: var(--dropdown-text); font-size: 1.35rem; line-height: 1.18; margin-top: auto; }
  .nav-utilities { flex: 0 0 auto; gap: clamp(12px, 1.5vw, 20px); margin-left: clamp(12px, 2vw, 28px); }
  .utility-link, .language-button, .utility-icon, .theme-toggle { color: var(--header-muted); display: none; font-size: 0.88rem; font-weight: 750; }

  .demo-button,
  .primary-button {
    align-items: center;
    background: linear-gradient(135deg, var(--purple), var(--purple-dark));
    border: 0;
    border-radius: 7px;
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.9rem;
    font-weight: 850;
    justify-content: center;
    line-height: 1;
    min-height: 40px;
    padding: 0 18px;
    white-space: nowrap;
    width: fit-content;
  }

  .nav-toggle { background: transparent; border: 0; display: none; height: 42px; width: 42px; }
  .nav-toggle span { background: var(--header-text); display: block; height: 2px; margin: 6px 0; width: 24px; }

  .product-hero {
    align-items: center;
    background: radial-gradient(circle at 14% 84%, rgba(229, 175, 245, 0.86), transparent 36%), linear-gradient(125deg, #8736df 0%, #7d2dea 45%, #4a04dc 100%);
    color: #fff;
    display: flex;
    flex-direction: column;
    min-height: 670px;
    padding: 145px 24px 118px;
    text-align: center;
  }

  .product-hero span { font-size: 0.86rem; font-weight: 850; margin-bottom: 2rem; }
  .product-hero h1 { font-size: clamp(3rem, 7vw, 5.3rem); font-weight: 500; letter-spacing: 0; line-height: 1.04; max-width: 1120px; }
  .product-hero p { font-size: clamp(0.98rem, 1.6vw, 1.18rem); line-height: 1.55; margin: 2.2rem auto 2.1rem; max-width: 1160px; }

  .intro-section,
  .detail-section {
    display: grid;
    gap: clamp(3rem, 8vw, 8rem);
    grid-template-columns: minmax(280px, 1fr) minmax(320px, 1fr);
    margin: 0 auto;
    max-width: 1120px;
    padding: 142px 30px;
  }

  .photo-card { align-self: center; border-radius: 18px; overflow: hidden; }
  .photo-card img { display: block; height: 100%; object-fit: cover; width: 100%; }
  .intro-photo { aspect-ratio: 1.43; }
  .detail-photo { aspect-ratio: 1.48; }
  .intro-copy h2 { color: #333136; font-size: clamp(2.3rem, 4.1vw, 4rem); font-weight: 500; line-height: 1.06; }
  .intro-copy p,
  .detail-copy p { color: #1d1c24; font-size: 1.05rem; line-height: 1.68; margin-top: 2rem; }
  .detail-copy p:first-child { margin-top: 0; }

  .band-section { background: #4d27cf; color: #fff; padding: 72px 24px; text-align: center; }
  .band-section h2 { font-size: clamp(2rem, 4vw, 3.3rem); font-weight: 500; line-height: 1.1; margin: 0 auto; max-width: 1040px; }

  .storage-section { background: #f1f1f3; padding: 90px 30px 120px; }
  .storage-grid { display: grid; gap: 34px; grid-template-columns: repeat(2, minmax(0, 1fr)); margin: 0 auto; max-width: 1120px; }
  .storage-card { background: #fff; border: 1px solid var(--line); border-radius: 18px; min-height: 330px; padding: 46px 36px 40px; }
  .storage-card h3 { color: #383840; font-size: 1.55rem; font-weight: 500; margin-top: 4rem; }
  .storage-card p { color: #4b4d55; font-size: 1rem; line-height: 1.6; margin-top: 1.7rem; }
  .storage-card a { display: inline-flex; font-weight: 800; gap: 0.55rem; margin-top: 1.7rem; }
  .folder-icon { border: 6px solid #111; border-radius: 4px; height: 44px; position: relative; width: 62px; }
  .folder-icon::before { background: #fff; border: 6px solid #111; border-bottom: 0; border-radius: 4px 4px 0 0; content: ""; height: 18px; left: 7px; position: absolute; top: -20px; width: 28px; }

  .resources-section { background: #fff; padding: 95px 30px 105px; }
  .section-heading.centered { margin: 0 auto; max-width: 850px; text-align: center; }
  .section-heading h2 { color: #333136; font-size: clamp(2.3rem, 4vw, 3.6rem); font-weight: 500; }
  .resource-grid { display: grid; gap: 40px min(9vw, 230px); grid-template-columns: repeat(2, minmax(260px, 365px)); margin: 65px auto 0; max-width: 970px; }
  .resource-card { border: 1px solid var(--line); border-radius: 18px; overflow: hidden; }
  .resource-card img { aspect-ratio: 1.5; display: block; object-fit: cover; object-position: top center; width: 100%; }
  .resource-body { background: #fff; padding: 40px 38px; }
  .resource-body span, .resource-body strong { background: #f1f1f3; border-radius: 999px; color: #191826; display: inline-flex; font-size: 0.86rem; font-weight: 900; justify-content: center; line-height: 1.35; padding: 0.55rem 1rem; text-transform: uppercase; }
  .resource-body strong { display: flex; margin-top: 1.2rem; max-width: 270px; text-align: center; }
  .resource-body h3 { color: #11111b; font-size: 1.8rem; font-weight: 500; line-height: 1.12; margin-top: 2.1rem; }
  .resource-card a { color: #111118; display: inline-flex; font-weight: 800; gap: 0.5rem; margin-top: 1.6rem; }
  .resource-controls { display: flex; gap: 20px; margin: 48px auto 0; max-width: 970px; }
  .resource-controls button { background: #fff; border: 1px solid #a9a9b2; border-radius: 999px; color: #7d7d87; height: 64px; width: 64px; }

  .site-footer { background: #fff; color: #5f626b; padding: 0 30px 55px; }
  .site-footer > * { margin-left: auto; margin-right: auto; max-width: 1120px; }
  .footer-lines { border-top: 1px solid #cfcfd4; }
  .footer-lines details { border-bottom: 1px solid #cfcfd4; color: #22222b; padding: 1.35rem 0; }
  .footer-lines summary { cursor: pointer; font-size: 1.18rem; font-weight: 800; }
  .footer-lines p { color: #656873; line-height: 1.6; margin-top: 0.75rem; }
  .footer-logo { color: #5b2bd7; display: block; font-size: 2rem; font-weight: 900; letter-spacing: 1px; margin-top: 2.4rem; text-transform: uppercase; }
  .site-footer p { font-size: 1.05rem; line-height: 1.65; margin-top: 1.4rem; }
  .store-row { display: flex; flex-direction: column; gap: 10px; margin-top: 2.4rem; }
  .store-row span { align-items: center; background: #17101b; border-radius: 6px; color: #fff; display: inline-flex; font-size: 0.9rem; font-weight: 800; height: 40px; justify-content: center; width: 168px; }
  .social-row { border-top: 1px solid #d1d1d6; padding-top: 1.7rem; }
  .legal a { text-decoration: underline; }

  @media (max-width: 1280px) {
    .nav-toggle { display: block; margin-left: 12px; order: 1; }
    .site-header { flex-wrap: wrap; }
    .site-logo { order: 0; }
    .nav-links { background: var(--header-bg); border-top: 1px solid var(--header-border); display: none; flex: 1 0 100%; order: 2; padding: 10px 0 14px; }
    .nav-links.open { align-items: stretch; display: grid; }
    .nav-links > a, .nav-trigger { justify-content: space-between; min-height: 48px; width: 100%; }
    .nav-item { display: grid; }
    .mega-menu { display: none; opacity: 1; position: static; transform: none; }
    .nav-item:hover .mega-menu, .nav-item:focus-within .mega-menu { display: none; }
    .nav-item.is-open .mega-menu { display: block; }
    .mega-inner { box-shadow: none; grid-template-columns: 1fr; min-height: 0; padding: 16px; }
    .nav-utilities { align-items: stretch; display: flex; margin-left: auto; order: 0; }
  }

  @media (max-width: 900px) {
    .product-hero { min-height: 560px; padding: 105px 20px 90px; }
    .intro-section, .detail-section { gap: 3rem; grid-template-columns: 1fr; padding: 85px 20px; }
    .storage-section, .resources-section { padding: 72px 20px; }
    .storage-grid, .resource-grid { grid-template-columns: 1fr; }
    .resource-grid { margin-left: auto; margin-right: auto; max-width: 365px; }
    .storage-card { min-height: 0; padding: 36px 28px; }
    .file-storage-page .product-hero > .primary-button {
      max-width: 100%;
      width: fit-content !important;
    }
  }

  @media (max-width: 560px) {
    .product-hero h1 { font-size: 2.7rem; }
    .intro-copy h2, .section-heading h2 { font-size: 2.2rem; }
    .band-section h2 { font-size: 2rem; }
    .file-storage-page .product-hero > .primary-button {
      font-size: 0.9rem !important;
      min-height: 40px;
      padding-inline: 18px;
      white-space: normal;
    }
  }
</style>
