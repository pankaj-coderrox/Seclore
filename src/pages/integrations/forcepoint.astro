---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const solutionCards = [
  {
    title: "Content discovery for data at rest",
    text: "Forcepoint's advanced discovery engine can identify sensitive data and other critical assets across endpoints and on-premises network file servers to keep them protected.",
    icon: "user"
  },
  {
    title: "Content discovery for data in motion",
    text: "Forcepoint can identify sensitive data shared via email, and tag it for downstream actions such as applying persistent protection with Seclore.",
    icon: "search"
  },
  {
    title: "Automate classification and protection with Seclore",
    text: "When Forcepoint discovers sensitive data on endpoints, Seclore can automatically apply classification and persistent protection to ensure data security and compliance.",
    icon: "gear"
  },
  {
    title: "Manage access and monitor activity",
    text: "Track who can access sensitive data, when, and where for Seclore-protected files shared outside your enterprise network. Unauthorized attempts are also logged, analyzed, and blocked to mitigate risks in real time.",
    icon: "lock"
  }
];

const resources = [
  {
    image: "/images/integrations/dlp-casb/debate-ai.png",
    type: "Blog Post",
    tag: "AI, Company, Data Security",
    title: "The Debate About AI in the Enterprise Is Over. Here Is the Only Question That Matters.",
    cta: "View Blog Post"
  },
  {
    image: "/images/integrations/dlp-casb/ai-perimeter.png",
    type: "Blog Post",
    tag: "AI Risk, Data Security",
    title: "The Missing Link in Enterprise AI: Why Context and Behavior Are the New Security Perimeter",
    cta: "View Blog Post"
  },
  {
    image: "/images/integrations/dlp-casb/ai-readiness.png",
    type: "On-Demand Webinar",
    tag: "Compliance",
    title: "From AI Risk to AI Readiness: Where Trust Becomes Operational, Not Aspirational",
    cta: "View On-Demand Webinar"
  }
];
---

<BaseLayout
  title="Forcepoint DLP Integration | seclore"
  description="Combine Forcepoint DLP content awareness with Seclore persistent digital asset protection to discover, classify, protect, and track sensitive data."
>
  <main id="top" class="forcepoint-page">
    <Nav />

    <section class="product-hero">
      <span>Integrations</span>
      <h1>Forcepoint DLP</h1>
      <p>
        Combine the content-awareness of Forcepoint DLP with Seclore's persistent digital asset
        protection to discover, classify, protect, and track sensitive data throughout its entire
        lifecycle.
      </p>
      <div class="hero-actions">
        <a class="primary-button" href="#demo">Book a Demo</a>
        <a class="secondary-button" href="#resources">Watch Video</a>
      </div>
    </section>

    <section class="intro-section">
      <div class="empty-media" aria-hidden="true"></div>
      <div class="intro-copy">
        <h2>Persistent data protection with Seclore and Forcepoint</h2>
        <p>
          Seclore's integration with Forcepoint DLP enhances enterprise data security by combining
          Forcepoint's content-aware detection with Seclore's persistent data-centric protection.
          This ensures that sensitive information remains protected throughout its lifecycle,
          whether inside or outside the organization. By mapping Forcepoint DLP policies to
          Seclore's granular usage controls, businesses can improve data governance, reduce false
          positives, and maintain compliance.
        </p>
        <a class="primary-button small" href="#resources">Read Solution Brief</a>
      </div>
    </section>

    <section class="solutions-section">
      <div class="section-heading centered">
        <h2>Get more from your Forcepoint DLP</h2>
        <div class="partner-lockup" aria-label="Seclore and Forcepoint">
          <strong>seclore</strong>
          <span></span>
          <b>Forcepoint</b>
        </div>
      </div>
      <div class="solution-list">
        {solutionCards.map((card) => (
          <article class="solution-card">
            <div class={`line-icon ${card.icon}`} aria-hidden="true"></div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="resources-section" id="resources">
      <div class="section-heading centered">
        <h2>Additional Resources</h2>
      </div>
      <div class="resource-grid">
        {resources.map((resource) => (
          <article class="resource-card">
            <img src={resource.image} alt="" loading="lazy" />
            <div class="resource-body">
              <span>{resource.type}</span>
              <strong>{resource.tag}</strong>
              <h3>{resource.title}</h3>
              <a href="#resources">{resource.cta} <span aria-hidden="true">&rarr;</span></a>
            </div>
          </article>
        ))}
      </div>
      <div class="resource-controls" aria-label="Resource carousel controls">
        <button type="button" aria-label="Previous resources">&larr;</button>
        <button type="button" aria-label="Next resources">&rarr;</button>
      </div>
    </section>

    <section class="cta-section" id="demo">
      <h2>Ready to get started?</h2>
      <p>Contact our sales team to find out how Seclore can help with data security and compliance.</p>
      <a class="primary-button" href="#top">Book a Demo</a>
    </section>
  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f6f6f7;
    --page-text: #29282d;
    --purple: #5b2bd7;
    --purple-dark: #4515c7;
    --line: #dedee5;
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    font: inherit;
  }

  .forcepoint-page h1,
  .forcepoint-page h2,
  .forcepoint-page h3,
  .forcepoint-page p {
    margin: 0;
  }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    font-size: 1.35rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .nav-links,
  .nav-utilities {
    align-items: center;
    display: flex;
  }

  .nav-links {
    flex: 1 1 auto;
    gap: clamp(18px, 2.2vw, 34px);
    justify-content: center;
    min-width: 0;
  }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:hover .nav-trigger,
  .nav-item:focus-within .nav-trigger {
    color: var(--header-text);
  }

  .nav-item {
    position: static;
  }

  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret {
    transform: rotate(225deg) translateY(-1px);
  }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .mega-column,
  .mega-sublinks {
    display: grid;
  }

  .mega-column {
    gap: 10px;
  }

  .mega-title {
    color: var(--dropdown-title);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mega-link,
  .mega-link-group {
    border: 1px solid transparent;
    border-radius: 8px;
  }

  .mega-link {
    display: grid;
    gap: 5px;
    padding: 13px;
  }

  .mega-link strong {
    color: var(--dropdown-text);
  }

  .mega-link small,
  .mega-sublinks a {
    color: var(--dropdown-muted);
  }

  .mega-link:hover,
  .mega-link-group:hover {
    background: var(--dropdown-link-hover);
    border-color: var(--dropdown-link-border);
  }

  .mega-link-group {
    display: grid;
    gap: 4px;
    padding: 4px;
  }

  .mega-sublinks {
    gap: 2px;
    padding: 0 9px 8px 22px;
  }

  .mega-sublinks a {
    font-size: 0.84rem;
    padding: 5px 0;
  }

  .mega-feature {
    align-content: end;
    background: var(--dropdown-feature-bg);
    border: 1px solid var(--dropdown-feature-border);
    border-radius: 8px;
    display: grid;
    min-height: 268px;
    padding: 24px;
  }

  .mega-feature span,
  .mega-feature em {
    color: var(--dropdown-title);
  }

  .mega-feature strong {
    color: var(--dropdown-text);
    font-size: 1.35rem;
    line-height: 1.18;
    margin-top: auto;
  }

  .nav-utilities {
    flex: 0 0 auto;
    gap: clamp(12px, 1.5vw, 20px);
    margin-left: clamp(12px, 2vw, 28px);
  }

  .utility-link,
  .language-button,
  .utility-icon,
  .theme-toggle {
    color: var(--header-muted);
    display: none;
    font-size: 0.88rem;
    font-weight: 750;
  }

  .demo-button,
  .primary-button,
  .secondary-button {
    align-items: center;
    border: 0;
    border-radius: 7px;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.9rem;
    font-weight: 850;
    justify-content: center;
    min-height: 40px;
    padding: 0 18px;
  }

  .demo-button,
  .primary-button {
    background: linear-gradient(135deg, var(--purple), var(--purple-dark));
    color: #fff;
  }

  .secondary-button {
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.42);
    color: #fff;
  }

  .primary-button.small {
    font-size: 0.9rem;
    line-height: 1;
    min-height: 40px;
    padding: 0 18px;
    white-space: nowrap;
    width: fit-content;
  }

  .nav-toggle {
    background: transparent;
    border: 0;
    display: none;
    height: 42px;
    width: 42px;
  }

  .nav-toggle span {
    background: var(--header-text);
    display: block;
    height: 2px;
    margin: 6px 0;
    width: 24px;
  }

  .product-hero {
    align-items: center;
    background:
      radial-gradient(circle at 14% 84%, rgba(229, 175, 245, 0.86), transparent 36%),
      linear-gradient(125deg, #8736df 0%, #7d2dea 45%, #4a04dc 100%);
    color: #fff;
    display: flex;
    flex-direction: column;
    min-height: 665px;
    padding: 145px 28px 115px;
    text-align: center;
  }

  .product-hero span {
    font-size: 0.86rem;
    font-weight: 850;
    margin-bottom: 2rem;
  }

  .product-hero h1 {
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.04;
  }

  .product-hero p {
    font-size: clamp(0.98rem, 1.6vw, 1.18rem);
    line-height: 1.55;
    margin: 2.2rem auto 2.1rem;
    max-width: 1040px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: center;
  }

  .intro-section {
    display: grid;
    gap: clamp(3rem, 8vw, 8rem);
    grid-template-columns: minmax(260px, 1fr) minmax(310px, 0.76fr);
    margin: 0 auto;
    max-width: 1120px;
    padding: 142px 30px 150px;
  }

  .empty-media {
    min-height: 1px;
  }

  .intro-copy h2,
  .section-heading h2 {
    color: #333136;
    font-size: clamp(2.25rem, 4.1vw, 4rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.06;
  }

  .intro-copy p {
    color: #1d1c24;
    font-size: 1.05rem;
    line-height: 1.66;
    margin-top: 2.1rem;
  }

  .intro-copy .primary-button {
    margin-top: 2.2rem;
  }

  .solutions-section {
    background: #f1f1f3;
    padding: 80px 30px 112px;
  }

  .section-heading.centered {
    margin: 0 auto;
    max-width: 820px;
    text-align: center;
  }

  .partner-lockup {
    align-items: center;
    display: flex;
    gap: 34px;
    justify-content: center;
    margin: 55px auto 70px;
  }

  .partner-lockup strong {
    color: #ef2953;
    font-size: clamp(2rem, 4vw, 3.55rem);
    font-weight: 950;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .partner-lockup span {
    background: #7e7f87;
    height: 62px;
    width: 2px;
  }

  .partner-lockup b {
    color: #20242b;
    font-size: clamp(1.8rem, 3vw, 3rem);
    font-weight: 900;
    letter-spacing: -1px;
  }

  .partner-lockup b::first-letter {
    color: #0b3d4a;
  }

  .solution-list {
    display: grid;
    gap: 34px;
    margin: 0 auto;
    max-width: 1120px;
  }

  .solution-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 36px 34px 40px;
  }

  .solution-card h3 {
    color: #171720;
    font-size: 1.32rem;
    font-weight: 500;
    line-height: 1.28;
    margin-top: 1.6rem;
  }

  .solution-card p {
    color: #30313a;
    font-size: 0.98rem;
    line-height: 1.62;
    margin-top: 1.5rem;
  }

  .line-icon {
    height: 46px;
    position: relative;
    width: 46px;
  }

  .line-icon::before,
  .line-icon::after {
    content: "";
    position: absolute;
  }

  .line-icon.user::before {
    border: 4px solid var(--purple);
    border-radius: 50%;
    height: 16px;
    left: 13px;
    top: 2px;
    width: 16px;
  }

  .line-icon.user::after {
    border: 4px solid #ef8d29;
    border-radius: 18px 18px 5px 5px;
    height: 20px;
    left: 7px;
    top: 22px;
    width: 28px;
  }

  .line-icon.search::before {
    border: 4px solid var(--purple);
    border-radius: 50%;
    height: 22px;
    left: 8px;
    top: 5px;
    width: 22px;
  }

  .line-icon.search::after {
    background: #ef8d29;
    height: 18px;
    left: 31px;
    top: 27px;
    transform: rotate(-35deg);
    width: 4px;
  }

  .line-icon.gear::before {
    border: 4px solid var(--purple);
    border-radius: 9px;
    height: 28px;
    left: 8px;
    top: 8px;
    transform: rotate(45deg);
    width: 28px;
  }

  .line-icon.gear::after {
    border: 4px solid #ef8d29;
    border-radius: 50%;
    height: 10px;
    left: 17px;
    top: 17px;
    width: 10px;
  }

  .line-icon.lock::before {
    border: 4px solid var(--purple);
    border-radius: 4px;
    bottom: 5px;
    height: 23px;
    left: 7px;
    width: 31px;
  }

  .line-icon.lock::after {
    border: 4px solid #ef8d29;
    border-bottom: 0;
    border-radius: 16px 16px 0 0;
    height: 18px;
    left: 14px;
    top: 2px;
    width: 17px;
  }

  .resources-section {
    background: #fff;
    padding: 95px 30px 105px;
  }

  .resource-grid {
    display: grid;
    gap: 40px min(9vw, 230px);
    grid-template-columns: repeat(2, minmax(260px, 365px));
    margin: 65px auto 0;
    max-width: 970px;
  }

  .resource-card {
    border: 1px solid var(--line);
    border-radius: 18px;
    overflow: hidden;
  }

  .resource-card img {
    aspect-ratio: 1.5;
    display: block;
    object-fit: cover;
    object-position: top center;
    width: 100%;
  }

  .resource-body {
    background: #fff;
    padding: 40px 38px;
  }

  .resource-body span,
  .resource-body strong {
    background: #f1f1f3;
    border-radius: 999px;
    color: #191826;
    display: inline-flex;
    font-size: 0.86rem;
    font-weight: 900;
    justify-content: center;
    line-height: 1.35;
    padding: 0.55rem 1rem;
    text-transform: uppercase;
  }

  .resource-body strong {
    display: flex;
    margin-top: 1.2rem;
    max-width: 270px;
    text-align: center;
  }

  .resource-body h3 {
    color: #11111b;
    font-size: 1.8rem;
    font-weight: 500;
    line-height: 1.12;
    margin-top: 2.1rem;
  }

  .resource-card a {
    color: #111118;
    display: inline-flex;
    font-weight: 800;
    gap: 0.5rem;
    margin-top: 1.6rem;
  }

  .resource-controls {
    display: flex;
    gap: 20px;
    margin: 48px auto 0;
    max-width: 970px;
  }

  .resource-controls button {
    background: #fff;
    border: 1px solid #a9a9b2;
    border-radius: 999px;
    color: #7d7d87;
    height: 64px;
    width: 64px;
  }

  .cta-section {
    background: #fff;
    padding: 55px 30px 65px;
  }

  .cta-section h2,
  .cta-section p,
  .cta-section a {
    margin-left: auto;
    margin-right: auto;
    max-width: 1120px;
  }

  .cta-section h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 500;
  }

  .cta-section p {
    color: #92939b;
    font-size: 1.16rem;
    line-height: 1.55;
    margin-top: 0.8rem;
  }

  .cta-section .primary-button {
    margin-top: 2rem;
  }

  .site-footer {
    background: #fff;
    color: #5f626b;
    padding: 0 30px 55px;
  }

  .site-footer > * {
    margin-left: auto;
    margin-right: auto;
    max-width: 1120px;
  }

  .footer-lines {
    border-top: 1px solid #cfcfd4;
  }

  .footer-lines details {
    border-bottom: 1px solid #cfcfd4;
    color: #22222b;
    padding: 1.35rem 0;
  }

  .footer-lines summary {
    cursor: pointer;
    font-size: 1.18rem;
    font-weight: 800;
  }

  .footer-lines p {
    color: #656873;
    line-height: 1.6;
    margin-top: 0.75rem;
  }

  .footer-logo {
    color: #5b2bd7;
    display: block;
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: 1px;
    margin-top: 2.4rem;
    text-transform: uppercase;
  }

  .site-footer p {
    font-size: 1.05rem;
    line-height: 1.65;
    margin-top: 1.4rem;
  }

  .store-row {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 2.4rem;
  }

  .store-row span {
    align-items: center;
    background: #17101b;
    border-radius: 6px;
    color: #fff;
    display: inline-flex;
    font-size: 0.9rem;
    font-weight: 800;
    height: 40px;
    justify-content: center;
    width: 168px;
  }

  .social-row {
    border-top: 1px solid #d1d1d6;
    padding-top: 1.7rem;
  }

  .legal a {
    text-decoration: underline;
  }

  @media (max-width: 1280px) {
    .nav-toggle {
      display: block;
      margin-left: 12px;
      order: 1;
    }

    .site-header {
      flex-wrap: wrap;
    }

    .site-logo {
      order: 0;
    }

    .nav-links {
      background: var(--header-bg);
      border-top: 1px solid var(--header-border);
      display: none;
      flex: 1 0 100%;
      order: 2;
      padding: 10px 0 14px;
    }

    .nav-links.open {
      align-items: stretch;
      display: grid;
    }

    .nav-links > a,
    .nav-trigger {
      justify-content: space-between;
      min-height: 48px;
      width: 100%;
    }

    .nav-item {
      display: grid;
    }

    .mega-menu {
