---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const benefits = [
  {
    title: "Improve ROI",
    text: "Get more out of the investments you've made setting up discovery and remediation in your DLP or CASB platform.",
    icon: "bars"
  },
  {
    title: "Automate protection",
    text: "When sensitive data is discovered with your DLP or CASB, you can automatically apply classification, advanced encryption, granular access controls, and the ability to track protected assets beyond your network.",
    icon: "file"
  },
  {
    title: "Retain control",
    text: "Retain control, visibility, and the ability to revoke access to digital assets after they have been shared with third parties.",
    icon: "users"
  },
  {
    title: "Lower overhead",
    text: "Reduce your dependency on user-driven protection and admin overhead caused by policy and incident management in DLPs or CASBs.",
    icon: "clock"
  }
];

const partners = [
  {
    id: "broadcom",
    logo: "Broadcom",
    title: "Broadcom (Symantec) DLP",
    text: "Address the growing risk of cyber-attacks, insider threats, and non-compliance by seamlessly integrating Symantec DLP with Seclore.",
    href: "/integrations/broadcom/"
  },
  {
    id: "forcepoint",
    logo: "Forcepoint",
    title: "ForcePoint DLP",
    text: "Protect files inside and outside your organization, reduce false positives during discovery, and automate data protection to simplify regulatory compliance.",
    href: "/integrations/forcepoint/"
  },
  {
    id: "skyhigh",
    logo: "Skyhigh Security",
    title: "Skyhigh Security CASB",
    text: "Get unprecedented security over discovered data by applying Seclore EDRM to sensitive data instead of simply blocking or monitoring it.",
    href: "/integrations/skyhigh/"
  }
];

const resources = [
  {
    image: "/images/integrations/dlp-casb/data-catalog-dashboard.png",
    imageClass: "dashboard-resource",
    type: "Blog Post",
    tag: "AI, Company, Data Security",
    title: "The Debate About AI in the Enterprise Is Over. Here Is the Only Question That Matters.",
    cta: "View Blog Post"
  },
  {
    image: "/images/integrations/dlp-casb/ai-dlp-diagram-resource.png",
    imageClass: "diagram-resource",
    type: "Blog Post",
    tag: "AI Risk, Data Security",
    title: "The Missing Link in Enterprise AI: Why Context and Behavior Are the New Security Perimeter",
    cta: "View Blog Post"
  },
  {
    image: "/images/integrations/dlp-casb/ai-readiness.png",
    type: "On-Demand Webinar",
    tag: "Compliance",
    title: "From AI Risk to AI Readiness: Where Trust Becomes Operational, Not Aspirational",
    cta: "View On-Demand Webinar"
  }
];
---

<BaseLayout
  title="DLP and CASB Integrations | seclore"
  description="Strengthen DLP, CASB, and DSPM protection with Seclore integrations for discovery, classification, protection, tracking, and revocation."
>
  <main id="top" class="dlp-casb-page">
    <Nav />

    <section class="dlp-hero">
      <span>Integrations</span>
      <h1>Strengthen DLP, CASB, and DSPM Protection with Seclore</h1>
      <p>
        Seclore integrates with the tools you trust, automating and streamlining enterprise data
        discovery, classification, protection, tracking, and revocation.
      </p>
      <a class="primary-button" href="/demo/">Get a Demo</a>
    </section>

    <section class="split-section intro">
      <div class="photo-card intro-photo">
        <img src="/images/integrations/dlp-casb.png" alt="Security analyst reviewing sensitive data signals" loading="lazy" />
      </div>
      <div class="split-copy">
        <h2>Extending data security beyond the enterprise network</h2>
        <p>
          In today's complex digital landscape, enterprises face the increasingly difficult
          challenge of securing sensitive data across cloud and on-premise environments. While DLPs,
          CASBs, and DSPMs play a crucial role in governing data flow and preventing unauthorized
          access within an organization's network, they fall short when it comes to securing
          sensitive data that leaves the organization's perimeter.
        </p>
        <p>
          Seclore, in seamless coordination with DLPs and CASBs, offers a holistic data security
          solution that adds advanced encryption, real-time access/usage controls, tracking, and
          revocation to digital assets. Now digital assets shared and accessed outside your network
          always remain protected.
        </p>
        <a class="primary-button small" href="#resources">Download Datasheet</a>
      </div>
    </section>

    <section class="potential-section">
      <div class="section-heading centered">
        <h2>Unlocking the full potential of DLPs and CASBs with Seclore</h2>
      </div>
      <img class="flow-image" src="/images/integrations/dlp-casb/dlp-flow.png" alt="DLP and CASB signals flowing through Seclore to secured digital assets" loading="lazy" />

      <div class="benefit-grid">
        {benefits.map((benefit) => (
          <article class="benefit-card">
            <div class={`line-icon ${benefit.icon}`} aria-hidden="true"></div>
            <h3>{benefit.title}</h3>
            <p>{benefit.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="split-section strategy">
      <div class="split-copy">
        <h2>Elevate your digital asset protection strategy</h2>
        <p>
          Embrace a culture of confidence and collaboration, with confidence and complete control
          over sensitive digital assets inside or outside your organization.
        </p>
        <ul>
          <li><strong>Protect assets beyond your perimeter:</strong> Persistent security for your digital assets wherever they go.</li>
          <li><strong>Granular access controls:</strong> Control user behavior and revoke access on-demand.</li>
          <li><strong>Automated protection:</strong> Reduce human errors and dependencies with automated discovery, classification and protection.</li>
          <li><strong>Comprehensive tracking:</strong> Track how sensitive data is accessed and used to support compliance and quickly spot unusual activity.</li>
        </ul>
      </div>
      <div class="photo-card strategy-photo">
        <img src="/images/integrations/dlp-casb/strategy-meeting.png" alt="Hybrid meeting discussing digital asset protection strategy" loading="lazy" />
      </div>
    </section>

    <section class="partner-section" id="partners">
      <div class="section-heading centered">
        <h2>Seamlessly integrate with leading DLP &amp; CASB solutions</h2>
      </div>
      <div class="partner-grid">
        {partners.map((partner) => (
          <article class="partner-card" id={partner.id}>
            <strong class={`partner-logo ${partner.id}`}>{partner.logo}</strong>
            <h3>{partner.title}</h3>
            <p>{partner.text}</p>
            <a href={partner.href || "/demo/"}>Learn more <span aria-hidden="true">&rarr;</span></a>
          </article>
        ))}
      </div>
    </section>

    <section class="resources-section" id="resources">
      <div class="section-heading centered">
        <h2>Additional Resources</h2>
      </div>
      <div class="resource-grid">
        {resources.map((resource) => (
          <article class="resource-card">
            <img class={resource.imageClass || ""} src={resource.image} alt="" loading="lazy" />
            <div class="resource-body">
              <span>{resource.type}</span>
              <strong>{resource.tag}</strong>
              <h3>{resource.title}</h3>
              <a href="#resources">{resource.cta} <span aria-hidden="true">&rarr;</span></a>
            </div>
          </article>
        ))}
      </div>
      <div class="resource-controls" aria-label="Resource carousel controls">
        <button type="button" aria-label="Previous resources">&larr;</button>
        <button type="button" aria-label="Next resources">&rarr;</button>
      </div>
    </section>
  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f6f6f7;
    --page-text: #29282d;
    --page-muted: #686b73;
    --purple: #5b2bd7;
    --purple-dark: #4515c7;
    --line: #dedee5;
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #5b2bd7;
    --demo-button-text: #ffffff;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  .dlp-casb-page {
    background: var(--page-bg);
    min-height: 100vh;
    overflow-x: hidden;
  }

  .dlp-casb-page h1,
  .dlp-casb-page h2,
  .dlp-casb-page h3,
  .dlp-casb-page p {
    margin: 0;
  }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    font-size: 1.35rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .nav-links,
  .nav-utilities {
    align-items: center;
    display: flex;
  }

  .nav-links {
    flex: 1 1 auto;
    gap: clamp(18px, 2.2vw, 34px);
    justify-content: center;
    min-width: 0;
  }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:hover .nav-trigger,
  .nav-item:focus-within .nav-trigger {
    color: var(--header-text);
  }

  .nav-item {
    position: static;
  }

  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret {
    transform: rotate(225deg) translateY(-1px);
  }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .mega-column,
  .mega-sublinks {
    display: grid;
  }

  .mega-column {
    gap: 10px;
  }

  .mega-title {
    color: var(--dropdown-title);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mega-link,
  .mega-link-group {
    border: 1px solid transparent;
    border-radius: 8px;
  }

  .mega-link {
    display: grid;
    gap: 5px;
    padding: 13px;
  }

  .mega-link strong {
    color: var(--dropdown-text);
  }

  .mega-link small,
  .mega-sublinks a {
    color: var(--dropdown-muted);
  }

  .mega-link:hover,
  .mega-link-group:hover {
    background: var(--dropdown-link-hover);
    border-color: var(--dropdown-link-border);
  }

  .mega-link-group {
    display: grid;
    gap: 4px;
    padding: 4px;
  }

  .mega-sublinks {
    gap: 2px;
    padding: 0 9px 8px 22px;
  }

  .mega-sublinks a {
    font-size: 0.84rem;
    padding: 5px 0;
  }

  .mega-feature {
    align-content: end;
    background: var(--dropdown-feature-bg);
    border: 1px solid var(--dropdown-feature-border);
    border-radius: 8px;
    display: grid;
    min-height: 268px;
    padding: 24px;
  }

  .mega-feature span,
  .mega-feature em {
    color: var(--dropdown-title);
  }

  .mega-feature strong {
    color: var(--dropdown-text);
    font-size: 1.35rem;
    line-height: 1.18;
    margin-top: auto;
  }

  .nav-utilities {
    flex: 0 0 auto;
    gap: clamp(12px, 1.5vw, 20px);
    margin-left: clamp(12px, 2vw, 28px);
  }

  .utility-link,
  .language-button,
  .utility-icon,
  .theme-toggle {
    color: var(--header-muted);
    display: none;
    font-size: 0.88rem;
    font-weight: 750;
  }

  .demo-button {
    align-items: center;
    background: var(--demo-button-bg);
    border: 0;
    border-radius: 7px;
    color: var(--demo-button-text);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.94rem;
    font-weight: 700;
    justify-content: center;
    line-height: 1.15;
    min-height: 42px;
    padding: 0 22px;
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-toggle {
    background: transparent;
    border: 0;
    display: none;
    height: 42px;
    width: 42px;
  }

  .nav-toggle span {
    background: var(--header-text);
    display: block;
    height: 2px;
    margin: 6px 0;
    width: 24px;
  }

  .primary-button {
    align-items: center;
    background: var(--purple);
    border: 0;
    border-radius: 7px;
    color: #fff;
    display: inline-flex;
    font-size: 0.94rem;
    font-weight: 700;
    justify-content: center;
    line-height: 1.15;
    min-height: 42px;
    padding: 0 22px;
    text-decoration: none;
    white-space: nowrap;
  }

  .dlp-casb-page .dlp-hero > .primary-button,
  .dlp-casb-page .split-copy > .primary-button {
    border-radius: 7px !important;
    min-height: 42px !important;
    padding: 0 22px !important;
    width: auto !important;
  }

  .primary-button.small {
    font-size: 0.9rem;
    min-height: 40px;
    padding: 0 18px;
  }

  .dlp-hero {
    align-items: center;
    background:
      radial-gradient(circle at 18% 82%, rgba(229, 175, 245, 0.86), transparent 36%),
      linear-gradient(125deg, #8736df 0%, #7d2dea 45%, #4a04dc 100%);
    color: #fff;
    display: flex;
    flex-direction: column;
    min-height: 750px;
    padding: 165px 28px 140px;
    text-align: center;
  }

  .dlp-hero span {
    font-size: 0.85rem;
    font-weight: 800;
    margin-bottom: 2rem;
  }

  .dlp-hero h1 {
    font-size: clamp(2.6rem, 8vw, 5.9rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 0.98;
    max-width: 1160px;
  }

  .dlp-hero p {
    color: #ffffff;
    font-size: clamp(1rem, 2vw, 1.32rem);
    line-height: 1.55;
    margin: 2.7rem auto 2.3rem;
    max-width: 1080px;
  }

  .split-section {
    display: grid;
    gap: clamp(3rem, 8vw, 9rem);
    grid-template-columns: minmax(260px, 0.85fr) minmax(320px, 1.35fr);
    margin: 0 auto;
    max-width: 1120px;
    padding: 145px 30px;
  }

  .split-section.strategy {
    align-items: center;
    grid-template-columns: minmax(320px, 0.92fr) minmax(340px, 1.08fr);
  }

  @media (min-width: 901px) {
    .dlp-casb-page .split-section.intro {
      align-items: start;
      gap: clamp(3rem, 5vw, 5.5rem);
      grid-template-columns: minmax(340px, 0.96fr) minmax(0, 1.04fr) !important;
      max-width: 1180px;
      padding-bottom: 110px;
      padding-top: 110px;
    }

    .dlp-casb-page .intro-photo {
      justify-self: start;
      margin-top: 0.5rem;
      max-width: 560px;
      width: 100%;
    }

    .dlp-casb-page .split-section.strategy {
      align-items: start;
      gap: clamp(3rem, 5vw, 5.5rem);
      grid-template-columns: minmax(0, 0.96fr) minmax(340px, 1.04fr) !important;
      max-width: 1180px;
      padding-bottom: 110px;
      padding-top: 110px;
    }

    .dlp-casb-page .strategy-photo {
      justify-self: end;
      margin-top: 0.5rem;
      max-width: 560px;
      width: 100%;
    }
  }

  .photo-card {
    border-radius: 18px;
    overflow: hidden;
  }

  .photo-card img {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .intro-photo {
    align-self: start;
    aspect-ratio: 1.45;
    margin-top: 2rem;
  }

  .strategy-photo {
    aspect-ratio: 1.52;
  }

  .split-copy h2,
  .section-heading h2 {
    color: #333136;
    font-size: clamp(2.2rem, 4.2vw, 4.1rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.05;
  }

  .split-copy p {
    color: #191921;
    font-size: 1.05rem;
    line-height: 1.72;
    margin-top: 2rem;
  }

  .split-copy p + p {
    margin-top: 2rem;
  }

  .split-copy .primary-button {
    margin-top: 2.3rem;
  }

  .split-copy ul {
    color: #292936;
    font-size: 1.02rem;
    line-height: 1.55;
    margin: 2.3rem 0 0;
    padding-left: 1.35rem;
  }

  .split-copy li + li {
    margin-top: 0.55rem;
  }

  .potential-section,
  .partner-section {
    background: #f1f1f3;
    padding: 85px 30px 115px;
  }

  .section-heading.centered {
    margin: 0 auto;
    max-width: 850px;
    text-align: center;
  }

  .flow-image {
    display: block;
    margin: 55px auto 65px;
    max-width: 690px;
    width: min(90vw, 690px);
  }

  .benefit-grid {
    display: grid;
    gap: 34px;
    margin: 0 auto;
    max-width: 1120px;
  }

  .benefit-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 42px 30px;
  }

  .benefit-card h3 {
    color: #12121b;
    font-size: 1.45rem;
    font-weight: 500;
    margin-top: 1.7rem;
  }

  .benefit-card p {
    color: #161620;
    font-size: 1rem;
    line-height: 1.6;
    margin-top: 1.35rem;
  }

  .line-icon {
    height: 42px;
    position: relative;
    width: 42px;
  }

  .line-icon::before,
  .line-icon::after {
    content: "";
    position: absolute;
  }

  .line-icon.bars::before {
    border-bottom: 5px solid #5b2bd7;
    border-left: 5px solid #5b2bd7;
    bottom: 6px;
    height: 24px;
    left: 5px;
    width: 27px;
  }

  .line-icon.bars::after {
    background: linear-gradient(90deg, #35a7ff 0 6px, transparent 6px 10px, #f28c28 10px 16px, transparent 16px 20px, #8b54e9 20px 26px);
    bottom: 10px;
    height: 30px;
    left: 11px;
    width: 26px;
  }

  .line-icon.file::before {
    border: 4px solid #5b2bd7;
    border-radius: 3px;
    height: 31px;
    left: 7px;
    top: 2px;
    width: 24px;
  }

  .line-icon.file::after {
    border: 3px solid #f08a24;
    border-radius: 4px;
    bottom: 3px;
    height: 12px;
    left: 14px;
    width: 18px;
  }

  .line-icon.users::before {
    border: 4px solid #5b2bd7;
    border-radius: 50%;
    height: 14px;
    left: 12px;
    top: 1px;
    width: 14px;
  }

  .line-icon.users::after {
    border: 4px solid #f08a24;
    border-radius: 20px 20px 6px 6px;
    height: 19px;
    left: 6px;
    top: 18px;
    width: 26px;
  }

  .line-icon.clock::before {
    border: 4px solid #5b2bd7;
    border-radius: 50%;
    height: 32px;
    left: 3px;
    top: 3px;
    width: 32px;
  }

  .line-icon.clock::after {
    border-right: 4px solid #f08a24;
    border-top: 4px solid #f08a24;
    height: 13px;
    left: 20px;
    top: 10px;
    transform: rotate(8deg);
    width: 12px;
  }

  .partner-grid {
    display: grid;
    gap: 28px;
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    margin: 60px auto 0;
    max-width: 1180px;
  }

  .partner-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 54px 34px 38px;
  }

  .partner-logo {
    color: #20242b;
    display: block;
    font-size: clamp(1.65rem, 2vw, 2.1rem);
    font-weight: 900;
    line-height: 1;
    min-height: 58px;
  }

  .partner-logo.broadcom::before {
    background: #df0038;
    border-radius: 50%;
    color: #fff;
    content: "~";
    display: inline-flex;
    font-size: 1.15rem;
    height: 28px;
    justify-content: center;
