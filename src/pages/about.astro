---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const learnCards = [
  {
    id: "careers",
    title: "Careers",
    text: "Explore job opportunities",
    href: "/about/careers/",
    tone: "pink",
    icon: "M12 3l7 4v7c0 4.4-3 7.8-7 8.8C8 21.8 5 18.4 5 14V7l7-4Zm-2 8h4m-2-2v4"
  },
  {
    id: "leadership",
    title: "Leadership",
    text: "Meet the leadership team",
    href: "/about/leadership/",
    tone: "orange",
    icon: "M8 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm8 0a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM4 20a4 4 0 0 1 8 0m0 0a4 4 0 0 1 8 0"
  },
  {
    id: "news",
    title: "News",
    text: "Latest news about Seclore",
    href: "/about/newsroom/",
    tone: "plum",
    icon: "M6 5h12v14H6zM9 9h6M9 13h6M9 17h3"
  },
  {
    id: "contact",
    title: "Contact Us",
    text: "Get in touch with us",
    href: "/about/contact-us/",
    tone: "coral",
    icon: "M5 8.5 12 13l7-4.5M5 6h14v12H5z"
  }
];

---

<BaseLayout
  title="About Seclore | Company Overview and Story"
  description="Learn about Seclore's story, journey, people, and mission to protect the world's sensitive data."
>
  <main id="top" class="about-page">
    <Nav />

    <section class="about-hero">
      <span>About Seclore</span>
      <h1>Protecting the World's Data</h1>
      <p>
        Seclore's mission is to protect sensitive data, giving organizations complete control over
        critical information with innovative solutions.
      </p>
      <a class="primary-button" href="#demo">Book a Demo</a>
    </section>

    <section class="story-section">
      <div class="story-copy">
        <h2>Our story</h2>
        <p>
          At Seclore, we believe that cybersecurity should revolve around what matters most: your
          data. Traditional security perimeters are no longer enough in today's hyper-connected
          world. That's why we take a data-centric approach, giving organizations complete control
          over their sensitive information wherever it travels.
        </p>
      </div>
      <img
        src="https://www.seclore.com/wp-content/uploads/2.png"
        alt="Seclore team members gathered in a circle"
        loading="lazy"
      />
    </section>

    <section class="journey-section">
      <img
        src="https://www.seclore.com/wp-content/uploads/seclore-timeline_v2.png"
        alt="Seclore company journey timeline"
        loading="lazy"
      />
      <div class="journey-copy">
        <h2>The Seclore journey</h2>
        <p>
          Seclore was founded on the principle that security should go beyond access controls and
          actively protect the data itself. With our cutting-edge technology, enterprises can
          safeguard their most valuable assets while achieving seamless digital transformation and
          maintaining compliance with the highest security standards.
        </p>
        <p>
          We are committed to exceptional customer service, continuously innovating to help
          organizations mitigate risks, prevent data breaches, and maintain complete visibility and
          control over their information. With Seclore, businesses can confidently collaborate,
          share, and innovate without ever compromising security.
        </p>
      </div>
    </section>

    <section class="people-section">
      <div>
        <h2>Our people</h2>
        <p>
          We consider the people within and surrounding Seclore to be our biggest asset. Seclore's
          extended team is made up of the perfect mix of the right attitude, skills, work ethic, and
          grit. We venture where no one has gone before!
        </p>
        <p>
          Seclore's team represents diversity of thought, culture and backgrounds. We revel in this
          diversity.
        </p>
      </div>
    </section>

    <section class="learn-section">
      <div class="learn-heading">
        <h2>Learn more about Seclore</h2>
        <a class="secondary-button" href="/about/why-seclore/">Learn More</a>
      </div>
      <div class="learn-grid">
        {learnCards.map((card) => (
          <article id={card.id} class="learn-card">
            <span class={`learn-icon ${card.tone}`} aria-hidden="true">
              <svg viewBox="0 0 24 24" role="img">
                <path d={card.icon}></path>
              </svg>
            </span>
            <h3>{card.title}</h3>
            <a href={card.href}>{card.text}<span aria-hidden="true">-></span></a>
          </article>
        ))}
      </div>
    </section>

    <section class="ready-section" id="demo">
      <h2>Ready to get started?</h2>
      <p>Contact our sales team to find out how Seclore can help with data security and compliance.</p>
      <a class="primary-button" href="#top">Book a Demo</a>
    </section>
  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #ffffff;
    --page-soft: #f1f2f4;
    --page-text: #09090b;
    --page-muted: #4e515a;
    --purple: #5b2bd7;
    --purple-dark: #4a1fc1;
    --pink: #df1f54;
    --orange: #f28b00;
    --plum: #92234d;
    --coral: #fb6422;
    --line: rgba(23, 24, 31, 0.14);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #5b2bd7;
    --demo-button-text: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    font: inherit;
  }

  .about-page .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .about-page .site-logo {
    color: var(--purple);
    font-size: 1.35rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .about-page .nav-links,
  .about-page .nav-utilities {
    align-items: center;
    display: flex;
  }

  .about-page .nav-links {
    flex: 1 1 auto;
    gap: clamp(18px, 2.2vw, 34px);
    justify-content: center;
    min-width: 0;
  }

  .about-page .nav-links > a,
  .about-page .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .about-page .nav-links > a:hover,
  .about-page .nav-trigger:hover,
  .about-page .nav-item:hover .nav-trigger,
  .about-page .nav-item:focus-within .nav-trigger {
    color: var(--header-text);
  }

  .about-page .nav-item {
    position: static;
  }

  .about-page .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .about-page .nav-item:hover .nav-caret,
  .about-page .nav-item:focus-within .nav-caret,
  .about-page .nav-item.is-open .nav-caret {
    transform: rotate(225deg) translateY(-1px);
  }

  .about-page .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .about-page .nav-item:hover .mega-menu,
  .about-page .nav-item:focus-within .mega-menu,
  .about-page .nav-item.is-open .mega-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .about-page .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .about-page .mega-columns {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .about-page .mega-column,
  .about-page .mega-sublinks {
    display: grid;
  }

  .about-page .mega-column {
    gap: 10px;
  }

  .about-page .mega-title {
    color: var(--dropdown-title);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .about-page .mega-link,
  .about-page .mega-link-group {
    border: 1px solid transparent;
    border-radius: 8px;
  }

  .about-page .mega-link {
    display: grid;
    gap: 5px;
    padding: 13px;
  }

  .about-page .mega-link strong {
    color: var(--dropdown-text);
  }

  .about-page .mega-link small,
  .about-page .mega-sublinks a {
    color: var(--dropdown-muted);
  }

  .about-page .mega-link:hover,
  .about-page .mega-link-group:hover {
    background: var(--dropdown-link-hover);
    border-color: var(--dropdown-link-border);
  }

  .about-page .mega-link-group {
    display: grid;
    gap: 4px;
    padding: 4px;
  }

  .about-page .mega-sublinks {
    gap: 2px;
    padding: 0 9px 8px 22px;
  }

  .about-page .mega-sublinks a {
    font-size: 0.84rem;
    padding: 5px 0;
  }

  .about-page .mega-feature {
    align-content: end;
    background: var(--dropdown-feature-bg);
    border: 1px solid var(--dropdown-feature-border);
    border-radius: 8px;
    display: grid;
    min-height: 268px;
    padding: 24px;
  }

  .about-page .mega-feature span,
  .about-page .mega-feature em {
    color: var(--dropdown-title);
  }

  .about-page .mega-feature strong {
    color: var(--dropdown-text);
    font-size: 1.35rem;
    line-height: 1.18;
    margin-top: auto;
  }

  .about-page .nav-utilities {
    flex: 0 0 auto;
    gap: clamp(12px, 1.5vw, 20px);
    margin-left: clamp(12px, 2vw, 28px);
  }

  .about-page .utility-link,
  .about-page .language-button,
  .about-page .utility-icon,
  .about-page .theme-toggle {
    display: none;
  }

  .about-page .demo-button,
  .primary-button,
  .secondary-button {
    align-items: center;
    border: 0;
    border-radius: 7px;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.86rem;
    font-weight: 850;
    justify-content: center;
    min-height: 40px;
    padding: 0 18px;
  }

  .about-page .demo-button,
  .primary-button {
    background: var(--purple);
    color: #ffffff;
  }

  .secondary-button {
    background: var(--pink);
    color: #ffffff;
  }

  .about-page .nav-toggle {
    background: transparent;
    border: 0;
    display: none;
    height: 42px;
    width: 42px;
  }

  .about-page .nav-toggle span {
    background: var(--header-text);
    display: block;
    height: 2px;
    margin: 6px 0;
    width: 24px;
  }

  .about-page h1,
  .about-page h2,
  .about-page h3,
  .about-page p {
    margin-top: 0;
  }

  .about-page h1,
  .about-page h2,
  .about-page h3 {
    color: var(--page-text);
    font-weight: 430;
    letter-spacing: 0;
  }

  .about-page h1 {
    color: #ffffff;
    font-size: clamp(3.1rem, 7vw, 6.25rem);
    line-height: 1;
    margin-bottom: 28px;
  }

  .about-page h2 {
    font-size: clamp(2.6rem, 5.2vw, 4.65rem);
    line-height: 1.02;
    margin-bottom: 26px;
  }

  .about-page h3 {
    font-size: 1.35rem;
    line-height: 1.2;
    margin-bottom: 24px;
  }

  .about-page p {
    color: var(--page-muted);
    font-size: 1rem;
    line-height: 1.55;
  }

  .about-hero {
    align-items: center;
    background:
      radial-gradient(circle at 15% 72%, rgba(255, 255, 255, 0.35), transparent 30%),
      linear-gradient(135deg, #c882e8 0%, #8925f5 44%, #5f0de8 100%);
    color: #ffffff;
    display: grid;
    min-height: 590px;
    padding: 104px clamp(18px, 3vw, 42px) 98px;
    place-items: center;
    text-align: center;
  }

  .about-hero span {
    display: block;
    font-size: 1rem;
    font-weight: 900;
    margin-bottom: 34px;
  }

  .about-hero p {
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    margin-inline: auto;
    max-width: 850px;
  }

  .about-hero .primary-button {
    margin-top: 22px;
  }

  .story-section,
  .journey-section,
  .people-section {
    display: grid;
    gap: clamp(30px, 5vw, 70px);
    padding: clamp(58px, 7vw, 88px) clamp(18px, 3vw, 42px);
  }

  .story-section {
    align-items: center;
    background: var(--page-soft);
    grid-template-columns: minmax(0, 0.92fr) minmax(320px, 1.08fr);
  }

  .story-copy,
  .people-section div {
    max-width: 620px;
  }

  .story-section img,
  .journey-section img,
  .people-section img {
    border-radius: 8px;
    display: block;
    height: auto;
    object-fit: cover;
    width: 100%;
  }

  .story-section img {
    aspect-ratio: 16 / 9;
  }

  .journey-section {
    align-items: start;
    background: #ffffff;
    grid-template-columns: minmax(0, 1.08fr) minmax(300px, 0.92fr);
  }

  .journey-section img {
    max-height: 760px;
    object-fit: contain;
  }

  .journey-copy {
    max-width: 560px;
  }

  .journey-copy p + p,
  .people-section p + p {
    margin-top: 34px;
  }

  .people-section {
    align-items: center;
    background: #ffffff;
    grid-template-columns: minmax(300px, 0.88fr) minmax(0, 1.12fr);
    padding-top: 24px;
  }

  .people-section img {
    aspect-ratio: 16 / 9;
  }

  .learn-section {
    background: var(--page-soft);
    padding: clamp(58px, 7vw, 90px) clamp(18px, 3vw, 42px);
  }

  .learn-heading {
    margin: 0 auto 48px;
    max-width: 980px;
    text-align: center;
  }

  .learn-heading h2 {
    margin-bottom: 24px;
  }

  .learn-grid {
    display: grid;
    gap: clamp(24px, 3vw, 44px);
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .learn-card {
    background: #ffffff;
    border: 1px solid rgba(18, 19, 28, 0.08);
    border-radius: 8px;
    min-height: 175px;
    padding: 28px;
  }

  .learn-card:nth-child(4) {
    grid-column: 1 / 2;
  }

  .learn-icon {
    align-items: center;
    border-radius: 8px;
    color: #ffffff;
    display: inline-flex;
    height: 44px;
    justify-content: center;
    margin-bottom: 28px;
    width: 44px;
  }

  .learn-icon svg {
    fill: none;
    height: 24px;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
    width: 24px;
  }

  .learn-icon.pink {
    background: var(--pink);
  }

  .learn-icon.orange {
    background: var(--orange);
  }

  .learn-icon.plum {
    background: var(--plum);
  }

  .learn-icon.coral {
    background: var(--coral);
  }

  .learn-card a {
    align-items: center;
    color: #1f2028;
    display: inline-flex;
    font-size: 0.9rem;
    font-weight: 850;
    gap: 10px;
  }

  .ready-section,
  .about-footer {
    background: #ffffff;
    padding-inline: clamp(18px, 3vw, 42px);
  }

  .ready-section {
    border-bottom: 1px solid var(--line);
    padding-bottom: 44px;
    padding-top: 42px;
  }

  .ready-section h2 {
    font-size: clamp(2rem, 3vw, 3rem);
    margin-bottom: 10px;
  }

  .ready-section .primary-button {
    margin-top: 24px;
    min-width: 170px;
  }

  .about-footer {
    padding-bottom: 42px;
  }

  .footer-lines {
    border-block: 1px solid var(--line);
    margin-bottom: 36px;
  }

  .footer-lines details {
    border-bottom: 1px solid var(--line);
    padding: 18px 0;
  }

  .footer-lines details:last-child {
    border-bottom: 0;
  }

  .footer-lines summary {
    cursor: pointer;
    font-size: 1.15rem;
    font-weight: 850;
  }

  .footer-logo {
    color: var(--purple);
    display: block;
    font-size: 1.45rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-bottom: 24px;
    text-transform: uppercase;
  }

  .about-footer p {
    font-size: 0.92rem;
  }

  .store-row {
    display: grid;
    gap: 9px;
    margin: 30px 0;
    max-width: 180px;
  }

  .store-row span {
    background: #19121f;
    border-radius: 5px;
    color: #ffffff;
    font-size: 0.82rem;
    font-weight: 850;
    padding: 10px 14px;
  }

  .social-row {
    border-top: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    padding-top: 26px;
  }

  .social-row a {
    color: #303038;
    font-weight: 900;
  }

  .legal {
    font-size: 0.9rem;
    margin-top: 24px;
  }

  .legal a {
    text-decoration: underline;
  }

  @media (max-width: 1180px) {
    .about-page .site-header {
      flex-wrap: wrap;
    }

    .about-page .site-logo {
      order: 0;
    }

    .about-page .nav-toggle {
      display: block;
      margin-left: auto;
      order: 1;
    }

    .about-page .nav-links {
      background: var(--header-bg);
      border-top: 1px solid var(--header-border);
      display: none;
      flex: 1 0 100%;
      order: 2;
      padding: 10px 0 14px;
    }

    .about-page .nav-links.open {
      align-items: stretch;
      display: grid;
    }

    .about-page .nav-links > a,
    .about-page .nav-trigger {
      justify-content: space-between;
      min-height: 48px;
      width: 100%;
    }

    .about-page .nav-item {
      display: grid;
    }

    .about-page .mega-menu {
      display: none;
      opacity: 1;
      position: static;
      transform: none;
    }

    .about-page .nav-item:hover .mega-menu,
    .about-page .nav-item:focus-within .mega-menu {
      display: none;
    }

    .about-page .nav-item.is-open .mega-menu {
      display: block;
    }

    .about-page .mega-inner {
      box-shadow: none;
      grid-template-columns: 1fr;
      min-height: 0;
      padding: 16px;
    }

    .about-page .nav-utilities {
      align-items: stretch;
      display: flex;
      margin-left: auto;
      order: 0;
    }
  }

  @media (max-width: 920px) {
    .story-section,
    .journey-section,
    .people-section {
      grid-template-columns: 1fr;
    }

    .journey-section img {
      order: 2;
    }

    .learn-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .learn-card:nth-child(4) {
      grid-column: auto;
    }
  }

  @media (max-width: 620px) {
    .about-hero {
      min-height: 520px;
      padding-top: 76px;
    }

    .about-page h1 {
      font-size: 3.25rem;
    }

    .about-page h2 {
      font-size: 2.65rem;
    }

    .learn-grid {
      grid-template-columns: 1fr;
    }

    .story-section,
    .journey-section,
    .people-section,
    .learn-section,
    .ready-section,
    .about-footer {
      padding-inline: 16px;
    }
  }
</style>
