---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const insightCards = [
  ["Discover", "Find sensitive data, AI activity, and risky access patterns across enterprise systems."],
  ["Context", "Understand business value, sensitivity, location, user behavior, and intent."],
  ["Enforce", "Apply protection, classification, and access controls with the right level of friction."],
  ["Prove", "Maintain evidence, audit trails, and reporting for security and compliance teams."]
];

---

<BaseLayout
  title="Data Intelligence Framework | seclore"
  description="Explore Seclore's data intelligence framework for discovering, contextualizing, enforcing, and proving data security controls."
>
  <main id="top" class="framework-page">
    <Nav />

    <section class="framework-hero">
      <div class="framework-copy">
        <span>Data Security Intelligence</span>
        <h1>Data Security Intelligence Framework</h1>
        <p>
          Turn protected file activity and classification telemetry into clear, visual insights so
          security, compliance, and business teams can see how sensitive data moves.
        </p>
        <a
          href="/resources/"
          class="framework-button"
          style="background:#5630d6;border-color:#5630d6;color:#ffffff;"
        >
          Explore Resources
        </a>
      </div>

      <figure class="framework-visual" aria-label="Data security intelligence dashboard preview">
        <img
          src="/images/framework/data-security-framework-monitor.png"
          alt="Monitor showing Seclore data security intelligence dashboard bars"
          loading="eager"
          decoding="async"
          style="display:block;height:auto;object-fit:contain;width:100%;"
        />
      </figure>
    </section>

    <section class="framework-grid" aria-label="Framework steps">
      {insightCards.map(([title, text], index) => (
        <article>
          <span class="step-number">{String(index + 1).padStart(2, "0")}</span>
          <h2>{title}</h2>
          <p>{text}</p>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .framework-page {
    background: #ffffff;
    color: #101828;
    min-height: 100vh;
  }

  .framework-hero {
    align-items: center;
    background: #ffffff;
    display: grid;
    gap: clamp(48px, 5.8vw, 84px);
    grid-template-columns: minmax(0, 0.92fr) minmax(360px, 1.08fr);
    margin: 0 auto;
    max-width: 1190px;
    padding: 68px 24px 92px;
  }

  .framework-hero span {
    color: #5630d6;
    display: block;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .framework-hero h1 {
    font-size: clamp(3.25rem, 5.7vw, 5.75rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1;
    margin: 0 0 26px;
    max-width: 720px;
  }

  .framework-hero p {
    color: #3b3b44;
    font-size: 1.2rem;
    line-height: 1.56;
    margin: 0;
    max-width: 600px;
  }

  .framework-button {
    align-items: center;
    background: #5630d6;
    border: 1px solid #5630d6;
    border-radius: 7px;
    color: #ffffff;
    display: inline-flex;
    font-weight: 800;
    justify-content: center;
    margin-top: 24px;
    min-height: 48px;
    padding: 0 22px;
    text-decoration: none;
  }

  .framework-button:hover {
    background: #4420bd;
    border-color: #4420bd;
    color: #ffffff;
  }

  .framework-visual {
    justify-self: end;
    margin: 0;
    max-width: 620px;
    width: 100%;
  }

  .framework-visual img {
    display: block;
    height: auto;
    margin: 0;
    object-fit: contain;
    transform: translateX(16px);
    width: 100%;
  }

  .framework-grid {
    display: grid;
    gap: 24px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin: 0 auto;
    max-width: 1190px;
    padding: 0 24px 96px;
  }

  .framework-grid article {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    min-height: 214px;
    padding: 28px;
  }

  .step-number {
    color: #5630d6;
    display: block;
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    margin-bottom: 24px;
  }

  .framework-grid h2 {
    font-size: 1.28rem;
    font-weight: 650;
    line-height: 1.16;
    margin: 0 0 14px;
  }

  .framework-grid p {
    color: #5b6472;
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 900px) {
    .framework-hero {
      grid-template-columns: 1fr;
      padding: 56px 20px 72px;
    }

    .framework-hero h1 {
      font-size: 40px;
      font-weight: 400;
      line-height: 1.1;
      max-width: 340px;
    }

    .framework-hero p {
      font-size: 18px;
      line-height: 1.5;
      max-width: 330px;
    }

    .framework-button {
      min-height: 42px;
    }

    .framework-visual {
      justify-self: stretch;
      max-width: none;
    }

    .framework-visual img {
      transform: none;
    }

    .framework-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      padding: 0 20px 72px;
    }
  }

  @media (max-width: 560px) {
    .framework-hero {
      gap: 42px;
      padding-top: 56px;
    }

    .framework-hero span {
      font-size: 0.86rem;
      line-height: 1.35;
      margin-bottom: 26px;
      max-width: 320px;
    }

    .framework-visual {
      margin-left: -14px;
      margin-top: -8px;
      width: calc(100% + 28px);
    }

    .framework-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
