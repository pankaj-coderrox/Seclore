---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const insightCards = [
  ["Discover", "Find sensitive data, AI activity, and risky access patterns across enterprise systems."],
  ["Context", "Understand business value, sensitivity, location, user behavior, and intent."],
  ["Enforce", "Apply protection, classification, and access controls with the right level of friction."],
  ["Prove", "Maintain evidence, audit trails, and reporting for security and compliance teams."]
];
---

<BaseLayout
  title="Data Intelligence Framework | seclore"
  description="Explore Seclore's data intelligence framework for discovering, contextualizing, enforcing, and proving data security controls."
>
  <main id="top" class="framework-page">
    <Nav />

    <section class="framework-hero">
      <span>Insights</span>
      <h1>Data Intelligence Framework</h1>
      <p>
        Bring discovery, context, enforcement, and proof together so sensitive data can be trusted
        and controlled wherever people and AI work.
      </p>
      <a href="/resources/" class="framework-button">Explore Resources</a>
    </section>

    <section class="framework-grid" aria-label="Framework steps">
      {insightCards.map(([title, text]) => (
        <article>
          <h2>{title}</h2>
          <p>{text}</p>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .framework-page {
    background: #f8f8fb;
    color: #111827;
    min-height: 100vh;
  }

  .framework-hero {
    background: #ffffff;
    padding: clamp(72px, 9vw, 128px) clamp(24px, 6vw, 84px);
  }

  .framework-hero span {
    color: #5630d6;
    display: block;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin-bottom: 18px;
    text-transform: uppercase;
  }

  .framework-hero h1 {
    font-size: clamp(2.55rem, 7vw, 5.6rem);
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1;
    margin: 0 0 26px;
    max-width: 880px;
  }

  .framework-hero p {
    color: #374151;
    font-size: clamp(1.05rem, 1.5vw, 1.32rem);
    line-height: 1.55;
    max-width: 720px;
  }

  .framework-button {
    align-items: center;
    border: 1px solid #5630d6;
    border-radius: 7px;
    color: #5630d6;
    display: inline-flex;
    font-weight: 800;
    justify-content: center;
    margin-top: 24px;
    min-height: 48px;
    padding: 0 22px;
    text-decoration: none;
  }

  .framework-grid {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    padding: clamp(48px, 6vw, 78px) clamp(24px, 6vw, 84px);
  }

  .framework-grid article {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    min-height: 210px;
    padding: 28px;
  }

  .framework-grid h2 {
    font-size: 1.35rem;
    font-weight: 600;
    margin: 0 0 14px;
  }

  .framework-grid p {
    color: #5b6472;
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 900px) {
    .framework-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .framework-hero {
      padding-top: 54px;
    }

    .framework-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
