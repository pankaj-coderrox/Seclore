---
const footerGroups = [
  {
    title: "Product",
    links: [
      ["ARMOR", "/armor/"],
      ["DSPM", "/armor/dspm/"],
      ["AI-DLP", "/armor/aidlp/"],
      ["Data Classification", "/platform/classification/"],
      ["Integrations", "/integrations/"],
      ["Pricing", "/pricing/"],
      ["Resources", "/resources/"]
    ]
  },
  {
    title: "Support",
    links: [
      ["Support Portal", "/support/home/"],
      ["Solutions", "/support/solutions/"],
      ["New Support Ticket", "/support/tickets/new/"],
      ["Contact Support", "/support/tickets/new/"],
      ["How to open a Seclore File", "/how-to-open-a-seclore-protected-file/"]
    ]
  },
  {
    title: "About",
    links: [
      ["Why Seclore", "/about/why-seclore/"],
      ["Leadership", "/about/leadership/"],
      ["Newsroom", "/about/newsroom/"],
      ["Press Releases", "/about/press-releases/"],
      ["Contact Us", "/about/contact-us/"],
      ["Careers", "/about/careers/"]
    ]
  },
  {
    title: "Regulations",
    links: [
      ["NIAP", "/solutions/government/"],
      ["NCA", "/solutions/government/"],
      ["PCI-DSS", "/solutions/financial-services/"],
      ["ITAR", "/solutions/manufacturing/"],
      ["GLBA", "/solutions/financial-services/"],
      ["NIST", "/solutions/compliance/"],
      ["GDPR", "/solutions/compliance/"],
      ["DORA", "/solutions/financial-services/"]
    ]
  }
];

const appLinks = {
  google: "https://play.google.com/store/apps/details?id=com.seclore.filesecure.android.lite&hl=en_US",
  apple: "https://apps.apple.com/us/app/seclore/id526784478"
};

const footerSocials = [
  ["Facebook", "https://www.facebook.com/Seclore", "f"],
  ["LinkedIn", "https://www.linkedin.com/company/seclore", "in"],
  ["X", "https://x.com/seclore", "x"],
  ["YouTube", "https://www.youtube.com/@Seclore", "yt"],
  ["Instagram", "https://www.instagram.com/seclore", "ig"],
  ["Bluesky", "https://bsky.app/profile/seclore.bsky.social", "b"]
];

const countries = [
  "United States",
  "India",
  "United Kingdom",
  "Canada",
  "Australia",
  "Germany",
  "France",
  "Singapore",
  "United Arab Emirates",
  "Saudi Arabia",
  "Qatar",
  "Japan"
];

const configuredApiBase = String(import.meta.env.PUBLIC_API_BASE_URL || "").replace(/\/$/, "");
const localApiBasePattern = /^https?:\/\/(127\.0\.0\.1|localhost)(:\d+)?$/i;
const apiBase = import.meta.env.DEV
  ? configuredApiBase || "http://127.0.0.1:5000"
  : localApiBasePattern.test(configuredApiBase) ? "" : configuredApiBase;
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || "6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Book a personalized Seclore ARMOR demo." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Book a Demo | Seclore</title>
    <script is:inline>
      window.renderDemoRecaptcha = () => {
        const widget = document.querySelector(".g-recaptcha");
        const wrapper = widget?.closest(".captcha-widget");

        if (widget && window.grecaptcha && !widget.dataset.widgetId) {
          try {
            widget.dataset.widgetId = window.grecaptcha.render(widget, {
              sitekey: widget.dataset.sitekey
            });
            wrapper?.classList.add("is-rendered");
          } catch (error) {
            console.error("[Demo form] reCAPTCHA render failed.", error);
          }
        }
      };

      window.onDemoRecaptchaLoad = () => {
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", window.renderDemoRecaptcha, { once: true });
          return;
        }

        window.renderDemoRecaptcha();
      };
    </script>
    <script
      is:inline
      src="https://www.google.com/recaptcha/api.js?onload=onDemoRecaptchaLoad&render=explicit"
      async
      defer
      onerror="this.onerror=null;this.src='https://www.recaptcha.net/recaptcha/api.js?onload=onDemoRecaptchaLoad&render=explicit';"
    ></script>
  </head>
  <body>
    <main class="demo-page">
      <header class="demo-header" aria-label="Demo page header">
        <a class="demo-logo" href="/" aria-label="Seclore home">
          <img src="/images/home/seclore-logo-2026.svg" alt="Seclore" decoding="async" />
        </a>
        <a class="back-home" href="/">
          <span aria-hidden="true"></span>
          Back to Home
        </a>
      </header>

      <section class="hero-shell" aria-labelledby="demo-title">
        <div class="hero-copy">
          <h1 id="demo-title">
            <span>Get a</span>
            <span>Personalized</span>
            <span>Demo</span>
          </h1>
          <p class="demo-hero-subtitle">
            <span>See ARMOR in action! Learn</span>
            <span>how to enable safe use of</span>
            <span>Data and AI.</span>
          </p>

          <div class="trusted">
            <h2>Trusted by industry-leading enterprises</h2>
            <div class="trusted-logos" role="region" aria-label="Trusted enterprise customers" tabindex="0" data-demo-logo-scroller>
              <div class="trusted-logos__track">
                <span>adani</span>
                <span>stc</span>
                <span>SKYWorks</span>
                <span>MARUTI SUZUKI</span>
                <span>linde</span>
                <span>HDFC BANK</span>
                <span>FORD</span>
                <span>FLEX</span>
                <span aria-hidden="true">adani</span>
                <span aria-hidden="true">stc</span>
                <span aria-hidden="true">SKYWorks</span>
                <span aria-hidden="true">MARUTI SUZUKI</span>
                <span aria-hidden="true">linde</span>
                <span aria-hidden="true">HDFC BANK</span>
                <span aria-hidden="true">FORD</span>
                <span aria-hidden="true">FLEX</span>
              </div>
            </div>
          </div>
        </div>

        <form class="demo-form" id="start-here" data-endpoint="/api/demo">
          <h2>Start Here</h2>
          <div class="form-rule"></div>

          <label>
            Business Email<span>*</span>
            <input name="email" type="email" autocomplete="email" required />
          </label>

          <label>
            First Name<span>*</span>
            <input name="firstName" autocomplete="given-name" required minlength="2" />
          </label>

          <label>
            Last Name<span>*</span>
            <input name="lastName" autocomplete="family-name" required minlength="2" />
          </label>

          <label>
            Company name<span>*</span>
            <input name="company" autocomplete="organization" required />
          </label>

          <label>
            Job title<span>*</span>
            <input name="role" autocomplete="organization-title" required />
          </label>

          <label>
            Phone number<span>*</span>
            <input name="phone" autocomplete="tel" required />
          </label>

          <label class="country-field">
            Country<span>*</span>
            <select name="country" required>
              <option value="">Please Select</option>
              {countries.map((country) => <option value={country}>{country}</option>)}
            </select>
          </label>

          <div class="captcha-widget">
            <div class="g-recaptcha" data-sitekey={recaptchaSiteKey}></div>
            <div class="recaptcha-fallback" aria-hidden="true">
              <span></span>
              <strong>reCAPTCHA</strong>
              <small>Loading verification...</small>
            </div>
          </div>

          <button type="submit">Submit</button>
          <p class="form-status" role="status" aria-live="polite"></p>
        </form>
      </section>

      <section class="ready-section" aria-labelledby="ready-title">
        <h2 id="ready-title">Ready to get started?</h2>
        <p>Contact our sales team to find out how Seclore can help with data security and compliance.</p>
        <a href="#start-here">Book a Demo</a>
      </section>

      <footer class="demo-footer">
        <div class="footer-accordions">
          {footerGroups.map((group) => (
            <details>
              <summary>
                {group.title}
                <span aria-hidden="true"></span>
              </summary>
              <div>
                {group.links.map(([label, href]) => <a href={href}>{label}</a>)}
              </div>
            </details>
          ))}
        </div>

        <div class="footer-contact">
          <a class="footer-logo" href="/" aria-label="Seclore home">
            <img src="/images/home/seclore-logo-2026.svg" alt="Seclore" loading="lazy" decoding="async" />
          </a>
          <address>5201 Great America Parkway Suite 440 Santa Clara, CA 95054</address>
          <p>
            <a href="tel:18444732567">1-844-4-Seclore</a>
            <a href="tel:18444732567">1-844-473-2567</a>
          </p>
          <a class="email-link" href="mailto:hello@seclore.com">hello@seclore.com</a>

          <div class="store-badges" aria-label="Download Seclore apps">
            <a class="store-badge google" href={appLinks.google} target="_blank" rel="noreferrer" aria-label="Get Seclore on Google Play">
              <span aria-hidden="true"></span>
              <b><small>GET IT ON</small>Google Play</b>
            </a>
            <a class="store-badge apple" href={appLinks.apple} target="_blank" rel="noreferrer" aria-label="Download Seclore on the App Store">
              <svg aria-hidden="true" viewBox="0 0 24 28" focusable="false">
                <path d="M18.7 14.7c0-3.1 2.5-4.6 2.6-4.7-1.4-2.1-3.6-2.4-4.4-2.4-1.9-.2-3.6 1.1-4.6 1.1-.9 0-2.4-1.1-4-1-2 0-3.9 1.2-5 3-2.1 3.7-.5 9.2 1.5 12.2 1 1.5 2.2 3.1 3.8 3 1.5-.1 2.1-1 4-1s2.4 1 4 1c1.6 0 2.7-1.5 3.7-2.9 1.2-1.7 1.7-3.4 1.7-3.5-.1-.1-3.3-1.3-3.3-4.8Z" />
                <path d="M15.7 5.6c.8-1 1.4-2.4 1.2-3.8-1.2 0-2.6.8-3.4 1.8-.8.9-1.4 2.3-1.2 3.7 1.3.1 2.6-.7 3.4-1.7Z" />
              </svg>
              <b><small>Download on the</small> App Store</b>
            </a>
          </div>
        </div>

        <div class="footer-bottom">
          <nav class="socials" aria-label="Social media links">
            {footerSocials.map(([label, href, icon]) => <a href={href} target="_blank" rel="noreferrer" aria-label={label}>{icon}</a>)}
          </nav>
          <p>&copy; 2026 Seclore. All Rights Reserved. <a href="https://license.seclore.com/licensingportal/static/html/privacy.html" target="_blank" rel="noreferrer">Legal</a></p>
        </div>
      </footer>
    </main>

    <script is:inline define:vars={{ apiBase, recaptchaSiteKey }}>
      const form = document.querySelector(".demo-form");
      const status = form?.querySelector(".form-status");
      const submit = form?.querySelector("button[type='submit']");
      const defaultSubmitText = submit?.textContent || "Submit";
      const localHostPattern = /^(127\.0\.0\.1|localhost|::1)$/i;
      const privateHostPattern = /^(10(?:\.\d{1,3}){3}|192\.168(?:\.\d{1,3}){2}|172\.(?:1[6-9]|2\d|3[01])(?:\.\d{1,3}){2})$/;
      let isSubmitting = false;

      function resolveApiUrl(endpoint) {
        const path = endpoint || "/api/demo";

        if (/^https?:\/\//i.test(path)) {
          return path;
        }

        const configuredBase = String(apiBase || "").replace(/\/$/, "");
        const isLocalPage = localHostPattern.test(window.location.hostname);
        const isPrivateDevPage = privateHostPattern.test(window.location.hostname);
        const isLocalApiBase = /^https?:\/\/(127\.0\.0\.1|localhost)(:\d+)?$/i.test(configuredBase);

        if (configuredBase && (!isLocalApiBase || isLocalPage)) {
          return `${configuredBase}${path.startsWith("/") ? "" : "/"}${path}`;
        }

        if (configuredBase && isLocalApiBase && !isLocalPage && !isPrivateDevPage) {
          console.warn("[Demo form] Ignoring local API base URL on production page.", {
            apiBase: configuredBase,
            pageHost: window.location.hostname
          });
        }

        if (isLocalPage || isPrivateDevPage) {
          const apiHost = isPrivateDevPage ? window.location.hostname : "127.0.0.1";
          return `http://${apiHost}:5000${path.startsWith("/") ? "" : "/"}${path}`;
        }

        return path;
      }

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (isSubmitting) {
          return;
        }

        if (!form.reportValidity()) {
          return;
        }

        const data = new FormData(form);
        const firstName = String(data.get("firstName") || "").trim();
        const lastName = String(data.get("lastName") || "").trim();
        const recaptchaWidget = form.querySelector(".g-recaptcha");
        const recaptchaWidgetId = recaptchaWidget?.dataset.widgetId ? Number(recaptchaWidget.dataset.widgetId) : undefined;
        const recaptchaReady = !recaptchaSiteKey || Boolean(window.grecaptcha?.getResponse);
        const recaptchaToken = String(data.get("g-recaptcha-response") || window.grecaptcha?.getResponse?.(recaptchaWidgetId) || "").trim();

        if (recaptchaSiteKey && (!recaptchaReady || !recaptchaToken)) {
          if (status) {
            status.textContent = recaptchaReady ? "Please complete the reCAPTCHA." : "reCAPTCHA is still loading. Please wait a moment and try again.";
            status.className = "form-status error";
          }
          return;
        }

        const payload = {
          name: `${firstName} ${lastName}`.trim(),
          email: data.get("email"),
          company: data.get("company"),
          phone: data.get("phone"),
          role: data.get("role"),
          country: data.get("country"),
          interest: "Personalized Demo",
          message: `Country: ${data.get("country") || ""}`,
          recaptchaToken,
          source: "demo-page"
        };

        isSubmitting = true;
        submit?.setAttribute("disabled", "true");
        submit?.setAttribute("aria-busy", "true");
        if (submit) submit.textContent = "Submitting...";
        if (status) {
          status.textContent = "Submitting...";
          status.className = "form-status";
        }

        let requestUrl = form.dataset.endpoint || "/api/demo";

        try {
          requestUrl = resolveApiUrl(form.dataset.endpoint);
          const response = await fetch(requestUrl, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });
          const result = await response.json().catch(() => ({}));

          if (!response.ok) {
            console.error("[Demo form] API request failed.", {
              url: requestUrl,
              status: response.status,
              response: result
            });
            throw new Error(result.message || "We could not send the request. Please check the API server and try again.");
          }

          form.reset();
          window.grecaptcha?.reset?.(recaptchaWidgetId);
          if (status) {
            status.textContent = result.message || "Demo request received.";
            status.classList.add("success");
          }
        } catch (error) {
          console.error("[Demo form] Submit request error.", {
            url: requestUrl,
            error
          });
          if (status) {
            const isNetworkError = error instanceof TypeError;
            status.textContent = isNetworkError
              ? "We could not reach the demo API. Check that the backend server is running and accessible from this device."
              : error instanceof Error ? error.message : "We could not send the request. Please try again.";
            status.classList.add("error");
          }
        } finally {
          isSubmitting = false;
          submit?.removeAttribute("disabled");
          submit?.removeAttribute("aria-busy");
          if (submit) submit.textContent = defaultSubmitText;
        }
      });

      document.querySelectorAll("[data-demo-logo-scroller]").forEach((scroller) => {
        let isDragging = false;
        let startX = 0;
        let startScrollLeft = 0;
        let pauseUntil = 0;
        let lastFrame = performance.now();
        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const pauseAutoScroll = (duration = 1800) => {
          pauseUntil = performance.now() + duration;
        };

        const autoScroll = (time) => {
          const halfWidth = scroller.scrollWidth / 2;

          if (!prefersReducedMotion && !isDragging && time > pauseUntil && halfWidth > scroller.clientWidth) {
            const elapsed = Math.min(time - lastFrame, 40);
            scroller.scrollLeft += elapsed * 0.052;

            if (scroller.scrollLeft >= halfWidth) {
              scroller.scrollLeft -= halfWidth;
            }
          }

          lastFrame = time;
          requestAnimationFrame(autoScroll);
        };

        requestAnimationFrame(autoScroll);

        scroller.addEventListener("pointerdown", (event) => {
          if (!(event instanceof PointerEvent)) {
            return;
          }

          pauseAutoScroll(2400);
          isDragging = true;
          startX = event.clientX;
          startScrollLeft = scroller.scrollLeft;
          scroller.classList.add("is-dragging");
          scroller.setPointerCapture(event.pointerId);
        });

        scroller.addEventListener("pointermove", (event) => {
          if (!isDragging || !(event instanceof PointerEvent)) {
            return;
          }

          pauseAutoScroll(2400);
          scroller.scrollLeft = startScrollLeft - (event.clientX - startX);
        });

        ["pointerup", "pointercancel", "mouseleave"].forEach((eventName) => {
          scroller.addEventListener(eventName, (event) => {
            isDragging = false;
            scroller.classList.remove("is-dragging");

            if (event instanceof PointerEvent && scroller.hasPointerCapture(event.pointerId)) {
              scroller.releasePointerCapture(event.pointerId);
            }
          });
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --purple: #5630d6;
    --text: #2b2b2d;
    --muted: #77777a;
    --line: #c9c9c9;
    --field-bg: #f4f8fb;
    --field-border: #cbd9e7;
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: #ffffff;
    scroll-behavior: smooth;
  }

  body {
    background: #ffffff;
    color: var(--text);
    margin: 0;
    min-width: 320px;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  select {
    font: inherit;
  }

  .demo-page {
    background: #ffffff;
    min-height: 100vh;
    overflow: clip;
    padding: 0 clamp(24px, 2.5vw, 38px);
  }

  .demo-header {
    align-items: center;
    display: flex;
    justify-content: space-between;
    padding: 24px 0 0;
  }

  .demo-logo,
  .footer-logo {
    display: inline-flex;
    line-height: 1;
  }

  .demo-logo img {
    display: block;
    width: 174px;
  }

  .back-home {
    align-items: center;
    color: #373737;
    display: inline-flex;
    font-size: 20px;
    font-weight: 400;
    gap: 17px;
    line-height: 1;
  }

  .back-home span {
    border-bottom: 4px solid #2d2d2d;
    border-left: 4px solid #2d2d2d;
    display: block;
    height: 16px;
    transform: rotate(45deg);
    width: 16px;
  }

  .hero-shell {
    display: grid;
    align-items: start;
    gap: clamp(34px, 5vw, 92px);
    grid-template-columns: minmax(0, 0.96fr) minmax(360px, 0.82fr);
    margin: 96px 0 0;
    min-height: 0;
  }

  .hero-copy {
    display: grid;
    grid-template-rows: auto auto auto;
    min-height: 0;
  }

  .hero-copy h1 {
    color: #2d2d2f;
    font-size: clamp(76px, 6.8vw, 91px);
    font-weight: 400;
    letter-spacing: 0;
    line-height: 0.98;
    margin: 0 0 38px;
    max-width: 580px;
  }

  .hero-copy h1 span {
    display: block;
    white-space: nowrap;
  }

  .hero-copy > p {
    color: var(--purple);
    font-size: clamp(34px, 3vw, 43px);
    font-weight: 400;
    line-height: 1.05;
    margin: 0;
    max-width: 520px;
  }

  .demo-hero-subtitle span {
    display: block;
    white-space: nowrap;
  }

  .trusted {
    align-self: start;
    margin: clamp(78px, 8vw, 104px) 0 0;
    max-width: min(100%, 440px);
  }

  .trusted h2 {
    color: #2f333b;
    font-size: clamp(21px, 1.65vw, 24px);
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.28;
    margin: 0 0 clamp(26px, 2.8vw, 34px);
  }

  .trusted-logos {
    cursor: grab;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 2px 0 8px;
    scroll-behavior: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    width: 100%;
  }

  .trusted-logos::-webkit-scrollbar {
    display: none;
  }

  .trusted-logos:focus-visible {
    outline: 2px solid rgba(86, 48, 214, 0.38);
    outline-offset: 8px;
  }

  .trusted-logos.is-dragging {
    cursor: grabbing;
    user-select: none;
  }

  .trusted-logos__track {
    align-items: center;
    display: flex;
    gap: clamp(76px, 8vw, 108px);
    min-width: max-content;
    width: max-content;
  }

  .trusted-logos span {
    color: #3d3f44;
    display: inline-block;
    flex: 0 0 auto;
    font-size: clamp(24px, 2.35vw, 32px);
    font-weight: 820;
    letter-spacing: 0.06em;
    line-height: 1;
    opacity: 0.78;
    white-space: nowrap;
  }

  .trusted-logos span:nth-child(2n + 1) {
    letter-spacing: -0.03em;
    text-transform: lowercase;
  }

  .demo-form {
    color: #222225;
    display: grid;
    justify-self: end;
    padding: 18px clamp(16px, 1.65vw, 26px) 0;
    width: min(100%, 560px);
  }

  .demo-form h2 {
    color: #262629;
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
    font-size: 36px;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.05;
    margin: 0;
  }

  .form-rule {
    border-top: 1px solid #c7c7c7;
    height: 1px;
    margin: 24px 0 34px;
    width: 100%;
  }

  .demo-form label {
    color: #33363b;
    display: block;
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
    font-size: 14px;
    font-weight: 650;
    letter-spacing: 0;
    line-height: 1.18;
    margin: 0 0 12px;
  }

  .demo-form label span {
    color: #ff2c2c;
  }

  .demo-form input,
  .demo-form select {
    background: var(--field-bg);
    border: 1px solid var(--field-border);
    border-radius: 3px;
    color: #202327;
    display: block;
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
    font-size: 15px;
    font-weight: 400;
    height: 44px;
    margin-top: 7px;
    outline: none;
    padding: 0 13px;
    width: 100%;
  }

  .demo-form select {
    appearance: auto;
    color: #b7b7b7;
    font-size: 15px;
    font-weight: 400;
  }

  .demo-form select:valid {
    color: #202327;
    font-size: 16px;
