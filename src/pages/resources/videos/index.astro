---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const webinars = [
  {
    title: "From AI Risk to AI Readiness: Where Trust Becomes Operational, Not Aspirational",
    tags: ["On-Demand Webinar", "Compliance"],
    imageUrl: "https://www.seclore.com/wp-content/uploads/march-2026-webinar-recap-768x768.png"
  },
  {
    title: "DPDP Readiness in the Age of AI: The Role of Data Security Intelligence",
    tags: ["On-Demand Webinar", "Compliance"],
    imageUrl: "https://www.seclore.com/wp-content/uploads/feb-2026-recap-webinar-graphic-768x768.png"
  },
  {
    title: "2026 Data Security Reality Check: What's Critical Now and What's Coming",
    tags: ["On-Demand Webinar", "Data Security"],
    imageUrl: "https://www.seclore.com/wp-content/uploads/jan-2026-recap-webinar-graphic-768x768.png"
  },
  {
    title: "Inside the Data Intelligence Framework",
    tags: ["On-Demand Webinar", "Data Security"],
    imageUrl: "https://www.seclore.com/wp-content/uploads/webinar-Inside-the-Data-Intelligence-Lab-768x768.png"
  },
  {
    title: "If You Can't Answer These 3 Questions, Your Data Is Already Exposed",
    tags: ["On-Demand Webinar", "EDRM"],
    imageUrl: "https://www.seclore.com/wp-content/uploads/Nov-2025-Recap-webinar-graphic.png"
  },
  {
    title: "Breach Is Inevitable. Data Loss Isn't",
    tags: ["On-Demand Webinar", "Data Loss Prevention"],
    imageUrl: "https://www.seclore.com/wp-content/uploads/Recap-graphic-October-2025-Webinar.png"
  },
  {
    title: "Protecting Your Data from \"Shadow\" GenAI",
    tags: ["On-Demand Webinar", "AI Risk"],
    imageUrl: "https://www.seclore.com/wp-content/uploads/seclore-august-webinar-featured-image.png"
  },
  {
    title: "The GenAI Security Gap: Closing It with Symantec and Seclore",
    tags: ["On-Demand Webinar", "AI Risk"],
    imageUrl: "https://www.seclore.com/wp-content/uploads/the-genai-security-gap-closing-it-with-symantec-and-seclore.png"
  },
  {
    title: "The New Rules for Protecting Data in an AI-Driven World",
    tags: ["On-Demand Webinar", "AI Risk"],
    imageUrl: "https://www.seclore.com/wp-content/uploads/the-new-rules-for-protecting-data-in-an-ai-driven-world-1.png"
  },
  {
    title: "The Myth of Perimeter Security: Why Your Network Is No Longer the Front Line of Defense",
    tags: ["On-Demand Webinar", "Data Security"],
    imageUrl: "https://www.seclore.com/wp-content/uploads/track-in-motion.png"
  },
  {
    title: "2025 Data Security Forecast: Trends to Watch and Prepare for",
    tags: ["On-Demand Webinar", "Data Security"],
    imageUrl: "https://www.seclore.com/wp-content/uploads/2025-data-security-forecast-trends-to-watch-and-prepare-for-1.png"
  },
  {
    title: "Extending Data Security Coverage with Symantec and Seclore",
    tags: ["On-Demand Webinar", "Partners & Integrations"],
    imageUrl: "https://www.seclore.com/wp-content/uploads/extending-data-security-coverage-with-symantec-and-seclore.png"
  }
];

const categoryLinks = [
  ["Datasheets", "/resources/datasheets/"],
  ["Infographics", "/resources/"],
  ["Customer Case Studies", "/resources/customer-case-studies/"],
  ["Whitepapers & Reports", "/resources/whitepapers-reports/"],
  ["Videos", "/resources/videos/"],
  ["eBooks", "/resources/ebooks/"]
];

---

<BaseLayout
  title="Data Security Webinars & Videos | seclore"
  description="Explore Seclore data security webinars and videos."
>
  <main id="top" class="videos-page">
    <Nav />

    <section class="videos-hero">
      <span>Resources</span>
      <h1>Data Security Webinars &amp; Videos</h1>
      <p>
        Learn more about data-centric security, and how to protect your organization from data theft
        and noncompliance.
      </p>
    </section>

    <section class="catalog" id="results">
      <form class="filter-bar" aria-label="Filter webinars and videos">
        <strong>Filter by:</strong>
        <select aria-label="Industry"><option>Any industry</option></select>
        <select aria-label="Category"><option>All categories</option></select>
        <label class="search-box">
          <span aria-hidden="true"></span>
          <input type="search" placeholder="Enter keywords" aria-label="Enter keywords" />
        </label>
      </form>

      <div class="results-row">
        <strong>Results:</strong>
        <select aria-label="Sort webinars and videos"><option>Sort by</option></select>
      </div>

      <div class="video-grid">
        {webinars.map((webinar) => (
          <article class="video-card">
            <div class="video-thumb">
              <img src={webinar.imageUrl} alt="" loading="lazy" decoding="async" />
            </div>
            <div class="video-card-copy">
              <div class="meta-row">
                {webinar.tags.map((tag) => <span>{tag}</span>)}
              </div>
              <h2>{webinar.title}</h2>
              <a href="/resources/videos/digital-asset-classification-and-risk-insight/">
                View On-Demand Webinar <span aria-hidden="true">-&gt;</span>
              </a>
            </div>
          </article>
        ))}
      </div>

      <nav class="pagination" aria-label="Videos pagination">
        <a class="current" href="#results">1</a>
        <a href="#results">2</a>
        <a href="#results">3</a>
        <a href="#results">Next</a>
      </nav>
    </section>

    <section class="category-band" aria-label="Resource categories">
      {categoryLinks.map(([item, href]) => (
        <a href={href}>
          {item}
          <span aria-hidden="true">+</span>
        </a>
      ))}
    </section>

  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #ffffff;
    --page-soft: #f8f7f9;
    --page-text: #24222b;
    --page-muted: #77737e;
    --purple: #5b2bd7;
    --purple-dark: #4422ba;
    --line: rgba(32, 29, 40, 0.12);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: none;
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #5b2bd7;
    --demo-button-text: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  select {
    font: inherit;
  }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid transparent;
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 74px;
    padding: 0 clamp(20px, 4vw, 42px) 0 34px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    flex: 0 0 auto;
    font-size: 1.45rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .nav-links,
  .nav-utilities {
    align-items: center;
    display: flex;
  }

  .nav-links {
    flex: 1 1 auto;
    gap: clamp(18px, 2.2vw, 34px);
    justify-content: center;
    min-width: 0;
  }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:hover .nav-trigger,
  .nav-item:focus-within .nav-trigger {
    color: var(--header-text);
  }

  .nav-item {
    position: static;
  }

  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret {
    transform: rotate(225deg) translateY(-1px);
  }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .mega-column,
  .mega-sublinks {
    display: grid;
  }

  .mega-column {
    gap: 10px;
  }

  .mega-title {
    color: var(--dropdown-title);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mega-link,
  .mega-link-group {
    border: 1px solid transparent;
    border-radius: 8px;
  }

  .mega-link {
    display: grid;
    gap: 5px;
    padding: 13px;
  }

  .mega-link strong {
    color: var(--dropdown-text);
  }

  .mega-link small,
  .mega-sublinks a {
    color: var(--dropdown-muted);
  }

  .mega-link:hover,
  .mega-link-group:hover {
    background: var(--dropdown-link-hover);
    border-color: var(--dropdown-link-border);
  }

  .mega-link-group {
    display: grid;
    gap: 4px;
    padding: 4px;
  }

  .mega-sublinks {
    gap: 2px;
    padding: 0 9px 8px 22px;
  }

  .mega-sublinks a {
    font-size: 0.84rem;
    padding: 5px 0;
  }

  .mega-feature {
    align-content: end;
    background: var(--dropdown-feature-bg);
    border: 1px solid var(--dropdown-feature-border);
    border-radius: 8px;
    display: grid;
    min-height: 268px;
    padding: 24px;
  }

  .mega-feature span,
  .mega-feature em {
    color: var(--dropdown-title);
  }

  .mega-feature strong {
    color: var(--dropdown-text);
    font-size: 1.35rem;
    line-height: 1.18;
    margin-top: auto;
  }

  .nav-utilities {
    flex: 0 0 auto;
    gap: clamp(12px, 1.5vw, 20px);
    margin-left: clamp(12px, 2vw, 28px);
  }

  .utility-link,
  .language-button,
  .utility-icon,
  .theme-toggle {
    color: var(--header-muted);
    display: none;
    font-size: 0.88rem;
    font-weight: 750;
  }

  .demo-button,
  .primary-button {
    align-items: center;
    background: var(--demo-button-bg);
    border: 0;
    border-radius: 6px;
    color: var(--demo-button-text);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.88rem;
    font-weight: 850;
    justify-content: center;
    min-height: 38px;
    padding: 0 18px;
  }

  .nav-toggle {
    background: transparent;
    border: 0;
    display: none;
    height: 42px;
    margin-left: auto;
    width: 42px;
  }

  .nav-toggle span {
    background: var(--header-text);
    display: block;
    height: 2px;
    margin: 7px 0;
    width: 28px;
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  .videos-hero {
    align-items: center;
    background:
      radial-gradient(circle at 18% 88%, rgba(240, 184, 239, 0.78), transparent 35%),
      linear-gradient(135deg, #9028ed 0%, #7d24e2 52%, #631fe0 100%);
    color: #ffffff;
    display: grid;
    min-height: 350px;
    padding: 62px clamp(16px, 5vw, 72px) 72px;
    place-items: center;
    text-align: center;
  }

  .videos-hero span {
    font-size: 0.78rem;
    font-weight: 800;
    margin-bottom: 18px;
  }

  .videos-hero h1 {
    font-size: clamp(2.8rem, 6.6vw, 5.6rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.02;
    margin-bottom: 24px;
    max-width: 1120px;
  }

  .videos-hero p {
    color: rgba(255, 255, 255, 0.78);
    font-size: clamp(0.96rem, 1.6vw, 1.2rem);
    line-height: 1.55;
    margin-bottom: 0;
    max-width: 1100px;
  }

  .catalog {
    background: #ffffff;
    padding: 36px clamp(16px, 2.5vw, 34px) 72px;
  }

  .filter-bar,
  .results-row {
    align-items: center;
    display: flex;
    gap: 12px;
  }

  .filter-bar {
    background: #ffffff;
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: 0 12px 30px rgba(27, 20, 45, 0.04);
    flex-wrap: wrap;
    margin-bottom: 28px;
    padding: 16px;
  }

  .filter-bar strong,
  .results-row strong {
    color: #292531;
    font-size: 0.9rem;
  }

  .filter-bar select,
  .results-row select,
  .search-box {
    background: var(--page-soft);
    border: 1px solid transparent;
    border-radius: 6px;
    color: #67626f;
    min-height: 36px;
  }

  .filter-bar select,
  .results-row select {
    min-width: 150px;
    padding: 0 12px;
  }

  .search-box {
    align-items: center;
    display: flex;
    gap: 8px;
    min-width: min(100%, 230px);
    padding: 0 12px;
  }

  .search-box span {
    border: 2px solid #a7a2ad;
    border-radius: 50%;
    height: 14px;
    position: relative;
    width: 14px;
  }

  .search-box span::after {
    background: #a7a2ad;
    content: "";
    height: 2px;
    position: absolute;
    right: -6px;
    top: 9px;
    transform: rotate(45deg);
    width: 7px;
  }

  .search-box input {
    background: transparent;
    border: 0;
    color: #292531;
    min-height: 34px;
    min-width: 0;
    outline: 0;
    width: 100%;
  }

  .results-row {
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .video-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .video-card {
    background: #ffffff;
    border: 1px solid var(--line);
    border-radius: 8px;
    display: grid;
    grid-template-rows: auto 1fr;
    min-height: 380px;
    overflow: hidden;
  }

  .video-thumb {
    aspect-ratio: 1.76 / 1;
    background: #f3f2f5;
    overflow: hidden;
    position: relative;
  }

  .video-thumb img {
    display: block;
    height: 100%;
    inset: 0;
    object-fit: cover;
    object-position: center;
    position: absolute;
    width: 100%;
  }

  .video-card-copy {
    align-content: start;
    display: grid;
    padding: 26px;
  }

  .meta-row {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .meta-row span {
    background: #f0eff2;
    border-radius: 999px;
    color: #4d4856;
    font-size: 0.66rem;
    font-weight: 850;
    letter-spacing: 0.03em;
    max-width: 100%;
    padding: 6px 9px;
    text-transform: uppercase;
  }

  .video-card h2 {
    font-size: clamp(0.98rem, 1.18vw, 1.18rem);
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 28px;
  }

  .video-card a {
    align-self: end;
    color: #2d2936;
    font-size: 0.82rem;
    font-weight: 800;
    margin-top: auto;
  }

  .pagination {
    align-items: center;
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-top: 52px;
  }

  .pagination a {
    color: #2f2a37;
    font-size: 0.9rem;
    font-weight: 800;
  }

  .pagination .current {
    background: #e8e6ea;
    border-radius: 3px;
    padding: 9px 12px;
  }

  .category-band {
    background: var(--purple-dark);
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    padding: 30px clamp(16px, 2.5vw, 34px);
  }

  .category-band a {
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.38);
    border-radius: 6px;
    color: #ffffff;
    display: flex;
    font-size: 0.9rem;
    font-weight: 800;
    justify-content: space-between;
    min-height: 50px;
    padding: 0 20px;
  }

  .resource-footer {
    background: #ffffff;
    padding-inline: clamp(16px, 2.5vw, 34px);
  }

  .resource-footer p {
    color: var(--page-muted);
    font-size: 0.98rem;
    line-height: 1.6;
  }

  .footer-lines {
    border-block: 1px solid var(--line);
    margin-bottom: 34px;
  }

  .footer-lines details {
    border-bottom: 1px solid var(--line);
    padding: 22px 0;
  }

  .footer-lines details:last-child {
    border-bottom: 0;
  }

  .footer-lines summary {
    cursor: pointer;
    font-size: 1rem;
    font-weight: 800;
  }

  .footer-logo {
    color: var(--purple);
    display: block;
    font-size: 1.75rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-bottom: 28px;
    text-transform: uppercase;
  }

  .store-row,
  .social-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 28px 0;
  }

  .store-row span {
    background: #151019;
    border-radius: 5px;
    color: #ffffff;
    font-size: 0.78rem;
    font-weight: 800;
    padding: 9px 14px;
  }

  .social-row {
    border-top: 1px solid var(--line);
    padding-top: 28px;
  }

  .social-row span {
    color: #343238;
    font-weight: 900;
  }

  .legal {
    font-size: 0.88rem;
    padding-bottom: 30px;
  }

  @media (max-width: 1180px) {
    .nav-toggle {
      display: block;
      order: 1;
    }

    .site-header {
      flex-wrap: wrap;
    }

    .site-logo {
      order: 0;
    }

    .nav-links {
      background: var(--header-bg);
      border-top: 1px solid var(--header-border);
      display: none;
      flex: 1 0 100%;
      order: 2;
      padding: 10px 0 14px;
    }

    .nav-links.open {
      align-items: stretch;
      display: grid;
    }

    .nav-links > a,
    .nav-trigger {
      justify-content: space-between;
      min-height: 48px;
      width: 100%;
    }

    .nav-item {
      display: grid;
    }

    .mega-menu {
      display: none;
      opacity: 1;
      position: static;
      transform: none;
    }

    .nav-item:hover .mega-menu,
    .nav-item:focus-within .mega-menu {
      display: none;
    }

    .nav-item.is-open .mega-menu {
      display: block;
    }

    .mega-inner {
      box-shadow: none;
      grid-template-columns: 1fr;
      min-height: 0;
      padding: 16px;
    }

    .nav-utilities {
      align-items: stretch;
      display: flex;
      margin-left: auto;
      order: 0;
    }

    .nav-links.open + .nav-utilities {
      display: grid;
      flex: 1 0 100%;
      order: 3;
    }

    .video-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .video-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .site-header {
      min-height: 58px;
      padding-left: 8px;
      padding-right: 10px;
    }

    .site-logo {
      font-size: 0.85rem;
    }

    .demo-button {
      font-size: 0.66rem;
      min-height: 30px;
      padding-inline: 12px;
    }

    .nav-toggle {
      height: 32px;
      width: 32px;
    }

    .nav-toggle span {
      margin: 5px 0;
      width: 21px;
    }

    .videos-hero {
      min-height: 205px;
      padding: 34px 8px 42px;
    }

    .videos-hero h1 {
      font-size: 1.76rem;
      max-width: 340px;
    }

    .videos-hero p {
      font-size: 0.66rem;
      max-width: 340px;
    }

    .catalog {
      padding: 24px 8px 48px;
    }

    .filter-bar {
      display: grid;
      grid-template-columns: auto 1fr 1fr;
      padding: 12px;
    }

    .filter-bar strong {
      grid-row: span 2;
    }

