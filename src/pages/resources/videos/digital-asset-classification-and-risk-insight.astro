---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:5000";

const learningItems = [
  "An overview of the capabilities",
  "Differentiation between the new Seclore offerings and legacy classification solutions",
  "Tips for how to help customers maximize their Seclore deployment"
];

const trustLogos = ["aramco", "American Express", "adani", "stc", "SKYWORKS"];
---

<BaseLayout
  title="Digital Asset Classification and Risk Insights Overview | seclore"
  description="Watch Seclore's webinar overview for Digital Asset Classification and Risk Insights."
>
  <main id="top" class="video-page">
    <Nav />

    <section class="video-hero">
      <div class="hero-copy">
        <h1>Digital Asset Classification and Risk Insights Overview</h1>
        <a class="primary-button" href="#webinar">Watch the Webinar</a>
      </div>
      <div class="webinar-visual" aria-label="Risk insights dashboard webinar preview">
        <div class="person-shape"></div>
        <div class="desk"></div>
        <div class="monitor monitor-one">
          <span></span><span></span><span></span>
        </div>
        <div class="monitor monitor-two">
          <span></span><span></span><span></span>
        </div>
        <div class="chart-card">
          <strong>Risk Insights</strong>
          <div class="bars"><span></span><span></span><span></span><span></span></div>
        </div>
      </div>
    </section>

    <section class="webinar-copy" id="webinar">
      <p>
        The Digital Asset Classification capability from Seclore, combined with risk insights,
        enables enterprises to simultaneously classify and protect their most sensitive digital
        assets and visualize where the greatest risks lie in real-time.
      </p>
      <p>Watch this webinar recording to learn:</p>
      <ul>
        {learningItems.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="trust-section">
      <h2>Trusted by industry-leading enterprises</h2>
      <div class="trust-row">
        {trustLogos.map((logo) => <span>{logo}</span>)}
      </div>
    </section>

    <section class="demo-section" id="demo">
      <div class="demo-copy">
        <h2>Ready to get started?</h2>
        <p>Contact our sales team to find out how Seclore can help with data security and compliance.</p>
        <a class="primary-button" href="#demo-form">Book a Demo</a>
      </div>
      <form class="resource-form" id="demo-form" data-endpoint="/api/demo">
        <h3>Book a Demo</h3>
        <label>Email<input name="email" type="email" required /></label>
        <label>First Name<input name="name" required minlength="2" /></label>
        <label>Company Name<input name="company" required /></label>
        <label>Job Title<input name="role" /></label>
        <label>Phone Number<input name="phone" /></label>
        <label>Comments<textarea name="message" rows="4"></textarea></label>
        <button class="primary-button" type="submit">Schedule a Demo</button>
        <p class="form-status" role="status" aria-live="polite"></p>
      </form>
    </section>
  </main>

  <script is:inline define:vars={{ apiBase }}>
    document.querySelectorAll(".resource-form").forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const status = form.querySelector(".form-status");
        const button = form.querySelector("button[type='submit']");
        const payload = Object.fromEntries(new FormData(form).entries());

        status.textContent = "Sending...";
        status.className = "form-status";
        button.disabled = true;

        try {
          const response = await fetch(`${apiBase}${form.dataset.endpoint}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });
          const data = await response.json();
          if (!response.ok) throw new Error(data.message || "Request failed.");
          form.reset();
          status.textContent = data.message || "Submitted successfully.";
          status.classList.add("success");
        } catch (error) {
          status.textContent = error.message || "Something went wrong.";
          status.classList.add("error");
        } finally {
          button.disabled = false;
        }
      });
    });
  </script>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #ffffff;
    --page-text: #242329;
    --page-muted: #666a73;
    --purple: #5b2bd7;
    --purple-dark: #3f1cad;
    --card: #ffffff;
    --line: rgba(29, 29, 34, 0.18);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: none;
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #5b2bd7;
    --demo-button-text: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid transparent;
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 76px;
    padding: 0 clamp(20px, 4vw, 42px) 0 34px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    font-size: 1.6rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .nav-links,
  .nav-utilities {
    align-items: center;
    display: flex;
  }

  .nav-links {
    flex: 1 1 auto;
    gap: clamp(18px, 2.2vw, 34px);
    justify-content: center;
    min-width: 0;
  }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:hover .nav-trigger,
  .nav-item:focus-within .nav-trigger {
    color: var(--header-text);
  }

  .nav-item {
    position: static;
  }

  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret {
    transform: rotate(225deg) translateY(-1px);
  }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .mega-column,
  .mega-sublinks {
    display: grid;
  }

  .mega-column {
    gap: 10px;
  }

  .mega-title {
    color: var(--dropdown-title);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mega-link,
  .mega-link-group {
    border: 1px solid transparent;
    border-radius: 8px;
  }

  .mega-link {
    display: grid;
    gap: 5px;
    padding: 13px;
  }

  .mega-link strong {
    color: var(--dropdown-text);
  }

  .mega-link small,
  .mega-sublinks a {
    color: var(--dropdown-muted);
  }

  .mega-link:hover,
  .mega-link-group:hover {
    background: var(--dropdown-link-hover);
    border-color: var(--dropdown-link-border);
  }

  .mega-link-group {
    display: grid;
    gap: 4px;
    padding: 4px;
  }

  .mega-sublinks {
    gap: 2px;
    padding: 0 9px 8px 22px;
  }

  .mega-sublinks a {
    font-size: 0.84rem;
    padding: 5px 0;
  }

  .mega-feature {
    align-content: end;
    background: var(--dropdown-feature-bg);
    border: 1px solid var(--dropdown-feature-border);
    border-radius: 8px;
    display: grid;
    min-height: 268px;
    padding: 24px;
  }

  .mega-feature span,
  .mega-feature em {
    color: var(--dropdown-title);
  }

  .mega-feature strong {
    color: var(--dropdown-text);
    font-size: 1.35rem;
    line-height: 1.18;
    margin-top: auto;
  }

  .nav-utilities {
    flex: 0 0 auto;
    gap: clamp(12px, 1.5vw, 20px);
    margin-left: clamp(12px, 2vw, 28px);
  }

  .utility-link,
  .language-button,
  .utility-icon,
  .theme-toggle {
    color: var(--header-muted);
    font-size: 0.88rem;
    font-weight: 750;
  }

  .utility-link,
  .language-button,
  .utility-icon,
  .theme-toggle {
    display: none;
  }

  .demo-button,
  .primary-button {
    align-items: center;
    background: var(--demo-button-bg);
    border: 0;
    border-radius: 8px;
    color: var(--demo-button-text);
    cursor: pointer;
    display: inline-flex;
    font-size: 1rem;
    font-weight: 850;
    justify-content: center;
    min-height: 44px;
    padding: 0 26px;
  }

  .nav-toggle {
    background: transparent;
    border: 0;
    display: none;
    height: 42px;
    width: 42px;
  }

  .nav-toggle span {
    background: var(--header-text);
    display: block;
    height: 2px;
    margin: 7px 0;
    width: 28px;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    font-size: clamp(3.7rem, 8.2vw, 7.6rem);
    font-weight: 450;
    letter-spacing: 0;
    line-height: 0.98;
    margin-bottom: 46px;
    overflow-wrap: break-word;
  }

  h2 {
    font-size: clamp(2rem, 3.6vw, 3rem);
    font-weight: 450;
    line-height: 1.05;
  }

  p,
  li {
    color: var(--page-muted);
    font-size: clamp(1.05rem, 1.7vw, 1.35rem);
    line-height: 1.55;
  }

  .video-hero,
  .webinar-copy,
  .trust-section,
  .demo-section,
  .resource-footer {
    padding-inline: clamp(24px, 3.2vw, 46px);
  }

  .video-hero {
    align-items: start;
    display: grid;
    gap: clamp(32px, 5vw, 72px);
    grid-template-columns: minmax(0, 1.35fr) minmax(300px, 0.65fr);
    padding-top: clamp(42px, 6vw, 92px);
  }

  .webinar-visual {
    background: linear-gradient(135deg, #f5eeec, #ffffff 44%, #d9edf0);
    border-radius: 22px;
    min-height: 315px;
    overflow: hidden;
    position: relative;
  }

  .person-shape {
    background: linear-gradient(160deg, #6f7d92, #1c263a);
    border-radius: 48% 52% 0 0;
    bottom: 0;
    height: 185px;
    left: 32px;
    position: absolute;
    width: 110px;
  }

  .person-shape::before {
    background: #8a5a42;
    border-radius: 50%;
    content: "";
    height: 56px;
    left: 34px;
    position: absolute;
    top: -48px;
    width: 56px;
  }

  .desk {
    background: rgba(255, 255, 255, 0.92);
    bottom: 32px;
    height: 34px;
    left: 0;
    position: absolute;
    right: 0;
  }

  .monitor {
    background: #ffffff;
    border: 6px solid #dbe1e6;
    border-radius: 10px;
    box-shadow: 0 16px 32px rgba(35, 48, 62, 0.14);
    display: grid;
    gap: 8px;
    padding: 14px;
    position: absolute;
  }

  .monitor span,
  .chart-card strong,
  .bars span {
    border-radius: 999px;
    display: block;
  }

  .monitor span {
    background: linear-gradient(90deg, #6b34d8, #52c2bd, #f3a737);
    height: 10px;
  }

  .monitor-one {
    height: 145px;
    right: 34px;
    top: 48px;
    width: 190px;
  }

  .monitor-two {
    bottom: 58px;
    height: 118px;
    right: 132px;
    width: 165px;
  }

  .chart-card {
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(91, 43, 215, 0.16);
    border-radius: 12px;
    bottom: 34px;
    display: grid;
    gap: 10px;
    padding: 14px;
    position: absolute;
    right: 28px;
    width: 145px;
  }

  .chart-card strong {
    color: var(--purple);
    font-size: 0.84rem;
  }

  .bars {
    align-items: end;
    display: grid;
    gap: 7px;
    grid-template-columns: repeat(4, 1fr);
    height: 62px;
  }

  .bars span {
    background: linear-gradient(180deg, #5b2bd7, #7ec7c0);
  }

  .bars span:nth-child(1) { height: 42%; }
  .bars span:nth-child(2) { height: 72%; }
  .bars span:nth-child(3) { height: 56%; }
  .bars span:nth-child(4) { height: 88%; }

  .webinar-copy {
    padding-top: clamp(42px, 5vw, 70px);
  }

  .webinar-copy p,
  .webinar-copy ul {
    max-width: 1320px;
  }

  .webinar-copy ul {
    margin: 30px 0 0;
    padding-left: 28px;
  }

  .trust-section {
    padding-block: clamp(86px, 10vw, 150px) clamp(72px, 9vw, 124px);
    text-align: center;
  }

  .trust-section h2 {
    font-size: clamp(1.15rem, 1.9vw, 1.55rem);
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-bottom: 58px;
    text-transform: uppercase;
  }

  .trust-row {
    align-items: center;
    display: grid;
    gap: clamp(24px, 5vw, 78px);
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .trust-row span {
    color: rgba(36, 35, 41, 0.48);
    font-size: clamp(1.25rem, 2.6vw, 2.3rem);
    font-weight: 900;
    letter-spacing: 0.06em;
  }

  .demo-section {
    display: grid;
    gap: 42px;
    grid-template-columns: minmax(0, 1fr) minmax(310px, 430px);
    padding-bottom: 50px;
  }

  .demo-copy p {
    color: #9a9da4;
  }

  .resource-form {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 28px;
  }

  .resource-form h3 {
    text-align: center;
  }

  .resource-form label {
    color: var(--page-text);
    display: grid;
    font-size: 0.88rem;
    gap: 8px;
    margin-bottom: 14px;
  }

  .resource-form input,
  .resource-form textarea {
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(15, 23, 42, 0.16);
    border-radius: 4px;
    color: #111827;
    min-height: 40px;
    padding: 10px;
  }

  .resource-form textarea {
    resize: vertical;
  }

  .form-status {
    min-height: 24px;
  }

  .form-status.success {
    color: #087f6f;
  }

  .form-status.error {
    color: #bd2b2b;
  }

  .resource-footer {
    padding-bottom: 34px;
  }

  .footer-lines {
    border-block: 1px solid var(--line);
    margin-bottom: 34px;
  }

  .footer-lines details {
    border-bottom: 1px solid var(--line);
    padding: 22px 0;
  }

  .footer-lines details:last-child {
    border-bottom: 0;
  }

  .footer-lines summary {
    cursor: pointer;
    font-size: 1.3rem;
    font-weight: 800;
  }

  .footer-logo {
    color: var(--purple);
    display: block;
    font-size: 2rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-bottom: 28px;
    text-transform: uppercase;
  }

  .store-row,
  .social-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 30px 0;
  }

  .store-row span {
    background: #1a1421;
    border-radius: 5px;
    color: #ffffff;
    font-size: 0.85rem;
    font-weight: 800;
    padding: 10px 16px;
  }

  .social-row {
    border-top: 1px solid var(--line);
    padding-top: 30px;
  }

  .social-row span {
    color: #343238;
    font-weight: 900;
  }

  .legal {
    font-size: 0.95rem;
  }

  @media (max-width: 1180px) {
    .nav-toggle {
      display: block;
      margin-left: auto;
      order: 1;
    }

    .site-header {
      flex-wrap: wrap;
    }

    .site-logo {
      order: 0;
    }

    .nav-links {
      background: var(--header-bg);
      border-top: 1px solid var(--header-border);
      display: none;
      flex: 1 0 100%;
      order: 2;
      padding: 10px 0 14px;
    }

    .nav-links.open {
      align-items: stretch;
      display: grid;
    }

    .nav-links > a,
    .nav-trigger {
      justify-content: space-between;
      min-height: 48px;
      width: 100%;
    }

    .nav-item {
      display: grid;
    }

    .mega-menu {
      display: none;
      opacity: 1;
      position: static;
      transform: none;
    }

    .nav-item:hover .mega-menu,
    .nav-item:focus-within .mega-menu {
      display: none;
    }

    .nav-item.is-open .mega-menu {
      display: block;
    }

    .mega-inner {
      box-shadow: none;
      grid-template-columns: 1fr;
      min-height: 0;
      padding: 16px;
    }

    .nav-utilities {
      align-items: stretch;
      display: flex;
      margin-left: auto;
      order: 0;
    }

    .nav-links.open + .nav-utilities {
      display: grid;
      flex: 1 0 100%;
      order: 3;
    }
  }

  @media (max-width: 900px) {
    .video-hero,
    .demo-section {
      grid-template-columns: 1fr;
    }

    .trust-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .site-header {
      padding-left: 24px;
      padding-right: 18px;
    }

    .demo-button {
      padding-inline: 18px;
    }

    h1 {
      font-size: 2.65rem;
      line-height: 1.04;
    }

    .webinar-visual {
      min-height: 250px;
    }

    .monitor-two,
    .chart-card {
      display: none;
    }
  }
</style>
