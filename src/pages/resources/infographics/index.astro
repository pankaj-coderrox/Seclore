const categories = [...new Set(infographics.map((item) => item.category))];

const categoryLinks = [
  ["Datasheets", "/resources/datasheets/"],
  ["Infographics", "/resources/infographics/"],
  ["Customer Case Studies", "/resources/customer-case-studies/"],
  ["Whitepapers & Reports", "/resources/whitepapers-reports/"],
  ["Videos", "/resources/videos/"],
  ["eBooks", "/resources/"]
