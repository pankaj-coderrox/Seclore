---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";

const featured = {
  title: "Enhancing Compliance with Jordan Cybersecurity Framework and Seclore Solutions",
  summary:
    "Read this whitepaper to learn how Seclore helps organizations in Jordan ensure data privacy along with data protection."
};

const papers = [
  {
    title: "Complying with the National Information Assurance Policy (NIAP)",
    tags: ["Whitepaper", "Compliance"],
    image: "meeting"
  },
  {
    title: "Enterprise Digital Rights Management for Banking and Financial Services",
    tags: ["Whitepaper", "Banking & Financial Services", "EDRM"],
    image: "bank"
  },
  {
    title: "Enhancing Compliance with Jordan Cybersecurity Framework and Seclore Solutions",
    tags: ["Whitepaper", "Compliance"],
    image: "jordan"
  },
  {
    title: "A Guide to ISR Compliance and Data Protection for Dubai Government Entities",
    tags: ["Whitepaper", "Government/Public Sector", "Compliance"],
    image: "blank"
  },
  {
    title: "AI Brings Speed, Profit, and Cybersecurity Risk to the Semiconductor Industry",
    tags: ["Whitepaper", "Semiconductor Manufacturing", "AI Risk"],
    image: "blank"
  },
  {
    title: "Complying with the Personal Data Protection Law (PDPL) Using Seclore's Data-Centric Security Platform",
    tags: ["Whitepaper", "Compliance"],
    image: "blank"
  },
  {
    title: "Embracing Oman's Cyber Security & Resilience Framework (CS&RF) With Data-Centric Security",
    tags: ["Whitepaper", "Banking & Financial Services", "Compliance"],
    image: "blank"
  },
  {
    title: "A Comprehensive Guide to Data-Centric Email Security",
    tags: ["Whitepaper", "Email Encryption"],
    image: "blank"
  },
  {
    title: "Enhancing Banking Security and Compliance: Navigating RBI Guidelines with a Data-Centric Approach",
    tags: ["Whitepaper", "Banking", "Compliance"],
    image: "blank"
  },
  {
    title: "An Overview of State-Level Data Privacy Laws: Implications for Businesses and Academics",
    tags: ["Whitepaper", "Compliance"],
    image: "blank"
  },
  {
    title: "Complying with the Multitudes of Data Privacy Regulations in Financial Services",
    tags: ["Whitepaper", "Financial Services", "Compliance"],
    image: "blank"
  },
  {
    title: "Safeguarding Intellectual Property in the Semiconductor Equipment Industry",
    tags: ["Whitepaper", "Semiconductor Manufacturing", "Third Party Risk"],
    image: "blank"
  }
];

const categoryLinks = [
  ["Datasheets", "/resources/datasheets/"],
  ["Infographics", "/resources/"],
  ["Customer Case Studies", "/resources/customer-case-studies/"],
  ["Whitepapers & Reports", "/resources/whitepapers-reports/"],
  ["Videos", "/resources/videos/"],
  ["eBooks", "/resources/ebooks/"]
];

---

<BaseLayout
  title="Data Security & Compliance Papers | seclore"
  description="Explore Seclore whitepapers and reports on data-centric security and compliance."
>
  <main id="top" class="papers-page">
    <Nav />

    <section class="papers-hero">
      <span>Resources</span>
      <h1>Data Security &amp; Compliance Papers</h1>
      <p>Learn more about data-centric security and compliance from industry-leading experts.</p>
    </section>

    <section class="featured-wrap" aria-label="Featured whitepaper">
      <article class="featured-card">
        <div class="featured-copy">
          <span>Featured</span>
          <h2>{featured.title}</h2>
          <p>{featured.summary}</p>
          <a class="primary-button" href="#results">Read More</a>
          <div class="carousel-controls" aria-label="Featured carousel controls">
            <button type="button" aria-label="Previous featured paper"></button>
            <button type="button" aria-label="Next featured paper"></button>
          </div>
        </div>
        <div class="paper-image jordan large" aria-hidden="true">
          <span></span>
        </div>
        <div class="carousel-dots" aria-label="Slide position">
          <span></span><span class="active"></span><span></span>
        </div>
      </article>
    </section>

    <section class="catalog" id="results">
      <form class="filter-bar" aria-label="Filter whitepapers">
        <strong>Filter by:</strong>
        <select aria-label="Industry"><option>Any industry</option></select>
        <select aria-label="Category"><option>All categories</option></select>
        <label class="search-box">
          <span aria-hidden="true"></span>
          <input type="search" placeholder="Enter keywords" aria-label="Enter keywords" />
        </label>
      </form>

      <div class="results-row">
        <strong>Results:</strong>
        <select aria-label="Sort whitepapers"><option>Sort by</option></select>
      </div>

      <div class="paper-grid">
        {papers.map((paper) => (
          <article class="paper-card">
            <div class={`paper-thumb ${paper.image}`} aria-hidden="true">
              {paper.image !== "blank" && <span></span>}
            </div>
            <div class="paper-card-copy">
              <div class="meta-row">
                {paper.tags.map((tag) => <span>{tag}</span>)}
              </div>
              <h2>{paper.title}</h2>
              <a href="#top">View Whitepaper <span aria-hidden="true">-&gt;</span></a>
            </div>
          </article>
        ))}
      </div>

      <nav class="pagination" aria-label="Whitepapers pagination">
        <a class="current" href="#results">1</a>
        <a href="#results">2</a>
        <a href="#results">3</a>
        <a href="#results">Next</a>
      </nav>
    </section>

    <section class="category-band" aria-label="Resource categories">
      {categoryLinks.map(([item, href]) => (
        <a href={href}>
          {item}
          <span aria-hidden="true">+</span>
        </a>
      ))}
    </section>

    <section class="ready-section" id="demo">
      <h2>Ready to get started?</h2>
      <p>Contact our sales team to find out how Seclore can help with data security and compliance.</p>
      <a class="primary-button" href="#demo">Book a Demo</a>
    </section>
  </main>
</BaseLayout>

<style is:global>
  :root {
    color-scheme: light;
    --page-bg: #f7f7f8;
    --page-text: #24222b;
    --page-muted: #77737e;
    --purple: #5b2bd7;
    --purple-dark: #4422ba;
    --line: rgba(32, 29, 40, 0.12);
    --shadow: 0 20px 45px rgba(27, 20, 45, 0.08);
    --header-bg: #ffffff;
    --header-border: rgba(15, 23, 42, 0.08);
    --header-shadow: none;
    --header-text: #25242a;
    --header-muted: #28272c;
    --dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --dropdown-border: rgba(15, 23, 42, 0.1);
    --dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --dropdown-link-border: rgba(15, 76, 129, 0.16);
    --dropdown-title: #0b5cad;
    --dropdown-text: #101828;
    --dropdown-muted: #667085;
    --dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --demo-button-bg: #5b2bd7;
    --demo-button-text: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--page-bg);
    color: var(--page-text);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  select {
    font: inherit;
  }

  .site-header {
    align-items: center;
    background: var(--header-bg);
    border-bottom: 1px solid transparent;
    box-shadow: var(--header-shadow);
    display: flex;
    gap: 18px;
    min-height: 74px;
    padding: 0 clamp(20px, 4vw, 42px) 0 34px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-logo {
    color: var(--purple);
    flex: 0 0 auto;
    font-size: 1.45rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    margin-right: clamp(14px, 2vw, 28px);
    text-transform: uppercase;
  }

  .nav-links,
  .nav-utilities {
    align-items: center;
    display: flex;
  }

  .nav-links {
    flex: 1 1 auto;
    gap: clamp(18px, 2.2vw, 34px);
    justify-content: center;
    min-width: 0;
  }

  .nav-links > a,
  .nav-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--header-muted);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
  }

  .nav-links > a:hover,
  .nav-trigger:hover,
  .nav-item:hover .nav-trigger,
  .nav-item:focus-within .nav-trigger {
    color: var(--header-text);
  }

  .nav-item {
    position: static;
  }

  .nav-caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret,
  .nav-item.is-open .nav-caret {
    transform: rotate(225deg) translateY(-1px);
  }

  .mega-menu {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .nav-item:hover .mega-menu,
  .nav-item:focus-within .mega-menu,
  .nav-item.is-open .mega-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mega-inner {
    background: var(--dropdown-bg), repeating-linear-gradient(135deg, var(--dropdown-grid-line) 0, var(--dropdown-grid-line) 1px, transparent 1px, transparent 20px);
    border: 1px solid var(--dropdown-border);
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .mega-columns {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .mega-column,
  .mega-sublinks {
    display: grid;
  }

  .mega-column {
    gap: 10px;
  }

  .mega-title {
    color: var(--dropdown-title);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mega-link,
  .mega-link-group {
    border: 1px solid transparent;
    border-radius: 8px;
  }

  .mega-link {
    display: grid;
    gap: 5px;
    padding: 13px;
  }

  .mega-link strong {
    color: var(--dropdown-text);
  }

  .mega-link small,
  .mega-sublinks a {
    color: var(--dropdown-muted);
  }

  .mega-link:hover,
  .mega-link-group:hover {
    background: var(--dropdown-link-hover);
    border-color: var(--dropdown-link-border);
  }

  .mega-link-group {
    display: grid;
    gap: 4px;
    padding: 4px;
  }

  .mega-sublinks {
    gap: 2px;
    padding: 0 9px 8px 22px;
  }

  .mega-sublinks a {
    font-size: 0.84rem;
    padding: 5px 0;
  }

  .mega-feature {
    align-content: end;
    background: var(--dropdown-feature-bg);
    border: 1px solid var(--dropdown-feature-border);
    border-radius: 8px;
    display: grid;
    min-height: 268px;
    padding: 24px;
  }

  .mega-feature span,
  .mega-feature em {
    color: var(--dropdown-title);
  }

  .mega-feature strong {
    color: var(--dropdown-text);
    font-size: 1.35rem;
    line-height: 1.18;
    margin-top: auto;
  }

  .nav-utilities {
    flex: 0 0 auto;
    gap: clamp(12px, 1.5vw, 20px);
    margin-left: clamp(12px, 2vw, 28px);
  }

  .utility-link,
  .language-button,
  .utility-icon,
  .theme-toggle {
    color: var(--header-muted);
    display: none;
    font-size: 0.88rem;
    font-weight: 750;
  }

  .demo-button,
  .primary-button {
    align-items: center;
    background: var(--demo-button-bg);
    border: 0;
    border-radius: 6px;
    color: var(--demo-button-text);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.88rem;
    font-weight: 850;
    justify-content: center;
    min-height: 38px;
    padding: 0 18px;
  }

  .nav-toggle {
    background: transparent;
    border: 0;
    display: none;
    height: 42px;
    margin-left: auto;
    width: 42px;
  }

  .nav-toggle span {
    background: var(--header-text);
    display: block;
    height: 2px;
    margin: 7px 0;
    width: 28px;
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  .papers-hero {
    align-items: center;
    background:
      radial-gradient(circle at 18% 88%, rgba(240, 184, 239, 0.78), transparent 35%),
      linear-gradient(135deg, #9028ed 0%, #7d24e2 52%, #631fe0 100%);
    color: #ffffff;
    display: grid;
    min-height: 350px;
    padding: 62px clamp(16px, 5vw, 72px) 72px;
    place-items: center;
    text-align: center;
  }

  .papers-hero span {
    font-size: 0.78rem;
    font-weight: 800;
    margin-bottom: 18px;
  }

  .papers-hero h1 {
    font-size: clamp(2.7rem, 6.2vw, 5.4rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.02;
    margin-bottom: 24px;
    max-width: 1100px;
  }

  .papers-hero p {
    color: rgba(255, 255, 255, 0.78);
    font-size: clamp(0.96rem, 1.6vw, 1.2rem);
    line-height: 1.55;
    margin-bottom: 0;
  }

  .featured-wrap {
    padding: 34px clamp(16px, 4vw, 48px) 56px;
  }

  .featured-card {
    background: #ffffff;
    border-radius: 8px;
    box-shadow: var(--shadow);
    display: grid;
    gap: clamp(18px, 4vw, 58px);
    grid-template-columns: minmax(0, 0.95fr) minmax(260px, 0.82fr);
    margin-inline: auto;
    max-width: 1480px;
    min-height: 430px;
    padding: clamp(24px, 4vw, 52px);
    position: relative;
  }

  .featured-copy {
    align-content: start;
    display: grid;
  }

  .featured-copy > span {
    color: var(--purple);
    font-size: 0.84rem;
    font-weight: 800;
    margin-bottom: 22px;
  }

  .featured-copy h2 {
    font-size: clamp(2rem, 4.3vw, 3.45rem);
    font-weight: 450;
    letter-spacing: 0;
    line-height: 1.04;
    margin-bottom: 24px;
    max-width: 680px;
  }

  .featured-copy p {
    color: #6b6873;
    font-size: clamp(0.98rem, 1.35vw, 1.14rem);
    line-height: 1.55;
    margin-bottom: 22px;
    max-width: 640px;
  }

  .featured-copy .primary-button {
    justify-self: start;
  }

  .paper-image,
  .paper-thumb {
    overflow: hidden;
    position: relative;
  }

  .paper-image {
    align-self: center;
    aspect-ratio: 1.75 / 1;
    border-radius: 8px;
    min-height: 230px;
  }

  .paper-image.jordan,
  .paper-thumb.jordan {
    background:
      linear-gradient(90deg, transparent 0 44%, rgba(255, 255, 255, 0.62) 44% 49%, transparent 49%),
      linear-gradient(14deg, rgba(235, 120, 58, 0.16), rgba(255, 244, 222, 0.86)),
      repeating-linear-gradient(153deg, rgba(212, 102, 47, 0.24) 0 2px, transparent 2px 20px),
      #f8e0c2;
  }

  .paper-image.jordan span,
  .paper-thumb.jordan span {
    background:
      linear-gradient(90deg, #111 0 34%, #ffffff 34% 68%, #17834c 68%),
      linear-gradient(135deg, transparent 0 44%, #d51d2a 44% 58%, transparent 58%);
    border-radius: 2px;
    box-shadow: 0 8px 18px rgba(70, 36, 20, 0.18);
    display: block;
    height: 34%;
    left: 48%;
    position: absolute;
    top: 28%;
    transform: translateX(-50%);
    width: 38%;
  }

  .paper-thumb.meeting {
    background:
      radial-gradient(circle at 26% 40%, #27344f 0 8%, transparent 9%),
      radial-gradient(circle at 72% 42%, #e6b48b 0 8%, transparent 9%),
      linear-gradient(135deg, #d7ecf4, #ffffff 48%, #f0d4bf);
  }

  .paper-thumb.bank {
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.18), transparent 54%),
      repeating-linear-gradient(90deg, rgba(106, 77, 54, 0.26) 0 10px, transparent 10px 42px),
      linear-gradient(135deg, #9d7b59, #d1bd9f);
  }

  .paper-thumb.bank::after {
    color: rgba(58, 39, 27, 0.68);
    content: "BANK";
    font-size: clamp(1.5rem, 3vw, 3rem);
    font-weight: 900;
    left: 50%;
    letter-spacing: 0.08em;
    position: absolute;
    top: 42%;
    transform: translate(-50%, -50%);
  }

  .carousel-controls {
    display: flex;
    gap: 12px;
    margin-top: 42px;
  }

  .carousel-controls button {
    background: #ffffff;
    border: 1px solid #d8d5dd;
    border-radius: 50%;
    cursor: pointer;
    height: 38px;
    position: relative;
    width: 38px;
  }

  .carousel-controls button::before {
    color: #4d4856;
    content: "<";
    font-weight: 900;
  }

  .carousel-controls button + button::before {
    content: ">";
  }

  .carousel-dots {
    bottom: 42px;
    display: flex;
    gap: 8px;
    left: 50%;
    position: absolute;
    transform: translateX(-50%);
  }

  .carousel-dots span {
    background: #cfcbd5;
    border-radius: 50%;
    height: 6px;
    width: 6px;
  }

  .carousel-dots .active {
    background: #625c6d;
  }

  .catalog {
    background: #ffffff;
    padding: 28px clamp(16px, 2.5vw, 34px) 62px;
  }

  .filter-bar,
  .results-row {
    align-items: center;
    display: flex;
    gap: 12px;
  }

  .filter-bar {
    background: #ffffff;
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: 0 12px 30px rgba(27, 20, 45, 0.04);
    flex-wrap: wrap;
    margin-bottom: 28px;
    padding: 16px;
  }

  .filter-bar strong,
  .results-row strong {
    color: #292531;
    font-size: 0.9rem;
  }

  .filter-bar select,
  .results-row select,
  .search-box {
    background: #f7f6f8;
    border: 1px solid transparent;
    border-radius: 6px;
    color: #67626f;
    min-height: 36px;
  }

  .filter-bar select,
  .results-row select {
    min-width: 150px;
    padding: 0 12px;
  }

  .search-box {
    align-items: center;
    display: flex;
    gap: 8px;
    min-width: min(100%, 230px);
    padding: 0 12px;
  }

  .search-box span {
    border: 2px solid #a7a2ad;
    border-radius: 50%;
    height: 14px;
    position: relative;
    width: 14px;
  }

  .search-box span::after {
    background: #a7a2ad;
    content: "";
    height: 2px;
    position: absolute;
    right: -6px;
    top: 9px;
    transform: rotate(45deg);
    width: 7px;
  }

  .search-box input {
    background: transparent;
    border: 0;
    color: #292531;
    min-height: 34px;
    min-width: 0;
    outline: 0;
    width: 100%;
  }

  .results-row {
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .paper-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .paper-card {
    background: #ffffff;
    border: 1px solid var(--line);
    border-radius: 8px;
    display: grid;
    min-height: 380px;
    overflow: hidden;
  }

  .paper-thumb {
    aspect-ratio: 1.65 / 1;
    min-height: 146px;
  }

  .paper-thumb.blank {
    background: #ffffff;
  }

  .paper-card-copy {
    align-content: start;
    display: grid;
    padding: 18px;
  }

  .meta-row {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .meta-row span {
    background: #f0eff2;
    border-radius: 999px;
    color: #4d4856;
    font-size: 0.66rem;
    font-weight: 850;
    letter-spacing: 0.03em;
    max-width: 100%;
    padding: 6px 9px;
    text-transform: uppercase;
  }

  .paper-card h2 {
    font-size: clamp(0.95rem, 1.12vw, 1.15rem);
    font-weight: 500;
    line-height: 1.28;
    margin-bottom: 22px;
  }

  .paper-card a {
    align-self: end;
    color: #2d2936;
    font-size: 0.82rem;
    font-weight: 800;
    margin-top: auto;
  }

  .pagination {
    align-items: center;
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-top: 52px;
  }

  .pagination a {
    color: #2f2a37;
    font-size: 0.9rem;
    font-weight: 800;
  }

  .pagination .current {
    background: #e8e6ea;
    border-radius: 3px;
    padding: 9px 12px;
  }

  .category-band {
    background: var(--purple-dark);
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    padding: 30px clamp(16px, 2.5vw, 34px);
  }

  .category-band a {
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.38);
    border-radius: 6px;
    color: #ffffff;
    display: flex;
    font-size: 0.9rem;
    font-weight: 800;
    justify-content: space-between;
    min-height: 50px;
    padding: 0 20px;
  }

  .ready-section,
  .resource-footer {
    background: #ffffff;
    padding-inline: clamp(16px, 2.5vw, 34px);
  }

  .ready-section {
    padding-block: 32px 40px;
  }

  .ready-section h2 {
    font-size: clamp(1.45rem, 2.2vw, 2rem);
    font-weight: 450;
