---
type SimpleNavLink = [label: string, href: string];
type NestedNavLink = {
  label: string;
  href: string;
  children: SimpleNavLink[];
};
type NavLink = SimpleNavLink | NestedNavLink;
type NavColumn = {
  title: string;
  href?: string;
  links: NavLink[];
};
type NavFeature = {
  title: string;
  text: string;
  cta: string;
  href: string;
};
type NavItem = {
  label: string;
  brand?: boolean;
  href?: string;
  columns?: NavColumn[];
  feature?: NavFeature;
};

