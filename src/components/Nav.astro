const mainItems = navItems;
const currentPath = Astro.url.pathname;
const isArabicPage = currentPath === "/ar/" || currentPath.startsWith("/ar/");
const englishLanguageHref = "/";
const arabicLanguageHref = "/ar/";

function isActive(href?: string) {
  if (!href || href.startsWith("#")) {
    return false;
  }

  const cleanHref = href.split("#")[0];
  const normalizedHref = cleanHref.endsWith("/") ? cleanHref : `${cleanHref}/`;
  const normalizedPath = currentPath.endsWith("/") ? currentPath : `${currentPath}/`;
  return normalizedPath === normalizedHref || (normalizedHref !== "/" && normalizedPath.startsWith(normalizedHref));
}

function isLinkActive(link: NavLink) {
  return Array.isArray(link)
    ? isActive(link[1])
    : isActive(link.href) || link.children.some(([, childHref]) => isActive(childHref));
}

function isNavItemActive(item: NavItem) {
  if (item.href) {
    return isActive(item.href);
  }

  return Boolean(
    item.feature && isActive(item.feature.href) ||
    item.columns?.some((column) =>
      isActive(column.href) || column.links.some((link) => isLinkActive(link))
    )
  );
}
---

<header class="seclore-nav">
  <a class="seclore-nav__logo" href="/" aria-label="seclore home">
    <img src="/images/home/seclore-logo-2026.svg" alt="" decoding="async" />
    <span>seclore</span>
  </a>

  <div class="seclore-nav__mobile-scroll">
  <nav class="seclore-nav__links" aria-label="Primary navigation">
    {mainItems.map((item) => (
      item.href || !item.columns || !item.feature ? (
        <a class:list={[{ "is-active": isNavItemActive(item) }]} href={item.href ?? "#top"} aria-current={isNavItemActive(item) ? "page" : undefined}>{item.label}</a>
      ) : (
        <div class:list={["seclore-nav__item", { "seclore-nav__item--wide": item.label === "ARMOR" || item.label === "Solutions", "seclore-nav__item--compact": item.label !== "ARMOR" && item.label !== "Solutions", "is-active": isNavItemActive(item) }]}>
          <button class="seclore-nav__trigger" type="button" aria-expanded="false">
            {item.label}
            <span class="seclore-nav__caret" aria-hidden="true"></span>
          </button>
          <div class="seclore-nav__mega">
            <div class="seclore-nav__mega-inner">
              <div class="seclore-nav__mega-columns">
                {item.columns.map((column) => (
                  <div class="seclore-nav__mega-column">
                    {"href" in column && column.href ? (
                      <a class:list={["seclore-nav__mega-title", { "is-active": isActive(column.href) }]} href={column.href} aria-current={isActive(column.href) ? "page" : undefined}>{column.title}</a>
                    ) : column.title ? (
                      <span class="seclore-nav__mega-title">{column.title}</span>
                    ) : null}
                    {column.links.map((link) => (
                      Array.isArray(link) ? (
                        <a class:list={["seclore-nav__mega-link", { "is-active": isActive(link[1]) }]} href={link[1]} aria-current={isActive(link[1]) ? "page" : undefined}>
                          <strong>{link[0]}</strong>
                          <small>Security controls that stay close to the data.</small>
                        </a>
                      ) : (
                        <div class="seclore-nav__mega-link-group">
                          <a class:list={["seclore-nav__mega-link", "seclore-nav__mega-parent-link", { "is-active": isActive(link.href) }]} href={link.href} aria-current={isActive(link.href) ? "page" : undefined}>
                            <strong>{link.label}</strong>
                            <small>Connected controls across enterprise systems.</small>
                          </a>
                          <div class="seclore-nav__mega-sublinks">
                            {link.children.map(([childLabel, childHref]) => (
                              <a class:list={[{ "is-active": isActive(childHref) }]} href={childHref} aria-current={isActive(childHref) ? "page" : undefined}>{childLabel}</a>
                            ))}
                          </div>
                        </div>
                      )
                    ))}
                  </div>
                ))}
              </div>
              <a class="seclore-nav__mega-feature" href={item.feature.href}>
                <span>{item.feature.title}</span>
                <strong>{item.feature.text}</strong>
                <em>{item.feature.cta}</em>
              </a>
            </div>
          </div>
        </div>
      )
    ))}
  </nav>

  <div class="seclore-nav__utilities" aria-label="Header utilities">
    <a class="seclore-nav__utility-link seclore-nav__file-help" href="/how-to-open-a-seclore-protected-file/">How to open a seclore file</a>
    <button class="seclore-nav__utility-label seclore-nav__search-open" type="button" aria-label="Open search">
      <span>Search</span>
      <span class="seclore-nav__search-icon" aria-hidden="true"></span>
    </button>
    <div class="seclore-nav__mobile-search-panel" aria-hidden="true">
      <form class="seclore-nav__mobile-search-form" action="/resources/" role="search">
        <label class="seclore-nav__search-field-label" for="seclore-nav-mobile-search">Search</label>
        <input id="seclore-nav-mobile-search" name="search" type="search" placeholder="Enter keyword and search" autocomplete="off" />
      </form>
    </div>
    <button class="seclore-nav__utility-label seclore-nav__language-open" type="button" aria-label="Open language selector">
      <span>Language</span>
      <span class="seclore-nav__globe-icon seclore-nav__utility-globe" aria-hidden="true"></span>
      <span class="seclore-nav__language-caret" aria-hidden="true"></span>
    </button>
    <button class="seclore-nav__language-button seclore-nav__language-open" type="button" aria-label="Open language selector">
      <span class="seclore-nav__globe-icon" aria-hidden="true"></span>
    </button>
    <div class="seclore-nav__language-menu" aria-hidden="true">
      <a class:list={[{ "is-active": !isArabicPage }]} href={englishLanguageHref} lang="en" aria-current={!isArabicPage ? "true" : undefined}>
        English
        {!isArabicPage && <span class="seclore-nav__language-check" aria-hidden="true"></span>}
      </a>
      <a class:list={[{ "is-active": isArabicPage }]} href={arabicLanguageHref} lang="ar" dir="rtl" aria-current={isArabicPage ? "true" : undefined}>
        العربية
        {isArabicPage && <span class="seclore-nav__language-check" aria-hidden="true"></span>}
      </a>
    </div>
    <button class="seclore-nav__theme-toggle" type="button" aria-label="Switch to light mode" aria-pressed="true">
      <span class="seclore-nav__theme-toggle-track" aria-hidden="true">
        <span class="seclore-nav__theme-toggle-thumb"></span>
      </span>
      <span class="seclore-nav__theme-toggle-text">Dark</span>
    </button>
  </div>
  </div>

  <a class="seclore-nav__demo-button" href="/demo/">
    <span class="seclore-nav__demo-label-full">Book a Demo</span>
    <span class="seclore-nav__demo-label-mobile">Book a<br />Demo</span>
  </a>

  <button class="seclore-nav__toggle" type="button" aria-label="Open navigation" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <div class="seclore-nav__search-panel" aria-hidden="true">
    <form class="seclore-nav__search-form" action="/resources/" role="search">
      <label class="seclore-nav__search-field-label" for="seclore-nav-search">Search</label>
      <input id="seclore-nav-search" name="search" type="search" placeholder="Enter keyword and search" autocomplete="off" />
      <button class="seclore-nav__search-submit" type="submit" aria-label="Submit search">
        <span class="seclore-nav__search-panel-icon" aria-hidden="true"></span>
      </button>
    </form>
  </div>
</header>

<script>
  const nav = document.querySelector(".seclore-nav");
  const navLogo = document.querySelector(".seclore-nav__logo");
  const navToggle = document.querySelector(".seclore-nav__toggle");
  const navDemoButton = document.querySelector(".seclore-nav__demo-button");
  const navScrollPanel = document.querySelector(".seclore-nav__mobile-scroll");
  const navLinks = document.querySelector(".seclore-nav__links");
  const navTriggers = document.querySelectorAll(".seclore-nav__trigger");
  const searchPanel = document.querySelector(".seclore-nav__search-panel");
  const mobileSearchPanel = document.querySelector(".seclore-nav__mobile-search-panel");
  const searchOpeners = document.querySelectorAll(".seclore-nav__search-open");
  const searchInput = document.querySelector<HTMLInputElement>("#seclore-nav-search");
  const mobileSearchInput = document.querySelector<HTMLInputElement>("#seclore-nav-mobile-search");
  const languagePanel = document.querySelector(".seclore-nav__language-menu");
  const languageOpeners = document.querySelectorAll(".seclore-nav__language-open");
  const themeToggle = document.querySelector(".seclore-nav__theme-toggle");
  const themeText = document.querySelector(".seclore-nav__theme-toggle-text");
  const mobileMenuCloseDuration = 360;
  let mobileMenuCloseTimer: number | undefined;
  let bodyScrollLocked = false;
  let previousBodyOverflow = "";
  let previousHtmlOverflow = "";
  const mobileMenuToggleLockProperties = [
    "--seclore-logo-close-top",
    "--seclore-logo-close-left",
    "--seclore-logo-close-width",
    "--seclore-logo-close-height",
    "--seclore-toggle-close-top",
    "--seclore-toggle-close-left",
    "--seclore-toggle-close-width",
    "--seclore-toggle-close-height",
    "--seclore-demo-close-top",
    "--seclore-demo-close-left",
    "--seclore-demo-close-width",
    "--seclore-demo-close-height",
  ];

  function lockMobileTogglePosition() {
    if (navLogo instanceof HTMLElement) {
      const logoRect = navLogo.getBoundingClientRect();
      navLogo.style.setProperty("--seclore-logo-close-top", `${logoRect.top}px`);
      navLogo.style.setProperty("--seclore-logo-close-left", `${logoRect.left}px`);
      navLogo.style.setProperty("--seclore-logo-close-width", `${logoRect.width}px`);
      navLogo.style.setProperty("--seclore-logo-close-height", `${logoRect.height}px`);
    }

    if (navDemoButton instanceof HTMLElement) {
      const demoRect = navDemoButton.getBoundingClientRect();
      navDemoButton.style.setProperty("--seclore-demo-close-top", `${demoRect.top}px`);
      navDemoButton.style.setProperty("--seclore-demo-close-left", `${demoRect.left}px`);
      navDemoButton.style.setProperty("--seclore-demo-close-width", `${demoRect.width}px`);
      navDemoButton.style.setProperty("--seclore-demo-close-height", `${demoRect.height}px`);
    }

    if (navToggle instanceof HTMLElement) {
      const rect = navToggle.getBoundingClientRect();
      navToggle.style.setProperty("--seclore-toggle-close-top", `${rect.top}px`);
      navToggle.style.setProperty("--seclore-toggle-close-left", `${rect.left}px`);
      navToggle.style.setProperty("--seclore-toggle-close-width", `${rect.width}px`);
      navToggle.style.setProperty("--seclore-toggle-close-height", `${rect.height}px`);
    }
  }

  function clearMobileTogglePositionLock() {
    mobileMenuToggleLockProperties.forEach((property) => {
      if (navLogo instanceof HTMLElement) navLogo.style.removeProperty(property);
      if (navToggle instanceof HTMLElement) navToggle.style.removeProperty(property);
      if (navDemoButton instanceof HTMLElement) navDemoButton.style.removeProperty(property);
    });
  }

  function setBodyScrollLock(locked: boolean) {
    if (locked && !bodyScrollLocked) {
      previousBodyOverflow = document.body.style.overflow;
      previousHtmlOverflow = document.documentElement.style.overflow;
      document.documentElement.style.overflow = "hidden";
      document.body.style.overflow = "hidden";
      bodyScrollLocked = true;
      return;
    }

    if (!locked && bodyScrollLocked) {
      document.documentElement.style.overflow = previousHtmlOverflow;
      document.body.style.overflow = previousBodyOverflow;
      bodyScrollLocked = false;
    }
  }

  function closeLanguagePanel() {
    nav?.classList.remove("is-language-open");
    languagePanel?.setAttribute("aria-hidden", "true");
  }

  function closeSearchPanel() {
    nav?.classList.remove("is-search-open");
    nav?.classList.remove("is-mobile-search-open");
    searchPanel?.setAttribute("aria-hidden", "true");
    mobileSearchPanel?.setAttribute("aria-hidden", "true");
  }

  function focusSearchInput(input: HTMLInputElement | null, preventScroll = false) {
    window.setTimeout(() => input?.focus({ preventScroll }), 180);
  }

  function openSearchPanel() {
    const isMobileMenu = window.matchMedia("(max-width: 1180px)").matches && nav?.classList.contains("is-menu-open");
    if (isMobileMenu) {
      closeLanguagePanel();
      nav?.classList.add("is-mobile-search-open");
      mobileSearchPanel?.setAttribute("aria-hidden", "false");
      return;
    }
    closeMobileMenu();
    closeLanguagePanel();
    nav?.classList.add("is-search-open");
    searchPanel?.setAttribute("aria-hidden", "false");
    focusSearchInput(searchInput);
  }

  function toggleLanguagePanel() {
    closeSearchPanel();
    const open = !nav?.classList.contains("is-language-open");
    nav?.classList.toggle("is-language-open", open);
    languagePanel?.setAttribute("aria-hidden", String(!open));
  }

  function finishMobileMenuClose() {
    nav?.classList.remove("is-menu-open");
    nav?.classList.remove("is-menu-closing");
    navLinks?.classList.remove("open");
    mobileSearchPanel?.setAttribute("aria-hidden", "true");
    navToggle?.setAttribute("aria-expanded", "false");
    navToggle?.setAttribute("aria-label", "Open navigation");
    clearMobileTogglePositionLock();
    document.body.classList.remove("seclore-nav-lock");
    setBodyScrollLock(false);
    document.querySelectorAll(".seclore-nav__item.is-open").forEach((item) => {
      item.classList.remove("is-open");
      item.querySelector(".seclore-nav__trigger")?.setAttribute("aria-expanded", "false");
    });
  }

  function closeMobileMenu(immediate = false) {
    window.clearTimeout(mobileMenuCloseTimer);

    if (!nav?.classList.contains("is-menu-open")) {
      finishMobileMenuClose();
      return;
    }

    if (immediate || window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      finishMobileMenuClose();
      return;
    }

    lockMobileTogglePosition();
    nav.classList.add("is-menu-closing");
    mobileMenuCloseTimer = window.setTimeout(finishMobileMenuClose, mobileMenuCloseDuration);
  }

  function setTheme(theme: string) {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem("theme", theme);
    const isDark = theme === "dark";
    themeToggle?.setAttribute("aria-pressed", String(isDark));
    themeToggle?.setAttribute("aria-label", isDark ? "Switch to light mode" : "Switch to dark mode");
    if (themeText) {
      themeText.textContent = isDark ? "Dark" : "Light";
    }
  }

  setTheme(document.documentElement.dataset.theme || "dark");

  themeToggle?.addEventListener("click", () => {
    const nextTheme = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    setTheme(nextTheme);
  });

  searchOpeners.forEach((opener) => {
    opener.addEventListener("click", (event) => {
      event.stopPropagation();
      const isMobileMenu =
        window.matchMedia("(max-width: 1180px)").matches && nav?.classList.contains("is-menu-open");
      if (nav?.classList.contains("is-search-open")) {
        (isMobileMenu ? mobileSearchInput : searchInput)?.focus({ preventScroll: isMobileMenu });
        return;
      }
      if (isMobileMenu && nav?.classList.contains("is-mobile-search-open")) {
        mobileSearchInput?.focus({ preventScroll: true });
        return;
      }
      openSearchPanel();
    });
  });

  languageOpeners.forEach((opener) => {
    opener.addEventListener("click", (event) => {
      event.stopPropagation();
      toggleLanguagePanel();
    });
  });

  navToggle?.addEventListener("click", () => {
    const expanded = navToggle.getAttribute("aria-expanded") === "true";
    const open = !expanded;

    if (!open) {
      closeMobileMenu();
      return;
    }

    window.clearTimeout(mobileMenuCloseTimer);
    lockMobileTogglePosition();
    nav?.classList.remove("is-menu-closing");
    nav?.classList.toggle("is-menu-open", open);
    if (nav) {
      nav.scrollTop = 0;
    }
    navScrollPanel?.scrollTo({ top: 0, behavior: "auto" });
    navLinks?.classList.toggle("open", open);
    mobileSearchPanel?.setAttribute("aria-hidden", "true");
    navToggle.setAttribute("aria-expanded", String(open));
    navToggle.setAttribute("aria-label", open ? "Close navigation" : "Open navigation");
    document.body.classList.toggle("seclore-nav-lock", open);
    setBodyScrollLock(open);
    if (open) {
      closeSearchPanel();
      closeLanguagePanel();
    }
  });

  navTriggers.forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const item = trigger.closest(".seclore-nav__item");
      const expanded = trigger.getAttribute("aria-expanded") === "true";

      document.querySelectorAll(".seclore-nav__item.is-open").forEach((openItem) => {
        if (openItem !== item) {
          openItem.classList.remove("is-open");
          openItem.querySelector(".seclore-nav__trigger")?.setAttribute("aria-expanded", "false");
        }
      });

      item?.classList.toggle("is-open", !expanded);
      trigger.setAttribute("aria-expanded", String(!expanded));
    });
  });

  document.addEventListener("click", (event) => {
    if (!(event.target instanceof Element) || !event.target.closest(".seclore-nav")) {
      closeSearchPanel();
      closeLanguagePanel();
      document.querySelectorAll(".seclore-nav__item.is-open").forEach((item) => {
        item.classList.remove("is-open");
        item.querySelector(".seclore-nav__trigger")?.setAttribute("aria-expanded", "false");
      });
    }
  });

  nav?.addEventListener("click", (event) => {
    if (!(event.target instanceof Element)) {
      return;
    }

    const link = event.target.closest("a[href]");
    if (!(link instanceof HTMLAnchorElement)) {
      return;
    }

    const href = link.getAttribute("href");
    const isModifiedClick = event instanceof MouseEvent && (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0);

    if (!href || isModifiedClick) {
      return;
    }

    if (window.matchMedia("(max-width: 1180px)").matches && nav.classList.contains("is-menu-open")) {
      if (!href.startsWith("#")) {
        event.preventDefault();
        const destination = link.href;
        closeMobileMenu();
        window.location.assign(destination);
        return;
      }

      window.setTimeout(closeMobileMenu, 0);
    }
  }, true);

  window.addEventListener("resize", () => {
    if (window.matchMedia("(min-width: 1181px)").matches) {
      closeMobileMenu(true);
    }
  });

