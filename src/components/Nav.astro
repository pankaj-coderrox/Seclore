const mainItems = navItems;
const currentPath = Astro.url.pathname;

function isActive(href?: string) {
  if (!href || href.startsWith("#")) {
    return false;
  }

  const normalizedHref = href.endsWith("/") ? href : `${href}/`;
  const normalizedPath = currentPath.endsWith("/") ? currentPath : `${currentPath}/`;
  return normalizedPath === normalizedHref || (normalizedHref !== "/" && normalizedPath.startsWith(normalizedHref));
}
---

<header class="seclore-nav">
  <a class="seclore-nav__logo" href="/" aria-label="seclore home">seclore</a>

  <nav class="seclore-nav__links" aria-label="Primary navigation">
    {mainItems.map((item) => (
      item.href || !item.columns || !item.feature ? (
        <a class:list={[{ "is-active": isActive(item.href) }]} href={item.href ?? "#top"} aria-current={isActive(item.href) ? "page" : undefined}>{item.label}</a>
      ) : (
        <div class:list={["seclore-nav__item", { "is-active": item.columns.some((column) => column.links.some((link) => Array.isArray(link) ? isActive(link[1]) : isActive(link.href) || link.children.some(([, childHref]) => isActive(childHref)))) }]}>
          <button class="seclore-nav__trigger" type="button" aria-expanded="false">
            {item.label}
            <span class="seclore-nav__caret" aria-hidden="true"></span>
          </button>
          <div class="seclore-nav__mega">
            <div class="seclore-nav__mega-inner">
              <div class="seclore-nav__mega-columns">
                {item.columns.map((column) => (
                  <div class="seclore-nav__mega-column">
                    <span class="seclore-nav__mega-title">{column.title}</span>
                    {column.links.map((link) => (
                      Array.isArray(link) ? (
                        <a class:list={["seclore-nav__mega-link", { "is-active": isActive(link[1]) }]} href={link[1]} aria-current={isActive(link[1]) ? "page" : undefined}>
                          <strong>{link[0]}</strong>
                          <small>Security controls that stay close to the data.</small>
                        </a>
                      ) : (
                        <div class="seclore-nav__mega-link-group">
                          <a class:list={["seclore-nav__mega-link", "seclore-nav__mega-parent-link", { "is-active": isActive(link.href) }]} href={link.href} aria-current={isActive(link.href) ? "page" : undefined}>
                            <strong>{link.label}</strong>
                            <small>Connected controls across enterprise systems.</small>
                          </a>
                          <div class="seclore-nav__mega-sublinks">
                            {link.children.map(([childLabel, childHref]) => (
                              <a class:list={[{ "is-active": isActive(childHref) }]} href={childHref} aria-current={isActive(childHref) ? "page" : undefined}>{childLabel}</a>
                            ))}
                          </div>
                        </div>
                      )
                    ))}
                  </div>
                ))}
              </div>
              <a class="seclore-nav__mega-feature" href={item.feature.href}>
                <span>{item.feature.title}</span>
                <strong>{item.feature.text}</strong>
                <em>{item.feature.cta}</em>
              </a>
            </div>
          </div>
        </div>
      )
    ))}
  </nav>

  <div class="seclore-nav__utilities" aria-label="Header utilities">
    <a class="seclore-nav__utility-link seclore-nav__file-help" href="/how-to-open-a-seclore-protected-file/">How to open a seclore file</a>
    <span class="seclore-nav__utility-label">Search</span>
    <button class="seclore-nav__utility-icon" type="button" aria-label="Search">
      <span class="seclore-nav__search-icon" aria-hidden="true"></span>
    </button>
    <span class="seclore-nav__utility-label">Language</span>
    <button class="seclore-nav__language-button" type="button" aria-label="Language selector">
      <span class="seclore-nav__globe-icon" aria-hidden="true"></span>
    </button>
    <button class="seclore-nav__theme-toggle" type="button" aria-label="Switch to light mode" aria-pressed="true">
      <span class="seclore-nav__theme-toggle-track" aria-hidden="true">
        <span class="seclore-nav__theme-toggle-thumb"></span>
      </span>
      <span class="seclore-nav__theme-toggle-text">Dark</span>
    </button>
  </div>

  <a class="seclore-nav__demo-button" href="#demo">Book a Demo</a>

  <button class="seclore-nav__toggle" type="button" aria-label="Open navigation" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>
</header>

<script>
  const navToggle = document.querySelector(".seclore-nav__toggle");
  const navLinks = document.querySelector(".seclore-nav__links");
  const navTriggers = document.querySelectorAll(".seclore-nav__trigger");
  const themeToggle = document.querySelector(".seclore-nav__theme-toggle");
  const themeText = document.querySelector(".seclore-nav__theme-toggle-text");

  function setTheme(theme: string) {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem("theme", theme);
    const isDark = theme === "dark";
    themeToggle?.setAttribute("aria-pressed", String(isDark));
    themeToggle?.setAttribute("aria-label", isDark ? "Switch to light mode" : "Switch to dark mode");
    if (themeText) {
      themeText.textContent = isDark ? "Dark" : "Light";
    }
  }

  setTheme(document.documentElement.dataset.theme || "dark");

  themeToggle?.addEventListener("click", () => {
    const nextTheme = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    setTheme(nextTheme);
  });

  navToggle?.addEventListener("click", () => {
    const expanded = navToggle.getAttribute("aria-expanded") === "true";
    navToggle.setAttribute("aria-expanded", String(!expanded));
    navLinks?.classList.toggle("open");
  });

  navTriggers.forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const item = trigger.closest(".seclore-nav__item");
      const expanded = trigger.getAttribute("aria-expanded") === "true";

      document.querySelectorAll(".seclore-nav__item.is-open").forEach((openItem) => {
        if (openItem !== item) {
          openItem.classList.remove("is-open");
          openItem.querySelector(".seclore-nav__trigger")?.setAttribute("aria-expanded", "false");
        }
      });

      item?.classList.toggle("is-open", !expanded);
      trigger.setAttribute("aria-expanded", String(!expanded));
    });
  });

  document.addEventListener("click", (event) => {
    if (!(event.target instanceof Element) || !event.target.closest(".seclore-nav")) {
      document.querySelectorAll(".seclore-nav__item.is-open").forEach((item) => {
        item.classList.remove("is-open");
        item.querySelector(".seclore-nav__trigger")?.setAttribute("aria-expanded", "false");
      });
    }
  });

  document.querySelectorAll(".seclore-nav__mega-link, .seclore-nav__mega-feature, .seclore-nav__mega-sublinks a, .seclore-nav__links > a").forEach((link) => {
    link.addEventListener("click", () => {
      navLinks?.classList.remove("open");
      navToggle?.setAttribute("aria-expanded", "false");
      document.querySelectorAll(".seclore-nav__item.is-open").forEach((item) => {
        item.classList.remove("is-open");
        item.querySelector(".seclore-nav__trigger")?.setAttribute("aria-expanded", "false");
      });
    });
  });
</script>

<style is:global>
  .seclore-nav,
  .seclore-nav * {
    box-sizing: border-box;
  }

  .seclore-nav {
    --seclore-nav-header-bg: #ffffff;
    --seclore-nav-header-border: rgba(15, 23, 42, 0.08);
    --seclore-nav-header-shadow: 0 10px 28px rgba(8, 19, 33, 0.05);
    --seclore-nav-header-text: #07111f;
    --seclore-nav-header-muted: #2a2a2a;
    --seclore-nav-purple: #5630d6;
    --seclore-nav-dropdown-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    --seclore-nav-dropdown-grid-line: rgba(10, 42, 75, 0.035);
    --seclore-nav-dropdown-border: rgba(15, 23, 42, 0.1);
    --seclore-nav-dropdown-link-hover: rgba(15, 76, 129, 0.055);
    --seclore-nav-dropdown-link-border: rgba(15, 76, 129, 0.16);
    --seclore-nav-dropdown-title: #0b5cad;
    --seclore-nav-dropdown-text: #101828;
    --seclore-nav-dropdown-muted: #667085;
    --seclore-nav-dropdown-feature-bg: linear-gradient(160deg, rgba(15, 92, 173, 0.12), rgba(11, 140, 115, 0.08)), rgba(15, 76, 129, 0.04);
    --seclore-nav-dropdown-feature-border: rgba(15, 76, 129, 0.14);
    --seclore-nav-demo-button-bg: #5630d6;
    --seclore-nav-demo-button-text: #ffffff;
    --seclore-nav-shadow: 0 24px 80px rgba(0, 0, 0, 0.16);
    align-items: center;
    background: var(--seclore-nav-header-bg);
    border-bottom: 1px solid var(--seclore-nav-header-border);
    box-shadow: var(--seclore-nav-header-shadow);
    color: var(--seclore-nav-header-text);
    display: flex;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    gap: 18px;
    left: 0;
    min-height: 68px;
    padding: 0 clamp(20px, 4vw, 42px) 0 22px;
    position: sticky;
    right: 0;
    top: 0;
    z-index: 1000;
  }

  .seclore-nav a {
    color: inherit;
    text-decoration: none;
  }

  .seclore-nav button {
    font: inherit;
  }

  .seclore-nav__logo,
  .seclore-nav__links,
  .seclore-nav__utilities {
    align-items: center;
    display: flex;
  }

  .seclore-nav__logo {
    color: var(--seclore-nav-header-text);
    flex: 0 0 auto;
    font-size: 1.35rem;
    font-weight: 900;
    letter-spacing: 0;
    line-height: 1;
    margin-right: clamp(14px, 2vw, 28px);
    white-space: nowrap;
  }

  .seclore-nav__links {
    flex: 1 1 auto;
    flex-wrap: nowrap;
    gap: clamp(18px, 2.2vw, 34px);
    justify-content: center;
    min-width: 0;
  }

  .seclore-nav__links > a,
  .seclore-nav__trigger {
    align-items: center;
    background: transparent;
    border: 0;
    border-radius: 8px;
    color: var(--seclore-nav-header-muted);
    cursor: pointer;
    display: inline-flex;
    flex: 0 0 auto;
    font-size: 0.98rem;
    font-weight: 800;
    gap: 8px;
    min-height: 68px;
    padding: 0;
    white-space: nowrap;
  }

  .seclore-nav__links > a:hover,
  .seclore-nav__links > a.is-active,
  .seclore-nav__trigger:hover,
  .seclore-nav__item.is-active > .seclore-nav__trigger,
  .seclore-nav__item:focus-within .seclore-nav__trigger,
  .seclore-nav__item:hover .seclore-nav__trigger {
    color: var(--seclore-nav-header-text);
  }

  .seclore-nav__item {
    position: static;
  }

  .seclore-nav__caret {
    border-bottom: 2px solid currentColor;
    border-right: 2px solid currentColor;
    display: inline-block;
    height: 8px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 180ms ease;
    width: 8px;
  }

  .seclore-nav__item:hover .seclore-nav__caret,
  .seclore-nav__item:focus-within .seclore-nav__caret,
  .seclore-nav__item.is-open .seclore-nav__caret {
    transform: rotate(225deg) translateY(-1px);
  }

  .seclore-nav__utilities {
    flex: 0 0 auto;
    gap: clamp(12px, 1.5vw, 20px);
    margin-left: clamp(12px, 2vw, 28px);
  }

  .seclore-nav__utility-link,
  .seclore-nav__utility-label,
  .seclore-nav__language-button,
  .seclore-nav__utility-icon,
  .seclore-nav__theme-toggle {
    color: var(--seclore-nav-header-muted);
    font-size: 0.88rem;
    font-weight: 750;
    white-space: nowrap;
  }

  .seclore-nav__utility-icon,
  .seclore-nav__language-button,
  .seclore-nav__theme-toggle {
    align-items: center;
    background: transparent;
    border: 0;
    cursor: pointer;
    display: inline-flex;
    gap: 8px;
    padding: 0;
  }

  .seclore-nav__theme-toggle {
    font-weight: 800;
  }

  .seclore-nav__theme-toggle-track {
    align-items: center;
    background: rgba(127, 139, 155, 0.24);
    border: 1px solid var(--seclore-nav-header-border);
    border-radius: 999px;
    display: inline-flex;
    height: 24px;
    padding: 2px;
    transition: background 180ms ease, border-color 180ms ease;
    width: 44px;
  }

  .seclore-nav__theme-toggle-thumb {
    background: var(--seclore-nav-header-text);
    border-radius: 50%;
    display: block;
    height: 18px;
    transform: translateX(18px);
    transition: background 180ms ease, transform 180ms ease;
    width: 18px;
  }

  html[data-theme="light"] .seclore-nav__theme-toggle-thumb {
    transform: translateX(0);
  }

  .seclore-nav__search-icon {
    border: 2px solid currentColor;
    border-radius: 50%;
    display: inline-block;
    height: 17px;
    position: relative;
    width: 17px;
  }

  .seclore-nav__search-icon::after {
    background: currentColor;
    content: "";
    height: 2px;
    position: absolute;
    right: -6px;
    top: 12px;
    transform: rotate(45deg);
    width: 8px;
  }

  .seclore-nav__globe-icon {
    border: 2px solid currentColor;
    border-radius: 50%;
    display: inline-block;
    height: 20px;
    position: relative;
    width: 20px;
  }

  .seclore-nav__globe-icon::before,
  .seclore-nav__globe-icon::after {
    content: "";
    position: absolute;
  }

  .seclore-nav__globe-icon::before {
    border-inline: 1px solid currentColor;
    border-radius: 50%;
    inset: 1px 5px;
  }

  .seclore-nav__globe-icon::after {
    border-top: 1px solid currentColor;
    left: 2px;
    right: 2px;
    top: 8px;
  }

  .seclore-nav__demo-button {
    align-items: center;
    background: var(--seclore-nav-demo-button-bg);
    border-radius: 999px;
    color: var(--seclore-nav-demo-button-text);
    display: inline-flex;
    font-size: 0.9rem;
    font-weight: 850;
    justify-content: center;
    min-height: 42px;
    padding: 0 18px;
    white-space: nowrap;
  }

  .seclore-nav__mega {
    left: 22px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    right: clamp(20px, 4vw, 42px);
    top: calc(100% - 1px);
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .seclore-nav__item:hover .seclore-nav__mega,
  .seclore-nav__item:focus-within .seclore-nav__mega,
  .seclore-nav__item.is-open .seclore-nav__mega {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .seclore-nav__mega-inner {
    background:
      var(--seclore-nav-dropdown-bg),
      repeating-linear-gradient(
        135deg,
        var(--seclore-nav-dropdown-grid-line) 0,
        var(--seclore-nav-dropdown-grid-line) 1px,
        transparent 1px,
        transparent 20px
      );
    border: 1px solid var(--seclore-nav-dropdown-border);
    border-radius: 8px;
    box-shadow: var(--seclore-nav-shadow);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    min-height: 320px;
    overflow: hidden;
    padding: 26px;
  }

  .seclore-nav__mega-columns {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .seclore-nav__mega-column {
    display: grid;
    gap: 10px;
  }

  .seclore-nav__mega-title {
    color: var(--seclore-nav-dropdown-title);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    margin-bottom: 4px;
    text-transform: uppercase;
  }

  .seclore-nav__mega-link,
  .seclore-nav__mega-link-group {
    border: 1px solid transparent;
    border-radius: 8px;
  }

  .seclore-nav__mega-link {
    display: grid;
