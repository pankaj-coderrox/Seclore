---
const footerGroups = [
  {
    title: "Product",
    links: [
      ["ARMOR", "/armor/"],
      ["DSPM", "/armor/dspm/"],
      ["AI-DLP", "/armor/aidlp/"],
      ["Data Classification", "/platform/classification/"],
      ["Integrations", "/integrations/"],
      ["Pricing", "/pricing/"],
      ["Resources", "/resources/"]
    ]
  },
  {
    title: "Support",
    links: [
      ["Support Portal", "/support/home/"],
      ["Solutions", "/support/solutions/"],
      ["New Support Ticket", "/support/tickets/new/"],
      ["Contact Support", "/support/tickets/new/"],
      ["How to Open a Seclore File", "/how-to-open-a-seclore-protected-file/"]
    ]
  },
  {
    title: "About",
    links: [
      ["Why Seclore", "/about/why-seclore/"],
      ["Leadership", "/about/leadership/"],
      ["Newsroom", "/about/newsroom/"],
      ["Press Releases", "/about/press-releases/"],
      ["Contact Us", "/about/contact-us/"],
      ["Careers", "/about/careers/"]
    ]
  },
  {
    title: "Regulations",
    links: [
      ["NIAP", "/solutions/government/"],
      ["NCA", "/solutions/government/"],
      ["PCI-DSS", "/solutions/financial-services/"],
      ["ITAR", "/solutions/manufacturing/"],
      ["GLBA", "/solutions/financial-services/"],
      ["NIST", "/solutions/compliance/"],
      ["NYCRR", "/solutions/financial-services/"],
      ["CCPA", "/solutions/compliance/"],
      ["DORA", "/solutions/financial-services/"],
      ["GDPR", "/solutions/compliance/"],
      ["NIS2", "/solutions/compliance/"],
      ["SDAIA-PDPL", "/solutions/compliance/"],
      ["UAE-PDPL", "/solutions/compliance/"],
      ["UAE CR #21", "/solutions/compliance/"],
      ["IRDAI", "/solutions/financial-services/"],
      ["DPDP", "/solutions/compliance/"]
    ]
  }
];

const appLinks = {
  google: "https://play.google.com/store/apps/details?id=com.seclore.filesecure.android.lite&hl=en_US",
  apple: "https://apps.apple.com/us/app/seclore/id526784478"
};

const footerSocials = [
  ["Facebook", "https://www.facebook.com/Seclore", "f"],
  ["LinkedIn", "https://www.linkedin.com/company/seclore", "in"],
  ["X", "https://x.com/seclore", "x"],
  ["YouTube", "https://www.youtube.com/@Seclore", "yt"],
  ["Instagram", "https://www.instagram.com/seclore", "ig"],
  ["Bluesky", "https://bsky.app/profile/seclore.bsky.social", "b"]
];
---

<footer class="seclore-footer">
  <div class="seclore-footer__inner">
    <section class="seclore-footer__ready" aria-labelledby="seclore-footer-ready-title">
      <div class="seclore-footer__ready-copy">
        <h2 id="seclore-footer-ready-title">Ready to get started?</h2>
        <p>Contact our sales team to find out how Seclore can help with data security and compliance.</p>
        <a href="/demo/">Book a Demo</a>
      </div>
    </section>

    <nav class="seclore-footer__accordions" aria-label="Footer navigation">
      {footerGroups.map((group) => (
        <details class="seclore-footer__details" data-footer-details>
          <summary>
            <span>{group.title}</span>
            <span class="seclore-footer__chevron" aria-hidden="true"></span>
          </summary>
          <div class:list={["seclore-footer__panel", { "seclore-footer__panel--split": group.title === "Regulations" }]}>
            {group.links.map(([label, href]) => <a href={href}>{label}</a>)}
          </div>
        </details>
      ))}
    </nav>

    <section class="seclore-footer__contact" aria-label="Seclore contact information">
      <a class="seclore-footer__brand" href="/" aria-label="Seclore home">
        <img src="/images/home/seclore-logo-2026.svg" alt="Seclore" loading="lazy" decoding="async" />
      </a>

      <address>5201 Great America Parkway Suite 440 Santa Clara, CA 95054</address>

      <p class="seclore-footer__phones">
        <a href="tel:18444732567">1-844-4-Seclore</a>
        <a href="tel:18444732567">1-844-473-2567</a>
      </p>

      <a class="seclore-footer__email" href="mailto:hello@seclore.com">hello@seclore.com</a>

      <div class="seclore-footer__stores" aria-label="Download Seclore apps">
        <a class="seclore-footer__store seclore-footer__store--google" href={appLinks.google} target="_blank" rel="noreferrer" aria-label="Get Seclore on Google Play">
          <img src="/images/footer/google-play-badge.svg" alt="Get it on Google Play" loading="lazy" decoding="async" />
        </a>
        <a class="seclore-footer__store seclore-footer__store--apple" href={appLinks.apple} target="_blank" rel="noreferrer" aria-label="Download Seclore on the App Store">
          <img src="/images/footer/app-store-badge.svg" alt="Download on the App Store" loading="lazy" decoding="async" />
        </a>
      </div>
    </section>

    <div class="seclore-footer__bottom">
      <nav class="seclore-footer__socials" aria-label="Social media links">
        {footerSocials.map(([label, href, icon]) => (
          <a href={href} target="_blank" rel="noreferrer" aria-label={label} class={`seclore-footer__social seclore-footer__social--${icon}`}>
            <span aria-hidden="true">{icon === "yt" ? "" : icon}</span>
          </a>
        ))}
      </nav>
      <p>&copy; 2026 Seclore. All Rights Reserved. <a href="https://license.seclore.com/licensingportal/static/html/privacy.html" target="_blank" rel="noreferrer">Legal</a></p>
    </div>
  </div>
</footer>

<script>
  const footerDetails = Array.from(document.querySelectorAll("[data-footer-details]"));

  footerDetails.forEach((details) => {
    details.addEventListener("toggle", () => {
      if (!(details instanceof HTMLDetailsElement) || !details.open) {
        return;
      }

      footerDetails.forEach((otherDetails) => {
        if (otherDetails !== details && otherDetails instanceof HTMLDetailsElement) {
          otherDetails.open = false;
        }
      });
    });
  });
</script>

<style is:global>
  .seclore-footer,
  .seclore-footer * {
    box-sizing: border-box;
  }

  .seclore-footer {
    background: #ffffff;
    color: #2b2d32;
    font-family: Inter, "Helvetica Neue", Arial, sans-serif;
    padding: 0 clamp(20px, 3vw, 38px) 28px;
  }

  .seclore-footer a {
    color: inherit;
    text-decoration: none;
  }

  .seclore-footer a:hover {
    color: #5630d6;
  }

  .seclore-footer__inner {
    margin: 0 auto;
    max-width: 1220px;
    width: 100%;
  }

  .seclore-footer__ready {
    padding: clamp(36px, 5vw, 56px) 0 32px;
  }

  .seclore-footer__ready h2 {
    color: #23262b;
    font-size: clamp(1.95rem, 3vw, 2.55rem);
    font-weight: 450;
    letter-spacing: 0;
    line-height: 1.08;
    margin: 0 0 14px;
  }

  .seclore-footer__ready p {
    color: #8d8f95;
    font-size: clamp(1rem, 1.45vw, 1.22rem);
    line-height: 1.45;
    margin: 0 0 30px;
    max-width: 820px;
  }

  .seclore-footer__ready a {
    align-items: center;
    background: #5630d6;
    border-radius: 7px;
    color: #ffffff;
    display: inline-flex;
    font-size: 0.98rem;
    font-weight: 800;
    justify-content: center;
    min-height: 42px;
    min-width: 136px;
    padding: 0 22px;
  }

  .seclore-footer__ready a:hover {
    background: #4321b4;
    color: #ffffff;
  }

  .seclore-footer__accordions {
    border-top: 1px solid #b6b6b8;
  }

  .seclore-footer__details {
    border-bottom: 1px solid #c9c9cb;
  }

  .seclore-footer__details summary {
    align-items: center;
    color: #25282d;
    cursor: pointer;
    display: flex;
    font-size: clamp(1.05rem, 1.8vw, 1.24rem);
    font-weight: 800;
    justify-content: space-between;
    line-height: 1.2;
    list-style: none;
    min-height: 60px;
    padding: 0;
  }

  .seclore-footer__details summary::-webkit-details-marker {
    display: none;
  }

  .seclore-footer__chevron {
    border-bottom: 2px solid #2b2e33;
    border-right: 2px solid #2b2e33;
    display: inline-block;
    flex: 0 0 auto;
    height: 10px;
    margin-left: 20px;
    transform: rotate(45deg) translateY(-2px);
    transition: transform 160ms ease;
    width: 10px;
  }

  .seclore-footer__details[open] .seclore-footer__chevron {
    transform: rotate(225deg) translate(-1px, -1px);
  }

  .seclore-footer__panel {
    display: grid;
    gap: 11px;
    padding: 0 0 22px;
  }

  .seclore-footer__panel--split {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    max-width: 540px;
  }

  .seclore-footer__panel a {
    color: #5d646f;
    font-size: clamp(0.95rem, 1.4vw, 1.06rem);
    line-height: 1.35;
  }

  .seclore-footer__contact {
    padding: 36px 0 0;
  }

  .seclore-footer__brand {
    display: inline-flex;
    line-height: 1;
  }

  .seclore-footer__brand img {
    display: block;
    height: auto;
    width: clamp(144px, 19vw, 204px);
  }

  .seclore-footer address,
  .seclore-footer__phones,
  .seclore-footer__email,
  .seclore-footer__bottom p {
    color: #626974;
    font-size: clamp(0.95rem, 1.45vw, 1.05rem);
    line-height: 1.45;
  }

  .seclore-footer address {
    font-style: normal;
    margin: 30px 0 22px;
    max-width: 460px;
  }

  .seclore-footer__phones {
    display: grid;
    gap: 2px;
    margin: 0 0 24px;
  }

  .seclore-footer__email {
    display: inline-flex;
    margin: 0 0 62px;
  }

  .seclore-footer__stores {
    display: grid;
    gap: 12px;
    justify-items: end;
  }

  .seclore-footer__store {
    align-items: center;
    border-radius: 8px;
    color: #ffffff;
    display: inline-flex;
    line-height: 1;
    overflow: hidden;
  }

  .seclore-footer__store:hover {
    color: #ffffff;
    transform: translateY(-1px);
  }

  .seclore-footer__store img {
    display: block;
    height: auto;
    width: clamp(132px, 13vw, 170px);
  }

  .seclore-footer__bottom {
    border-top: 1px solid #c4c4c6;
    margin-top: 46px;
    padding-top: 28px;
  }

  .seclore-footer__socials {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin-bottom: 22px;
  }

  .seclore-footer__social {
    align-items: center;
    color: #303236;
    display: inline-flex;
    font-size: 0.94rem;
    font-weight: 900;
    height: 22px;
    justify-content: center;
    line-height: 1;
    min-width: 18px;
    position: relative;
    text-transform: lowercase;
  }

  .seclore-footer__social--in span {
    font-size: 0.82rem;
  }

  .seclore-footer__social--yt::before {
    border-bottom: 6px solid transparent;
    border-left: 10px solid currentColor;
    border-top: 6px solid transparent;
    content: "";
    display: block;
    height: 0;
    width: 0;
  }

  .seclore-footer__social--ig {
    border: 2px solid currentColor;
    border-radius: 6px;
    height: 19px;
    min-width: 19px;
  }

  .seclore-footer__social--ig::before {
    border: 2px solid currentColor;
    border-radius: 50%;
    content: "";
    height: 6px;
    width: 6px;
  }

  .seclore-footer__social--ig span {
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    height: 1px;
    overflow: hidden;
    position: absolute;
    width: 1px;
  }

  .seclore-footer__bottom p {
    margin: 0;
  }

  .seclore-footer__bottom p a {
    color: #33343a;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (min-width: 760px) {
    .seclore-footer__inner {
      max-width: 1320px;
    }

    .seclore-footer__ready {
      padding-top: 54px;
    }

    .seclore-footer__details summary {
      min-height: 72px;
    }

    .seclore-footer__panel {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      padding-bottom: 28px;
    }

    .seclore-footer__panel--split {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      max-width: none;
    }

    .seclore-footer__contact {
      padding-top: 44px;
    }

    .seclore-footer__bottom {
      align-items: end;
      display: flex;
      justify-content: space-between;
    }

    .seclore-footer__socials {
      margin-bottom: 0;
    }

    .seclore-footer__bottom p {
      text-align: right;
    }
  }

  @media (max-width: 430px) {
    .seclore-footer {
      padding-inline: 20px;
    }

    .seclore-footer__ready a {
      min-width: 136px;
    }

    .seclore-footer__panel--split {
      grid-template-columns: 1fr;
    }
  }

  /* Premium footer refinement */
  .seclore-footer {
    background:
      linear-gradient(180deg, #ffffff 0%, #f6f8fc 100%);
    border-top: 1px solid rgba(15, 23, 42, 0.08);
    padding: 0 clamp(18px, 4.2vw, 64px) 32px;
  }

  .seclore-footer__inner {
    max-width: 1320px;
  }

  .seclore-footer__ready {
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    padding: clamp(52px, 7vw, 86px) 0 clamp(36px, 5vw, 54px);
  }

  .seclore-footer__ready-copy {
    max-width: 760px;
  }

  .seclore-footer__ready h2 {
    color: #0b1020;
    font-size: clamp(2.2rem, 4.4vw, 4.35rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 0.98;
    margin-bottom: 16px;
    white-space: nowrap;
  }

  .seclore-footer__ready p {
    color: #5f6b7a;
    font-size: clamp(1rem, 1.35vw, 1.16rem);
    font-weight: 400;
    line-height: 1.62;
    margin-bottom: 24px;
    max-width: 720px;
  }

  .seclore-footer__ready a {
    background: #5730d6;
    border: 1px solid #5730d6;
    border-radius: 7px;
    box-shadow: none;
    font-family: Inter, "Helvetica Neue", Arial, sans-serif;
    font-size: 1rem;
    font-weight: 650;
    letter-spacing: 0;
    min-height: 52px;
    min-width: 154px;
    padding: 0 28px;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
    width: fit-content;
  }

  .seclore-footer__ready a:hover {
    background: #4623bd;
    border-color: #4623bd;
    transform: translateY(-2px);
  }

  .seclore-footer__accordions {
    border-top: 0;
  }

  .seclore-footer__details {
    border-bottom-color: rgba(15, 23, 42, 0.1);
  }

  .seclore-footer__details summary {
    color: #0f172a;
    font-size: clamp(1rem, 1.35vw, 1.18rem);
    font-weight: 720;
  }

  .seclore-footer__panel {
    gap: 12px 28px;
  }

  .seclore-footer__panel a,
  .seclore-footer address,
  .seclore-footer__phones,
  .seclore-footer__email,
  .seclore-footer__bottom p {
    color: #5f6b7a;
  }

  .seclore-footer__panel a {
    transition:
      color 180ms ease,
      transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .seclore-footer__panel a:hover {
    color: #5730d6;
    transform: translateX(2px);
  }

  .seclore-footer__contact {
    align-items: start;
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(220px, 0.9fr) minmax(220px, 1fr) auto;
    padding-top: clamp(34px, 5vw, 56px);
  }

  .seclore-footer__brand {
    grid-column: 1;
    grid-row: 1;
  }

  .seclore-footer address {
    grid-column: 1;
    grid-row: 2;
    margin: 0;
  }

  .seclore-footer__phones {
    grid-column: 1;
    grid-row: 3;
    margin: 0;
  }

  .seclore-footer__email {
    grid-column: 1;
    grid-row: 4;
    margin: 0;
  }

  .seclore-footer__stores {
    align-self: end;
    gap: 10px;
    grid-column: 1;
    grid-row: 5;
    justify-self: start;
  }

  .seclore-footer__store {
    border-radius: 8px;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .seclore-footer__store:hover {
    box-shadow: 0 14px 30px rgba(33, 20, 38, 0.16);
  }

  .seclore-footer__bottom {
    border-top-color: rgba(15, 23, 42, 0.1);
  }

  .seclore-footer__social {
    border-radius: 8px;
    transition:
      color 180ms ease,
      transform 180ms ease;
  }

  .seclore-footer__social:hover {
    color: #5730d6;
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .seclore-footer__ready,
    .seclore-footer__contact {
      grid-template-columns: 1fr;
    }

    .seclore-footer__ready a,
    .seclore-footer__stores {
      justify-self: start;
    }

    .seclore-footer__stores {
      grid-column: auto;
      grid-row: auto;
      justify-items: start;
    }
  }

  @media (max-width: 560px) {
    .seclore-footer {
      padding-inline: 16px;
    }

    .seclore-footer__ready {
      padding-top: 44px;
    }

    .seclore-footer__ready h2 {
      white-space: normal;
    }

    .seclore-footer__ready a {
      width: fit-content;
    }

    .seclore-footer__panel,
    .seclore-footer__panel--split {
      grid-template-columns: 1fr;
    }
  }
</style>
