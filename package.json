{
  "name": "seclore-astro-security-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:frontend\" \"npm:dev:backend\"",
    "dev:frontend": "astro dev --host 0.0.0.0 --port 4321",
    "dev:backend": "node --watch server/index.js",
    "check": "astro check",
    "build": "astro build",
    "preview": "astro preview --host 127.0.0.1 --port 4321",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "astro": "^5.7.13",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "mongoose": "^8.13.2",
    "morgan": "^1.10.0",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
